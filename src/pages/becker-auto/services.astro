---
import Analytics from '../../components/Analytics.astro';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Services — Becker Auto Repair | Alexandria, MN</title>
  <meta name="description" content="Full auto repair services in Alexandria, MN. Brakes, diagnostics, oil changes, transmission, AC, engine repair, and more." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <Analytics />
</head>
<body>

  <header class="nav">
    <div class="nav__inner">
      <a href="/becker-auto" class="nav__brand">
        <img src="/images/becker/logo.png" alt="Becker Auto Repair" class="nav__logo" />
        <span class="nav__name">Becker Auto</span>
      </a>
      <nav class="nav__links">
        <a href="/becker-auto" class="nav__link">Home</a>
        <a href="/becker-auto/services" class="nav__link nav__link--active">Services</a>
        <a href="/becker-auto/about" class="nav__link">About</a>
        <a href="/becker-auto/contact" class="nav__link">Contact</a>
      </nav>
      <a href="tel:3207628060" class="nav__cta">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 013.12 4.18 2 2 0 015.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        (320) 762-8060
      </a>
      <button class="nav__hamburger" aria-label="Menu"><span></span><span></span><span></span></button>
    </div>
  </header>

  <!-- PAGE HEADER -->
  <section class="page-header">
    <div class="container">
      <div class="page-header__breadcrumb">
        <a href="/becker-auto">Home</a> <span>/</span> <span>Services</span>
      </div>
      <h1>Our Services</h1>
      <p>From routine maintenance to major repairs — we handle it all.</p>
    </div>
  </section>

  <!-- ALL SERVICES -->
  <section class="section">
    <div class="container">

      <div class="service-detail" id="diagnostics">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>Engine Diagnostics</h2>
          <p>Our computerized diagnostic equipment can quickly identify check engine lights, performance issues, electrical problems, and sensor malfunctions. We'll give you a clear explanation of what's wrong and an honest estimate before any work begins.</p>
          <ul>
            <li>Check engine light diagnosis</li>
            <li>OBD-II code scanning & analysis</li>
            <li>Electrical system troubleshooting</li>
            <li>Performance issue identification</li>
          </ul>
        </div>
      </div>

      <div class="service-detail" id="brakes">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>Brake Service</h2>
          <p>Don't compromise on safety. We provide complete brake system service — from inspections to full replacements. We'll check your pads, rotors, calipers, and brake fluid to make sure you stop safely every time.</p>
          <ul>
            <li>Brake pad replacement</li>
            <li>Rotor resurfacing & replacement</li>
            <li>Caliper service</li>
            <li>Brake fluid flush</li>
            <li>Complete brake system inspection</li>
          </ul>
        </div>
      </div>

      <div class="service-detail" id="oil">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>Oil Changes</h2>
          <p>Regular oil changes are the single best thing you can do for your engine. We use quality filters and fluids, and we'll check your other fluids and filters while we're at it.</p>
          <ul>
            <li>Conventional & synthetic oil</li>
            <li>High-mileage formulas available</li>
            <li>Filter replacement</li>
            <li>Multi-point inspection included</li>
          </ul>
        </div>
      </div>

      <div class="service-detail" id="ac">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>AC Repair</h2>
          <p>Minnesota summers are no joke. If your AC isn't blowing cold, bring it in. We handle refrigerant recharges, compressor repair, and full system diagnosis.</p>
          <ul>
            <li>AC system diagnosis</li>
            <li>Refrigerant recharge</li>
            <li>Compressor repair & replacement</li>
            <li>Leak detection</li>
          </ul>
        </div>
      </div>

      <div class="service-detail" id="transmission">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>Transmission Service</h2>
          <p>Whether your transmission is slipping, shifting rough, or just due for maintenance — we've got you covered. We service both automatic and manual transmissions.</p>
          <ul>
            <li>Transmission fluid change</li>
            <li>Filter replacement</li>
            <li>Shift quality diagnosis</li>
            <li>Transmission repair</li>
          </ul>
        </div>
      </div>

      <div class="service-detail" id="engine">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="1" y="3" width="15" height="13" rx="2"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>Engine Repair</h2>
          <p>From minor fixes to major overhauls, our technicians have the experience to get your engine running right. We work on all makes and models, including diesel.</p>
          <ul>
            <li>Head gasket repair</li>
            <li>Timing belt/chain service</li>
            <li>Engine rebuild</li>
            <li>All makes and models, including diesel</li>
          </ul>
        </div>
      </div>

      <!-- Additional Services -->
      <div class="additional-services">
        <h2>We Also Provide</h2>
        <div class="additional-grid">
          <div class="additional-item">
            <strong>Tire Rotation</strong>
            <p>Regular rotation to extend tire life and ensure even wear.</p>
          </div>
          <div class="additional-item">
            <strong>Coolant Flush</strong>
            <p>Flush and refill to prevent overheating and protect your engine.</p>
          </div>
          <div class="additional-item">
            <strong>Filter Replacement</strong>
            <p>Air, fuel, and cabin filter replacement for efficiency.</p>
          </div>
          <div class="additional-item">
            <strong>Belt & Hose Inspection</strong>
            <p>Serpentine and timing belt inspection before they fail.</p>
          </div>
          <div class="additional-item">
            <strong>Suspension & Steering</strong>
            <p>Struts, shocks, and steering service for a smooth ride.</p>
          </div>
          <div class="additional-item">
            <strong>Exhaust System</strong>
            <p>Muffler repair, exhaust leaks, and catalytic converter service.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--cta">
    <div class="container cta-content">
      <h2>Need Service? Give Us a Call.</h2>
      <p>No appointment needed for most services. Just stop by or call ahead.</p>
      <div class="cta-actions">
        <a href="tel:3207628060" class="btn btn--primary btn--lg">Call (320) 762-8060</a>
        <a href="/becker-auto/contact" class="btn btn--outline btn--lg">Get Directions</a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container footer__inner">
      <div class="footer__col">
        <h4>Becker Auto Repair</h4>
        <p>Honest auto repair in Alexandria, MN since 1994.</p>
        <div class="footer__social">
          <a href="https://facebook.com/p/Becker-Auto-Repair-100031192286521" target="_blank" rel="noopener" aria-label="Facebook">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
          </a>
        </div>
      </div>
      <div class="footer__col">
        <h4>Quick Links</h4>
        <ul><li><a href="/becker-auto">Home</a></li><li><a href="/becker-auto/services">Services</a></li><li><a href="/becker-auto/about">About Us</a></li><li><a href="/becker-auto/contact">Contact</a></li></ul>
      </div>
      <div class="footer__col">
        <h4>Contact</h4>
        <p>1811 S Nokomis St, Suite B<br/>Alexandria, MN 56308</p>
        <p><a href="tel:3207628060">(320) 762-8060</a></p>
      </div>
      <div class="footer__col">
        <h4>Hours</h4>
        <table class="footer__hours"><tr><td>Mon–Thu</td><td>7:30 AM – 5:30 PM</td></tr><tr><td>Friday</td><td>7:30 AM – 3:30 PM</td></tr><tr><td>Sat–Sun</td><td>Closed</td></tr></table>
      </div>
    </div>
    <div class="footer__bottom"><p>&copy; 2026 Becker Auto Repair. All rights reserved.</p></div>
  </footer>

  <script>
    const nav = document.querySelector('.nav');
    window.addEventListener('scroll', () => nav?.classList.toggle('nav--scrolled', window.scrollY > 20));
    document.querySelector('.nav__hamburger')?.addEventListener('click', () => document.querySelector('.nav__links')?.classList.toggle('nav__links--open'));
  </script>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root { --primary: #263238; --accent: #ff6f00; --text: #1a1a1a; --text-mid: #555; --bg: #fff; --border: #e5e7eb; }
  body { font-family: 'Inter', -apple-system, sans-serif; color: var(--text); line-height: 1.6; -webkit-font-smoothing: antialiased; }
  .container { max-width: 1140px; margin: 0 auto; padding: 0 1.5rem; }

  .nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: var(--primary); transition: box-shadow 0.2s; }
  .nav--scrolled { box-shadow: 0 2px 20px rgba(0,0,0,0.15); }
  .nav__inner { max-width: 1140px; margin: 0 auto; padding: 0 1.5rem; display: flex; align-items: center; justify-content: space-between; height: 64px; }
  .nav__brand { display: flex; align-items: center; gap: 0.6rem; text-decoration: none; }
  .nav__logo { height: 36px; width: auto; }
  .nav__name { color: #fff; font-weight: 700; font-size: 1.1rem; }
  .nav__links { display: flex; gap: 0.25rem; }
  .nav__link { color: rgba(255,255,255,0.75); text-decoration: none; font-size: 0.88rem; font-weight: 500; padding: 0.4rem 0.75rem; border-radius: 6px; transition: color 0.15s, background 0.15s; }
  .nav__link:hover, .nav__link--active { color: #fff; background: rgba(255,255,255,0.1); }
  .nav__cta { display: flex; align-items: center; gap: 0.4rem; background: var(--accent); color: #fff; text-decoration: none; font-size: 0.85rem; font-weight: 600; padding: 0.5rem 1rem; border-radius: 6px; }
  .nav__hamburger { display: none; background: none; border: none; cursor: pointer; flex-direction: column; gap: 5px; padding: 4px; }
  .nav__hamburger span { display: block; width: 22px; height: 2px; background: #fff; border-radius: 1px; }
  @media (max-width: 768px) {
    .nav__links { display: none; position: absolute; top: 64px; left: 0; right: 0; background: var(--primary); flex-direction: column; padding: 1rem; }
    .nav__links--open { display: flex; }
    .nav__cta { display: none; }
    .nav__hamburger { display: flex; }
  }

  /* PAGE HEADER */
  .page-header { background: var(--primary); padding: 7rem 0 2.5rem; }
  .page-header__breadcrumb { font-size: 0.82rem; color: rgba(255,255,255,0.45); margin-bottom: 0.75rem; }
  .page-header__breadcrumb a { color: rgba(255,255,255,0.6); text-decoration: none; }
  .page-header__breadcrumb a:hover { color: var(--accent); }
  .page-header__breadcrumb span { margin: 0 0.35rem; }
  .page-header h1 { color: #fff; font-size: clamp(1.75rem, 4vw, 2.75rem); font-weight: 800; margin-bottom: 0.5rem; }
  .page-header p { color: rgba(255,255,255,0.7); font-size: 1.05rem; }

  .section { padding: 4.5rem 0; }

  /* SERVICE DETAIL BLOCKS */
  .service-detail {
    display: flex; gap: 1.5rem; padding: 2.25rem 0;
    border-bottom: 1px solid var(--border);
  }
  .service-detail:first-of-type { padding-top: 0; }
  .service-detail__icon {
    flex-shrink: 0; width: 56px; height: 56px; border-radius: 12px;
    background: rgba(255,111,0,0.08); color: var(--accent);
    display: flex; align-items: center; justify-content: center;
  }
  .service-detail__body h2 { font-size: 1.25rem; font-weight: 700; margin-bottom: 0.5rem; }
  .service-detail__body p { font-size: 0.95rem; color: var(--text-mid); line-height: 1.7; margin-bottom: 0.75rem; }
  .service-detail__body ul { list-style: none; display: flex; flex-wrap: wrap; gap: 0.4rem 1.5rem; }
  .service-detail__body li {
    font-size: 0.85rem; color: var(--text-mid); padding-left: 1.1rem;
    position: relative;
  }
  .service-detail__body li::before {
    content: ''; position: absolute; left: 0; top: 0.45rem;
    width: 6px; height: 6px; border-radius: 50%; background: var(--accent);
  }
  @media (max-width: 640px) {
    .service-detail { flex-direction: column; gap: 1rem; }
  }

  /* ADDITIONAL SERVICES */
  .additional-services { margin-top: 3rem; padding: 2rem; background: #fafafa; border-radius: 10px; border: 1px solid var(--border); }
  .additional-services h2 { font-size: 1.15rem; font-weight: 700; margin-bottom: 1.25rem; }
  .additional-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
  .additional-item strong { display: block; font-size: 0.92rem; margin-bottom: 0.2rem; }
  .additional-item p { font-size: 0.85rem; color: var(--text-mid); line-height: 1.55; }
  @media (max-width: 768px) { .additional-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .additional-grid { grid-template-columns: 1fr; } }

  .btn { display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.92rem; font-weight: 600; text-decoration: none; padding: 0.7rem 1.5rem; border-radius: 6px; transition: all 0.15s; border: 2px solid transparent; }
  .btn--primary { background: var(--accent); color: #fff; border-color: var(--accent); }
  .btn--primary:hover { opacity: 0.9; }
  .btn--outline { background: transparent; color: #fff; border-color: rgba(255,255,255,0.4); }
  .btn--outline:hover { border-color: #fff; }
  .btn--lg { padding: 0.85rem 2rem; font-size: 1rem; }

  .section--cta { background: linear-gradient(135deg, var(--accent) 0%, #e65100 100%); text-align: center; padding: 4rem 0; }
  .cta-content h2 { font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 800; color: #fff; margin-bottom: 0.75rem; }
  .cta-content p { font-size: 1.05rem; color: rgba(255,255,255,0.85); margin-bottom: 2rem; }
  .cta-actions { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
  .cta-actions .btn--primary { background: #fff; color: var(--accent); border-color: #fff; }

  .footer { background: #1a1f23; color: rgba(255,255,255,0.7); padding: 4rem 0 0; }
  .footer__inner { display: grid; grid-template-columns: 1.5fr 1fr 1fr 1fr; gap: 2.5rem; }
  .footer__col h4 { color: #fff; font-size: 0.95rem; font-weight: 700; margin-bottom: 1rem; }
  .footer__col p { font-size: 0.88rem; line-height: 1.65; }
  .footer__col ul { list-style: none; }
  .footer__col li { margin-bottom: 0.4rem; }
  .footer__col a { color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.88rem; }
  .footer__col a:hover { color: var(--accent); }
  .footer__social { display: flex; gap: 0.75rem; margin-top: 1rem; }
  .footer__social a { color: rgba(255,255,255,0.5); }
  .footer__social a:hover { color: var(--accent); }
  .footer__hours { font-size: 0.85rem; border-collapse: collapse; }
  .footer__hours td { padding: 0.2rem 0; }
  .footer__hours td:first-child { padding-right: 1.25rem; color: rgba(255,255,255,0.5); }
  .footer__bottom { margin-top: 3rem; padding: 1.25rem 0; border-top: 1px solid rgba(255,255,255,0.08); text-align: center; }
  .footer__bottom p { font-size: 0.8rem; color: rgba(255,255,255,0.35); }
  @media (max-width: 768px) { .footer__inner { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 480px) { .footer__inner { grid-template-columns: 1fr; } }
</style>
</body>
</html>
