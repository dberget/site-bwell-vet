---
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Analytics from '../../components/Analytics.astro';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Becker Auto Repair — Honest Auto Repair in Alexandria, MN</title>
  <meta name="description" content="Honest auto repair in Alexandria, MN since 1994. ASE-certified technicians. Oil changes, brakes, diagnostics, and more." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <Analytics />
</head>
<body>

  <!-- NAV -->
  <header class="nav">
    <div class="nav__inner">
      <a href="/becker-auto" class="nav__brand">
        <img src="/images/becker/logo.png" alt="Becker Auto Repair" class="nav__logo" />
        <span class="nav__name">Becker Auto</span>
      </a>
      <nav class="nav__links">
        <a href="/becker-auto" class="nav__link nav__link--active">Home</a>
        <a href="/becker-auto/services" class="nav__link">Services</a>
        <a href="/becker-auto/about" class="nav__link">About</a>
        <a href="/becker-auto/contact" class="nav__link">Contact</a>
      </nav>
      <a href="tel:3207628060" class="nav__cta">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 013.12 4.18 2 2 0 015.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        (320) 762-8060
      </a>
      <button class="nav__hamburger" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </header>

  <!-- HERO -->
  <section class="hero">
    <div class="hero__bg">
      <img src="/images/becker/banner.jpg" alt="Becker Auto Repair shop" class="hero__bg-img" />
      <div class="hero__overlay"></div>
    </div>
    <div class="hero__content">
      <span class="hero__badge">Serving Alexandria Since 1994</span>
      <h1 class="hero__title">Honest Auto Repair.<br/>Fair Prices. Every Time.</h1>
      <p class="hero__desc">ASE-certified technicians handling everything from oil changes to full engine diagnostics. We treat every vehicle like it's our own.</p>
      <div class="hero__actions">
        <a href="tel:3207628060" class="btn btn--primary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 013.12 4.18 2 2 0 015.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          Call for Service
        </a>
        <a href="/becker-auto/services" class="btn btn--outline">View Our Services</a>
      </div>
      <div class="hero__stats">
        <div class="hero__stat">
          <span class="hero__stat-num">30+</span>
          <span class="hero__stat-label">Years Experience</span>
        </div>
        <div class="hero__stat-divider"></div>
        <div class="hero__stat">
          <span class="hero__stat-num">6</span>
          <span class="hero__stat-label">Star Reviews</span>
        </div>
        <div class="hero__stat-divider"></div>
        <div class="hero__stat">
          <span class="hero__stat-num">ASE</span>
          <span class="hero__stat-label">Certified</span>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURED SERVICES -->
  <section class="section" id="services">
    <div class="container">
      <span class="eyebrow">What We Do</span>
      <h2 class="section__title">Our Services</h2>
      <div class="services-grid">
        <div class="service-card">
          <div class="service-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>
          </div>
          <h3>Engine Diagnostics</h3>
          <p>Computerized diagnostics to identify check engine lights, performance issues, and electrical problems.</p>
        </div>
        <div class="service-card">
          <div class="service-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          </div>
          <h3>Brake Service</h3>
          <p>Brake inspection, pad replacement, rotor resurfacing, and complete brake system repair.</p>
        </div>
        <div class="service-card">
          <div class="service-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
          </div>
          <h3>AC Repair</h3>
          <p>Full air conditioning diagnosis and repair. Stay cool with a properly functioning AC system.</p>
        </div>
        <div class="service-card">
          <div class="service-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
          </div>
          <h3>Transmission</h3>
          <p>Transmission repair, fluid service, and maintenance for automatic and manual transmissions.</p>
        </div>
        <div class="service-card">
          <div class="service-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3>Oil Changes</h3>
          <p>Quick, affordable oil changes with quality filters and fluids. Keep your engine running smooth.</p>
        </div>
        <div class="service-card">
          <div class="service-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="1" y="3" width="15" height="13" rx="2"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          </div>
          <h3>Engine Repair</h3>
          <p>From minor engine work to major repairs, our skilled technicians get your engine running right.</p>
        </div>
      </div>
      <div class="services-more">
        <a href="/becker-auto/services" class="btn btn--secondary">View All Services →</a>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="section section--dark" id="testimonials">
    <div class="container">
      <span class="eyebrow eyebrow--light">Customer Reviews</span>
      <h2 class="section__title section__title--light">What Our Customers Say</h2>
      <div class="testimonials-grid">
        <div class="testimonial-card testimonial-card--featured">
          <div class="testimonial-card__stars">★★★★★</div>
          <blockquote>"This is a very honest and great repair shop that clearly puts their customers first by doing the right thing. These guys are very knowledgeable and skilled technicians and I appreciate you guys helping me out of a bind!"</blockquote>
          <cite>— Pauly</cite>
        </div>
        <div class="testimonial-card">
          <div class="testimonial-card__stars">★★★★★</div>
          <blockquote>"We brought our truck here because the check engine light came on. These guys did the diagnostics & replaced all worn out components — our truck still starts and runs like new even with 254,000 miles."</blockquote>
          <cite>— Leon K.</cite>
        </div>
        <div class="testimonial-card">
          <div class="testimonial-card__stars">★★★★★</div>
          <blockquote>"Great Auto repair shop, very friendly and reliable guys. Quality, reliable work, with low prices."</blockquote>
          <cite>— Will S.</cite>
        </div>
        <div class="testimonial-card">
          <div class="testimonial-card__stars">★★★★★</div>
          <blockquote>"Always knowledgeable and helpful. Willing to get us in at the last minute to try to fix our problems."</blockquote>
          <cite>— Nathan B.</cite>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--cta">
    <div class="container cta-content">
      <h2>Ready to Get Your Vehicle Serviced?</h2>
      <p>Call us today or stop by the shop. No appointment needed for most services.</p>
      <div class="cta-actions">
        <a href="tel:3207628060" class="btn btn--primary btn--lg">Call (320) 762-8060</a>
        <a href="/becker-auto/contact" class="btn btn--outline btn--lg">Get Directions</a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container footer__inner">
      <div class="footer__col">
        <h4>Becker Auto Repair</h4>
        <p>Honest auto repair in Alexandria, MN since 1994. ASE-certified technicians you can trust.</p>
        <div class="footer__social">
          <a href="https://facebook.com/p/Becker-Auto-Repair-100031192286521" target="_blank" rel="noopener" aria-label="Facebook">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
          </a>
        </div>
      </div>
      <div class="footer__col">
        <h4>Quick Links</h4>
        <ul>
          <li><a href="/becker-auto">Home</a></li>
          <li><a href="/becker-auto/services">Services</a></li>
          <li><a href="/becker-auto/about">About Us</a></li>
          <li><a href="/becker-auto/contact">Contact</a></li>
        </ul>
      </div>
      <div class="footer__col">
        <h4>Contact</h4>
        <p>1811 S Nokomis St, Suite B<br/>Alexandria, MN 56308</p>
        <p><a href="tel:3207628060">(320) 762-8060</a></p>
        <p><a href="mailto:info@beckerautorepair.com">info@beckerautorepair.com</a></p>
      </div>
      <div class="footer__col">
        <h4>Hours</h4>
        <table class="footer__hours">
          <tr><td>Mon–Thu</td><td>7:30 AM – 5:30 PM</td></tr>
          <tr><td>Friday</td><td>7:30 AM – 3:30 PM</td></tr>
          <tr><td>Sat–Sun</td><td>Closed</td></tr>
        </table>
      </div>
    </div>
    <div class="footer__bottom">
      <p>&copy; 2026 Becker Auto Repair. All rights reserved.</p>
    </div>
  </footer>

  <script>
    // Sticky nav shadow
    const nav = document.querySelector('.nav');
    window.addEventListener('scroll', () => {
      nav?.classList.toggle('nav--scrolled', window.scrollY > 20);
    });
    // Mobile menu
    document.querySelector('.nav__hamburger')?.addEventListener('click', () => {
      document.querySelector('.nav__links')?.classList.toggle('nav__links--open');
    });
  </script>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --primary: #263238;
    --accent: #ff6f00;
    --text: #1a1a1a;
    --text-mid: #555;
    --text-light: #888;
    --bg: #fff;
    --bg-warm: #fafafa;
    --border: #e5e7eb;
  }

  body {
    font-family: 'Inter', -apple-system, sans-serif;
    color: var(--text);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  .container { max-width: 1140px; margin: 0 auto; padding: 0 1.5rem; }

  /* NAV */
  .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: var(--primary);
    transition: box-shadow 0.2s;
  }
  .nav--scrolled { box-shadow: 0 2px 20px rgba(0,0,0,0.15); }
  .nav__inner {
    max-width: 1140px; margin: 0 auto; padding: 0 1.5rem;
    display: flex; align-items: center; justify-content: space-between;
    height: 64px;
  }
  .nav__brand { display: flex; align-items: center; gap: 0.6rem; text-decoration: none; }
  .nav__logo { height: 36px; width: auto; }
  .nav__name { color: #fff; font-weight: 700; font-size: 1.1rem; }
  .nav__links { display: flex; gap: 0.25rem; }
  .nav__link {
    color: rgba(255,255,255,0.75); text-decoration: none; font-size: 0.88rem;
    font-weight: 500; padding: 0.4rem 0.75rem; border-radius: 6px;
    transition: color 0.15s, background 0.15s;
  }
  .nav__link:hover, .nav__link--active { color: #fff; background: rgba(255,255,255,0.1); }
  .nav__cta {
    display: flex; align-items: center; gap: 0.4rem;
    background: var(--accent); color: #fff; text-decoration: none;
    font-size: 0.85rem; font-weight: 600; padding: 0.5rem 1rem;
    border-radius: 6px; transition: opacity 0.15s;
  }
  .nav__cta:hover { opacity: 0.9; }
  .nav__hamburger {
    display: none; background: none; border: none; cursor: pointer;
    flex-direction: column; gap: 5px; padding: 4px;
  }
  .nav__hamburger span {
    display: block; width: 22px; height: 2px; background: #fff;
    border-radius: 1px; transition: 0.2s;
  }

  @media (max-width: 768px) {
    .nav__links {
      display: none; position: absolute; top: 64px; left: 0; right: 0;
      background: var(--primary); flex-direction: column; padding: 1rem;
      box-shadow: 0 8px 20px rgba(0,0,0,0.2);
    }
    .nav__links--open { display: flex; }
    .nav__link { padding: 0.75rem 1rem; }
    .nav__cta { display: none; }
    .nav__hamburger { display: flex; }
  }

  /* HERO */
  .hero {
    position: relative; min-height: 85vh; display: flex; align-items: center;
    padding: 8rem 1.5rem 5rem;
  }
  .hero__bg { position: absolute; inset: 0; }
  .hero__bg-img { width: 100%; height: 100%; object-fit: cover; }
  .hero__overlay {
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(38,50,56,0.88) 0%, rgba(38,50,56,0.7) 100%);
  }
  .hero__content {
    position: relative; max-width: 720px; margin: 0 auto 0 0;
    padding-left: calc((100vw - 1140px) / 2);
  }
  @media (max-width: 1172px) { .hero__content { padding-left: 1.5rem; } }
  .hero__badge {
    display: inline-block; background: var(--accent); color: #fff;
    font-size: 0.78rem; font-weight: 700; letter-spacing: 0.08em;
    text-transform: uppercase; padding: 0.35rem 0.9rem; border-radius: 4px;
    margin-bottom: 1.25rem;
  }
  .hero__title {
    font-size: clamp(2.25rem, 5vw, 3.5rem); font-weight: 900;
    line-height: 1.1; color: #fff; margin-bottom: 1.25rem;
  }
  .hero__desc {
    font-size: 1.1rem; line-height: 1.7; color: rgba(255,255,255,0.85);
    margin-bottom: 2rem; max-width: 560px;
  }
  .hero__actions { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 2.5rem; }
  .hero__stats {
    display: flex; align-items: center; gap: 2rem;
    padding-top: 2rem; border-top: 1px solid rgba(255,255,255,0.15);
  }
  .hero__stat { text-align: center; }
  .hero__stat-num { display: block; font-size: 1.5rem; font-weight: 800; color: var(--accent); }
  .hero__stat-label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.06em; color: rgba(255,255,255,0.6); }
  .hero__stat-divider { width: 1px; height: 40px; background: rgba(255,255,255,0.15); }

  @media (max-width: 480px) {
    .hero { min-height: 70vh; padding: 6rem 1.25rem 3rem; }
    .hero__actions { flex-direction: column; }
    .hero__stats { gap: 1.25rem; }
    .hero__stat-divider { display: none; }
  }

  /* BUTTONS */
  .btn {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-size: 0.92rem; font-weight: 600; text-decoration: none;
    padding: 0.7rem 1.5rem; border-radius: 6px; transition: all 0.15s;
    border: 2px solid transparent; cursor: pointer;
  }
  .btn--primary { background: var(--accent); color: #fff; border-color: var(--accent); }
  .btn--primary:hover { opacity: 0.9; transform: translateY(-1px); }
  .btn--outline { background: transparent; color: #fff; border-color: rgba(255,255,255,0.4); }
  .btn--outline:hover { border-color: #fff; background: rgba(255,255,255,0.1); }
  .btn--secondary { background: var(--primary); color: #fff; }
  .btn--secondary:hover { opacity: 0.9; }
  .btn--lg { padding: 0.85rem 2rem; font-size: 1rem; }

  /* SECTIONS */
  .section { padding: 5rem 0; }
  .section--dark { background: var(--primary); }
  .section--cta {
    background: linear-gradient(135deg, var(--accent) 0%, #e65100 100%);
    text-align: center; padding: 4rem 0;
  }
  .eyebrow {
    display: block; font-size: 0.78rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--accent); margin-bottom: 0.5rem;
  }
  .eyebrow--light { color: var(--accent); }
  .section__title {
    font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 800;
    margin-bottom: 2.5rem; line-height: 1.2;
  }
  .section__title--light { color: #fff; }

  /* SERVICES GRID */
  .services-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem; margin-bottom: 2rem;
  }
  .service-card {
    background: #fff; border: 1px solid var(--border); border-radius: 8px;
    padding: 1.75rem; transition: box-shadow 0.2s, transform 0.2s;
    border-top: 4px solid var(--accent);
  }
  .service-card:hover { box-shadow: 0 8px 24px rgba(0,0,0,0.08); transform: translateY(-2px); }
  .service-card__icon {
    width: 48px; height: 48px; border-radius: 10px;
    background: rgba(255,111,0,0.1); color: var(--accent);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 1rem;
  }
  .service-card h3 { font-size: 1.05rem; font-weight: 700; margin-bottom: 0.4rem; }
  .service-card p { font-size: 0.88rem; color: var(--text-mid); line-height: 1.6; }
  .services-more { text-align: center; }

  @media (max-width: 768px) { .services-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .services-grid { grid-template-columns: 1fr; } }

  /* TESTIMONIALS */
  .testimonials-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem;
  }
  .testimonial-card {
    background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
    border-radius: 8px; padding: 1.75rem;
  }
  .testimonial-card--featured {
    grid-column: 1 / -1;
    background: rgba(255,111,0,0.1); border-color: rgba(255,111,0,0.2);
  }
  .testimonial-card__stars { color: var(--accent); font-size: 1rem; margin-bottom: 0.75rem; letter-spacing: 2px; }
  .testimonial-card blockquote {
    font-size: 0.95rem; color: rgba(255,255,255,0.85); line-height: 1.7;
    margin-bottom: 0.75rem; font-style: italic;
  }
  .testimonial-card--featured blockquote { font-size: 1.1rem; }
  .testimonial-card cite { font-size: 0.85rem; color: rgba(255,255,255,0.5); font-style: normal; font-weight: 600; }

  @media (max-width: 640px) { .testimonials-grid { grid-template-columns: 1fr; } }

  /* CTA */
  .cta-content h2 { font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 800; color: #fff; margin-bottom: 0.75rem; }
  .cta-content p { font-size: 1.05rem; color: rgba(255,255,255,0.85); margin-bottom: 2rem; }
  .cta-actions { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
  .cta-actions .btn--primary { background: #fff; color: var(--accent); border-color: #fff; }
  .cta-actions .btn--outline { color: #fff; border-color: rgba(255,255,255,0.5); }

  /* FOOTER */
  .footer { background: #1a1f23; color: rgba(255,255,255,0.7); padding: 4rem 0 0; }
  .footer__inner { display: grid; grid-template-columns: 1.5fr 1fr 1fr 1fr; gap: 2.5rem; }
  .footer__col h4 { color: #fff; font-size: 0.95rem; font-weight: 700; margin-bottom: 1rem; }
  .footer__col p { font-size: 0.88rem; line-height: 1.65; }
  .footer__col ul { list-style: none; }
  .footer__col li { margin-bottom: 0.4rem; }
  .footer__col a { color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.88rem; transition: color 0.15s; }
  .footer__col a:hover { color: var(--accent); }
  .footer__social { display: flex; gap: 0.75rem; margin-top: 1rem; }
