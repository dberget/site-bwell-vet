---
import Analytics from '../../components/Analytics.astro';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Services — Northside Collision | Alexandria, MN</title>
  <meta name="description" content="Full collision repair services in Alexandria, MN. Auto body, collision repair, boat repair, glass replacement, paint services, and free estimates." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <Analytics />
</head>
<body>

  <header class="nav">
    <div class="nav__inner">
      <a href="/northside-collision" class="nav__brand">
        <img src="/images/northside/logo.png" alt="Northside Collision" class="nav__logo" />
        <span class="nav__name">Northside Collision</span>
      </a>
      <nav class="nav__links">
        <a href="/northside-collision" class="nav__link">Home</a>
        <a href="/northside-collision/services" class="nav__link nav__link--active">Services</a>
        <a href="/northside-collision/about" class="nav__link">About</a>
        <a href="/northside-collision/contact" class="nav__link">Contact</a>
      </nav>
      <a href="tel:3207633224" class="nav__cta">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 013.12 4.18 2 2 0 015.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        (320) 763-3224
      </a>
      <button class="nav__hamburger" aria-label="Menu"><span></span><span></span><span></span></button>
    </div>
  </header>

  <!-- PAGE HEADER -->
  <section class="page-header">
    <div class="container">
      <div class="page-header__breadcrumb">
        <a href="/northside-collision">Home</a> <span>/</span> <span>Services</span>
      </div>
      <h1>Our Services</h1>
      <p>From minor dents to major collision repair &mdash; we handle it all.</p>
    </div>
  </section>

  <!-- ALL SERVICES -->
  <section class="section">
    <div class="container">

      <div class="service-detail" id="auto-body">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>Auto Body Repair</h2>
          <p>Our skilled technicians restore your vehicle's appearance to pre-accident condition. From minor dents and dings to full body panel replacement, we deliver precision work with expert paint matching every time.</p>
          <ul>
            <li>Dent and ding removal</li>
            <li>Full body panel repair and replacement</li>
            <li>Precision paint matching</li>
            <li>Bumper repair and replacement</li>
          </ul>
        </div>
      </div>

      <div class="service-detail" id="collision">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>Collision Repair</h2>
          <p>When a major accident happens, trust our I-CAR certified team to handle the heavy lifting. We specialize in frame straightening, structural repair, and complete accident restoration to ensure your vehicle is safe and road-ready.</p>
          <ul>
            <li>Major accident repair</li>
            <li>Frame straightening</li>
            <li>Structural repair</li>
            <li>Unibody alignment</li>
          </ul>
        </div>
      </div>

      <div class="service-detail" id="boat">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M2 12h4M18 12h4M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>Boat Repair</h2>
          <p>Living in the heart of Minnesota lake country means we know boats. Our team handles fiberglass repair, gel coat restoration, and marine painting to get your boat looking and performing its best on the water.</p>
          <div class="service-detail__image">
            <img src="/images/northside/boat.png" alt="Boat repair at Northside Collision" loading="lazy" />
          </div>
          <ul>
            <li>Fiberglass repair</li>
            <li>Gel coat restoration</li>
            <li>Marine painting</li>
            <li>Hull damage repair</li>
          </ul>
        </div>
      </div>

      <div class="service-detail" id="glass">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="2" y1="20" x2="22" y2="20"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>Glass Replacement</h2>
          <p>Cracked or shattered auto glass is a safety hazard. We provide professional replacement for windshields, side glass, and back glass on all makes and models, with quick turnaround times.</p>
          <ul>
            <li>Windshield replacement</li>
            <li>Side glass replacement</li>
            <li>Back glass replacement</li>
            <li>All makes and models</li>
          </ul>
        </div>
      </div>

      <div class="service-detail" id="estimates">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="2" y="3" width="20" height="18" rx="2"/><line x1="8" y1="7" x2="16" y2="7"/><line x1="8" y1="11" x2="16" y2="11"/><line x1="8" y1="15" x2="12" y2="15"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>Free Computerized Estimates</h2>
          <p>Get an accurate, no-obligation estimate using our computerized assessment system. We coordinate directly with your insurance company to make the claims process as smooth as possible.</p>
          <ul>
            <li>Digital damage assessment</li>
            <li>Insurance coordination</li>
            <li>No-obligation quotes</li>
            <li>Quick turnaround on estimates</li>
          </ul>
        </div>
      </div>

      <div class="service-detail" id="paint">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>Paint Services</h2>
          <p>Whether you need a spot repair or a complete repaint, our paint technicians deliver flawless results. We use computerized color matching to ensure a seamless blend with your vehicle's original finish.</p>
          <ul>
            <li>Computerized color matching</li>
            <li>Full paint jobs</li>
            <li>Clear coat application</li>
            <li>Spot and panel painting</li>
          </ul>
        </div>
      </div>

      <!-- Additional Services -->
      <div class="additional-services">
        <h2>We Also Provide</h2>
        <div class="additional-grid">
          <div class="additional-item">
            <strong>Insurance Claim Assistance</strong>
            <p>We work with all major insurance companies and handle the paperwork for you.</p>
          </div>
          <div class="additional-item">
            <strong>Towing Coordination</strong>
            <p>Need your vehicle towed to our shop? We can help coordinate towing services.</p>
          </div>
          <div class="additional-item">
            <strong>Rental Car Assistance</strong>
            <p>We'll help arrange a rental car while your vehicle is being repaired.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--cta">
    <div class="container cta-content">
      <h2>Need a Repair? Get a Free Estimate.</h2>
      <p>Call us today or stop by for a no-obligation computerized estimate.</p>
      <div class="cta-actions">
        <a href="tel:3207633224" class="btn btn--primary btn--lg">Call (320) 763-3224</a>
        <a href="/northside-collision/contact" class="btn btn--outline btn--lg">Get Directions</a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container footer__inner">
      <div class="footer__col">
        <h4>Northside Collision</h4>
        <p>Expert collision repair in Alexandria, MN since 1989.</p>
        <div class="footer__social">
          <a href="https://facebook.com/Northsidecollisioncenter" target="_blank" rel="noopener" aria-label="Facebook">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
          </a>
        </div>
      </div>
      <div class="footer__col">
        <h4>Quick Links</h4>
        <ul><li><a href="/northside-collision">Home</a></li><li><a href="/northside-collision/services">Services</a></li><li><a href="/northside-collision/about">About Us</a></li><li><a href="/northside-collision/contact">Contact</a></li></ul>
      </div>
      <div class="footer__col">
        <h4>Contact</h4>
        <p>1301 Northside Dr NE<br/>Alexandria, MN</p>
        <p><a href="tel:3207633224">(320) 763-3224</a></p>
      </div>
      <div class="footer__col">
        <h4>Hours</h4>
        <table class="footer__hours"><tr><td>Mon&ndash;Fri</td><td>8:00 AM &ndash; 5:00 PM</td></tr><tr><td>Saturday</td><td>Closed</td></tr><tr><td>Sunday</td><td>Closed</td></tr></table>
      </div>
    </div>
    <div class="footer__bottom"><p>&copy; 2026 Northside Collision. All rights reserved.</p></div>
  </footer>

  <script>
    const nav = document.querySelector('.nav');
    window.addEventListener('scroll', () => nav?.classList.toggle('nav--scrolled', window.scrollY > 20));
    document.querySelector('.nav__hamburger')?.addEventListener('click', () => document.querySelector('.nav__links')?.classList.toggle('nav__links--open'));
  </script>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root { --primary: #1a237e; --accent: #d32f2f; --text: #1a1a1a; --text-mid: #555; --bg: #fff; --border: #e5e7eb; }
  body { font-family: 'Inter', -apple-system, sans-serif; color: var(--text); line-height: 1.6; -webkit-font-smoothing: antialiased; }
  .container { max-width: 1140px; margin: 0 auto; padding: 0 1.5rem; }

  .nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: var(--primary); transition: box-shadow 0.2s; }
  .nav--scrolled { box-shadow: 0 2px 20px rgba(0,0,0,0.15); }
  .nav__inner { max-width: 1140px; margin: 0 auto; padding: 0 1.5rem; display: flex; align-items: center; justify-content: space-between; height: 64px; }
  .nav__brand { display: flex; align-items: center; gap: 0.6rem; text-decoration: none; }
  .nav__logo { height: 36px; width: auto; }
  .nav__name { color: #fff; font-weight: 700; font-size: 1.1rem; }
  .nav__links { display: flex; gap: 0.25rem; }
  .nav__link { color: rgba(255,255,255,0.75); text-decoration: none; font-size: 0.88rem; font-weight: 500; padding: 0.4rem 0.75rem; border-radius: 6px; transition: color 0.15s, background 0.15s; }
  .nav__link:hover, .nav__link--active { color: #fff; background: rgba(255,255,255,0.1); }
  .nav__cta { display: flex; align-items: center; gap: 0.4rem; background: var(--accent); color: #fff; text-decoration: none; font-size: 0.85rem; font-weight: 600; padding: 0.5rem 1rem; border-radius: 6px; }
  .nav__cta:hover { opacity: 0.9; }
  .nav__hamburger { display: none; background: none; border: none; cursor: pointer; flex-direction: column; gap: 5px; padding: 4px; }
  .nav__hamburger span { display: block; width: 22px; height: 2px; background: #fff; border-radius: 1px; }
  @media (max-width: 768px) {
    .nav__links { display: none; position: absolute; top: 64px; left: 0; right: 0; background: var(--primary); flex-direction: column; padding: 1rem; box-shadow: 0 8px 20px rgba(0,0,0,0.2); }
    .nav__links--open { display: flex; }
    .nav__link { padding: 0.75rem 1rem; }
    .nav__cta { display: none; }
    .nav__hamburger { display: flex; }
  }

  /* PAGE HEADER */
  .page-header { background: var(--primary); padding: 7rem 0 2.5rem; }
  .page-header__breadcrumb { font-size: 0.82rem; color: rgba(255,255,255,0.45); margin-bottom: 0.75rem; }
  .page-header__breadcrumb a { color: rgba(255,255,255,0.6); text-decoration: none; }
  .page-header__breadcrumb a:hover { color: var(--accent); }
  .page-header__breadcrumb span { margin: 0 0.35rem; }
  .page-header h1 { color: #fff; font-size: clamp(1.75rem, 4vw, 2.75rem); font-weight: 800; margin-bottom: 0.5rem; }
  .page-header p { color: rgba(255,255,255,0.7); font-size: 1.05rem; }

  .section { padding: 4.5rem 0; }

  /* SERVICE DETAIL BLOCKS */
  .service-detail {
    display: flex; gap: 1.5rem; padding: 2.25rem 0;
    border-bottom: 1px solid var(--border);
  }
  .service-detail:first-of-type { padding-top: 0; }
  .service-detail__icon {
    flex-shrink: 0; width: 56px; height: 56px; border-radius: 12px;
    background: rgba(211,47,47,0.08); color: var(--accent);
    display: flex; align-items: center; justify-content: center;
  }
  .service-detail__body h2 { font-size: 1.25rem; font-weight: 700; margin-bottom: 0.5rem; }
  .service-detail__body p { font-size: 0.95rem; color: var(--text-mid); line-height: 1.7; margin-bottom: 0.75rem; }
  .service-detail__body ul { list-style: none; display: flex; flex-wrap: wrap; gap: 0.4rem 1.5rem; }
  .service-detail__body li {
    font-size: 0.85rem; color: var(--text-mid); padding-left: 1.1rem;
    position: relative;
  }
  .service-detail__body li::before {
    content: ''; position: absolute; left: 0; top: 0.45rem;
    width: 6px; height: 6px; border-radius: 50%; background: var(--accent);
  }
  .service-detail__image {
    margin-bottom: 1rem; border-radius: 8px; overflow: hidden;
  }
  .service-detail__image img {
    width: 100%; max-width: 480px; height: auto; border-radius: 8px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.1);
  }
  @media (max-width: 640px) {
    .service-detail { flex-direction: column; gap: 1rem; }
  }

  /* ADDITIONAL SERVICES */
  .additional-services { margin-top: 3rem; padding: 2rem; background: #fafafa; border-radius: 10px; border: 1px solid var(--border); }
  .additional-services h2 { font-size: 1.15rem; font-weight: 700; margin-bottom: 1.25rem; }
  .additional-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
  .additional-item strong { display: block; font-size: 0.92rem; margin-bottom: 0.2rem; }
  .additional-item p { font-size: 0.85rem; color: var(--text-mid); line-height: 1.55; }
  @media (max-width: 768px) { .additional-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .additional-grid { grid-template-columns: 1fr; } }

  .btn { display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.92rem; font-weight: 600; text-decoration: none; padding: 0.7rem 1.5rem; border-radius: 6px; transition: all 0.15s; border: 2px solid transparent; cursor: pointer; }
  .btn--primary { background: var(--accent); color: #fff; border-color: var(--accent); }
  .btn--primary:hover { opacity: 0.9; }
  .btn--outline { background: transparent; color: #fff; border-color: rgba(255,255,255,0.4); }
  .btn--outline:hover { border-color: #fff; }
  .btn--lg { padding: 0.85rem 2rem; font-size: 1rem; }

  .section--cta { background: linear-gradient(135deg, var(--accent) 0%, #b71c1c 100%); text-align: center; padding: 4rem 0; }
  .cta-content h2 { font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 800; color: #fff; margin-bottom: 0.75rem; }
  .cta-content p { font-size: 1.05rem; color: rgba(255,255,255,0.85); margin-bottom: 2rem; }
  .cta-actions { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
  .cta-actions .btn--primary { background: #fff; color: var(--accent); border-color: #fff; }

  .footer { background: #1a1f23; color: rgba(255,255,255,0.7); padding: 4rem 0 0; }
  .footer__inner { display: grid; grid-template-columns: 1.5fr 1fr 1fr 1fr; gap: 2.5rem; }
  .footer__col h4 { color: #fff; font-size: 0.95rem; font-weight: 700; margin-bottom: 1rem; }
  .footer__col p { font-size: 0.88rem; line-height: 1.65; }
  .footer__col ul { list-style: none; }
  .footer__col li { margin-bottom: 0.4rem; }
  .footer__col a { color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.88rem; }
  .footer__col a:hover { color: var(--accent); }
  .footer__social { display: flex; gap: 0.75rem; margin-top: 1rem; }
  .footer__social a { color: rgba(255,255,255,0.5); }
  .footer__social a:hover { color: var(--accent); }
  .footer__hours { font-size: 0.85rem; border-collapse: collapse; }
  .footer__hours td { padding: 0.2rem 0; }
  .footer__hours td:first-child { padding-right: 1.25rem; color: rgba(255,255,255,0.5); }
  .footer__bottom { margin-top: 3rem; padding: 1.25rem 0; border-top: 1px solid rgba(255,255,255,0.08); text-align: center; }
  .footer__bottom p { font-size: 0.8rem; color: rgba(255,255,255,0.35); }
  @media (max-width: 768px) { .footer__inner { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 480px) { .footer__inner { grid-template-columns: 1fr; } }
</style>
</body>
</html>
