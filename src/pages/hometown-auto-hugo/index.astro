    <div class="why-section__bg">
      <img src="https://picsum.photos/id/1071/1600/800" alt="Mechanic working" class="why-section__bg-img" />
      <div class="why-section__overlay"></div>
    </div>
    <div class="container why-section__inner">
      <div class="why-section__header">
        <span class="eyebrow eyebrow--light">Why Choose Us</span>
        <h2 class="section__title section__title--light">Why Hometown?</h2>
