---
import Analytics from '../../components/Analytics.astro';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Services — Hometown Auto Repair | Hugo, MN</title>
  <meta name="description" content="Full auto repair services in Hugo, MN. Oil changes, brakes, diagnostics, suspension, transmission, engine repair, and towing. Call (651) 426-2186." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <Analytics />
</head>
<body>

  <!-- NAV -->
  <header class="nav">
    <div class="nav__inner">
      <a href="/hometown-auto-hugo" class="nav__brand">
        <svg class="nav__brand-icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#cc3333" stroke-width="2" stroke-linecap="round"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>
        <span class="nav__name">Hometown Auto Repair</span>
      </a>
      <nav class="nav__links">
        <a href="/hometown-auto-hugo" class="nav__link">Home</a>
        <a href="/hometown-auto-hugo/services" class="nav__link nav__link--active">Services</a>
        <a href="/hometown-auto-hugo/contact" class="nav__link">Contact</a>
      </nav>
      <a href="tel:6514262186" class="nav__cta">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 013.12 4.18 2 2 0 015.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        (651) 426-2186
      </a>
      <button class="nav__hamburger" aria-label="Menu"><span></span><span></span><span></span></button>
    </div>
  </header>

  <!-- PAGE HEADER -->
  <section class="page-header">
    <div class="container">
      <div class="page-header__breadcrumb">
        <a href="/hometown-auto-hugo">Home</a> <span>/</span> <span>Services</span>
      </div>
      <h1>Our Services</h1>
      <p>From routine oil changes to major engine work -- we handle it all under one roof.</p>
    </div>
  </section>

  <!-- SERVICE BLOCKS -->
  <section class="section">
    <div class="container">

      <div class="service-detail" id="oil">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>Oil Changes &amp; Fluid Service</h2>
          <p>Regular oil changes are the foundation of engine longevity. We use quality oils and filters matched to your vehicle's specifications. While we're under the hood, we check all critical fluids -- coolant, brake fluid, power steering, and transmission -- so nothing gets overlooked.</p>
          <ul>
            <li>Conventional, synthetic blend, and full synthetic oil</li>
            <li>High-mileage oil formulas</li>
            <li>Quality oil filter replacement</li>
            <li>Complete fluid level inspection</li>
            <li>Coolant flush and refill service</li>
          </ul>
        </div>
      </div>

      <div class="service-detail" id="preventive">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>Preventive Maintenance</h2>
          <p>An ounce of prevention is worth a pound of cure -- especially when it comes to your vehicle. We follow OEM service schedules to catch small issues before they become expensive problems. Whether your car has 20,000 miles or 200,000, we'll help you stay on track.</p>
          <ul>
            <li>Manufacturer-recommended service intervals</li>
            <li>Air and cabin filter replacement</li>
            <li>Spark plug service</li>
            <li>Belt and hose inspection</li>
            <li>Tire rotation and pressure check</li>
            <li>Multi-point vehicle inspection</li>
          </ul>
        </div>
      </div>

      <div class="service-detail" id="brakes">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>Brake Service</h2>
          <p>Your brakes are your most important safety system. We inspect every component -- pads, rotors, calipers, lines, and fluid -- and give you an honest assessment. We'll never recommend work you don't need, but we'll never let you drive on unsafe brakes either.</p>
          <ul>
            <li>Brake pad and shoe replacement</li>
            <li>Rotor resurfacing and replacement</li>
            <li>Caliper inspection and service</li>
            <li>Brake fluid flush</li>
            <li>Brake line inspection</li>
            <li>Anti-lock braking system (ABS) diagnostics</li>
          </ul>
        </div>
      </div>

      <div class="service-detail" id="diagnostics">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>Engine Diagnostics</h2>
          <p>When your check engine light comes on, you need answers -- not guesswork. We use the latest diagnostic technology to read codes, analyze live data, and pinpoint the root cause of your vehicle's issues. You'll get a clear explanation and an honest estimate before we turn a single wrench.</p>
          <ul>
            <li>Check engine light diagnosis</li>
            <li>OBD-II code scanning and interpretation</li>
            <li>Live data stream analysis</li>
            <li>Electrical system troubleshooting</li>
            <li>Sensor testing and replacement</li>
            <li>Performance issue diagnosis</li>
          </ul>
        </div>
      </div>

      <div class="service-detail" id="suspension">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>Suspension &amp; Steering</h2>
          <p>Minnesota roads can be tough on your suspension. If your ride feels rough, your steering pulls, or you hear clunking over bumps, bring it in. We'll inspect everything from struts and shocks to tie rods and ball joints to get you riding smooth again.</p>
          <ul>
            <li>Strut and shock replacement</li>
            <li>Ball joint and tie rod service</li>
            <li>Control arm replacement</li>
            <li>Power steering service</li>
            <li>Wheel bearing replacement</li>
            <li>Alignment-related component inspection</li>
          </ul>
        </div>
      </div>

      <div class="service-detail" id="transmission">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M6 8v8"/><path d="M10 8v8"/><path d="M14 8v8"/><path d="M18 8v8"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>Transmission Service</h2>
          <p>Whether it's slipping, shifting hard, or just overdue for a fluid change, we service both automatic and manual transmissions. Catching transmission issues early can save you thousands compared to a full rebuild down the road.</p>
          <ul>
            <li>Transmission fluid change and flush</li>
            <li>Filter replacement</li>
            <li>Shift quality diagnosis</li>
            <li>Solenoid testing and replacement</li>
            <li>Transmission repair</li>
          </ul>
        </div>
      </div>

      <div class="service-detail" id="engine">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="1" y="3" width="15" height="13" rx="2"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>Major Engine Repair</h2>
          <p>When it's more than a simple fix, we have the experience and equipment to handle major engine work. Head gaskets, timing chains, engine rebuilds -- the jobs that other shops send to the dealer, we take care of right here in Hugo.</p>
          <ul>
            <li>Head gasket replacement</li>
            <li>Timing belt and chain service</li>
            <li>Engine rebuild and overhaul</li>
            <li>Intake and exhaust manifold repair</li>
            <li>All makes and models</li>
          </ul>
        </div>
      </div>

      <div class="service-detail" id="towing">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>Towing Service</h2>
          <p>Stuck on the side of the road? Don't stress. We can arrange towing directly to our shop so your vehicle gets the care it needs without the runaround. One call and we'll take it from there.</p>
          <ul>
            <li>Towing arranged to our shop</li>
            <li>Breakdown assistance coordination</li>
            <li>Direct-to-shop convenience</li>
          </ul>
        </div>
      </div>

      <!-- OEM CALLOUT -->
      <div class="oem-callout">
        <div class="oem-callout__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
        <div class="oem-callout__body">
          <h2>We Follow OEM Service Standards</h2>
          <p>At Hometown Auto Repair, we believe in doing things the right way. That means following your vehicle manufacturer's service recommendations -- not cutting corners to save a few dollars. We use the right parts, the right fluids, and the right procedures so your vehicle performs the way it was designed to. When you bring your car to us, you can trust that we're treating it with the same care the factory intended.</p>
        </div>
      </div>

    </div>
  </section>

  <!-- CTA -->
  <section class="cta-banner">
    <div class="container cta-banner__inner">
      <h2>Need Service? Give Us a Call.</h2>
      <p>No pressure, no upselling. Just honest auto repair from your neighbors in Hugo.</p>
      <div class="cta-banner__actions">
        <a href="tel:6514262186" class="btn btn--white btn--lg">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 013.12 4.18 2 2 0 015.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          Call (651) 426-2186
        </a>
        <a href="/hometown-auto-hugo/contact" class="btn btn--outline-white btn--lg">Contact Us</a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container footer__inner">
      <div class="footer__col">
        <h4>Hometown Auto Repair</h4>
        <p>Your trusted local mechanic in Hugo, MN. Locally owned and operated, committed to honest service and fair prices.</p>
        <div class="footer__social">
          <a href="https://facebook.com/HometownAutoRepairHugo" target="_blank" rel="noopener" aria-label="Facebook">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
          </a>
        </div>
      </div>
      <div class="footer__col">
        <h4>Quick Links</h4>
        <ul>
          <li><a href="/hometown-auto-hugo">Home</a></li>
          <li><a href="/hometown-auto-hugo/services">Services</a></li>
          <li><a href="/hometown-auto-hugo/contact">Contact</a></li>
        </ul>
      </div>
      <div class="footer__col">
        <h4>Contact</h4>
        <p>15409 Forest Blvd<br/>Hugo, MN 55038</p>
        <p><a href="tel:6514262186">(651) 426-2186</a></p>
      </div>
      <div class="footer__col">
        <h4>Hours</h4>
        <table class="footer__hours">
          <tr><td>Mon-Fri</td><td>8:00 AM - 5:30 PM</td></tr>
          <tr><td>Saturday</td><td>By Appointment</td></tr>
          <tr><td>Sunday</td><td>Closed</td></tr>
        </table>
      </div>
    </div>
    <div class="footer__bottom">
      <p>&copy; 2026 Hometown Auto Repair. All rights reserved.</p>
    </div>
  </footer>

  <script>
    const nav = document.querySelector('.nav');
    window.addEventListener('scroll', () => {
      nav?.classList.toggle('nav--scrolled', window.scrollY > 20);
    });
    document.querySelector('.nav__hamburger')?.addEventListener('click', () => {
      document.querySelector('.nav__links')?.classList.toggle('nav__links--open');
    });
  </script>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --primary: #2c2c2c;
    --accent: #cc3333;
    --text: #1a1a1a;
    --text-mid: #555;
    --text-light: #888;
    --bg: #fff;
    --bg-warm: #f7f7f5;
    --border: #e5e7eb;
  }

  body {
    font-family: 'Inter', -apple-system, sans-serif;
    color: var(--text);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  .container { max-width: 1140px; margin: 0 auto; padding: 0 1.5rem; }

  /* ===== NAV ===== */
  .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: var(--primary);
    transition: box-shadow 0.2s;
  }
  .nav--scrolled { box-shadow: 0 2px 24px rgba(0,0,0,0.25); }
  .nav__inner {
    max-width: 1140px; margin: 0 auto; padding: 0 1.5rem;
    display: flex; align-items: center; justify-content: space-between;
    height: 68px;
  }
  .nav__brand {
    display: flex; align-items: center; gap: 0.6rem; text-decoration: none;
  }
  .nav__brand-icon { flex-shrink: 0; }
  .nav__name {
    color: #fff; font-weight: 800; font-size: 1.15rem;
    letter-spacing: -0.01em;
  }
  .nav__links { display: flex; gap: 0.25rem; }
  .nav__link {
    color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.88rem;
    font-weight: 500; padding: 0.45rem 0.85rem; border-radius: 6px;
    transition: color 0.15s, background 0.15s;
  }
  .nav__link:hover, .nav__link--active {
    color: #fff; background: rgba(255,255,255,0.1);
  }
  .nav__cta {
    display: flex; align-items: center; gap: 0.4rem;
    background: var(--accent); color: #fff; text-decoration: none;
    font-size: 0.85rem; font-weight: 700; padding: 0.5rem 1.1rem;
    border-radius: 6px; transition: background 0.15s;
  }
  .nav__cta:hover { background: #b82d2d; }
  .nav__hamburger {
    display: none; background: none; border: none; cursor: pointer;
    flex-direction: column; gap: 5px; padding: 4px;
  }
  .nav__hamburger span {
    display: block; width: 24px; height: 2px; background: #fff;
    border-radius: 1px; transition: 0.2s;
  }

  @media (max-width: 768px) {
    .nav__links {
      display: none; position: absolute; top: 68px; left: 0; right: 0;
      background: var(--primary); flex-direction: column; padding: 1rem;
      box-shadow: 0 8px 24px rgba(0,0,0,0.3);
    }
    .nav__links--open { display: flex; }
    .nav__link { padding: 0.75rem 1rem; }
    .nav__cta { display: none; }
    .nav__hamburger { display: flex; }
  }

  /* ===== PAGE HEADER ===== */
  .page-header { background: var(--primary); padding: 7.5rem 0 2.5rem; }
  .page-header__breadcrumb { font-size: 0.82rem; color: rgba(255,255,255,0.4); margin-bottom: 0.75rem; }
  .page-header__breadcrumb a { color: rgba(255,255,255,0.6); text-decoration: none; }
  .page-header__breadcrumb a:hover { color: var(--accent); }
  .page-header__breadcrumb span { margin: 0 0.35rem; }
  .page-header h1 { color: #fff; font-size: clamp(1.75rem, 4vw, 2.75rem); font-weight: 800; margin-bottom: 0.5rem; }
  .page-header p { color: rgba(255,255,255,0.65); font-size: 1.05rem; }

  /* ===== SECTIONS ===== */
  .section { padding: 4.5rem 0; }

  /* ===== SERVICE DETAIL BLOCKS ===== */
  .service-detail {
    display: flex; gap: 1.75rem; padding: 2.5rem 0;
    border-bottom: 1px solid var(--border);
  }
  .service-detail:first-of-type { padding-top: 0; }
  .service-detail__icon {
    flex-shrink: 0; width: 60px; height: 60px; border-radius: 14px;
    background: rgba(204,51,51,0.08); color: var(--accent);
    display: flex; align-items: center; justify-content: center;
  }
  .service-detail__body h2 {
    font-size: 1.3rem; font-weight: 700; margin-bottom: 0.6rem;
  }
  .service-detail__body p {
    font-size: 0.95rem; color: var(--text-mid); line-height: 1.75;
    margin-bottom: 1rem; max-width: 640px;
  }
  .service-detail__body ul {
    list-style: none; display: flex; flex-wrap: wrap; gap: 0.4rem 1.75rem;
  }
  .service-detail__body li {
    font-size: 0.87rem; color: var(--text-mid); padding-left: 1.2rem;
    position: relative;
  }
  .service-detail__body li::before {
    content: ''; position: absolute; left: 0; top: 0.5rem;
    width: 6px; height: 6px; border-radius: 50%; background: var(--accent);
  }

  @media (max-width: 640px) {
    .service-detail { flex-direction: column; gap: 1rem; }
  }

  /* ===== OEM CALLOUT ===== */
  .oem-callout {
    display: flex; gap: 1.5rem; margin-top: 3rem;
    padding: 2.25rem; background: rgba(204,51,51,0.04);
    border: 1px solid rgba(204,51,51,0.12); border-radius: 12px;
    border-left: 5px solid var(--accent);
  }
  .oem-callout__icon {
    flex-shrink: 0; width: 60px; height: 60px; border-radius: 14px;
    background: rgba(204,51,51,0.1); color: var(--accent);
    display: flex; align-items: center; justify-content: center;
  }
  .oem-callout__body h2 {
    font-size: 1.2rem; font-weight: 700; margin-bottom: 0.5rem; color: var(--primary);
  }
  .oem-callout__body p {
    font-size: 0.95rem; color: var(--text-mid); line-height: 1.75;
  }

  @media (max-width: 640px) {
    .oem-callout { flex-direction: column; gap: 1rem; }
  }

  /* ===== BUTTONS ===== */
  .btn {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-size: 0.92rem; font-weight: 600; text-decoration: none;
    padding: 0.75rem 1.6rem; border-radius: 6px; transition: all 0.15s;
    border: 2px solid transparent; cursor: pointer;
    font-family: inherit;
  }
  .btn--primary { background: var(--accent); color: #fff; border-color: var(--accent); }
  .btn--primary:hover { background: #b82d2d; border-color: #b82d2d; }
  .btn--white { background: #fff; color: var(--accent); border-color: #fff; }
  .btn--white:hover { background: #f0f0f0; transform: translateY(-1px); }
  .btn--outline-white { background: transparent; color: #fff; border-color: rgba(255,255,255,0.4); }
  .btn--outline-white:hover { border-color: #fff; background: rgba(255,255,255,0.1); }
  .btn--lg { padding: 0.9rem 2rem; font-size: 1rem; }

  /* ===== CTA BANNER ===== */
  .cta-banner {
    background: linear-gradient(135deg, var(--accent) 0%, #a02828 100%);
    padding: 4.5rem 0; text-align: center;
  }
  .cta-banner__inner h2 {
    font-size: clamp(1.5rem, 3.5vw, 2.5rem); font-weight: 800;
    color: #fff; margin-bottom: 0.75rem;
  }
  .cta-banner__inner p {
    font-size: 1.1rem; color: rgba(255,255,255,0.85); margin-bottom: 2rem;
  }
  .cta-banner__actions {
    display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap;
  }

  /* ===== FOOTER ===== */
  .footer { background: #1c1c1c; color: rgba(255,255,255,0.65); padding: 4rem 0 0; }
  .footer__inner { display: grid; grid-template-columns: 1.5fr 1fr 1fr 1fr; gap: 2.5rem; }
