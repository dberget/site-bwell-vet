---
import Analytics from '../../components/Analytics.astro';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>CentraSota Electric — Alexandria's Family-Owned Local Electrician</title>
  <meta name="description" content="CentraSota Electric — family-owned electrical contractor in Alexandria, MN. Residential, commercial, repairs, generators, and lighting. Licensed & insured. Call (320) 762-9473." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <Analytics />
</head>
<body>

  <!-- NAV -->
  <header class="nav">
    <div class="nav__inner">
      <a href="/centrasota-electric" class="nav__brand">
        <span class="nav__name">CentraSota Electric</span>
      </a>
      <nav class="nav__links">
        <a href="/centrasota-electric" class="nav__link nav__link--active">Home</a>
        <a href="/centrasota-electric/services" class="nav__link">Services</a>
        <a href="/centrasota-electric/contact" class="nav__link">Contact</a>
      </nav>
      <a href="tel:3207629473" class="nav__cta">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 013.12 4.18 2 2 0 015.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        (320) 762-9473
      </a>
      <button class="nav__hamburger" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </header>

  <!-- HERO -->
  <section class="hero">
    <div class="hero__bg">
      <img src="https://picsum.photos/seed/centrasota/1400/700" alt="CentraSota Electric serving Alexandria, MN" class="hero__bg-img" />
      <div class="hero__overlay"></div>
    </div>
    <div class="hero__content">
      <span class="hero__badge">Licensed &amp; Insured | Family Owned</span>
      <h1 class="hero__title">Alexandria's Family-Owned<br/>Local Electrician</h1>
      <p class="hero__desc">Dignity, Integrity, and Honesty. Serving Alexandria and the surrounding area with safe, reliable electrical work for over a decade.</p>
      <div class="hero__actions">
        <a href="tel:3207629473" class="btn btn--primary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 013.12 4.18 2 2 0 015.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          Call for Service
        </a>
        <a href="/centrasota-electric/services" class="btn btn--outline">View Our Services</a>
      </div>
      <div class="hero__stats">
        <div class="hero__stat">
          <span class="hero__stat-num">10+</span>
          <span class="hero__stat-label">Years Experience</span>
        </div>
        <div class="hero__stat-divider"></div>
        <div class="hero__stat">
          <span class="hero__stat-num">Family</span>
          <span class="hero__stat-label">Owned</span>
        </div>
        <div class="hero__stat-divider"></div>
        <div class="hero__stat">
          <span class="hero__stat-num">Licensed</span>
          <span class="hero__stat-label">&amp; Insured</span>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURED SERVICES -->
  <section class="section" id="services">
    <div class="container">
      <span class="eyebrow">What We Do</span>
      <h2 class="section__title">Our Services</h2>
      <div class="services-grid">
        <div class="service-card">
          <div class="service-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </div>
          <h3>Residential Electrical</h3>
          <p>Panel upgrades, rewiring, outlet installation, ceiling fans, and whole-home electrical solutions.</p>
        </div>
        <div class="service-card">
          <div class="service-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><polyline points="16 3 12 7 8 3"/></svg>
          </div>
          <h3>Commercial Electrical</h3>
          <p>Office buildouts, retail spaces, restaurant wiring, and commercial code compliance.</p>
        </div>
        <div class="service-card">
          <div class="service-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>
          </div>
          <h3>Electrical Repairs</h3>
          <p>Troubleshooting, circuit breaker replacement, outlet and switch repair for any situation.</p>
        </div>
        <div class="service-card">
          <div class="service-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="1" y="3" width="15" height="13" rx="2"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          </div>
          <h3>New Construction</h3>
          <p>Complete electrical systems for new builds, spec homes, and additions from the ground up.</p>
        </div>
        <div class="service-card">
          <div class="service-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          </div>
          <h3>Generator Installation</h3>
          <p>Standby generators and transfer switches to keep your home or business powered through any outage.</p>
        </div>
        <div class="service-card">
          <div class="service-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
          </div>
          <h3>Lighting</h3>
          <p>Indoor and outdoor lighting, LED upgrades, and landscape lighting design and installation.</p>
        </div>
      </div>
      <div class="services-more">
        <a href="/centrasota-electric/services" class="btn btn--secondary">View All Services →</a>
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="section section--about" id="about">
    <div class="container about-grid">
      <div class="about__content">
        <span class="eyebrow">Who We Are</span>
        <h2 class="section__title">About CentraSota Electric</h2>
        <p>CentraSota Electric is a family-owned electrical contracting company led by Jason Schneiderhan for over 10 years. We are committed to providing safe, high-quality electrical work for both commercial and residential customers throughout Alexandria, MN and the surrounding area.</p>
        <p>Our work is guided by three core values: <strong>Dignity, Integrity, and Honesty</strong>. We treat every customer and every job with the respect they deserve, delivering dependable results you can count on.</p>
        <p>Whether you need a panel upgrade, full new-construction wiring, a generator install, or a simple repair, CentraSota Electric is the name Alexandria trusts.</p>
        <div class="about__values">
          <div class="about__value">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <span>Dignity</span>
          </div>
          <div class="about__value">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Integrity</span>
          </div>
          <div class="about__value">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
            <span>Honesty</span>
          </div>
        </div>
      </div>
      <div class="about__image">
        <img src="https://picsum.photos/seed/centrasota-about/600/500" alt="CentraSota Electric team" />
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="section section--dark" id="testimonials">
    <div class="container">
      <span class="eyebrow eyebrow--light">Customer Reviews</span>
      <h2 class="section__title section__title--light">What Our Customers Say</h2>
      <div class="testimonials-grid">
        <div class="testimonial-card testimonial-card--featured">
          <div class="testimonial-card__stars">★★★★★</div>
          <blockquote>"Jason and his crew rewired our entire 1960s home. They were on time every day, cleaned up after themselves, and explained everything clearly. The best electrician we've ever worked with — honest and fair pricing."</blockquote>
          <cite>— Sarah M.</cite>
        </div>
        <div class="testimonial-card">
          <div class="testimonial-card__stars">★★★★★</div>
          <blockquote>"Had CentraSota install a standby generator before winter. They handled everything from permits to the final hookup. When the power went out in January, we didn't even notice. Highly recommend."</blockquote>
          <cite>— Tom R.</cite>
        </div>
        <div class="testimonial-card">
          <div class="testimonial-card__stars">★★★★★</div>
          <blockquote>"Called them for a tripping breaker and they came out the same day. Diagnosed the problem quickly and fixed it on the spot. Very professional and reasonably priced."</blockquote>
          <cite>— Jennifer L.</cite>
        </div>
        <div class="testimonial-card">
          <div class="testimonial-card__stars">★★★★★</div>
          <blockquote>"We used CentraSota Electric for our new restaurant buildout. They worked around our schedule, passed every inspection on the first try, and were great to communicate with throughout the project."</blockquote>
          <cite>— Mike D.</cite>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--cta">
    <div class="container cta-content">
      <h2>Need an Electrician? Call CentraSota.</h2>
      <p>Licensed, insured, and family-owned. Serving Alexandria and the surrounding area for over 10 years.</p>
      <div class="cta-actions">
        <a href="tel:3207629473" class="btn btn--primary btn--lg">Call (320) 762-9473</a>
        <a href="/centrasota-electric/contact" class="btn btn--outline btn--lg">Contact Us</a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container footer__inner">
      <div class="footer__col">
        <h4>CentraSota Electric</h4>
        <p>Family-owned electrical contractor in Alexandria, MN. Dignity, Integrity, and Honesty in every job.</p>
      </div>
      <div class="footer__col">
        <h4>Quick Links</h4>
        <ul>
          <li><a href="/centrasota-electric">Home</a></li>
          <li><a href="/centrasota-electric/services">Services</a></li>
          <li><a href="/centrasota-electric/contact">Contact</a></li>
        </ul>
      </div>
      <div class="footer__col">
        <h4>Contact</h4>
        <p>PO Box 381<br/>Alexandria, MN</p>
        <p><a href="tel:3207629473">(320) 762-9473</a></p>
        <p>Owner: Jason Schneiderhan</p>
      </div>
      <div class="footer__col">
        <h4>Hours</h4>
        <table class="footer__hours">
          <tr><td>Mon–Fri</td><td>7:00 AM – 5:00 PM</td></tr>
          <tr><td>Sat–Sun</td><td>Emergency Only</td></tr>
        </table>
      </div>
    </div>
    <div class="footer__bottom">
      <p>&copy; 2026 CentraSota Electric. All rights reserved.</p>
    </div>
  </footer>

  <script>
    // Sticky nav shadow
    const nav = document.querySelector('.nav');
    window.addEventListener('scroll', () => {
      nav?.classList.toggle('nav--scrolled', window.scrollY > 20);
    });
    // Mobile menu
    document.querySelector('.nav__hamburger')?.addEventListener('click', () => {
      document.querySelector('.nav__links')?.classList.toggle('nav__links--open');
    });
  </script>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --primary: #0d47a1;
    --accent: #ffc107;
    --text: #1a1a1a;
    --text-mid: #555;
    --text-light: #888;
    --bg: #fff;
    --bg-warm: #fafafa;
    --border: #e5e7eb;
  }

  body {
    font-family: 'Inter', -apple-system, sans-serif;
    color: var(--text);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  .container { max-width: 1140px; margin: 0 auto; padding: 0 1.5rem; }

  /* NAV */
  .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: var(--primary);
    transition: box-shadow 0.2s;
  }
  .nav--scrolled { box-shadow: 0 2px 20px rgba(0,0,0,0.15); }
  .nav__inner {
    max-width: 1140px; margin: 0 auto; padding: 0 1.5rem;
    display: flex; align-items: center; justify-content: space-between;
    height: 64px;
  }
  .nav__brand { display: flex; align-items: center; gap: 0.6rem; text-decoration: none; }
  .nav__name { color: #fff; font-weight: 700; font-size: 1.1rem; }
  .nav__links { display: flex; gap: 0.25rem; }
  .nav__link {
    color: rgba(255,255,255,0.75); text-decoration: none; font-size: 0.88rem;
    font-weight: 500; padding: 0.4rem 0.75rem; border-radius: 6px;
    transition: color 0.15s, background 0.15s;
  }
  .nav__link:hover, .nav__link--active { color: #fff; background: rgba(255,255,255,0.1); }
  .nav__cta {
    display: flex; align-items: center; gap: 0.4rem;
    background: var(--accent); color: #1a1a1a; text-decoration: none;
    font-size: 0.85rem; font-weight: 600; padding: 0.5rem 1rem;
    border-radius: 6px; transition: opacity 0.15s;
  }
  .nav__cta:hover { opacity: 0.9; }
  .nav__hamburger {
    display: none; background: none; border: none; cursor: pointer;
    flex-direction: column; gap: 5px; padding: 4px;
  }
  .nav__hamburger span {
    display: block; width: 22px; height: 2px; background: #fff;
    border-radius: 1px; transition: 0.2s;
  }

  @media (max-width: 768px) {
    .nav__links {
      display: none; position: absolute; top: 64px; left: 0; right: 0;
      background: var(--primary); flex-direction: column; padding: 1rem;
      box-shadow: 0 8px 20px rgba(0,0,0,0.2);
    }
    .nav__links--open { display: flex; }
    .nav__link { padding: 0.75rem 1rem; }
    .nav__cta { display: none; }
    .nav__hamburger { display: flex; }
  }

  /* HERO */
  .hero {
    position: relative; min-height: 85vh; display: flex; align-items: center;
    padding: 8rem 1.5rem 5rem;
  }
  .hero__bg { position: absolute; inset: 0; }
  .hero__bg-img { width: 100%; height: 100%; object-fit: cover; }
  .hero__overlay {
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(13,71,161,0.92) 0%, rgba(13,71,161,0.75) 100%);
  }
  .hero__content {
    position: relative; max-width: 720px; margin: 0 auto 0 0;
    padding-left: calc((100vw - 1140px) / 2);
  }
  @media (max-width: 1172px) { .hero__content { padding-left: 1.5rem; } }
  .hero__badge {
    display: inline-block; background: var(--accent); color: #1a1a1a;
    font-size: 0.78rem; font-weight: 700; letter-spacing: 0.08em;
    text-transform: uppercase; padding: 0.35rem 0.9rem; border-radius: 4px;
    margin-bottom: 1.25rem;
  }
  .hero__title {
    font-size: clamp(2.25rem, 5vw, 3.5rem); font-weight: 900;
    line-height: 1.1; color: #fff; margin-bottom: 1.25rem;
  }
  .hero__desc {
    font-size: 1.1rem; line-height: 1.7; color: rgba(255,255,255,0.85);
    margin-bottom: 2rem; max-width: 560px;
  }
  .hero__actions { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 2.5rem; }
  .hero__stats {
    display: flex; align-items: center; gap: 2rem;
    padding-top: 2rem; border-top: 1px solid rgba(255,255,255,0.15);
  }
  .hero__stat { text-align: center; }
  .hero__stat-num { display: block; font-size: 1.5rem; font-weight: 800; color: var(--accent); }
  .hero__stat-label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.06em; color: rgba(255,255,255,0.6); }
  .hero__stat-divider { width: 1px; height: 40px; background: rgba(255,255,255,0.15); }

  @media (max-width: 480px) {
    .hero { min-height: 70vh; padding: 6rem 1.25rem 3rem; }
    .hero__actions { flex-direction: column; }
    .hero__stats { gap: 1.25rem; }
    .hero__stat-divider { display: none; }
  }

  /* BUTTONS */
  .btn {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-size: 0.92rem; font-weight: 600; text-decoration: none;
    padding: 0.7rem 1.5rem; border-radius: 6px; transition: all 0.15s;
    border: 2px solid transparent; cursor: pointer;
  }
  .btn--primary { background: var(--accent); color: #1a1a1a; border-color: var(--accent); }
  .btn--primary:hover { opacity: 0.9; transform: translateY(-1px); }
  .btn--outline { background: transparent; color: #fff; border-color: rgba(255,255,255,0.4); }
  .btn--outline:hover { border-color: #fff; background: rgba(255,255,255,0.1); }
  .btn--secondary { background: var(--primary); color: #fff; }
  .btn--secondary:hover { opacity: 0.9; }
  .btn--lg { padding: 0.85rem 2rem; font-size: 1rem; }

  /* SECTIONS */
  .section { padding: 5rem 0; }
  .section--dark { background: var(--primary); }
  .section--cta {
    background: linear-gradient(135deg, #0d47a1 0%, #0a3570 100%);
    text-align: center; padding: 4rem 0;
  }
  .eyebrow {
    display: block; font-size: 0.78rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--primary); margin-bottom: 0.5rem;
  }
  .eyebrow--light { color: var(--accent); }
  .section__title {
    font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 800;
    margin-bottom: 2.5rem; line-height: 1.2;
  }
  .section__title--light { color: #fff; }

  /* SERVICES GRID */
  .services-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem; margin-bottom: 2rem;
  }
  .service-card {
    background: #fff; border: 1px solid var(--border); border-radius: 8px;
    padding: 1.75rem; transition: box-shadow 0.2s, transform 0.2s;
    border-top: 4px solid var(--accent);
  }
  .service-card:hover { box-shadow: 0 8px 24px rgba(0,0,0,0.08); transform: translateY(-2px); }
  .service-card__icon {
    width: 48px; height: 48px; border-radius: 10px;
    background: rgba(255,193,7,0.12); color: var(--primary);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 1rem;
  }
  .service-card h3 { font-size: 1.05rem; font-weight: 700; margin-bottom: 0.4rem; }
  .service-card p { font-size: 0.88rem; color: var(--text-mid); line-height: 1.6; }
  .services-more { text-align: center; }

  @media (max-width: 768px) { .services-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .services-grid { grid-template-columns: 1fr; } }

  /* ABOUT */
  .section--about { background: var(--bg-warm); }
  .about-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 3.5rem; align-items: center;
  }
  .about__content p {
    font-size: 0.95rem; color: var(--text-mid); line-height: 1.7;
    margin-bottom: 1rem;
  }
  .about__values {
    display: flex; gap: 1.5rem; margin-top: 1.5rem; flex-wrap: wrap;
  }
  .about__value {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 0.92rem; font-weight: 600; color: var(--primary);
  }
  .about__value svg { color: var(--accent); }
  .about__image img {
    width: 100%; border-radius: 10px; object-fit: cover;
    box-shadow: 0 8px 30px rgba(0,0,0,0.1);
  }
  @media (max-width: 768px) {
    .about-grid { grid-template-columns: 1fr; gap: 2rem; }
    .about__image { order: -1; }
  }

  /* TESTIMONIALS */
  .testimonials-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem;
  }
  .testimonial-card {
    background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
    border-radius: 8px; padding: 1.75rem;
  }
  .testimonial-card--featured {
    grid-column: 1 / -1;
    background: rgba(255,193,7,0.1); border-color: rgba(255,193,7,0.2);
  }
  .testimonial-card__stars { color: var(--accent); font-size: 1rem; margin-bottom: 0.75rem; letter-spacing: 2px; }
  .testimonial-card blockquote {
    font-size: 0.95rem; color: rgba(255,255,255,0.85); line-height: 1.7;
