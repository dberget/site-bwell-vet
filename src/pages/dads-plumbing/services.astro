---
import Analytics from '../../components/Analytics.astro';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Services — Dad's Plumbing & Heating | Scandia, MN</title>
  <meta name="description" content="Residential and commercial plumbing, water heaters, boilers, drain cleaning, sewer lines, emergency service, and remodeling plumbing. Serving Scandia, Stillwater, and the St. Croix Valley since 1987." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <Analytics />
</head>
<body>

  <!-- EMERGENCY BAR (appears on scroll) -->
  <div class="emergency-bar" id="emergencyBar">
    <div class="emergency-bar__inner">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 013.12 4.18 2 2 0 015.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
      <span>24/7 Emergency Service</span>
      <a href="tel:6514366212">(651) 436-6212</a>
    </div>
  </div>

  <!-- NAV -->
  <header class="nav">
    <div class="nav__inner">
      <a href="/dads-plumbing" class="nav__brand">
        <span class="nav__name">Dad's Plumbing</span>
      </a>
      <nav class="nav__links">
        <a href="/dads-plumbing" class="nav__link">Home</a>
        <a href="/dads-plumbing/services" class="nav__link nav__link--active">Services</a>
        <a href="/dads-plumbing/contact" class="nav__link">Contact</a>
      </nav>
      <a href="tel:6514366212" class="nav__cta">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 013.12 4.18 2 2 0 015.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        24/7 Emergency: (651) 436-6212
      </a>
      <button class="nav__hamburger" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </header>

  <!-- PAGE HEADER -->
  <section class="page-header">
    <div class="container">
      <div class="page-header__breadcrumb">
        <a href="/dads-plumbing">Home</a> <span>/</span> <span>Services</span>
      </div>
      <h1>Our Services</h1>
      <p>Complete plumbing and heating solutions for your home and business, backed by three generations of expertise.</p>
    </div>
  </section>

  <!-- SERVICE BLOCKS (alternating layout) -->
  <section class="section">
    <div class="container">

      <!-- 1. Residential Plumbing -->
      <div class="service-block" id="residential">
        <div class="service-block__image">
          <img src="/images/dads-plumbing/content-01.png" alt="Residential plumbing services" loading="lazy" />
        </div>
        <div class="service-block__content">
          <span class="service-block__number">01</span>
          <h2>Residential Plumbing</h2>
          <p>From a leaky faucet to a full bathroom re-pipe, we handle every plumbing need in your home. Our technicians treat your house with the same care they'd give their own, arriving on time, working clean, and explaining every step.</p>
          <ul>
            <li>Faucet repair and installation</li>
            <li>Toilet repair and replacement</li>
            <li>Pipe repair and re-piping</li>
            <li>Fixture installation</li>
            <li>Garbage disposal service</li>
            <li>Water line repair</li>
          </ul>
        </div>
      </div>

      <!-- 2. Commercial Plumbing -->
      <div class="service-block service-block--reverse" id="commercial">
        <div class="service-block__image">
          <img src="/images/dads-plumbing/content-02.png" alt="Commercial plumbing services" loading="lazy" />
        </div>
        <div class="service-block__content">
          <span class="service-block__number">02</span>
          <h2>Commercial Plumbing</h2>
          <p>We provide dependable plumbing services for businesses throughout the St. Croix Valley. Whether you run a restaurant, office, or retail space, we understand that plumbing problems mean lost revenue, and we respond accordingly.</p>
          <ul>
            <li>Restaurant and food service plumbing</li>
            <li>Office building plumbing</li>
            <li>Commercial water heater service</li>
            <li>Backflow prevention</li>
            <li>Code compliance and inspections</li>
          </ul>
        </div>
      </div>

      <!-- 3. Water Heaters -->
      <div class="service-block" id="water-heaters">
        <div class="service-block__image">
          <img src="/images/dads-plumbing/content-03.png" alt="Water heater installation and repair" loading="lazy" />
        </div>
        <div class="service-block__content">
          <span class="service-block__number">03</span>
          <h2>Water Heater Sales, Installation & Repair</h2>
          <p>No hot water? We can diagnose the problem quickly and get your hot water flowing again. We sell, install, and repair both traditional tank and modern tankless water heaters from leading manufacturers.</p>
          <ul>
            <li>Tank water heater installation</li>
            <li>Tankless water heater installation</li>
            <li>Water heater repair</li>
            <li>Replacement and upgrades</li>
            <li>Sediment flush and maintenance</li>
            <li>Emergency water heater service</li>
          </ul>
        </div>
      </div>

      <!-- 4. Boiler Service -->
      <div class="service-block service-block--reverse" id="boilers">
        <div class="service-block__image">
          <img src="/images/dads-plumbing/content-04.png" alt="Boiler sales and repair" loading="lazy" />
        </div>
        <div class="service-block__content">
          <span class="service-block__number">04</span>
          <h2>Boiler Sales & Repair</h2>
          <p>Minnesota winters demand a reliable heating system. We install and service steam boilers, hot water boilers, and radiant heat systems. When your boiler stops working, we provide fast, expert repairs to get your home warm again.</p>
          <ul>
            <li>Steam boiler service</li>
            <li>Hot water boiler repair</li>
            <li>Radiant floor heating</li>
            <li>Boiler installation and replacement</li>
            <li>Annual maintenance and tune-ups</li>
            <li>Emergency no-heat service</li>
          </ul>
        </div>
      </div>

      <!-- 5. Drain Cleaning -->
      <div class="service-block" id="drain-cleaning">
        <div class="service-block__image">
          <img src="/images/dads-plumbing/content-01.png" alt="Drain cleaning services" loading="lazy" />
        </div>
        <div class="service-block__content">
          <span class="service-block__number">05</span>
          <h2>Drain Cleaning</h2>
          <p>Slow drains, gurgling pipes, and recurring clogs are signs of a problem that won't fix itself. We use professional-grade equipment to clear even the toughest blockages, including root intrusions and grease buildup.</p>
          <ul>
            <li>Clogged drain clearing</li>
            <li>Root removal from sewer lines</li>
            <li>Camera inspection and diagnosis</li>
            <li>Kitchen and bathroom drain service</li>
            <li>Floor drain maintenance</li>
            <li>Preventative drain cleaning</li>
          </ul>
        </div>
      </div>

      <!-- 6. Sewer Line Services -->
      <div class="service-block service-block--reverse" id="sewer">
        <div class="service-block__image">
          <img src="/images/dads-plumbing/content-02.png" alt="Sewer line services" loading="lazy" />
        </div>
        <div class="service-block__content">
          <span class="service-block__number">06</span>
          <h2>Sewer Line Services</h2>
          <p>Sewer line problems can cause serious damage to your home and property. We provide thorough sewer line repair, replacement, and video inspection to diagnose problems accurately and fix them right the first time.</p>
          <ul>
            <li>Sewer line repair</li>
            <li>Sewer line replacement</li>
            <li>Video camera inspection</li>
            <li>Root intrusion treatment</li>
            <li>Sewer backup cleanup</li>
            <li>New sewer line installation</li>
          </ul>
        </div>
      </div>

      <!-- 7. Emergency Plumbing -->
      <div class="service-block" id="emergency">
        <div class="service-block__image">
          <img src="/images/dads-plumbing/content-03.png" alt="Emergency plumbing service" loading="lazy" />
        </div>
        <div class="service-block__content">
          <span class="service-block__number">07</span>
          <h2>Emergency Plumbing 24/7</h2>
          <p>Plumbing emergencies don't wait for business hours, and neither do we. Whether it's a burst pipe at 2 AM, a flooded basement, or a gas leak, call us immediately. A real person answers, and we'll be at your door as fast as possible.</p>
          <ul>
            <li>Burst and frozen pipe repair</li>
            <li>Flooding and water damage mitigation</li>
            <li>Gas leak detection and repair</li>
            <li>No-heat emergencies</li>
            <li>Sewer backup response</li>
            <li>Available 24 hours, 365 days</li>
          </ul>
        </div>
      </div>

      <!-- 8. Remodeling Plumbing -->
      <div class="service-block service-block--reverse" id="remodeling">
        <div class="service-block__image">
          <img src="/images/dads-plumbing/content-04.png" alt="Remodeling plumbing services" loading="lazy" />
        </div>
        <div class="service-block__content">
          <span class="service-block__number">08</span>
          <h2>Remodeling Plumbing</h2>
          <p>Planning a bathroom or kitchen remodel? We work with you and your contractor to ensure the plumbing is done right from the start. From new construction rough-ins to finish fixture installation, we handle every detail.</p>
          <ul>
            <li>Bathroom remodel plumbing</li>
            <li>Kitchen remodel plumbing</li>
            <li>New construction rough-in</li>
            <li>Fixture and appliance hookup</li>
            <li>Re-piping for remodels</li>
            <li>Permit and inspection coordination</li>
          </ul>
        </div>
      </div>

    </div>
  </section>

  <!-- EMERGENCY CALLOUT -->
  <section class="emergency-callout">
    <div class="container">
      <div class="emergency-callout__card">
        <div class="emergency-callout__icon">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        </div>
        <div class="emergency-callout__text">
          <h2>Plumbing Emergency?</h2>
          <p>Don't wait. Our 24/7 emergency line is always answered by a real person. We'll be at your door as fast as possible.</p>
        </div>
        <a href="tel:6514366212" class="btn btn--gold btn--lg">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 013.12 4.18 2 2 0 015.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          Call (651) 436-6212
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--cta">
    <div class="container cta-content">
      <h2>Ready to Get Started?</h2>
      <p>Whether it's a routine repair or a major project, our family is here to help yours. Call today or send us a message.</p>
      <div class="cta-actions">
        <a href="tel:6514366212" class="btn btn--cta-primary btn--lg">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 013.12 4.18 2 2 0 015.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          Call (651) 436-6212
        </a>
        <a href="/dads-plumbing/contact" class="btn btn--cta-outline btn--lg">Contact Us</a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container footer__inner">
      <div class="footer__col">
        <h4>Dad's Plumbing & Heating</h4>
        <p>Complete plumbing and heating services since 1987. A 3rd generation family business proudly serving the St. Croix Valley.</p>
      </div>
      <div class="footer__col">
        <h4>Quick Links</h4>
        <ul>
          <li><a href="/dads-plumbing">Home</a></li>
          <li><a href="/dads-plumbing/services">Services</a></li>
          <li><a href="/dads-plumbing/contact">Contact</a></li>
        </ul>
      </div>
      <div class="footer__col">
        <h4>Contact</h4>
        <p>Scandia, MN</p>
        <p><a href="tel:6514366212">(651) 436-6212</a></p>
        <p class="footer__hours-note">24/7 Emergency Service</p>
      </div>
      <div class="footer__col">
        <h4>Service Area</h4>
        <ul>
          <li>Scandia</li>
          <li>Stillwater</li>
          <li>Marine on St. Croix</li>
          <li>Forest Lake</li>
          <li>Hugo</li>
          <li>Bayport</li>
        </ul>
      </div>
    </div>
    <div class="footer__bottom">
      <p>&copy; 2026 Dad's Plumbing & Heating Company, LLC. All rights reserved.</p>
    </div>
  </footer>

  <script>
    // Sticky nav shadow
    const nav = document.querySelector('.nav');
    window.addEventListener('scroll', () => {
      nav?.classList.toggle('nav--scrolled', window.scrollY > 20);
    });
    // Mobile menu
    document.querySelector('.nav__hamburger')?.addEventListener('click', () => {
      document.querySelector('.nav__links')?.classList.toggle('nav__links--open');
    });
    // Emergency bar show on scroll
    const emergencyBar = document.getElementById('emergencyBar');
    const navHeight = 68;
    window.addEventListener('scroll', () => {
      if (window.scrollY > navHeight) {
        emergencyBar?.classList.add('emergency-bar--visible');
      } else {
        emergencyBar?.classList.remove('emergency-bar--visible');
      }
    });
  </script>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --primary: #1a4731;
    --primary-dark: #122f21;
    --accent: #d4a843;
    --accent-dark: #b8922f;
    --text: #1a1a1a;
    --text-mid: #555;
    --text-light: #888;
    --bg: #fff;
    --bg-warm: #faf8f4;
    --bg-cream: #f5f0e8;
    --border: #e5e2da;
  }

  body {
    font-family: 'Inter', -apple-system, sans-serif;
    color: var(--text);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  .container { max-width: 1140px; margin: 0 auto; padding: 0 1.5rem; }

  /* EMERGENCY BAR */
  .emergency-bar {
    position: fixed; top: 0; left: 0; right: 0; z-index: 200;
    background: var(--primary-dark);
    transform: translateY(-100%);
    transition: transform 0.3s ease;
  }
  .emergency-bar--visible { transform: translateY(0); }
  .emergency-bar__inner {
    max-width: 1140px; margin: 0 auto; padding: 0.4rem 1.5rem;
    display: flex; align-items: center; justify-content: center; gap: 0.75rem;
    font-size: 0.82rem;
  }
  .emergency-bar__inner svg { color: var(--accent); flex-shrink: 0; }
  .emergency-bar__inner span { color: var(--accent); font-weight: 600; }
  .emergency-bar__inner a {
    color: #fff; text-decoration: none; font-weight: 700;
    background: var(--accent); padding: 0.15rem 0.6rem; border-radius: 4px;
    font-size: 0.8rem;
  }
  .emergency-bar__inner a:hover { background: var(--accent-dark); }

  /* NAV */
  .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: var(--primary);
    transition: box-shadow 0.2s;
  }
  .nav--scrolled { box-shadow: 0 2px 20px rgba(0,0,0,0.2); }
  .nav__inner {
    max-width: 1140px; margin: 0 auto; padding: 0 1.5rem;
    display: flex; align-items: center; justify-content: space-between;
    height: 68px;
  }
  .nav__brand { display: flex; align-items: center; gap: 0.6rem; text-decoration: none; }
  .nav__name {
    color: #fff; font-weight: 800; font-size: 1.2rem;
    letter-spacing: 0.03em;
  }
  .nav__links { display: flex; gap: 0.25rem; }
  .nav__link {
    color: rgba(255,255,255,0.75); text-decoration: none; font-size: 0.88rem;
    font-weight: 500; padding: 0.4rem 0.75rem; border-radius: 6px;
    transition: color 0.15s, background 0.15s;
  }
  .nav__link:hover, .nav__link--active { color: #fff; background: rgba(255,255,255,0.1); }
  .nav__cta {
    display: flex; align-items: center; gap: 0.4rem;
    background: var(--accent); color: var(--primary-dark); text-decoration: none;
    font-size: 0.82rem; font-weight: 700; padding: 0.5rem 1rem;
    border-radius: 6px; transition: background 0.15s;
  }
  .nav__cta:hover { background: var(--accent-dark); }
  .nav__cta svg { flex-shrink: 0; }
  .nav__hamburger {
    display: none; background: none; border: none; cursor: pointer;
    flex-direction: column; gap: 5px; padding: 4px;
  }
  .nav__hamburger span {
    display: block; width: 22px; height: 2px; background: #fff;
    border-radius: 1px; transition: 0.2s;
  }

  @media (max-width: 768px) {
    .nav__links {
      display: none; position: absolute; top: 68px; left: 0; right: 0;
      background: var(--primary); flex-direction: column; padding: 1rem;
      box-shadow: 0 8px 20px rgba(0,0,0,0.25);
    }
    .nav__links--open { display: flex; }
    .nav__link { padding: 0.75rem 1rem; }
    .nav__cta { display: none; }
    .nav__hamburger { display: flex; }
  }

  /* PAGE HEADER */
  .page-header { background: var(--primary); padding: 7.5rem 0 2.5rem; }
  .page-header__breadcrumb { font-size: 0.82rem; color: rgba(255,255,255,0.45); margin-bottom: 0.75rem; }
  .page-header__breadcrumb a { color: rgba(255,255,255,0.6); text-decoration: none; }
  .page-header__breadcrumb a:hover { color: var(--accent); }
  .page-header__breadcrumb span { margin: 0 0.35rem; }
  .page-header h1 { color: #fff; font-size: clamp(1.75rem, 4vw, 2.75rem); font-weight: 800; margin-bottom: 0.5rem; }
  .page-header p { color: rgba(255,255,255,0.7); font-size: 1.05rem; max-width: 600px; }

  .section { padding: 5rem 0; }

  /* SERVICE BLOCKS (alternating) */
  .service-block {
    display: grid; grid-template-columns: 1fr 1fr; gap: 3rem;
    align-items: center; padding: 3.5rem 0;
    border-bottom: 1px solid var(--border);
  }
  .service-block:first-of-type { padding-top: 0; }
  .service-block:last-of-type { border-bottom: none; }

  .service-block--reverse .service-block__image { order: 2; }
  .service-block--reverse .service-block__content { order: 1; }

  .service-block__image {
    border-radius: 10px; overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
  }
  .service-block__image img { width: 100%; height: 300px; object-fit: cover; display: block; }

  .service-block__number {
    display: inline-block; font-size: 0.75rem; font-weight: 800;
    color: var(--accent); letter-spacing: 0.08em;
    margin-bottom: 0.5rem;
  }
  .service-block__content h2 { font-size: 1.35rem; font-weight: 800; margin-bottom: 0.75rem; color: var(--primary); }
  .service-block__content p { font-size: 0.95rem; color: var(--text-mid); line-height: 1.7; margin-bottom: 1rem; }
  .service-block__content ul { list-style: none; display: grid; grid-template-columns: 1fr 1fr; gap: 0.35rem 1.25rem; }
  .service-block__content li {
    font-size: 0.88rem; color: var(--text-mid); padding-left: 1.1rem;
    position: relative;
  }
  .service-block__content li::before {
    content: ''; position: absolute; left: 0; top: 0.5rem;
    width: 6px; height: 6px; border-radius: 50%; background: var(--accent);
  }

  @media (max-width: 768px) {
    .service-block { grid-template-columns: 1fr; gap: 1.5rem; }
    .service-block--reverse .service-block__image { order: 0; }
    .service-block--reverse .service-block__content { order: 0; }
    .service-block__content ul { grid-template-columns: 1fr; }
  }

  /* EMERGENCY CALLOUT */
  .emergency-callout { padding: 3rem 0; }
  .emergency-callout__card {
    background: var(--primary); border-radius: 12px; padding: 2.5rem;
    display: flex; align-items: center; gap: 2rem;
  }
  .emergency-callout__icon {
    flex-shrink: 0; width: 72px; height: 72px; border-radius: 50%;
    background: rgba(212,168,67,0.15); color: var(--accent);
    display: flex; align-items: center; justify-content: center;
  }
  .emergency-callout__text { flex: 1; }
  .emergency-callout__text h2 { font-size: 1.35rem; font-weight: 800; color: #fff; margin-bottom: 0.35rem; }
  .emergency-callout__text p { font-size: 0.95rem; color: rgba(255,255,255,0.75); line-height: 1.6; }

  @media (max-width: 768px) {
    .emergency-callout__card { flex-direction: column; text-align: center; gap: 1.25rem; padding: 2rem 1.5rem; }
  }

  /* BUTTONS */
  .btn {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-size: 0.92rem; font-weight: 600; text-decoration: none;
    padding: 0.7rem 1.5rem; border-radius: 6px; transition: all 0.15s;
    border: 2px solid transparent; cursor: pointer;
  }
  .btn--gold { background: var(--accent); color: var(--primary-dark); border-color: var(--accent); }
  .btn--gold:hover { background: var(--accent-dark); border-color: var(--accent-dark); }
  .btn--lg { padding: 0.85rem 2rem; font-size: 1rem; }

  /* CTA */
  .section--cta {
    background: linear-gradient(135deg, var(--accent) 0%, #c49a2e 100%);
    text-align: center; padding: 4.5rem 0;
  }
  .cta-content h2 { font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 800; color: var(--primary-dark); margin-bottom: 0.75rem; }
  .cta-content p { font-size: 1.05rem; color: rgba(26,47,33,0.75); margin-bottom: 2rem; max-width: 560px; margin-left: auto; margin-right: auto; }
