  .testimonial-card__stars {
    display: flex; gap: 0.2rem; color: var(--accent);
    margin-bottom: 0.75rem;
  }
  .testimonial-card blockquote {
    font-size: 0.95rem; color: rgba(255,255,255,0.85); line-height: 1.7;
    margin-bottom: 1rem; font-style: italic;
  }
  .testimonial-card cite {
    font-size: 0.85rem; color: rgba(255,255,255,0.5); font-style: normal; font-weight: 600;
  }

  @media (max-width: 768px) { .testimonials-grid { grid-template-columns: 1fr; } }

  /* CTA */
  .cta-content h2 { font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 800; color: var(--primary-dark); margin-bottom: 0.75rem; }
  .cta-content p { font-size: 1.05rem; color: rgba(26,47,33,0.75); margin-bottom: 2rem; max-width: 560px; margin-left: auto; margin-right: auto; }
  .cta-actions { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
  .btn--cta-primary {
    background: var(--primary); color: #fff; border-color: var(--primary);
  }
  .btn--cta-primary:hover { background: var(--primary-dark); border-color: var(--primary-dark); }
  .btn--cta-outline {
    background: transparent; color: var(--primary-dark); border-color: var(--primary-dark);
  }
  .btn--cta-outline:hover { background: var(--primary-dark); color: #fff; }

  /* FOOTER */
  .footer { background: var(--primary-dark); color: rgba(255,255,255,0.7); padding: 4rem 0 0; }
  .footer__inner { display: grid; grid-template-columns: 1.5fr 1fr 1fr 1fr; gap: 2.5rem; }
  .footer__col h4 { color: var(--accent); font-size: 0.95rem; font-weight: 700; margin-bottom: 1rem; }
  .footer__col p { font-size: 0.88rem; line-height: 1.65; }
  .footer__col ul { list-style: none; }
  .footer__col li { margin-bottom: 0.4rem; font-size: 0.88rem; }
  .footer__col a { color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.88rem; transition: color 0.15s; }
  .footer__col a:hover { color: var(--accent); }
  .footer__hours-note { color: var(--accent); font-weight: 600; font-size: 0.85rem; margin-top: 0.5rem; }
  .footer__bottom {
    margin-top: 3rem; padding: 1.25rem 0;
    border-top: 1px solid rgba(255,255,255,0.08); text-align: center;
  }
  .footer__bottom p { font-size: 0.8rem; color: rgba(255,255,255,0.35); }

  @media (max-width: 768px) {
    .footer__inner { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 480px) {
    .footer__inner { grid-template-columns: 1fr; gap: 2rem; }
  }
