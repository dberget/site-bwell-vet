    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 1.25rem;
  }
  .promise-card h3 { font-size: 1.1rem; font-weight: 700; margin-bottom: 0.5rem; color: var(--primary); }
  .promise-card p { font-size: 0.88rem; color: var(--text-mid); line-height: 1.65; }

  @media (max-width: 768px) { .promise-grid { grid-template-columns: 1fr; gap: 1.25rem; } }

  /* TESTIMONIALS */
