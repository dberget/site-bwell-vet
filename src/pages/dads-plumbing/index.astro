    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem;
  }
  .testimonial-card {
    background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
    border-radius: 10px; padding: 1.75rem;
