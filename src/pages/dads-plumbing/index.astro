---
import Analytics from '../../components/Analytics.astro';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dad's Plumbing & Heating — Complete Plumbing and Heating Since 1987</title>
  <meta name="description" content="3rd generation family plumbing and heating company serving Scandia, Stillwater, Marine on St. Croix, and surrounding areas since 1987. 24/7 emergency service. Call (651) 436-6212." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <Analytics />
</head>
<body>

  <!-- EMERGENCY BAR (appears on scroll) -->
  <div class="emergency-bar" id="emergencyBar">
    <div class="emergency-bar__inner">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 013.12 4.18 2 2 0 015.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
      <span>24/7 Emergency Service</span>
      <a href="tel:6514366212">(651) 436-6212</a>
    </div>
  </div>

  <!-- NAV -->
