---
import Analytics from '../../components/Analytics.astro';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Hugo Barber Shop — Traditional Barbering in Hugo, MN</title>
  <meta name="description" content="Hugo Barber Shop offers traditional men's haircuts, beard trims, straight razor shaves, and kids haircuts in Hugo, Minnesota. Walk-ins welcome." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <Analytics />
</head>
<body>

  <!-- NAV -->
  <header class="hb-nav">
    <div class="hb-nav__inner">
      <a href="/hugo-barber" class="hb-nav__brand">
        <svg class="hb-nav__icon" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="5" r="3"/><path d="M12 8v8"/><circle cx="12" cy="19" r="3"/><path d="M8 5h0M16 5h0M8 19h0M16 19h0"/></svg>
        <span class="hb-nav__name">Hugo Barber Shop</span>
      </a>
      <nav class="hb-nav__links">
        <a href="/hugo-barber" class="hb-nav__link hb-nav__link--active">Home</a>
        <a href="/hugo-barber/contact" class="hb-nav__link">Contact</a>
      </nav>
      <a href="tel:6514290975" class="hb-nav__cta">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 013.12 4.18 2 2 0 015.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        (651) 429-0975
      </a>
      <button class="hb-nav__hamburger" aria-label="Menu"><span></span><span></span><span></span></button>
    </div>
  </header>

  <!-- HERO -->
  <section class="hb-hero">
    <div class="hb-hero__bg">
      <img src="https://picsum.photos/seed/barbershop-hero/1600/900" alt="Hugo Barber Shop interior" class="hb-hero__bg-img" />
      <div class="hb-hero__overlay"></div>
    </div>
    <div class="hb-hero__content">

      <h1 class="hb-hero__title">Hugo<br/>Barber Shop</h1>
      <p class="hb-hero__tagline">Traditional Barbering in Hugo Since Day One</p>
      <div class="hb-hero__actions">
        <a href="tel:6514290975" class="hb-btn hb-btn--gold">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 013.12 4.18 2 2 0 015.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          Call Now
        </a>
        <a href="/hugo-barber/contact" class="hb-btn hb-btn--outline">Get in Touch</a>
      </div>
    </div>
    <div class="hb-hero__scroll">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="hb-section" id="services">
    <div class="hb-container">
      <div class="hb-section__header">
        <span class="hb-eyebrow">What We Do</span>
        <h2 class="hb-section__title">Our Services</h2>
      </div>
      <div class="hb-services">
        <div class="hb-service">
          <div class="hb-service__num">01</div>
          <div class="hb-service__content">
            <h3>Men's Haircuts</h3>
            <p>Classic cuts done right. From fades to traditional styles, our barbers deliver precision cuts tailored to you.</p>
          </div>
          <div class="hb-service__icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round"><circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><line x1="20" y1="4" x2="8.12" y2="15.88"/><line x1="14.47" y1="14.48" x2="20" y2="20"/><line x1="8.12" y1="8.12" x2="12" y2="12"/></svg>
          </div>
        </div>
        <div class="hb-service">
          <div class="hb-service__num">02</div>
          <div class="hb-service__content">
            <h3>Beard Trims</h3>
            <p>Whether you're maintaining a full beard or shaping up the edges, we'll get your facial hair looking sharp.</p>
          </div>
          <div class="hb-service__icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round"><path d="M12 2C6.48 2 2 6 2 11c0 3 1.5 5.5 4 7v4l3-2c.97.32 2 .5 3 .5s2.03-.18 3-.5l3 2v-4c2.5-1.5 4-4 4-7 0-5-4.48-9-10-9z"/></svg>
          </div>
        </div>
        <div class="hb-service">
          <div class="hb-service__num">03</div>
          <div class="hb-service__content">
            <h3>Straight Razor Shaves</h3>
            <p>The real deal. Hot towel, lather, and a straight razor for the closest, smoothest shave you've ever had.</p>
          </div>
          <div class="hb-service__icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round"><path d="M7 2h3l9 10.5V22H7V2z"/><path d="M7 2v20"/><path d="M10 2v7"/></svg>
          </div>
        </div>
        <div class="hb-service">
          <div class="hb-service__num">04</div>
          <div class="hb-service__content">
            <h3>Kids Haircuts</h3>
            <p>Bring the little ones in. We make it easy and comfortable — a real barber shop experience for all ages.</p>
          </div>
          <div class="hb-service__icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round"><circle cx="12" cy="8" r="5"/><path d="M20 21a8 8 0 00-16 0"/></svg>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ABOUT / IMAGE BREAK -->
  <section class="hb-split">
    <div class="hb-split__image">
      <img src="https://picsum.photos/seed/barber-chair/800/600" alt="Barber chair at Hugo Barber Shop" />
    </div>
    <div class="hb-split__content">
      <span class="hb-eyebrow">About Us</span>
      <h2 class="hb-split__title">A Real<br/>Barber Shop</h2>
      <p>Hugo Barber Shop is the kind of place where you walk in, sit down, and leave looking your best. No frills, no fuss — just skilled barbers who know their craft.</p>
      <p>Located right on Forest Blvd in Hugo, we've been serving the community with honest, quality barbering. Every client gets the same thing: attention to detail and a clean, sharp cut.</p>
      <a href="/hugo-barber/contact" class="hb-btn hb-btn--gold" style="margin-top:1.5rem;">Book a Visit</a>
    </div>
  </section>

  <!-- LOCATION & HOURS -->
  <section class="hb-section hb-section--dark" id="location">
    <div class="hb-container">
      <div class="hb-section__header">
        <span class="hb-eyebrow">Find Us</span>
        <h2 class="hb-section__title" style="color:#fff;">Location &amp; Hours</h2>
      </div>
      <div class="hb-location-grid">
        <div class="hb-location-card">
          <div class="hb-location-card__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <h3>Address</h3>
          <p>14667 Forest Blvd N<br/>Hugo, MN 55038</p>
          <a href="https://maps.google.com/?q=14667+Forest+Blvd+N+Hugo+MN+55038" target="_blank" rel="noopener" class="hb-location-card__link">Get Directions</a>
        </div>
        <div class="hb-location-card">
          <div class="hb-location-card__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 013.12 4.18 2 2 0 015.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          </div>
          <h3>Phone</h3>
          <p><a href="tel:6514290975">(651) 429-0975</a></p>
          <span class="hb-location-card__sub">Walk-ins Welcome</span>
        </div>
        <div class="hb-location-card">
          <div class="hb-location-card__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <h3>Hours</h3>
          <p>Mon &ndash; Fri: 9am &ndash; 6pm<br/>Saturday: 8am &ndash; 3pm<br/>Sunday: Closed</p>
          <span class="hb-location-card__sub">Call to confirm</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="hb-cta">
    <div class="hb-container hb-cta__inner">
      <h2>Ready for a Fresh Cut?</h2>
      <p>Stop in or give us a call. No appointment needed — just walk in and we'll take care of you.</p>
      <div class="hb-cta__actions">
        <a href="tel:6514290975" class="hb-btn hb-btn--gold hb-btn--lg">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 013.12 4.18 2 2 0 015.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          Call (651) 429-0975
        </a>
        <a href="/hugo-barber/contact" class="hb-btn hb-btn--outline hb-btn--lg">Send a Message</a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="hb-footer">
    <div class="hb-container hb-footer__inner">
      <div class="hb-footer__col">
        <h4>Hugo Barber Shop</h4>
        <p>Traditional barbering in Hugo, Minnesota. Quality haircuts, beard trims, and straight razor shaves.</p>
      </div>
      <div class="hb-footer__col">
        <h4>Links</h4>
        <ul>
          <li><a href="/hugo-barber">Home</a></li>
          <li><a href="/hugo-barber/contact">Contact</a></li>
        </ul>
      </div>
      <div class="hb-footer__col">
        <h4>Visit Us</h4>
        <p>14667 Forest Blvd N<br/>Hugo, MN 55038</p>
        <p style="margin-top:0.5rem;"><a href="tel:6514290975">(651) 429-0975</a></p>
      </div>
    </div>
    <div class="hb-footer__bottom">
      <p>&copy; 2026 Hugo Barber Shop. All rights reserved.</p>
    </div>
  </footer>

  <script>
    const nav = document.querySelector('.hb-nav');
    window.addEventListener('scroll', () => nav?.classList.toggle('hb-nav--scrolled', window.scrollY > 20));
    document.querySelector('.hb-nav__hamburger')?.addEventListener('click', () => {
      document.querySelector('.hb-nav__links')?.classList.toggle('hb-nav__links--open');
    });
  </script>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --primary: #1c1c1c;
    --accent: #c9a96e;
    --text: #f0ece4;
    --text-mid: #a8a29e;
    --bg: #111111;
    --bg-card: #1a1a1a;
    --border: rgba(201,169,110,0.15);
  }

  body {
    font-family: 'Inter', -apple-system, sans-serif;
    color: var(--text);
    background: var(--bg);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  .hb-container { max-width: 1100px; margin: 0 auto; padding: 0 1.5rem; }

  /* NAV */
  .hb-nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: rgba(17,17,17,0.92); backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(201,169,110,0.08);
    transition: box-shadow 0.2s, background 0.2s;
  }
  .hb-nav--scrolled {
    background: rgba(17,17,17,0.98);
    box-shadow: 0 2px 24px rgba(0,0,0,0.4);
  }
  .hb-nav__inner {
    max-width: 1100px; margin: 0 auto; padding: 0 1.5rem;
    display: flex; align-items: center; justify-content: space-between;
    height: 68px;
  }
  .hb-nav__brand { display: flex; align-items: center; gap: 0.6rem; text-decoration: none; }
  .hb-nav__name {
    color: var(--text); font-weight: 800; font-size: 1rem;
    letter-spacing: 0.04em; text-transform: uppercase;
  }
  .hb-nav__links { display: flex; gap: 0.25rem; }
  .hb-nav__link {
    color: var(--text-mid); text-decoration: none; font-size: 0.85rem;
    font-weight: 500; padding: 0.45rem 0.85rem; border-radius: 6px;
    transition: color 0.15s, background 0.15s; letter-spacing: 0.02em;
  }
  .hb-nav__link:hover, .hb-nav__link--active { color: var(--accent); background: rgba(201,169,110,0.06); }
  .hb-nav__cta {
    display: flex; align-items: center; gap: 0.4rem;
    background: var(--accent); color: var(--primary); text-decoration: none;
    font-size: 0.82rem; font-weight: 700; padding: 0.5rem 1rem;
    border-radius: 6px; transition: opacity 0.15s; letter-spacing: 0.02em;
  }
  .hb-nav__cta:hover { opacity: 0.88; }
  .hb-nav__hamburger {
    display: none; background: none; border: none; cursor: pointer;
    flex-direction: column; gap: 5px; padding: 4px;
  }
  .hb-nav__hamburger span {
    display: block; width: 22px; height: 2px; background: var(--accent);
    border-radius: 1px; transition: 0.2s;
  }

  @media (max-width: 768px) {
    .hb-nav__links {
      display: none; position: absolute; top: 68px; left: 0; right: 0;
      background: rgba(17,17,17,0.98); flex-direction: column; padding: 1rem;
      border-bottom: 1px solid var(--border);
    }
    .hb-nav__links--open { display: flex; }
    .hb-nav__link { padding: 0.75rem 1rem; }
    .hb-nav__cta { display: none; }
    .hb-nav__hamburger { display: flex; }
  }

  /* HERO */
  .hb-hero {
    position: relative; min-height: 100vh; display: flex; align-items: center;
    justify-content: center; text-align: center;
  }
  .hb-hero__bg { position: absolute; inset: 0; }
  .hb-hero__bg-img { width: 100%; height: 100%; object-fit: cover; filter: grayscale(40%); }
  .hb-hero__overlay {
    position: absolute; inset: 0;
    background: linear-gradient(180deg, rgba(17,17,17,0.75) 0%, rgba(17,17,17,0.92) 70%, #111111 100%);
  }
  .hb-hero__content { position: relative; max-width: 700px; padding: 0 1.5rem; }
  .hb-hero__stripe {
    width: 4px; height: 48px; margin: 0 auto 2rem;
    background: repeating-linear-gradient(
      180deg,
      #c9a96e 0px, #c9a96e 8px,
      #fff 8px, #fff 16px,
      #3b82f6 16px, #3b82f6 24px,
      #fff 24px, #fff 32px
    );
    border-radius: 2px;
  }
  .hb-hero__title {
    font-size: clamp(3rem, 8vw, 5.5rem); font-weight: 900;
    line-height: 0.95; color: #fff; letter-spacing: -0.03em;
    margin-bottom: 1rem;
  }
  .hb-hero__tagline {
    font-size: 1.05rem; color: var(--accent); font-weight: 500;
    letter-spacing: 0.08em; text-transform: uppercase;
    margin-bottom: 2.5rem;
  }
  .hb-hero__actions { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
  .hb-hero__scroll {
    position: absolute; bottom: 2rem; left: 50%; transform: translateX(-50%);
    animation: hb-bounce 2s infinite;
  }
  @keyframes hb-bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(6px); }
  }

  @media (max-width: 480px) {
    .hb-hero { min-height: 90vh; }
    .hb-hero__actions { flex-direction: column; align-items: center; }
  }

  /* BUTTONS */
  .hb-btn {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-size: 0.9rem; font-weight: 700; text-decoration: none;
    padding: 0.7rem 1.6rem; border-radius: 4px; transition: all 0.15s;
    border: 2px solid transparent; cursor: pointer; letter-spacing: 0.02em;
    font-family: inherit;
  }
  .hb-btn--gold { background: var(--accent); color: var(--primary); border-color: var(--accent); }
  .hb-btn--gold:hover { background: #d4b67a; border-color: #d4b67a; }
  .hb-btn--outline { background: transparent; color: var(--text); border-color: rgba(201,169,110,0.4); }
  .hb-btn--outline:hover { border-color: var(--accent); color: var(--accent); }
  .hb-btn--lg { padding: 0.85rem 2rem; font-size: 0.95rem; }
  .hb-btn--full { width: 100%; justify-content: center; }

  /* SECTIONS */
  .hb-section { padding: 5.5rem 0; }
  .hb-section--dark { background: var(--primary); }
  .hb-section__header { margin-bottom: 3rem; }
  .hb-eyebrow {
    display: block; font-size: 0.72rem; font-weight: 700;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--accent); margin-bottom: 0.5rem;
  }
  .hb-section__title {
    font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 800;
    line-height: 1.15; letter-spacing: -0.02em;
  }

  /* SERVICES */
  .hb-services { display: flex; flex-direction: column; gap: 0; }
  .hb-service {
    display: grid; grid-template-columns: 60px 1fr 56px; gap: 1.5rem;
    align-items: center; padding: 2rem 0;
    border-bottom: 1px solid var(--border);
    transition: background 0.2s;
  }
  .hb-service:first-child { border-top: 1px solid var(--border); }
  .hb-service:hover { background: rgba(201,169,110,0.03); }
  .hb-service__num {
    font-size: 0.75rem; font-weight: 700; color: var(--accent);
    letter-spacing: 0.1em; font-variant-numeric: tabular-nums;
  }
  .hb-service__content h3 {
    font-size: 1.15rem; font-weight: 700; color: #fff; margin-bottom: 0.3rem;
  }
  .hb-service__content p { font-size: 0.9rem; color: var(--text-mid); line-height: 1.6; }
  .hb-service__icon { color: var(--accent); opacity: 0.5; }

  @media (max-width: 480px) {
    .hb-service { grid-template-columns: 40px 1fr; gap: 1rem; }
    .hb-service__icon { display: none; }
  }

  /* SPLIT SECTION */
  .hb-split {
    display: grid; grid-template-columns: 1fr 1fr; min-height: 500px;
  }
  .hb-split__image { overflow: hidden; }
  .hb-split__image img {
    width: 100%; height: 100%; object-fit: cover; filter: grayscale(30%);
    transition: filter 0.3s;
  }
  .hb-split__image:hover img { filter: grayscale(0%); }
  .hb-split__content {
    display: flex; flex-direction: column; justify-content: center;
    padding: 4rem 3.5rem; background: var(--primary);
  }
  .hb-split__title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem); font-weight: 800;
    line-height: 1.1; color: #fff; margin-bottom: 1.25rem;
    letter-spacing: -0.02em;
  }
  .hb-split__content p {
    font-size: 0.95rem; color: var(--text-mid); line-height: 1.7;
    margin-bottom: 0.75rem;
  }

  @media (max-width: 768px) {
    .hb-split { grid-template-columns: 1fr; }
    .hb-split__image { height: 300px; }
    .hb-split__content { padding: 3rem 1.5rem; }
  }

  /* LOCATION GRID */
  .hb-location-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;
  }
  .hb-location-card {
    background: rgba(201,169,110,0.04); border: 1px solid rgba(201,169,110,0.1);
    border-radius: 8px; padding: 2rem; text-align: center;
  }
  .hb-location-card__icon {
    width: 52px; height: 52px; border-radius: 50%;
    background: rgba(201,169,110,0.08);
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 1.25rem;
  }
  .hb-location-card h3 {
    font-size: 0.95rem; font-weight: 700; color: var(--accent);
    text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.75rem;
  }
  .hb-location-card p { font-size: 0.92rem; color: var(--text-mid); line-height: 1.7; }
  .hb-location-card a {
    color: var(--text-mid); text-decoration: none; transition: color 0.15s;
  }
  .hb-location-card a:hover { color: var(--accent); }
  .hb-location-card__link {
    display: inline-block; margin-top: 0.75rem; font-size: 0.85rem;
    font-weight: 600; color: var(--accent) !important;
  }
  .hb-location-card__sub {
    display: block; margin-top: 0.5rem; font-size: 0.78rem;
    color: var(--text-mid); font-style: italic;
  }

  @media (max-width: 768px) {
    .hb-location-grid { grid-template-columns: 1fr; gap: 1rem; }
  }

  /* CTA */
  .hb-cta {
    padding: 5rem 0;
