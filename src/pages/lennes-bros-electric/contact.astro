---
import Analytics from '../../components/Analytics.astro';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Contact Us — Lennes Bros. Electric Inc. | Alexandria & Long Prairie, MN</title>
  <meta name="description" content="Contact Lennes Bros. Electric Inc. Alexandria office: (320) 762-1500. Long Prairie office: (320) 533-3331. Same day emergency service available." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <Analytics />
</head>
<body>

  <header class="nav">
    <div class="nav__inner">
      <a href="/lennes-bros-electric" class="nav__brand">
        <img src="/images/lennes-bros-electric/logo.png" alt="Lennes Bros. Electric Inc." class="nav__logo" />
        <span class="nav__name">Lennes Bros. Electric</span>
      </a>
      <nav class="nav__links">
        <a href="/lennes-bros-electric" class="nav__link">Home</a>
        <a href="/lennes-bros-electric/services" class="nav__link">Services</a>
        <a href="/lennes-bros-electric/residential" class="nav__link">Residential</a>
        <a href="/lennes-bros-electric/commercial" class="nav__link">Commercial</a>
        <a href="/lennes-bros-electric/industrial" class="nav__link">Industrial</a>
        <a href="/lennes-bros-electric/agricultural" class="nav__link">Agricultural</a>
        <a href="/lennes-bros-electric/employment" class="nav__link">Employment</a>
      </nav>
      <a href="tel:3207621500" class="nav__cta">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 013.12 4.18 2 2 0 015.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        (320) 762-1500
      </a>
      <button class="nav__hamburger" aria-label="Menu"><span></span><span></span><span></span></button>
    </div>
  </header>

  <!-- HERO -->
  <section class="hero hero--short">
    <div class="hero__bg">
      <img src="/images/lennes-bros-electric/van.jpg" alt="Lennes Bros. Electric service van" class="hero__bg-img" />
      <div class="hero__overlay"></div>
    </div>
    <div class="hero__content">
      <h1 class="hero__title">Contact Us</h1>
      <p class="hero__desc">You can depend on us for all of your residential, commercial, industrial, and agricultural electrical needs. Same day emergency service.</p>
    </div>
  </section>

  <!-- CONTACT INFO + FORM -->
  <section class="section">
    <div class="container">
      <div class="contact-grid">

        <!-- LEFT: Info -->
        <div class="contact-info">
          <h2 class="contact-info__heading">Get in Touch</h2>

          <div class="contact-info__highlights">
            <span class="highlight-badge">FREE estimates</span>
            <span class="highlight-badge">Service guarantee</span>
          </div>

          <!-- Alexandria Office -->
          <div class="contact-info__location">
            <h3>Alexandria Office</h3>
            <div class="contact-info__block">
              <div class="contact-info__icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 013.12 4.18 2 2 0 015.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
              </div>
              <div>
                <strong>Phone</strong>
                <p><a href="tel:3207621500">(320) 762-1500</a></p>
              </div>
            </div>
            <div class="contact-info__block">
              <div class="contact-info__icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div>
                <strong>Address</strong>
                <p>2605 Aga Dr., Ste 7<br/>Alexandria, MN 56308</p>
                <a href="https://maps.google.com/?q=2605+Aga+Dr+Ste+7+Alexandria+MN+56308" target="_blank" rel="noopener" class="contact-info__link">Get Directions &rarr;</a>
              </div>
            </div>
          </div>

          <!-- Long Prairie Office -->
          <div class="contact-info__location">
            <h3>Long Prairie Office</h3>
            <div class="contact-info__block">
              <div class="contact-info__icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 013.12 4.18 2 2 0 015.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
              </div>
              <div>
                <strong>Phone</strong>
                <p><a href="tel:3205333331">(320) 533-3331</a></p>
              </div>
            </div>
            <div class="contact-info__block">
              <div class="contact-info__icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div>
                <strong>Address</strong>
                <p>110 Lake St. S<br/>Long Prairie, MN 56347</p>
                <a href="https://maps.google.com/?q=110+Lake+St+S+Long+Prairie+MN+56347" target="_blank" rel="noopener" class="contact-info__link">Get Directions &rarr;</a>
              </div>
            </div>
          </div>

          <!-- Email -->
          <div class="contact-info__block" style="margin-top: 1rem;">
            <div class="contact-info__icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="2" y="3" width="20" height="14" rx="2"/><polyline points="22 3 12 13 2 3"/></svg>
            </div>
            <div>
              <strong>Email</strong>
              <p><a href="mailto:lennesbros@earthlink.net">lennesbros@earthlink.net</a></p>
            </div>
          </div>
        </div>

        <!-- RIGHT: Form -->
        <div class="contact-form-wrap">
          <h2>Send Us a Message</h2>
          <p class="contact-form-desc">Have a question or need an estimate? Fill out the form below and we'll get back to you.</p>
          <form class="contact-form" action="/api/contact" method="POST">
            <input type="hidden" name="site" value="lennes-bros-electric" />
            <input type="text" name="_hp" style="display:none" tabindex="-1" autocomplete="off" />
            <div class="form-group">
              <label for="name">Name *</label>
              <input type="text" id="name" name="name" required placeholder="Your name" />
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="email">Email *</label>
                <input type="email" id="email" name="email" required placeholder="you@example.com" />
              </div>
              <div class="form-group">
                <label for="phone">Phone</label>
                <input type="tel" id="phone" name="phone" placeholder="(320) 555-0000" />
              </div>
            </div>
            <div class="form-group">
              <label for="message">Message *</label>
              <textarea id="message" name="message" rows="5" required placeholder="Tell us about your electrical project or question..."></textarea>
            </div>
            <button type="submit" class="btn btn--primary btn--lg btn--full">Send Message</button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- MAP -->
  <section class="map-section">
    <iframe
      src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2780.5!2d-95.3775!3d45.8850!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2z!5e0!3m2!1sen!2sus!4v1"
      width="100%" height="400" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"
      title="Lennes Bros. Electric locations"
    ></iframe>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container footer__inner">
      <div class="footer__col">
        <h4>Lennes Bros. Electric Inc.</h4>
        <p>Full-service electrical contractor serving the Alexandria and Long Prairie, MN area.</p>
      </div>
      <div class="footer__col">
        <h4>Quick Links</h4>
        <ul>
          <li><a href="/lennes-bros-electric">Home</a></li>
          <li><a href="/lennes-bros-electric/services">Services</a></li>
          <li><a href="/lennes-bros-electric/residential">Residential</a></li>
          <li><a href="/lennes-bros-electric/commercial">Commercial</a></li>
          <li><a href="/lennes-bros-electric/industrial">Industrial</a></li>
          <li><a href="/lennes-bros-electric/agricultural">Agricultural</a></li>
          <li><a href="/lennes-bros-electric/contact">Contact Us</a></li>
        </ul>
      </div>
      <div class="footer__col">
        <h4>Alexandria Office</h4>
        <p>2605 Aga Dr., Ste 7<br/>Alexandria, MN 56308</p>
        <p><a href="tel:3207621500">(320) 762-1500</a></p>
        <p style="margin-top:1rem;"><strong style="color:#fff;">Long Prairie Office</strong></p>
        <p>110 Lake St. S<br/>Long Prairie, MN 56347</p>
        <p><a href="tel:3205333331">(320) 533-3331</a></p>
      </div>
      <div class="footer__col">
        <h4>Contact</h4>
        <p><a href="mailto:lennesbros@earthlink.net">lennesbros@earthlink.net</a></p>
        <p style="margin-top:1rem; font-size:0.85rem; color:rgba(255,255,255,0.5);">Same day emergency service available</p>
      </div>
    </div>
    <div class="footer__bottom">
      <p>&copy; 2026 Lennes Bros. Electric Inc. All rights reserved.</p>
    </div>
  </footer>

  <script>
    const nav = document.querySelector('.nav');
    window.addEventListener('scroll', () => nav?.classList.toggle('nav--scrolled', window.scrollY > 20));
    document.querySelector('.nav__hamburger')?.addEventListener('click', () => document.querySelector('.nav__links')?.classList.toggle('nav__links--open'));
  </script>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root { --primary: #463939; --accent: #c8a84e; --text: #1a1a1a; --text-mid: #555; --border: #e5e7eb; }
  body { font-family: 'Inter', -apple-system, sans-serif; color: var(--text); line-height: 1.6; -webkit-font-smoothing: antialiased; }
  .container { max-width: 1140px; margin: 0 auto; padding: 0 1.5rem; }

  .nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: var(--primary); transition: box-shadow 0.2s; }
  .nav--scrolled { box-shadow: 0 2px 20px rgba(0,0,0,0.15); }
  .nav__inner { max-width: 1320px; margin: 0 auto; padding: 0 1.5rem; display: flex; align-items: center; gap: 1.5rem; height: 64px; }
  .nav__brand { display: flex; align-items: center; gap: 0.5rem; text-decoration: none; flex-shrink: 0; }
  .nav__logo { height: 36px; width: auto; }
  .nav__name { color: #fff; font-weight: 700; font-size: 0.95rem; white-space: nowrap; }
  .nav__links { display: flex; gap: 0.125rem; flex: 1; justify-content: center; }
  .nav__link { color: rgba(255,255,255,0.75); text-decoration: none; font-size: 0.8rem; font-weight: 500; padding: 0.375rem 0.55rem; border-radius: 6px; transition: color 0.15s, background 0.15s; white-space: nowrap; }
  .nav__link:hover, .nav__link--active { color: #fff; background: rgba(255,255,255,0.1); }
  .nav__cta { display: flex; align-items: center; gap: 0.4rem; background: var(--accent); color: #fff; text-decoration: none; font-size: 0.85rem; font-weight: 600; padding: 0.5rem 1rem; border-radius: 6px; transition: opacity 0.15s; white-space: nowrap; }
  .nav__cta:hover { opacity: 0.9; }
  .nav__hamburger { display: none; background: none; border: none; cursor: pointer; flex-direction: column; gap: 5px; padding: 4px; }
  .nav__hamburger span { display: block; width: 22px; height: 2px; background: #fff; border-radius: 1px; }
  @media (max-width: 768px) {
    .nav__links { display: none; position: absolute; top: 64px; left: 0; right: 0; background: var(--primary); flex-direction: column; padding: 1rem; box-shadow: 0 8px 20px rgba(0,0,0,0.2); }
    .nav__links--open { display: flex; }
    .nav__link { padding: 0.75rem 1rem; }
    .nav__cta { display: none; }
    .nav__hamburger { display: flex; }
  }

  /* HERO */
  .hero { position: relative; min-height: 50vh; display: flex; align-items: center; padding: 8rem 1.5rem 4rem; }
  .hero--short { min-height: 45vh; }
  .hero__bg { position: absolute; inset: 0; }
  .hero__bg-img { width: 100%; height: 100%; object-fit: cover; }
  .hero__overlay { position: absolute; inset: 0; background: linear-gradient(135deg, rgba(70,57,57,0.92) 0%, rgba(70,57,57,0.72) 100%); }
  .hero__content { position: relative; max-width: 720px; margin: 0 auto 0 0; padding-left: calc((100vw - 1140px) / 2); }
  @media (max-width: 1172px) { .hero__content { padding-left: 1.5rem; } }
  .hero__title { font-size: clamp(2rem, 4.5vw, 3rem); font-weight: 900; line-height: 1.1; color: #fff; margin-bottom: 1rem; }
  .hero__desc { font-size: 1.05rem; line-height: 1.7; color: rgba(255,255,255,0.85); max-width: 560px; }
  @media (max-width: 480px) { .hero { min-height: auto; padding: 6rem 1.25rem 3rem; } }

  .section { padding: 4.5rem 0; }

  /* CONTACT GRID */
  .contact-grid { display: grid; grid-template-columns: 1fr 1.25fr; gap: 3.5rem; }
  @media (max-width: 768px) { .contact-grid { grid-template-columns: 1fr; gap: 3rem; } }

  .contact-info__heading { font-size: 1.5rem; font-weight: 800; margin-bottom: 1rem; }

  .contact-info__highlights { display: flex; gap: 0.5rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
  .highlight-badge {
    display: inline-block; background: rgba(200,168,78,0.1); color: var(--accent);
    font-size: 0.8rem; font-weight: 700; padding: 0.35rem 0.75rem; border-radius: 4px;
    letter-spacing: 0.02em;
  }

  .contact-info__location { margin-bottom: 1.5rem; }
  .contact-info__location h3 { font-size: 1.05rem; font-weight: 700; margin-bottom: 0.75rem; color: var(--primary); }

  .contact-info__block {
    display: flex; gap: 1rem; padding: 0.75rem 0;
    border-bottom: 1px solid var(--border);
  }
  .contact-info__block:last-child { border-bottom: none; }
  .contact-info__icon {
    flex-shrink: 0; width: 40px; height: 40px; border-radius: 10px;
    background: rgba(200,168,78,0.08); color: var(--accent);
    display: flex; align-items: center; justify-content: center;
  }
  .contact-info__block strong { display: block; font-size: 0.92rem; margin-bottom: 0.15rem; }
  .contact-info__block p { font-size: 0.9rem; color: var(--text-mid); line-height: 1.6; }
  .contact-info__block a { color: var(--text-mid); text-decoration: none; }
  .contact-info__block a:hover { color: var(--accent); }
  .contact-info__link { display: inline-block; margin-top: 0.4rem; color: var(--accent) !important; font-size: 0.85rem; font-weight: 600; }

  /* FORM */
  .contact-form-wrap h2 { font-size: 1.35rem; font-weight: 700; margin-bottom: 0.5rem; }
  .contact-form-desc { font-size: 0.92rem; color: var(--text-mid); margin-bottom: 1.5rem; }

  .form-group { margin-bottom: 1.25rem; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  @media (max-width: 480px) { .form-row { grid-template-columns: 1fr; } }

  .form-group label {
    display: block; font-size: 0.82rem; font-weight: 600;
    margin-bottom: 0.35rem; color: var(--text);
  }
  .form-group input, .form-group textarea {
    width: 100%; padding: 0.7rem 0.9rem; font-size: 0.92rem;
    border: 1.5px solid var(--border); border-radius: 8px;
    font-family: inherit; transition: border-color 0.15s;
    background: #fff;
  }
  .form-group input:focus, .form-group textarea:focus {
    outline: none; border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(200,168,78,0.1);
  }
  .form-group textarea { resize: vertical; min-height: 120px; }

  .btn { display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem; font-size: 0.92rem; font-weight: 600; text-decoration: none; padding: 0.7rem 1.5rem; border-radius: 6px; border: 2px solid transparent; cursor: pointer; transition: all 0.15s; }
  .btn--primary { background: var(--accent); color: #fff; border-color: var(--accent); }
  .btn--primary:hover { opacity: 0.9; }
  .btn--lg { padding: 0.85rem 2rem; font-size: 1rem; }
  .btn--full { width: 100%; }

  .map-section { line-height: 0; }
  .map-section iframe { width: 100%; height: 400px; }

  .footer { background: #2a2020; color: rgba(255,255,255,0.7); padding: 4rem 0 0; }
  .footer__inner { display: grid; grid-template-columns: 1.5fr 1fr 1fr 1fr; gap: 2.5rem; }
  .footer__col h4 { color: #fff; font-size: 0.95rem; font-weight: 700; margin-bottom: 1rem; }
  .footer__col p { font-size: 0.88rem; line-height: 1.65; }
  .footer__col ul { list-style: none; }
  .footer__col li { margin-bottom: 0.4rem; }
  .footer__col a { color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.88rem; transition: color 0.15s; }
  .footer__col a:hover { color: var(--accent); }
  .footer__bottom { margin-top: 3rem; padding: 1.25rem 0; border-top: 1px solid rgba(255,255,255,0.08); text-align: center; }
  .footer__bottom p { font-size: 0.8rem; color: rgba(255,255,255,0.35); }
  @media (max-width: 768px) { .footer__inner { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 480px) { .footer__inner { grid-template-columns: 1fr; gap: 2rem; } }
</style>
</body>
</html>
