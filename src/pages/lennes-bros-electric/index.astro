---
import Analytics from '../../components/Analytics.astro';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Lennes Bros. Electric Inc. — Electricians in Alexandria & Long Prairie, MN</title>
  <meta name="description" content="FREE estimates. Satisfaction guarantee. Same day emergency service. Residential, commercial, industrial, and agricultural electricians serving Alexandria and Long Prairie, MN. Call (320) 762-1500." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <Analytics />
</head>
<body>

  <!-- NAV -->
  <header class="nav">
    <div class="nav__inner">
      <a href="/lennes-bros-electric" class="nav__brand">
        <img src="/images/lennes-bros-electric/logo.png" alt="Lennes Bros. Electric Inc." class="nav__logo" />
        <span class="nav__name">Lennes Bros. Electric</span>
      </a>
      <nav class="nav__links">
        <a href="/lennes-bros-electric" class="nav__link nav__link--active">Home</a>
        <a href="/lennes-bros-electric/services" class="nav__link">Services</a>
        <a href="/lennes-bros-electric/residential" class="nav__link">Residential</a>
        <a href="/lennes-bros-electric/commercial" class="nav__link">Commercial</a>
        <a href="/lennes-bros-electric/industrial" class="nav__link">Industrial</a>
        <a href="/lennes-bros-electric/agricultural" class="nav__link">Agricultural</a>
        <a href="/lennes-bros-electric/employment" class="nav__link">Employment</a>
      </nav>
      <a href="tel:3207621500" class="nav__cta">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 013.12 4.18 2 2 0 015.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        (320) 762-1500
      </a>
      <button class="nav__hamburger" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </header>

  <!-- HERO -->
  <section class="hero">
    <div class="hero__bg">
      <img src="/images/lennes-bros-electric/hero.jpg" alt="Lennes Bros. Electric residential project" class="hero__bg-img" />
      <div class="hero__overlay"></div>
    </div>
    <div class="hero__content">
      <span class="hero__badge">Servicing The Alexandria & Long Prairie MN Area</span>
      <h1 class="hero__title">Helping You Maintain the Flow of Electricity to Your Property</h1>
      <p class="hero__desc">Protect your property from electrical mishaps by enlisting the services of our professional electricians. When you work with our company, you'll get the highest level of excellence and quality. Give us a call today to speak with our knowledgeable and friendly staff.</p>
      <div class="hero__actions">
        <a href="tel:3207621500" class="btn btn--primary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 013.12 4.18 2 2 0 015.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          Call (320) 762-1500
        </a>
        <a href="/lennes-bros-electric/services" class="btn btn--outline">Our Services</a>
      </div>
      <div class="hero__stats">
        <div class="hero__stat">
          <span class="hero__stat-num">FREE</span>
          <span class="hero__stat-label">Estimates</span>
        </div>
        <div class="hero__stat-divider"></div>
        <div class="hero__stat">
          <span class="hero__stat-num">100%</span>
          <span class="hero__stat-label">Satisfaction Guarantee</span>
        </div>
        <div class="hero__stat-divider"></div>
        <div class="hero__stat">
          <span class="hero__stat-num">24/7</span>
          <span class="hero__stat-label">Emergency Service</span>
        </div>
      </div>
    </div>
  </section>

  <!-- VALUES -->
  <section class="section section--warm" id="values">
    <div class="container">
      <h2 class="section__title" style="text-align:center;">Why Choose Lennes Bros. Electric</h2>
      <div class="values-grid">
        <div class="value-card">
          <div class="value-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/><circle cx="12" cy="12" r="5"/></svg>
          </div>
          <h3>FREE Estimate</h3>
          <p>We provide free estimates on all electrical projects.</p>
        </div>
        <div class="value-card">
          <div class="value-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3>Satisfaction Guarantee</h3>
          <p>We guarantee our performance and your satisfaction.</p>
        </div>
        <div class="value-card">
          <div class="value-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          </div>
          <h3>Same Day Emergency Service</h3>
          <p>When an electrical emergency strikes, we respond the same day.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES GRID -->
  <section class="section" id="services">
    <div class="container">
      <span class="eyebrow">What We Do</span>
      <h2 class="section__title">Our Services</h2>
      <div class="services-grid">
        <a href="/lennes-bros-electric/residential" class="service-card service-card--linked">
          <img src="/images/lennes-bros-electric/residential-icon.jpg" alt="Residential electrical" class="service-card__img" />
          <h3>Residential</h3>
          <p>Complete residential electrical services for homes of all sizes.</p>
        </a>
        <a href="/lennes-bros-electric/commercial" class="service-card service-card--linked">
          <img src="/images/lennes-bros-electric/commercial-icon.png" alt="Commercial electrical" class="service-card__img" />
          <h3>Commercial</h3>
          <p>Professional commercial electrical installations and repairs.</p>
        </a>
        <a href="/lennes-bros-electric/industrial" class="service-card service-card--linked">
          <img src="/images/lennes-bros-electric/industrial-icon.jpg" alt="Industrial electrical" class="service-card__img" />
          <h3>Industrial</h3>
          <p>Heavy-duty industrial electrical solutions for manufacturing and facilities.</p>
        </a>
        <a href="/lennes-bros-electric/agricultural" class="service-card service-card--linked">
          <img src="/images/lennes-bros-electric/agricultural-icon.jpg" alt="Agricultural electrical" class="service-card__img" />
          <h3>Agricultural</h3>
          <p>Specialized agricultural electrical services for farms and outbuildings.</p>
        </a>
      </div>
      <div class="services-more">
        <a href="/lennes-bros-electric/services" class="btn btn--secondary">View All Services &rarr;</a>
      </div>
    </div>
  </section>

  <!-- GALLERY -->
  <section class="section section--warm" id="gallery">
    <div class="container">
      <h2 class="section__title" style="text-align:center;">Our Work</h2>
      <div class="gallery-grid">
        <img src="/images/lennes-bros-electric/hero.jpg" alt="A large house with a driveway leading to it" loading="lazy" />
        <img src="/images/lennes-bros-electric/gallery-house-construction.jpg" alt="A large white house with a green roof is being built" loading="lazy" />
        <img src="/images/lennes-bros-electric/gallery-lakehouse.jpg" alt="A large house with a dock in front of it" loading="lazy" />
        <img src="/images/lennes-bros-electric/gallery-church-interior.jpg" alt="A large cross hangs from the ceiling of a church" loading="lazy" />
        <img src="/images/lennes-bros-electric/gallery-church-exterior.jpg" alt="A church with a cross on the front of it" loading="lazy" />
        <img src="/images/lennes-bros-electric/gallery-gas-station.jpg" alt="A gas station that is lit up at night" loading="lazy" />
        <img src="/images/lennes-bros-electric/gallery-hangar.jpg" alt="A plane in a hangar with a few lights on the ceiling" loading="lazy" />
        <img src="/images/lennes-bros-electric/gallery-warehouse.jpg" alt="A large empty warehouse with the sun shining through the windows" loading="lazy" />
        <img src="/images/lennes-bros-electric/gallery-electrical-panels.jpg" alt="A row of electrical boxes are lined up against a white wall" loading="lazy" />
        <img src="/images/lennes-bros-electric/gallery-barn.jpg" alt="A warehouse filled with hay bales under a wooden roof" loading="lazy" />
        <img src="/images/lennes-bros-electric/gallery-worker.jpg" alt="A man in a yellow hard hat is working on a machine" loading="lazy" />
        <img src="/images/lennes-bros-electric/gallery-van-house.jpg" alt="A white van is parked in front of a large house" loading="lazy" />
        <img src="/images/lennes-bros-electric/gallery-van-silos.jpg" alt="A white van is parked in front of a row of silos" loading="lazy" />
        <img src="/images/lennes-bros-electric/gallery-vans-construction.png" alt="Two white vans are parked in front of a building under construction" loading="lazy" />
        <img src="/images/lennes-bros-electric/gallery-rooftop-work.jpg" alt="A man is working on the roof of a building" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--cta">
    <div class="container cta-content">
      <h2>Need an Electrician?</h2>
      <p>Call us today for fast, reliable electrical service. Free estimates and same day emergency service available.</p>
      <div class="cta-actions">
        <a href="tel:3207621500" class="btn btn--primary btn--lg">Call (320) 762-1500</a>
        <a href="/lennes-bros-electric/contact" class="btn btn--outline btn--lg">Contact Us</a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container footer__inner">
      <div class="footer__col">
        <h4>Lennes Bros. Electric Inc.</h4>
        <p>Full-service electrical contractor serving the Alexandria and Long Prairie, MN area. Residential, commercial, industrial, and agricultural electrical services.</p>
      </div>
      <div class="footer__col">
        <h4>Quick Links</h4>
        <ul>
          <li><a href="/lennes-bros-electric">Home</a></li>
          <li><a href="/lennes-bros-electric/services">Services</a></li>
          <li><a href="/lennes-bros-electric/residential">Residential</a></li>
          <li><a href="/lennes-bros-electric/commercial">Commercial</a></li>
          <li><a href="/lennes-bros-electric/industrial">Industrial</a></li>
          <li><a href="/lennes-bros-electric/agricultural">Agricultural</a></li>
          <li><a href="/lennes-bros-electric/contact">Contact Us</a></li>
        </ul>
      </div>
      <div class="footer__col">
        <h4>Alexandria Office</h4>
        <p>2605 Aga Dr., Ste 7<br/>Alexandria, MN 56308</p>
        <p><a href="tel:3207621500">(320) 762-1500</a></p>
        <p style="margin-top:1rem;"><strong style="color:#fff;">Long Prairie Office</strong></p>
        <p>110 Lake St. S<br/>Long Prairie, MN 56347</p>
        <p><a href="tel:3205333331">(320) 533-3331</a></p>
      </div>
      <div class="footer__col">
        <h4>Contact</h4>
        <p><a href="mailto:lennesbros@earthlink.net">lennesbros@earthlink.net</a></p>
        <p style="margin-top:1rem; font-size:0.85rem; color:rgba(255,255,255,0.5);">Same day emergency service available</p>
      </div>
    </div>
    <div class="footer__bottom">
      <p>&copy; 2026 Lennes Bros. Electric Inc. All rights reserved.</p>
    </div>
  </footer>

  <script>
    // Sticky nav shadow
    const nav = document.querySelector('.nav');
    window.addEventListener('scroll', () => {
      nav?.classList.toggle('nav--scrolled', window.scrollY > 20);
    });
    // Mobile menu
    document.querySelector('.nav__hamburger')?.addEventListener('click', () => {
      document.querySelector('.nav__links')?.classList.toggle('nav__links--open');
    });
  </script>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --primary: #463939;
    --accent: #c8a84e;
    --text: #1a1a1a;
    --text-mid: #555;
    --text-light: #888;
    --bg: #fff;
    --bg-warm: #f8f7f5;
    --border: #e5e7eb;
  }

  body {
    font-family: 'Inter', -apple-system, sans-serif;
    color: var(--text);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  .container { max-width: 1140px; margin: 0 auto; padding: 0 1.5rem; }

  /* NAV */
  .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: var(--primary);
    transition: box-shadow 0.2s;
  }
  .nav--scrolled { box-shadow: 0 2px 20px rgba(0,0,0,0.15); }
  .nav__inner {
    max-width: 1320px; margin: 0 auto; padding: 0 1.5rem;
    display: flex; align-items: center; gap: 1.5rem;
    height: 64px;
  }
  .nav__brand { display: flex; align-items: center; gap: 0.5rem; text-decoration: none; flex-shrink: 0; }
  .nav__logo { height: 36px; width: auto; }
  .nav__name { color: #fff; font-weight: 700; font-size: 0.95rem; white-space: nowrap; }
  .nav__links { display: flex; gap: 0.125rem; flex: 1; justify-content: center; }
  .nav__link {
    color: rgba(255,255,255,0.75); text-decoration: none; font-size: 0.8rem;
    font-weight: 500; padding: 0.375rem 0.55rem; border-radius: 6px;
    transition: color 0.15s, background 0.15s; white-space: nowrap;
  }
  .nav__link:hover, .nav__link--active { color: #fff; background: rgba(255,255,255,0.1); }
  .nav__cta {
    display: flex; align-items: center; gap: 0.4rem;
    background: var(--accent); color: #fff; text-decoration: none;
    font-size: 0.85rem; font-weight: 600; padding: 0.5rem 1rem;
    border-radius: 6px; transition: opacity 0.15s; white-space: nowrap;
  }
  .nav__cta:hover { opacity: 0.9; }
  .nav__hamburger {
    display: none; background: none; border: none; cursor: pointer;
    flex-direction: column; gap: 5px; padding: 4px;
  }
  .nav__hamburger span {
    display: block; width: 22px; height: 2px; background: #fff;
    border-radius: 1px; transition: 0.2s;
  }

  @media (max-width: 768px) {
    .nav__links {
      display: none; position: absolute; top: 64px; left: 0; right: 0;
      background: var(--primary); flex-direction: column; padding: 1rem;
      box-shadow: 0 8px 20px rgba(0,0,0,0.2);
    }
    .nav__links--open { display: flex; }
    .nav__link { padding: 0.75rem 1rem; }
    .nav__cta { display: none; }
    .nav__hamburger { display: flex; }
  }

  /* HERO */
  .hero {
    position: relative; min-height: 85vh; display: flex; align-items: center;
    padding: 8rem 1.5rem 5rem;
  }
  .hero__bg { position: absolute; inset: 0; }
  .hero__bg-img { width: 100%; height: 100%; object-fit: cover; }
  .hero__overlay {
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(70,57,57,0.92) 0%, rgba(70,57,57,0.72) 100%);
  }
  .hero__content {
    position: relative; max-width: 720px; margin: 0 auto 0 0;
    padding-left: calc((100vw - 1140px) / 2);
  }
  @media (max-width: 1172px) { .hero__content { padding-left: 1.5rem; } }
  .hero__badge {
    display: inline-block; background: var(--accent); color: #fff;
    font-size: 0.78rem; font-weight: 700; letter-spacing: 0.08em;
    text-transform: uppercase; padding: 0.35rem 0.9rem; border-radius: 4px;
    margin-bottom: 1.25rem;
  }
  .hero__title {
    font-size: clamp(2.25rem, 5vw, 3.5rem); font-weight: 900;
    line-height: 1.1; color: #fff; margin-bottom: 1.25rem;
  }
  .hero__desc {
    font-size: 1.1rem; line-height: 1.7; color: rgba(255,255,255,0.85);
    margin-bottom: 2rem; max-width: 560px;
  }
  .hero__actions { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 2.5rem; }
  .hero__stats {
    display: flex; align-items: center; gap: 2rem;
    padding-top: 2rem; border-top: 1px solid rgba(255,255,255,0.15);
  }
  .hero__stat { text-align: center; }
  .hero__stat-num { display: block; font-size: 1.5rem; font-weight: 800; color: var(--accent); }
  .hero__stat-label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.06em; color: rgba(255,255,255,0.6); }
  .hero__stat-divider { width: 1px; height: 40px; background: rgba(255,255,255,0.15); }

  @media (max-width: 480px) {
    .hero { min-height: 70vh; padding: 6rem 1.25rem 3rem; }
    .hero__actions { flex-direction: column; }
    .hero__stats { gap: 1.25rem; }
    .hero__stat-divider { display: none; }
  }

  /* BUTTONS */
  .btn {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-size: 0.92rem; font-weight: 600; text-decoration: none;
    padding: 0.7rem 1.5rem; border-radius: 6px; transition: all 0.15s;
    border: 2px solid transparent; cursor: pointer;
  }
  .btn--primary { background: var(--accent); color: #fff; border-color: var(--accent); }
  .btn--primary:hover { opacity: 0.9; transform: translateY(-1px); }
  .btn--outline { background: transparent; color: #fff; border-color: rgba(255,255,255,0.4); }
  .btn--outline:hover { border-color: #fff; background: rgba(255,255,255,0.1); }
  .btn--secondary { background: var(--primary); color: #fff; }
  .btn--secondary:hover { opacity: 0.9; }
  .btn--lg { padding: 0.85rem 2rem; font-size: 1rem; }

  /* SECTIONS */
  .section { padding: 5rem 0; }
  .section--warm { background: var(--bg-warm); }
  .section--cta {
    background: linear-gradient(135deg, var(--primary) 0%, #2e2424 100%);
    text-align: center; padding: 4rem 0;
  }
  .eyebrow {
    display: block; font-size: 0.78rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--accent); margin-bottom: 0.5rem;
  }
  .section__title {
    font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 800;
    margin-bottom: 2.5rem; line-height: 1.2;
  }

  /* VALUES GRID */
  .values-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .value-card { text-align: center; padding: 2rem 1.5rem; background: #fff; border-radius: 10px; border: 1px solid var(--border); }
  .value-card__icon {
    width: 56px; height: 56px; border-radius: 14px;
    background: rgba(200,168,78,0.1); color: var(--accent);
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 1rem;
  }
  .value-card h3 { font-size: 1.05rem; font-weight: 700; margin-bottom: 0.4rem; }
  .value-card p { font-size: 0.88rem; color: var(--text-mid); line-height: 1.6; }

  @media (max-width: 768px) { .values-grid { grid-template-columns: 1fr; } }

  /* SERVICES GRID */
  .services-grid {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem; margin-bottom: 2rem;
  }
  .service-card {
    background: #fff; border: 1px solid var(--border); border-radius: 8px;
    padding: 0; overflow: hidden; transition: box-shadow 0.2s, transform 0.2s;
    border-top: 4px solid var(--accent);
  }
  .service-card--linked {
    text-decoration: none; color: inherit; display: block;
  }
  .service-card:hover { box-shadow: 0 8px 24px rgba(0,0,0,0.08); transform: translateY(-2px); }
  .service-card__img {
    width: 100%; height: 180px; object-fit: cover; display: block;
  }
  .service-card h3 { font-size: 1.05rem; font-weight: 700; margin-bottom: 0.4rem; padding: 1.25rem 1.25rem 0; }
  .service-card p { font-size: 0.88rem; color: var(--text-mid); line-height: 1.6; padding: 0 1.25rem 1.25rem; }
  .services-more { text-align: center; }

  @media (max-width: 768px) { .services-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .services-grid { grid-template-columns: 1fr; } }

  /* GALLERY */
  .gallery-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
  .gallery-grid img { width: 100%; height: 250px; object-fit: cover; border-radius: 8px; }
  @media (max-width: 640px) { .gallery-grid { grid-template-columns: 1fr 1fr; } .gallery-grid img { height: 180px; } }
  @media (max-width: 480px) { .gallery-grid { grid-template-columns: 1fr; } .gallery-grid img { height: 200px; } }

  /* CTA */
  .cta-content h2 { font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 800; color: #fff; margin-bottom: 0.75rem; }
  .cta-content p { font-size: 1.05rem; color: rgba(255,255,255,0.85); margin-bottom: 2rem; }
  .cta-actions { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
  .cta-actions .btn--primary { background: var(--accent); color: #fff; border-color: var(--accent); }
  .cta-actions .btn--outline { color: #fff; border-color: rgba(255,255,255,0.5); }

  /* FOOTER */
  .footer { background: #2a2020; color: rgba(255,255,255,0.7); padding: 4rem 0 0; }
  .footer__inner { display: grid; grid-template-columns: 1.5fr 1fr 1fr 1fr; gap: 2.5rem; }
  .footer__col h4 { color: #fff; font-size: 0.95rem; font-weight: 700; margin-bottom: 1rem; }
  .footer__col p { font-size: 0.88rem; line-height: 1.65; }
  .footer__col ul { list-style: none; }
  .footer__col li { margin-bottom: 0.4rem; }
  .footer__col a { color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.88rem; transition: color 0.15s; }
  .footer__col a:hover { color: var(--accent); }
  .footer__bottom {
    margin-top: 3rem; padding: 1.25rem 0;
