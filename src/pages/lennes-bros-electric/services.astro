  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <Analytics />
</head>
<body>

  <header class="nav">
    <div class="nav__inner">
      <a href="/lennes-bros-electric" class="nav__brand">
        <img src="/images/lennes-bros-electric/logo.png" alt="Lennes Bros. Electric Inc." class="nav__logo" />
        <span class="nav__name">Lennes Bros. Electric</span>
