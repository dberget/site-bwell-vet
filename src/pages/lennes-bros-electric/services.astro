      <div class="footer__col">
        <h4>Alexandria Office</h4>
        <p>2605 Aga Dr., Ste 7<br/>Alexandria, MN 56308</p>
        <p><a href="tel:3207621500">(320) 762-1500</a></p>
        <p style="margin-top:1rem;"><strong style="color:#fff;">Long Prairie Office</strong></p>
        <p>110 Lake St. S<br/>Long Prairie, MN 56347</p>
        <p><a href="tel:3205333331">(320) 533-3331</a></p>
      </div>
      <div class="footer__col">
        <h4>Contact</h4>
        <p><a href="mailto:lennesbros@earthlink.net">lennesbros@earthlink.net</a></p>
