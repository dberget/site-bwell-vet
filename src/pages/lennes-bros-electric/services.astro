      <nav class="nav__links">
        <a href="/lennes-bros-electric" class="nav__link">Home</a>
        <a href="/lennes-bros-electric/services" class="nav__link nav__link--active">Services</a>
        <a href="/lennes-bros-electric/residential" class="nav__link">Residential</a>
