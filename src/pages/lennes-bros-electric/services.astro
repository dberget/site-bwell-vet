  <!-- CTA -->
  <section class="section section--cta">
    <div class="container cta-content">
      <h2>Same Day Emergency Service</h2>
      <p>If an electrical emergency presents itself at your home or business, you can call on us for immediate, same day emergency service. You can always depend on Lennes Bros. Electric Inc. to have the solutions to all of your electrical problems. We guarantee our performance and your satisfaction.</p>
      <div class="cta-actions">
        <a href="tel:3207621500" class="btn btn--primary btn--lg">Call (320) 762-1500</a>
        <a href="/lennes-bros-electric/contact" class="btn btn--outline btn--lg">Contact Us</a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container footer__inner">
      <div class="footer__col">
        <h4>Lennes Bros. Electric Inc.</h4>
        <p>Full-service electrical contractor serving the Alexandria and Long Prairie, MN area.</p>
      </div>
      <div class="footer__col">
        <h4>Quick Links</h4>
        <ul>
          <li><a href="/lennes-bros-electric">Home</a></li>
          <li><a href="/lennes-bros-electric/services">Services</a></li>
          <li><a href="/lennes-bros-electric/residential">Residential</a></li>
          <li><a href="/lennes-bros-electric/commercial">Commercial</a></li>
          <li><a href="/lennes-bros-electric/industrial">Industrial</a></li>
          <li><a href="/lennes-bros-electric/agricultural">Agricultural</a></li>
          <li><a href="/lennes-bros-electric/contact">Contact Us</a></li>
        </ul>
