---
import Analytics from '../../components/Analytics.astro';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Cabins — Mill Lake Resort | Alexandria, MN</title>
  <meta name="description" content="Lakeside cabins on a private peninsula at Mill Lake Resort near Alexandria, MN. Every cabin right on the water with beautiful views. Call for rates." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <Analytics />
</head>
<body>

  <header class="nav">
    <div class="nav__inner">
      <a href="/mill-lake-resort" class="nav__brand">
        <img src="/images/mill-lake/logo.png" alt="Mill Lake Resort" class="nav__logo" />
        <span class="nav__name">Mill Lake Resort</span>
      </a>
      <nav class="nav__links">
        <a href="/mill-lake-resort" class="nav__link">Home</a>
        <a href="/mill-lake-resort/cabins" class="nav__link nav__link--active">Cabins</a>
        <a href="/mill-lake-resort/activities" class="nav__link">Activities</a>
        <a href="/mill-lake-resort/contact" class="nav__link">Contact</a>
      </nav>
      <a href="tel:3208865381" class="nav__cta">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 013.12 4.18 2 2 0 015.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        (320) 886-5381
      </a>
      <button class="nav__hamburger" aria-label="Menu"><span></span><span></span><span></span></button>
    </div>
  </header>

  <!-- PAGE HEADER -->
  <section class="page-header">
    <div class="container">
      <div class="page-header__breadcrumb">
        <a href="/mill-lake-resort">Home</a> <span>/</span> <span>Cabins</span>
      </div>
      <h1>Our Cabins</h1>
      <p>Lakeside cabins on a private peninsula with views you won't forget.</p>
    </div>
  </section>

  <!-- CABIN INTRO -->
  <section class="section">
    <div class="container">
      <div class="cabin-intro">
        <div class="cabin-intro__text">
          <h2>Your Home on the Lake</h2>
          <p>Mill Lake Resort sits on a private peninsula, surrounded by water on three sides. Every cabin is positioned right on the lake's edge, giving you unmatched views and direct access to one of Alexandria's cleanest spring-fed lakes.</p>
          <p>Whether you're watching the sunrise with a cup of coffee or listening to the loons at dusk, our cabins offer the kind of peaceful lakeside experience that keeps families coming back year after year.</p>
        </div>
        <div class="cabin-intro__image">
          <img src="/images/mill-lake/cabins.jpg" alt="Cabins at Mill Lake Resort" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="section section--warm">
    <div class="container">
      <span class="eyebrow">What Makes Us Special</span>
      <h2 class="section__title">Resort Features</h2>
      <div class="cabin-features-grid">
        <div class="cabin-feature">
          <div class="cabin-feature__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <h3>Private Peninsula Resort</h3>
          <p>Tucked away on a quiet peninsula, our resort offers privacy and seclusion while being just minutes from Alexandria and I-94.</p>
        </div>
        <div class="cabin-feature">
          <div class="cabin-feature__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </div>
          <h3>Cabins Right on the Lake</h3>
          <p>Every cabin sits right on the lake's edge. Step out your door and you're just steps from the water and your own beautiful view.</p>
        </div>
        <div class="cabin-feature">
          <div class="cabin-feature__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
          </div>
          <h3>Beautiful Views Everywhere</h3>
          <p>With 1,400 feet of shoreline wrapping around our peninsula, every direction offers a stunning view of the lake and surrounding nature.</p>
        </div>
        <div class="cabin-feature">
          <div class="cabin-feature__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3>Spring-Fed Lake</h3>
          <p>Mill Lake is one of Alexandria MN's cleanest lakes, fed by natural springs. The water is crystal clear and perfect for swimming.</p>
        </div>
        <div class="cabin-feature">
          <div class="cabin-feature__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
          </div>
          <h3>Family-Friendly Atmosphere</h3>
          <p>We've been welcoming families since the 1960s. Our resort is designed for all ages, from toddlers to grandparents.</p>
        </div>
        <div class="cabin-feature">
          <div class="cabin-feature__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </div>
          <h3>7 Acres of Resort Grounds</h3>
          <p>Plenty of space for your family to spread out, play, and explore. Our 7-acre property has room for everyone to find their own perfect spot.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- AERIAL IMAGE -->
  <section class="section">
    <div class="container">
      <div class="aerial-section">
        <div class="aerial-section__image">
          <img src="/images/mill-lake/aerial.jpg" alt="Aerial view of Mill Lake Resort peninsula" loading="lazy" />
        </div>
        <div class="aerial-section__text">
          <h2>See It from Above</h2>
          <p>Our private peninsula setting means you're surrounded by water on three sides. With 7 acres and 1,400 feet of shoreline, there's plenty of room for your family to enjoy the lake.</p>
          <p>Located just 8 miles west of Alexandria and 5 minutes off I-94, Mill Lake Resort is easy to get to but feels a world away.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- RATES -->
  <section class="section section--warm">
    <div class="container rates-section">
      <div class="rates-card">
        <div class="rates-card__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 013.12 4.18 2 2 0 015.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        </div>
        <h2>Call for Rates &amp; Availability</h2>
        <p>Rates vary by cabin size, time of season, and length of stay. Give us a call and we'll help you find the perfect cabin for your family.</p>
        <div class="rates-card__phones">
          <a href="tel:3208865381" class="btn btn--primary btn--lg">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 013.12 4.18 2 2 0 015.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            (320) 886-5381
          </a>
          <a href="tel:3207667954" class="btn btn--outline-dark">Cell: (320) 766-7954</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--cta">
    <div class="container cta-content">
      <h2>Ready to Book Your Stay?</h2>
      <p>Call us to check availability and reserve your cabin on the lake.</p>
      <div class="cta-actions">
        <a href="tel:3208865381" class="btn btn--primary btn--lg">Call (320) 886-5381</a>
        <a href="/mill-lake-resort/contact" class="btn btn--outline btn--lg">Contact Us</a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container footer__inner">
      <div class="footer__col">
        <h4>Mill Lake Resort</h4>
        <p>A family resort on one of Alexandria MN's cleanest spring-fed lakes. Private peninsula setting with cabins right on the water since the 1960s.</p>
        <div class="footer__social">
          <a href="https://facebook.com/MillLakeResort" target="_blank" rel="noopener" aria-label="Facebook">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
          </a>
        </div>
      </div>
      <div class="footer__col">
        <h4>Quick Links</h4>
        <ul>
          <li><a href="/mill-lake-resort">Home</a></li>
          <li><a href="/mill-lake-resort/cabins">Cabins</a></li>
          <li><a href="/mill-lake-resort/activities">Activities</a></li>
          <li><a href="/mill-lake-resort/contact">Contact</a></li>
        </ul>
      </div>
      <div class="footer__col">
        <h4>Contact</h4>
        <p>3551 W Mill Lake Rd SW<br/>Farwell, MN 56327</p>
        <p><a href="tel:3208865381">(320) 886-5381</a></p>
        <p><a href="tel:3207667954">(320) 766-7954</a></p>
      </div>
      <div class="footer__col">
        <h4>Season</h4>
        <p>Mill Lake Resort operates seasonally during the summer months.</p>
        <p style="margin-top:0.5rem;">Call for exact dates and availability for the upcoming season.</p>
      </div>
    </div>
    <div class="footer__bottom">
      <p>&copy; 2026 Mill Lake Resort. All rights reserved.</p>
    </div>
  </footer>

  <script>
    const nav = document.querySelector('.nav');
    window.addEventListener('scroll', () => nav?.classList.toggle('nav--scrolled', window.scrollY > 20));
    document.querySelector('.nav__hamburger')?.addEventListener('click', () => document.querySelector('.nav__links')?.classList.toggle('nav__links--open'));
  </script>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --primary: #1a5c3a;
    --accent: #c6922a;
    --text: #1a1a1a;
    --text-mid: #555;
    --text-light: #888;
    --bg: #fff;
    --bg-warm: #fafafa;
    --border: #e5e7eb;
  }

  body {
    font-family: 'Inter', -apple-system, sans-serif;
    color: var(--text);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  .container { max-width: 1140px; margin: 0 auto; padding: 0 1.5rem; }

  /* NAV */
  .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: var(--primary); transition: box-shadow 0.2s;
  }
  .nav--scrolled { box-shadow: 0 2px 20px rgba(0,0,0,0.15); }
  .nav__inner {
    max-width: 1140px; margin: 0 auto; padding: 0 1.5rem;
    display: flex; align-items: center; justify-content: space-between; height: 64px;
  }
  .nav__brand { display: flex; align-items: center; gap: 0.6rem; text-decoration: none; }
  .nav__logo { height: 36px; width: auto; }
  .nav__name { color: #fff; font-weight: 700; font-size: 1.1rem; }
  .nav__links { display: flex; gap: 0.25rem; }
  .nav__link {
    color: rgba(255,255,255,0.75); text-decoration: none; font-size: 0.88rem;
    font-weight: 500; padding: 0.4rem 0.75rem; border-radius: 6px;
    transition: color 0.15s, background 0.15s;
  }
  .nav__link:hover, .nav__link--active { color: #fff; background: rgba(255,255,255,0.1); }
  .nav__cta {
    display: flex; align-items: center; gap: 0.4rem;
    background: var(--accent); color: #fff; text-decoration: none;
    font-size: 0.85rem; font-weight: 600; padding: 0.5rem 1rem;
    border-radius: 6px; transition: opacity 0.15s;
  }
  .nav__cta:hover { opacity: 0.9; }
  .nav__hamburger {
    display: none; background: none; border: none; cursor: pointer;
    flex-direction: column; gap: 5px; padding: 4px;
  }
  .nav__hamburger span {
    display: block; width: 22px; height: 2px; background: #fff;
    border-radius: 1px; transition: 0.2s;
  }
  @media (max-width: 768px) {
    .nav__links {
      display: none; position: absolute; top: 64px; left: 0; right: 0;
      background: var(--primary); flex-direction: column; padding: 1rem;
      box-shadow: 0 8px 20px rgba(0,0,0,0.2);
    }
    .nav__links--open { display: flex; }
    .nav__link { padding: 0.75rem 1rem; }
    .nav__cta { display: none; }
    .nav__hamburger { display: flex; }
  }

  /* PAGE HEADER */
  .page-header { background: var(--primary); padding: 7rem 0 2.5rem; }
  .page-header__breadcrumb { font-size: 0.82rem; color: rgba(255,255,255,0.45); margin-bottom: 0.75rem; }
  .page-header__breadcrumb a { color: rgba(255,255,255,0.6); text-decoration: none; }
  .page-header__breadcrumb a:hover { color: var(--accent); }
  .page-header__breadcrumb span { margin: 0 0.35rem; }
  .page-header h1 { color: #fff; font-size: clamp(1.75rem, 4vw, 2.75rem); font-weight: 800; margin-bottom: 0.5rem; }
  .page-header p { color: rgba(255,255,255,0.7); font-size: 1.05rem; }

  .section { padding: 4.5rem 0; }
  .section--warm { background: #fafafa; }

  .eyebrow {
    display: block; font-size: 0.78rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--accent); margin-bottom: 0.5rem;
  }
  .section__title {
    font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 800;
    margin-bottom: 2.5rem; line-height: 1.2;
  }

  /* CABIN INTRO */
  .cabin-intro { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; }
  .cabin-intro__text h2 { font-size: 1.75rem; font-weight: 800; margin-bottom: 1.25rem; }
  .cabin-intro__text p { font-size: 0.98rem; color: var(--text-mid); line-height: 1.75; margin-bottom: 1rem; }
  .cabin-intro__image img { width: 100%; border-radius: 10px; box-shadow: 0 8px 30px rgba(0,0,0,0.12); }
  @media (max-width: 768px) { .cabin-intro { grid-template-columns: 1fr; gap: 2rem; } }

  /* CABIN FEATURES */
  .cabin-features-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem;
  }
  .cabin-feature {
    background: #fff; border: 1px solid var(--border); border-radius: 8px;
    padding: 1.75rem; transition: box-shadow 0.2s, transform 0.2s;
    border-top: 4px solid var(--accent);
  }
  .cabin-feature:hover { box-shadow: 0 8px 24px rgba(0,0,0,0.08); transform: translateY(-2px); }
  .cabin-feature__icon {
    width: 48px; height: 48px; border-radius: 10px;
    background: rgba(198,146,42,0.1); color: var(--accent);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 1rem;
  }
  .cabin-feature h3 { font-size: 1.05rem; font-weight: 700; margin-bottom: 0.4rem; }
  .cabin-feature p { font-size: 0.88rem; color: var(--text-mid); line-height: 1.6; }
  @media (max-width: 1024px) { .cabin-features-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .cabin-features-grid { grid-template-columns: 1fr; } }

  /* AERIAL */
  .aerial-section { display: grid; grid-template-columns: 1.2fr 1fr; gap: 3rem; align-items: center; }
  .aerial-section__image img { width: 100%; border-radius: 10px; box-shadow: 0 8px 30px rgba(0,0,0,0.12); }
  .aerial-section__text h2 { font-size: 1.75rem; font-weight: 800; margin-bottom: 1.25rem; }
  .aerial-section__text p { font-size: 0.98rem; color: var(--text-mid); line-height: 1.75; margin-bottom: 1rem; }
  @media (max-width: 768px) { .aerial-section { grid-template-columns: 1fr; gap: 2rem; } }

  /* RATES */
  .rates-section { text-align: center; }
  .rates-card {
    max-width: 640px; margin: 0 auto;
    background: #fff; border: 1px solid var(--border); border-radius: 12px;
    padding: 3rem 2.5rem; border-top: 4px solid var(--accent);
  }
  .rates-card__icon {
    width: 64px; height: 64px; border-radius: 16px;
    background: rgba(198,146,42,0.1); color: var(--accent);
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 1.5rem;
  }
  .rates-card h2 { font-size: 1.5rem; font-weight: 800; margin-bottom: 0.75rem; }
  .rates-card p { font-size: 0.98rem; color: var(--text-mid); line-height: 1.7; margin-bottom: 1.5rem; }
  .rates-card__phones { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }

  /* BUTTONS */
  .btn {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-size: 0.92rem; font-weight: 600; text-decoration: none;
    padding: 0.7rem 1.5rem; border-radius: 6px; transition: all 0.15s;
    border: 2px solid transparent; cursor: pointer;
  }
  .btn--primary { background: var(--accent); color: #fff; border-color: var(--accent); }
  .btn--primary:hover { opacity: 0.9; transform: translateY(-1px); }
  .btn--outline { background: transparent; color: #fff; border-color: rgba(255,255,255,0.4); }
  .btn--outline:hover { border-color: #fff; background: rgba(255,255,255,0.1); }
  .btn--outline-dark { background: transparent; color: var(--primary); border: 2px solid var(--primary); border-radius: 6px; padding: 0.7rem 1.5rem; font-size: 0.92rem; font-weight: 600; text-decoration: none; display: inline-flex; align-items: center; gap: 0.5rem; transition: all 0.15s; }
  .btn--outline-dark:hover { background: var(--primary); color: #fff; }
  .btn--lg { padding: 0.85rem 2rem; font-size: 1rem; }

  .section--cta {
    background: linear-gradient(135deg, #1a5c3a 0%, #0f3d25 100%);
    text-align: center; padding: 4rem 0;
  }
  .cta-content h2 { font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 800; color: #fff; margin-bottom: 0.75rem; }
  .cta-content p { font-size: 1.05rem; color: rgba(255,255,255,0.85); margin-bottom: 2rem; }
  .cta-actions { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
  .cta-actions .btn--primary { background: var(--accent); color: #fff; border-color: var(--accent); }
  .cta-actions .btn--outline { color: #fff; border-color: rgba(255,255,255,0.5); }

  /* FOOTER */
  .footer { background: #1a1f23; color: rgba(255,255,255,0.7); padding: 4rem 0 0; }
  .footer__inner { display: grid; grid-template-columns: 1.5fr 1fr 1fr 1fr; gap: 2.5rem; }
  .footer__col h4 { color: #fff; font-size: 0.95rem; font-weight: 700; margin-bottom: 1rem; }
  .footer__col p { font-size: 0.88rem; line-height: 1.65; }
  .footer__col ul { list-style: none; }
  .footer__col li { margin-bottom: 0.4rem; }
  .footer__col a { color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.88rem; transition: color 0.15s; }
  .footer__col a:hover { color: var(--accent); }
  .footer__social { display: flex; gap: 0.75rem; margin-top: 1rem; }
  .footer__social a { color: rgba(255,255,255,0.5); transition: color 0.15s; }
  .footer__social a:hover { color: var(--accent); }
  .footer__bottom {
    margin-top: 3rem; padding: 1.25rem 0;
    border-top: 1px solid rgba(255,255,255,0.08); text-align: center;
  }
  .footer__bottom p { font-size: 0.8rem; color: rgba(255,255,255,0.35); }
  @media (max-width: 768px) { .footer__inner { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 480px) { .footer__inner { grid-template-columns: 1fr; gap: 2rem; } }
</style>
</body>
</html>
