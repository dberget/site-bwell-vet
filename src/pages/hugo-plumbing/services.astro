---
import Analytics from '../../components/Analytics.astro';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Services — Hugo Plumbing and Pump Service Inc | Hugo, MN</title>
  <meta name="description" content="Complete plumbing services: repairs, well pumps, drain cleaning, sewer lines, water heaters, hydronic heating, sump pumps, bathroom remodeling, and more. Serving Hugo, MN area." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <Analytics />
</head>
<body>

  <!-- NAV -->
  <header class="nav">
    <div class="nav__inner">
      <a href="/hugo-plumbing" class="nav__brand">
        <span class="nav__wordmark">Hugo</span>
        <span class="nav__wordmark-sub">Plumbing</span>
      </a>
      <nav class="nav__links">
        <a href="/hugo-plumbing" class="nav__link">Home</a>
        <a href="/hugo-plumbing/services" class="nav__link nav__link--active">Services</a>
        <a href="/hugo-plumbing/about" class="nav__link">About</a>
        <a href="/hugo-plumbing/contact" class="nav__link">Contact</a>
      </nav>
      <a href="tel:6514334866" class="nav__cta">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 013.12 4.18 2 2 0 015.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        (651) 433-4866
      </a>
      <button class="nav__hamburger" aria-label="Menu"><span></span><span></span><span></span></button>
    </div>
  </header>

  <!-- PAGE HEADER -->
  <section class="page-header">
    <div class="container">
      <div class="page-header__breadcrumb">
        <a href="/hugo-plumbing">Home</a> <span>/</span> <span>Services</span>
      </div>
      <h1>Our Services</h1>
      <p>Complete plumbing solutions for residential and commercial properties.</p>
    </div>
  </section>

  <!-- ALL SERVICES -->
  <section class="section">
    <div class="container">

      <div class="service-detail" id="plumbing-repairs">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>General Plumbing Repairs &amp; Installations</h2>
          <p>From a dripping faucet to a complete fixture replacement, our licensed plumbers handle all types of residential and commercial plumbing work. With over 30 years of experience, we diagnose problems quickly and provide lasting repairs you can count on.</p>
          <ul>
            <li>Leaky faucet and fixture repair</li>
            <li>Pipe repair and replacement</li>
            <li>Toilet repair and installation</li>
            <li>New plumbing installations</li>
            <li>Frozen pipe thawing and prevention</li>
            <li>Water line repair</li>
          </ul>
        </div>
      </div>

      <div class="service-detail" id="well-pumps">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 2v6m0 12v2m-6-8H2m20 0h-4M7.8 7.8L5 5m14 14l-2.8-2.8M7.8 16.2L5 19m14-14l-2.8 2.8"/><circle cx="12" cy="12" r="4"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>Well Pump Services &amp; Pressure Tanks</h2>
          <p>Living in the Hugo and Forest Lake area often means relying on a well for your water supply. We specialize in well pump installation, repair, and pressure tank service to ensure you always have reliable water pressure and flow.</p>
          <ul>
            <li>Submersible pump installation and repair</li>
            <li>Jet pump service</li>
            <li>Pressure tank replacement</li>
            <li>Pressure switch adjustment and repair</li>
            <li>Well water flow testing</li>
            <li>Complete well pump system diagnostics</li>
          </ul>
        </div>
      </div>

      <div class="service-detail" id="drain-cleaning">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10"/><path d="M12 6v6l4 2"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>Drain Cleaning</h2>
          <p>Slow or clogged drains are one of the most common plumbing issues homeowners face. Our professional drain cleaning service uses commercial-grade equipment to clear even the most stubborn blockages and restore proper drainage throughout your home.</p>
          <ul>
            <li>Kitchen sink drain clearing</li>
            <li>Bathroom drain cleaning</li>
            <li>Floor drain maintenance</li>
            <li>Main line snaking</li>
            <li>Preventive drain maintenance</li>
          </ul>
        </div>
      </div>

      <div class="service-detail" id="sewer-lines">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 4h16v16H4z"/><path d="M4 12h16M12 4v16"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>Sewer Line Cleaning</h2>
          <p>Sewer line problems can cause serious damage to your home if left untreated. We provide thorough sewer line cleaning and inspection to keep your system flowing properly and prevent costly backups and overflows.</p>
          <ul>
            <li>Sewer line snaking and clearing</li>
            <li>Root intrusion removal</li>
            <li>Sewer line inspection</li>
            <li>Sewer backup prevention</li>
            <li>Sewer line repair and replacement</li>
          </ul>
        </div>
      </div>

      <div class="service-detail" id="water-heaters">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 9v3m0 0v3m0-3h3m-3 0H9"/><circle cx="12" cy="12" r="10"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>Water Heater Sales &amp; Installation</h2>
          <p>Whether your water heater needs repair or it is time for a replacement, we can help. We sell and install high-quality water heaters from trusted brands and ensure your new unit is properly sized and installed for maximum efficiency and longevity.</p>
          <ul>
            <li>Water heater installation</li>
            <li>Tank and tankless water heaters</li>
            <li>Water heater repair</li>
            <li>Anode rod replacement</li>
            <li>Temperature and pressure valve service</li>
            <li>Energy-efficient upgrades</li>
          </ul>
        </div>
      </div>

      <div class="service-detail" id="hydronic">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>Hydronic Heating</h2>
          <p>Hydronic (hot water) heating systems provide efficient, comfortable warmth throughout your home. We install, repair, and maintain hydronic heating systems including boilers, radiant floor heating, and baseboard heaters.</p>
          <ul>
            <li>Boiler installation and repair</li>
            <li>Radiant floor heating</li>
            <li>Baseboard heater service</li>
            <li>Hydronic system maintenance</li>
            <li>Zone valve repair</li>
            <li>Circulator pump service</li>
          </ul>
        </div>
      </div>

      <div class="service-detail" id="sump-pumps">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>Sump &amp; Ejector Pumps</h2>
          <p>Protect your basement and your home's foundation with a properly functioning sump pump system. We install, repair, and replace both sump pumps and ejector pumps to keep your home dry and your sewage system working properly.</p>
          <ul>
            <li>Sump pump installation</li>
            <li>Sump pump replacement</li>
            <li>Battery backup systems</li>
            <li>Ejector pump service</li>
            <li>Sump pit installation</li>
            <li>Alarm and monitoring systems</li>
          </ul>
        </div>
      </div>

      <div class="service-detail" id="remodeling">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>Bathroom &amp; Kitchen Remodeling</h2>
          <p>Planning a bathroom or kitchen remodel? We handle all the plumbing work so you can focus on the fun parts of your renovation. From rough-in work to final fixture installation, our licensed plumbers ensure everything is done right the first time.</p>
          <ul>
            <li>Bathroom plumbing rough-in</li>
            <li>Kitchen plumbing rough-in</li>
            <li>Fixture installation (sinks, tubs, showers)</li>
            <li>Faucet installation</li>
            <li>Pipe rerouting and relocation</li>
            <li>Code-compliant installations</li>
          </ul>
        </div>
      </div>

      <div class="service-detail" id="garbage-disposal">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>Garbage Disposal Installation</h2>
          <p>A properly installed garbage disposal makes kitchen cleanup faster and more convenient. We install new disposals and replace old or malfunctioning units, ensuring proper electrical and plumbing connections for safe, reliable operation.</p>
          <ul>
            <li>New garbage disposal installation</li>
            <li>Disposal replacement</li>
            <li>Garbage disposal repair</li>
            <li>Dishwasher connection</li>
            <li>Proper venting and drain connections</li>
          </ul>
        </div>
      </div>

    </div>
  </section>

  <!-- CTA -->
  <section class="section section--cta">
    <div class="container cta-content">
      <h2>Need a Plumber? Call Now.</h2>
      <p>Over 30 years of trusted service. Licensed, bonded, and guaranteed workmanship on every job.</p>
      <div class="cta-actions">
        <a href="tel:6514334866" class="btn btn--primary btn--lg">Call (651) 433-4866</a>
        <a href="/hugo-plumbing/contact" class="btn btn--outline btn--lg">Contact Us</a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container footer__inner">
      <div class="footer__col">
        <h4>Hugo Plumbing &amp; Pump Service</h4>
        <p>Licensed plumbing repairs and installations serving the Hugo, MN area for over 30 years. Family-owned, state licensed and bonded.</p>
      </div>
      <div class="footer__col">
        <h4>Quick Links</h4>
        <ul>
          <li><a href="/hugo-plumbing">Home</a></li>
          <li><a href="/hugo-plumbing/services">Services</a></li>
          <li><a href="/hugo-plumbing/about">About Us</a></li>
          <li><a href="/hugo-plumbing/contact">Contact</a></li>
        </ul>
      </div>
      <div class="footer__col">
        <h4>Contact</h4>
        <p>Hugo, MN Area</p>
        <p><a href="tel:6514334866">(651) 433-4866</a></p>
      </div>
      <div class="footer__col">
        <h4>Service Area</h4>
        <p>Hugo, Forest Lake, Scandia, Wyoming, Lino Lakes, Centerville, Columbus, and surrounding communities.</p>
      </div>
    </div>
    <div class="footer__bottom">
      <p>&copy; 2026 Hugo Plumbing and Pump Service Inc. All rights reserved.</p>
    </div>
  </footer>

  <script>
    const nav = document.querySelector('.nav');
    window.addEventListener('scroll', () => nav?.classList.toggle('nav--scrolled', window.scrollY > 20));
    document.querySelector('.nav__hamburger')?.addEventListener('click', () => document.querySelector('.nav__links')?.classList.toggle('nav__links--open'));
  </script>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --primary: #1b3a5c;
    --primary-dark: #122942;
    --accent: #e8792b;
    --accent-dark: #cf6520;
    --text: #1a1a1a;
    --text-mid: #555;
    --text-light: #888;
    --bg: #fff;
    --bg-warm: #f7f8fa;
    --border: #e5e7eb;
  }

  body {
    font-family: 'Inter', -apple-system, sans-serif;
    color: var(--text); line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  .container { max-width: 1140px; margin: 0 auto; padding: 0 1.5rem; }

  /* NAV */
  .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: var(--primary); transition: box-shadow 0.2s;
  }
  .nav--scrolled { box-shadow: 0 2px 20px rgba(0,0,0,0.2); }
  .nav__inner {
    max-width: 1140px; margin: 0 auto; padding: 0 1.5rem;
    display: flex; align-items: center; justify-content: space-between;
    height: 68px;
  }
  .nav__brand {
    display: flex; align-items: baseline; gap: 0.4rem;
    text-decoration: none;
  }
  .nav__wordmark {
    color: #fff; font-weight: 900; font-size: 1.35rem;
    letter-spacing: -0.02em;
  }
  .nav__wordmark-sub {
    color: var(--accent); font-weight: 600; font-size: 1.05rem;
    letter-spacing: -0.01em;
  }
  .nav__links { display: flex; gap: 0.25rem; }
  .nav__link {
    color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.88rem;
    font-weight: 500; padding: 0.4rem 0.8rem; border-radius: 6px;
    transition: color 0.15s, background 0.15s;
  }
  .nav__link:hover, .nav__link--active { color: #fff; background: rgba(255,255,255,0.1); }
  .nav__cta {
    display: flex; align-items: center; gap: 0.4rem;
    background: var(--accent); color: #fff; text-decoration: none;
    font-size: 0.85rem; font-weight: 600; padding: 0.5rem 1.1rem;
    border-radius: 6px; transition: background 0.15s;
  }
  .nav__cta:hover { background: var(--accent-dark); }
  .nav__hamburger {
    display: none; background: none; border: none; cursor: pointer;
    flex-direction: column; gap: 5px; padding: 4px;
  }
  .nav__hamburger span {
    display: block; width: 22px; height: 2px; background: #fff;
    border-radius: 1px;
  }
  @media (max-width: 768px) {
    .nav__links {
      display: none; position: absolute; top: 68px; left: 0; right: 0;
      background: var(--primary); flex-direction: column; padding: 1rem;
      box-shadow: 0 8px 20px rgba(0,0,0,0.2);
    }
    .nav__links--open { display: flex; }
    .nav__link { padding: 0.75rem 1rem; }
    .nav__cta { display: none; }
    .nav__hamburger { display: flex; }
  }

  /* PAGE HEADER */
  .page-header {
    background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
    padding: 7.5rem 0 2.5rem;
  }
  .page-header__breadcrumb { font-size: 0.82rem; color: rgba(255,255,255,0.45); margin-bottom: 0.75rem; }
  .page-header__breadcrumb a { color: rgba(255,255,255,0.6); text-decoration: none; }
  .page-header__breadcrumb a:hover { color: var(--accent); }
  .page-header__breadcrumb span { margin: 0 0.35rem; }
  .page-header h1 { color: #fff; font-size: clamp(1.75rem, 4vw, 2.75rem); font-weight: 800; margin-bottom: 0.5rem; }
  .page-header p { color: rgba(255,255,255,0.7); font-size: 1.05rem; }

  .section { padding: 4.5rem 0; }

  /* SERVICE DETAIL BLOCKS */
  .service-detail {
    display: flex; gap: 1.5rem; padding: 2.5rem 0;
    border-bottom: 1px solid var(--border);
  }
  .service-detail:first-of-type { padding-top: 0; }
  .service-detail:last-of-type { border-bottom: none; }
  .service-detail__icon {
    flex-shrink: 0; width: 60px; height: 60px; border-radius: 14px;
    background: rgba(232,121,43,0.1); color: var(--accent);
    display: flex; align-items: center; justify-content: center;
  }
  .service-detail__body h2 { font-size: 1.3rem; font-weight: 700; margin-bottom: 0.6rem; color: var(--primary); }
  .service-detail__body p { font-size: 0.95rem; color: var(--text-mid); line-height: 1.75; margin-bottom: 1rem; }
  .service-detail__body ul { list-style: none; display: flex; flex-wrap: wrap; gap: 0.4rem 1.5rem; }
  .service-detail__body li {
    font-size: 0.88rem; color: var(--text-mid); padding-left: 1.1rem;
    position: relative;
  }
  .service-detail__body li::before {
    content: ''; position: absolute; left: 0; top: 0.5rem;
    width: 6px; height: 6px; border-radius: 50%; background: var(--accent);
  }
  @media (max-width: 640px) {
    .service-detail { flex-direction: column; gap: 1rem; }
  }

  /* BUTTONS */
  .btn {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-size: 0.92rem; font-weight: 600; text-decoration: none;
    padding: 0.7rem 1.5rem; border-radius: 6px; transition: all 0.15s;
    border: 2px solid transparent; cursor: pointer;
  }
  .btn--primary { background: var(--accent); color: #fff; border-color: var(--accent); }
  .btn--primary:hover { background: var(--accent-dark); border-color: var(--accent-dark); }
  .btn--outline { background: transparent; color: #fff; border-color: rgba(255,255,255,0.4); }
  .btn--outline:hover { border-color: #fff; background: rgba(255,255,255,0.1); }
  .btn--lg { padding: 0.85rem 2rem; font-size: 1rem; }

  .section--cta {
    background: linear-gradient(135deg, var(--accent) 0%, #d4641a 100%);
    text-align: center; padding: 4rem 0;
  }
  .cta-content h2 { font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 800; color: #fff; margin-bottom: 0.75rem; }
  .cta-content p { font-size: 1.05rem; color: rgba(255,255,255,0.9); margin-bottom: 2rem; }
  .cta-actions { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
  .cta-actions .btn--primary { background: #fff; color: var(--accent); border-color: #fff; }
  .cta-actions .btn--primary:hover { background: #f0f0f0; }

  /* FOOTER */
  .footer { background: #111b27; color: rgba(255,255,255,0.7); padding: 4rem 0 0; }
  .footer__inner { display: grid; grid-template-columns: 1.5fr 1fr 1fr 1fr; gap: 2.5rem; }
  .footer__col h4 { color: #fff; font-size: 0.95rem; font-weight: 700; margin-bottom: 1rem; }
  .footer__col p { font-size: 0.88rem; line-height: 1.65; }
  .footer__col ul { list-style: none; }
  .footer__col li { margin-bottom: 0.4rem; }
  .footer__col a { color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.88rem; transition: color 0.15s; }
  .footer__col a:hover { color: var(--accent); }
  .footer__bottom {
    margin-top: 3rem; padding: 1.25rem 0;
    border-top: 1px solid rgba(255,255,255,0.08); text-align: center;
  }
  .footer__bottom p { font-size: 0.8rem; color: rgba(255,255,255,0.35); }
  @media (max-width: 768px) { .footer__inner { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 480px) { .footer__inner { grid-template-columns: 1fr; gap: 2rem; } }
</style>
</body>
</html>
