---
import Analytics from '../../components/Analytics.astro';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>About Us — Hugo Plumbing and Pump Service Inc | Hugo, MN</title>
  <meta name="description" content="Family-owned plumbing business serving Hugo, Forest Lake, Scandia, and surrounding areas for over 30 years. State Licensed & Bonded, BBB and NFIB member." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <Analytics />
</head>
<body>

  <!-- NAV -->
  <header class="nav">
    <div class="nav__inner">
      <a href="/hugo-plumbing" class="nav__brand">
        <span class="nav__wordmark">Hugo</span>
        <span class="nav__wordmark-sub">Plumbing</span>
      </a>
      <nav class="nav__links">
        <a href="/hugo-plumbing" class="nav__link">Home</a>
        <a href="/hugo-plumbing/services" class="nav__link">Services</a>
        <a href="/hugo-plumbing/about" class="nav__link nav__link--active">About</a>
        <a href="/hugo-plumbing/contact" class="nav__link">Contact</a>
      </nav>
      <a href="tel:6514334866" class="nav__cta">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 013.12 4.18 2 2 0 015.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        (651) 433-4866
      </a>
      <button class="nav__hamburger" aria-label="Menu"><span></span><span></span><span></span></button>
    </div>
  </header>

  <!-- PAGE HEADER -->
  <section class="page-header">
    <div class="container">
      <div class="page-header__breadcrumb">
        <a href="/hugo-plumbing">Home</a> <span>/</span> <span>About</span>
      </div>
      <h1>About Us</h1>
      <p>Family-owned. State licensed. Serving your community for over 30 years.</p>
    </div>
  </section>

  <!-- ABOUT STORY -->
  <section class="section">
    <div class="container">
      <div class="about-split">
        <div class="about-split__text">
          <h2>Family-Owned Since Day One</h2>
          <p>Hugo Plumbing and Pump Service Inc has been a trusted name in the Hugo, Forest Lake, and Scandia communities for more than three decades. What started as a small, family-run plumbing business has grown into one of the most respected plumbing service providers in the northern Twin Cities metro area.</p>
          <p>Our commitment to quality has never changed. Every job we take on is backed by our guarantee of workmanship, because we believe that when you hire a plumber, you deserve to have the work done right the first time. We do not cut corners, and we stand behind every repair and installation we complete.</p>
          <p>As a state licensed and bonded plumbing contractor, we hold ourselves to the highest professional standards. We are proud members of the Better Business Bureau and the National Federation of Independent Business, reflecting our dedication to ethical business practices and customer satisfaction.</p>
          <p>When you call Hugo Plumbing, you are not just getting a plumber -- you are getting a neighbor who cares about doing right by you and your family. That is the way we have operated for over 30 years, and it is the way we will continue to operate for years to come.</p>
        </div>
        <div class="about-split__image">
          <img src="/images/hugo-plumbing/service-1.jpg" alt="Hugo Plumbing team at work" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST BADGES -->
  <section class="section section--warm">
    <div class="container">
      <h2 class="badges-title">Our Credentials</h2>
      <div class="badges-grid">
        <div class="badge-card">
          <div class="badge-card__icon">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3>State Licensed &amp; Bonded</h3>
          <p>Fully licensed by the State of Minnesota. Bonded for your protection on every job we perform.</p>
        </div>
        <div class="badge-card">
          <div class="badge-card__icon">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <h3>BBB Member</h3>
          <p>Proud member of the Better Business Bureau, committed to resolving complaints and maintaining trust.</p>
        </div>
        <div class="badge-card">
          <div class="badge-card__icon">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
          </div>
          <h3>NFIB Member</h3>
          <p>Member of the National Federation of Independent Business, supporting small business values and community involvement.</p>
        </div>
        <div class="badge-card">
          <div class="badge-card__icon">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>
          </div>
          <h3>Guaranteed Workmanship</h3>
          <p>We stand behind every job with our guarantee. If it is not right, we will come back and make it right.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICE AREA -->
  <section class="section">
    <div class="container">
      <div class="area-section">
        <div class="area-section__header">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <h2>Our Service Area</h2>
        </div>
        <p class="area-section__desc">We are based in the Hugo, Minnesota area and proudly serve homeowners and businesses throughout the northern Twin Cities metro, including:</p>
        <div class="area-grid">
          <div class="area-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Hugo</span>
          </div>
          <div class="area-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Forest Lake</span>
          </div>
          <div class="area-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Scandia</span>
          </div>
          <div class="area-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Wyoming</span>
          </div>
          <div class="area-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Lino Lakes</span>
          </div>
          <div class="area-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Centerville</span>
          </div>
          <div class="area-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Columbus</span>
          </div>
          <div class="area-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Mahtomedi</span>
          </div>
          <div class="area-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span>White Bear Lake</span>
          </div>
          <div class="area-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span>North Oaks</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--cta">
    <div class="container cta-content">
      <h2>Need a Plumber? Call Now.</h2>
      <p>Over 30 years of trusted service. Licensed, bonded, and guaranteed workmanship on every job.</p>
      <div class="cta-actions">
        <a href="tel:6514334866" class="btn btn--primary btn--lg">Call (651) 433-4866</a>
        <a href="/hugo-plumbing/contact" class="btn btn--outline btn--lg">Contact Us</a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container footer__inner">
      <div class="footer__col">
        <h4>Hugo Plumbing &amp; Pump Service</h4>
        <p>Licensed plumbing repairs and installations serving the Hugo, MN area for over 30 years. Family-owned, state licensed and bonded.</p>
      </div>
      <div class="footer__col">
        <h4>Quick Links</h4>
        <ul>
          <li><a href="/hugo-plumbing">Home</a></li>
          <li><a href="/hugo-plumbing/services">Services</a></li>
          <li><a href="/hugo-plumbing/about">About Us</a></li>
          <li><a href="/hugo-plumbing/contact">Contact</a></li>
        </ul>
      </div>
      <div class="footer__col">
        <h4>Contact</h4>
        <p>Hugo, MN Area</p>
        <p><a href="tel:6514334866">(651) 433-4866</a></p>
      </div>
      <div class="footer__col">
        <h4>Service Area</h4>
        <p>Hugo, Forest Lake, Scandia, Wyoming, Lino Lakes, Centerville, Columbus, and surrounding communities.</p>
      </div>
    </div>
    <div class="footer__bottom">
      <p>&copy; 2026 Hugo Plumbing and Pump Service Inc. All rights reserved.</p>
    </div>
  </footer>

  <script>
    const nav = document.querySelector('.nav');
    window.addEventListener('scroll', () => nav?.classList.toggle('nav--scrolled', window.scrollY > 20));
    document.querySelector('.nav__hamburger')?.addEventListener('click', () => document.querySelector('.nav__links')?.classList.toggle('nav__links--open'));
  </script>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --primary: #1b3a5c;
    --primary-dark: #122942;
    --accent: #e8792b;
    --accent-dark: #cf6520;
    --text: #1a1a1a;
    --text-mid: #555;
    --text-light: #888;
    --bg: #fff;
    --bg-warm: #f7f8fa;
    --border: #e5e7eb;
  }

  body {
    font-family: 'Inter', -apple-system, sans-serif;
    color: var(--text); line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  .container { max-width: 1140px; margin: 0 auto; padding: 0 1.5rem; }

  /* NAV */
  .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: var(--primary); transition: box-shadow 0.2s;
  }
  .nav--scrolled { box-shadow: 0 2px 20px rgba(0,0,0,0.2); }
  .nav__inner {
    max-width: 1140px; margin: 0 auto; padding: 0 1.5rem;
    display: flex; align-items: center; justify-content: space-between;
    height: 68px;
  }
  .nav__brand {
    display: flex; align-items: baseline; gap: 0.4rem;
    text-decoration: none;
  }
  .nav__wordmark {
    color: #fff; font-weight: 900; font-size: 1.35rem;
    letter-spacing: -0.02em;
  }
  .nav__wordmark-sub {
    color: var(--accent); font-weight: 600; font-size: 1.05rem;
    letter-spacing: -0.01em;
  }
  .nav__links { display: flex; gap: 0.25rem; }
  .nav__link {
    color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.88rem;
    font-weight: 500; padding: 0.4rem 0.8rem; border-radius: 6px;
    transition: color 0.15s, background 0.15s;
  }
  .nav__link:hover, .nav__link--active { color: #fff; background: rgba(255,255,255,0.1); }
  .nav__cta {
    display: flex; align-items: center; gap: 0.4rem;
    background: var(--accent); color: #fff; text-decoration: none;
    font-size: 0.85rem; font-weight: 600; padding: 0.5rem 1.1rem;
    border-radius: 6px; transition: background 0.15s;
  }
  .nav__cta:hover { background: var(--accent-dark); }
  .nav__hamburger {
    display: none; background: none; border: none; cursor: pointer;
    flex-direction: column; gap: 5px; padding: 4px;
  }
  .nav__hamburger span {
    display: block; width: 22px; height: 2px; background: #fff;
    border-radius: 1px;
  }
  @media (max-width: 768px) {
    .nav__links {
      display: none; position: absolute; top: 68px; left: 0; right: 0;
      background: var(--primary); flex-direction: column; padding: 1rem;
      box-shadow: 0 8px 20px rgba(0,0,0,0.2);
    }
    .nav__links--open { display: flex; }
    .nav__link { padding: 0.75rem 1rem; }
    .nav__cta { display: none; }
    .nav__hamburger { display: flex; }
  }

  /* PAGE HEADER */
  .page-header {
    background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
    padding: 7.5rem 0 2.5rem;
  }
  .page-header__breadcrumb { font-size: 0.82rem; color: rgba(255,255,255,0.45); margin-bottom: 0.75rem; }
  .page-header__breadcrumb a { color: rgba(255,255,255,0.6); text-decoration: none; }
  .page-header__breadcrumb a:hover { color: var(--accent); }
  .page-header__breadcrumb span { margin: 0 0.35rem; }
  .page-header h1 { color: #fff; font-size: clamp(1.75rem, 4vw, 2.75rem); font-weight: 800; margin-bottom: 0.5rem; }
  .page-header p { color: rgba(255,255,255,0.7); font-size: 1.05rem; }

  .section { padding: 4.5rem 0; }
  .section--warm { background: var(--bg-warm); }

  /* ABOUT SPLIT */
  .about-split { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 3.5rem; align-items: start; }
  .about-split__text h2 { font-size: 1.85rem; font-weight: 800; margin-bottom: 1.5rem; color: var(--primary); }
  .about-split__text p { font-size: 0.98rem; color: var(--text-mid); line-height: 1.8; margin-bottom: 1.15rem; }
  .about-split__image img {
    width: 100%; border-radius: 12px;
    box-shadow: 0 12px 40px rgba(27,58,92,0.12);
  }
  @media (max-width: 768px) {
    .about-split { grid-template-columns: 1fr; gap: 2rem; }
  }

  /* TRUST BADGES */
  .badges-title { font-size: 1.5rem; font-weight: 800; text-align: center; margin-bottom: 2.5rem; color: var(--primary); }
  .badges-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }
  .badge-card {
    text-align: center; padding: 2rem 1.25rem;
    background: #fff; border-radius: 10px; border: 1px solid var(--border);
    transition: box-shadow 0.2s;
  }
  .badge-card:hover { box-shadow: 0 6px 20px rgba(0,0,0,0.06); }
  .badge-card__icon {
    width: 64px; height: 64px; border-radius: 16px;
    background: rgba(232,121,43,0.1); color: var(--accent);
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 1.25rem;
  }
  .badge-card h3 { font-size: 1rem; font-weight: 700; margin-bottom: 0.5rem; color: var(--primary); }
  .badge-card p { font-size: 0.85rem; color: var(--text-mid); line-height: 1.6; }
  @media (max-width: 1024px) { .badges-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .badges-grid { grid-template-columns: 1fr; } }

  /* SERVICE AREA */
  .area-section {
    background: #fff; border: 1px solid var(--border); border-radius: 12px;
    padding: 2.5rem; max-width: 800px; margin: 0 auto;
  }
  .area-section__header {
    display: flex; align-items: center; gap: 0.75rem;
    margin-bottom: 1rem; color: var(--primary);
  }
  .area-section__header h2 { font-size: 1.5rem; font-weight: 800; }
  .area-section__header svg { color: var(--accent); }
  .area-section__desc {
    font-size: 0.95rem; color: var(--text-mid); line-height: 1.7;
    margin-bottom: 1.5rem;
  }
  .area-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem;
  }
  .area-item {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 0.92rem; font-weight: 500; color: var(--text);
  }
  .area-item svg { color: var(--accent); flex-shrink: 0; }
  @media (max-width: 640px) {
    .area-grid { grid-template-columns: repeat(2, 1fr); }
    .area-section { padding: 1.75rem; }
  }
  @media (max-width: 400px) {
    .area-grid { grid-template-columns: 1fr; }
  }

  /* BUTTONS */
  .btn {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-size: 0.92rem; font-weight: 600; text-decoration: none;
    padding: 0.7rem 1.5rem; border-radius: 6px; transition: all 0.15s;
    border: 2px solid transparent; cursor: pointer;
  }
  .btn--primary { background: var(--accent); color: #fff; border-color: var(--accent); }
  .btn--primary:hover { background: var(--accent-dark); border-color: var(--accent-dark); }
  .btn--outline { background: transparent; color: #fff; border-color: rgba(255,255,255,0.4); }
  .btn--outline:hover { border-color: #fff; background: rgba(255,255,255,0.1); }
  .btn--lg { padding: 0.85rem 2rem; font-size: 1rem; }

  .section--cta {
    background: linear-gradient(135deg, var(--accent) 0%, #d4641a 100%);
    text-align: center; padding: 4rem 0;
  }
  .cta-content h2 { font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 800; color: #fff; margin-bottom: 0.75rem; }
  .cta-content p { font-size: 1.05rem; color: rgba(255,255,255,0.9); margin-bottom: 2rem; }
  .cta-actions { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
  .cta-actions .btn--primary { background: #fff; color: var(--accent); border-color: #fff; }
  .cta-actions .btn--primary:hover { background: #f0f0f0; }

  /* FOOTER */
  .footer { background: #111b27; color: rgba(255,255,255,0.7); padding: 4rem 0 0; }
  .footer__inner { display: grid; grid-template-columns: 1.5fr 1fr 1fr 1fr; gap: 2.5rem; }
  .footer__col h4 { color: #fff; font-size: 0.95rem; font-weight: 700; margin-bottom: 1rem; }
  .footer__col p { font-size: 0.88rem; line-height: 1.65; }
  .footer__col ul { list-style: none; }
  .footer__col li { margin-bottom: 0.4rem; }
  .footer__col a { color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.88rem; transition: color 0.15s; }
  .footer__col a:hover { color: var(--accent); }
  .footer__bottom {
    margin-top: 3rem; padding: 1.25rem 0;
    border-top: 1px solid rgba(255,255,255,0.08); text-align: center;
  }
  .footer__bottom p { font-size: 0.8rem; color: rgba(255,255,255,0.35); }
  @media (max-width: 768px) { .footer__inner { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 480px) { .footer__inner { grid-template-columns: 1fr; gap: 2rem; } }
</style>
</body>
</html>
