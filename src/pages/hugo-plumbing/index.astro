---
import Analytics from '../../components/Analytics.astro';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Hugo Plumbing and Pump Service Inc — Licensed Plumbing Repairs and Installations</title>
  <meta name="description" content="Hugo Plumbing and Pump Service Inc. 30+ years of licensed plumbing repairs and installations serving Hugo, Forest Lake, Scandia, and surrounding areas. State Licensed & Bonded. Call (651) 433-4866." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <Analytics />
</head>
<body>

  <!-- NAV -->
  <header class="nav">
    <div class="nav__inner">
      <a href="/hugo-plumbing" class="nav__brand">
        <span class="nav__wordmark">Hugo</span>
        <span class="nav__wordmark-sub">Plumbing</span>
      </a>
      <nav class="nav__links">
        <a href="/hugo-plumbing" class="nav__link nav__link--active">Home</a>
        <a href="/hugo-plumbing/services" class="nav__link">Services</a>
        <a href="/hugo-plumbing/about" class="nav__link">About</a>
        <a href="/hugo-plumbing/contact" class="nav__link">Contact</a>
      </nav>
      <a href="tel:6514334866" class="nav__cta">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 013.12 4.18 2 2 0 015.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        (651) 433-4866
