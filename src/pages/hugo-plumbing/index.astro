  <script>
    const nav = document.querySelector('.nav');
    window.addEventListener('scroll', () => {
      nav?.classList.toggle('nav--scrolled', window.scrollY > 20);
    });
    document.querySelector('.nav__hamburger')?.addEventListener('click', () => {
      document.querySelector('.nav__links')?.classList.toggle('nav__links--open');
    });
  </script>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --primary: #1b3a5c;
    --primary-dark: #122942;
    --accent: #e8792b;
    --accent-dark: #cf6520;
    --text: #1a1a1a;
    --text-mid: #555;
    --text-light: #888;
    --bg: #fff;
    --bg-warm: #f7f8fa;
    --border: #e5e7eb;
  }

  body {
    font-family: 'Inter', -apple-system, sans-serif;
    color: var(--text);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  .container { max-width: 1140px; margin: 0 auto; padding: 0 1.5rem; }

  /* NAV */
  .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: var(--primary);
    transition: box-shadow 0.2s;
  }
  .nav--scrolled { box-shadow: 0 2px 20px rgba(0,0,0,0.2); }
  .nav__inner {
    max-width: 1140px; margin: 0 auto; padding: 0 1.5rem;
    display: flex; align-items: center; justify-content: space-between;
    height: 68px;
  }
  .nav__brand {
    display: flex; align-items: baseline; gap: 0.4rem;
    text-decoration: none;
  }
  .nav__wordmark {
    color: #fff; font-weight: 900; font-size: 1.35rem;
    letter-spacing: -0.02em;
  }
  .nav__wordmark-sub {
    color: var(--accent); font-weight: 600; font-size: 1.05rem;
    letter-spacing: -0.01em;
  }
  .nav__links { display: flex; gap: 0.25rem; }
  .nav__link {
    color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.88rem;
    font-weight: 500; padding: 0.4rem 0.8rem; border-radius: 6px;
    transition: color 0.15s, background 0.15s;
  }
  .nav__link:hover, .nav__link--active { color: #fff; background: rgba(255,255,255,0.1); }
  .nav__cta {
    display: flex; align-items: center; gap: 0.4rem;
    background: var(--accent); color: #fff; text-decoration: none;
    font-size: 0.85rem; font-weight: 600; padding: 0.5rem 1.1rem;
    border-radius: 6px; transition: background 0.15s;
  }
  .nav__cta:hover { background: var(--accent-dark); }
  .nav__hamburger {
    display: none; background: none; border: none; cursor: pointer;
    flex-direction: column; gap: 5px; padding: 4px;
  }
  .nav__hamburger span {
    display: block; width: 22px; height: 2px; background: #fff;
    border-radius: 1px; transition: 0.2s;
  }

  @media (max-width: 768px) {
    .nav__links {
      display: none; position: absolute; top: 68px; left: 0; right: 0;
      background: var(--primary); flex-direction: column; padding: 1rem;
      box-shadow: 0 8px 20px rgba(0,0,0,0.2);
    }
    .nav__links--open { display: flex; }
    .nav__link { padding: 0.75rem 1rem; }
    .nav__cta { display: none; }
    .nav__hamburger { display: flex; }
  }

  /* HERO - SPLIT LAYOUT */
  .hero {
    padding: 7rem 0 4rem;
    background: linear-gradient(135deg, #f0f4f8 0%, #e8ecf2 100%);
  }
  .hero__inner {
    max-width: 1140px; margin: 0 auto; padding: 0 1.5rem;
    display: grid; grid-template-columns: 1fr 1fr; gap: 3.5rem;
    align-items: center;
  }
  .hero__badge {
    display: inline-block; background: var(--primary);
    color: #fff; font-size: 0.75rem; font-weight: 700;
    letter-spacing: 0.08em; text-transform: uppercase;
    padding: 0.4rem 1rem; border-radius: 20px; margin-bottom: 1.5rem;
  }
  .hero__title {
    font-size: clamp(2rem, 4.5vw, 3rem); font-weight: 900;
    line-height: 1.1; color: var(--primary); margin-bottom: 1.25rem;
  }
  .hero__desc {
    font-size: 1.02rem; line-height: 1.75; color: var(--text-mid);
    margin-bottom: 2rem; max-width: 520px;
  }
  .hero__actions { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 2rem; }
  .hero__trust {
    display: flex; gap: 1.75rem; flex-wrap: wrap;
    padding-top: 1.5rem; border-top: 1px solid var(--border);
  }
  .hero__trust-item {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 0.82rem; font-weight: 600; color: var(--primary);
  }
  .hero__trust-item svg { color: var(--accent); }
  .hero__image {
    position: relative;
  }
  .hero__image img {
    width: 100%; height: 420px; object-fit: cover;
    border-radius: 12px; box-shadow: 0 20px 60px rgba(27,58,92,0.15);
  }
  .hero__float-card {
    position: absolute; bottom: -24px; left: 50%; transform: translateX(-50%);
    background: #fff; border-radius: 10px; padding: 1rem 1.75rem;
    box-shadow: 0 8px 30px rgba(0,0,0,0.12);
    display: flex; align-items: center; gap: 1.25rem;
    white-space: nowrap;
  }
  .hero__float-stat { text-align: center; }
  .hero__float-stat strong {
    display: block; font-size: 1.05rem; font-weight: 800; color: var(--primary);
  }
  .hero__float-stat span {
    font-size: 0.72rem; color: var(--text-mid); text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .hero__float-divider {
    width: 1px; height: 32px; background: var(--border);
  }

  @media (max-width: 1024px) {
    .hero__inner { gap: 2.5rem; }
    .hero__image img { height: 360px; }
  }
  @media (max-width: 768px) {
    .hero { padding: 6rem 0 4rem; }
    .hero__inner { grid-template-columns: 1fr; gap: 2rem; }
    .hero__image img { height: 300px; }
    .hero__float-card { position: relative; bottom: auto; left: auto; transform: none; margin-top: 1rem; justify-content: center; }
  }
  @media (max-width: 480px) {
    .hero { padding: 5.5rem 0 3rem; }
    .hero__actions { flex-direction: column; }
    .hero__trust { flex-direction: column; gap: 0.75rem; }
    .hero__float-card { flex-direction: column; gap: 0.5rem; padding: 1rem; }
    .hero__float-divider { width: 40px; height: 1px; }
  }

  /* BUTTONS */
  .btn {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-size: 0.92rem; font-weight: 600; text-decoration: none;
    padding: 0.7rem 1.5rem; border-radius: 6px; transition: all 0.15s;
    border: 2px solid transparent; cursor: pointer;
  }
  .btn--primary { background: var(--accent); color: #fff; border-color: var(--accent); }
  .btn--primary:hover { background: var(--accent-dark); border-color: var(--accent-dark); transform: translateY(-1px); }
  .btn--outline { background: transparent; color: #fff; border-color: rgba(255,255,255,0.4); }
  .btn--outline:hover { border-color: #fff; background: rgba(255,255,255,0.1); }
  .btn--outline-dark { background: transparent; color: var(--primary); border-color: var(--primary); }
  .btn--outline-dark:hover { background: var(--primary); color: #fff; }
  .btn--secondary { background: var(--primary); color: #fff; }
  .btn--secondary:hover { background: var(--primary-dark); }
  .btn--lg { padding: 0.85rem 2rem; font-size: 1rem; }

  /* SECTIONS */
  .section { padding: 5rem 0; }
  .section--warm { background: var(--bg-warm); }
  .section--dark { background: var(--primary); }
  .section--cta {
    background: linear-gradient(135deg, var(--accent) 0%, #d4641a 100%);
    text-align: center; padding: 4rem 0;
  }
  .eyebrow {
    display: block; font-size: 0.78rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--accent); margin-bottom: 0.5rem;
  }
  .eyebrow--light { color: var(--accent); }
  .section__title {
    font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 800;
    margin-bottom: 2.5rem; line-height: 1.2;
  }
  .section__title--light { color: #fff; }

  /* SERVICES GRID */
  .services-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem; margin-bottom: 2rem;
  }
  .service-card {
    background: #fff; border: 1px solid var(--border); border-radius: 10px;
    padding: 1.75rem; transition: box-shadow 0.2s, transform 0.2s;
    border-top: 4px solid var(--accent);
  }
  .service-card:hover { box-shadow: 0 8px 24px rgba(0,0,0,0.08); transform: translateY(-2px); }
  .service-card__icon {
    width: 52px; height: 52px; border-radius: 12px;
    background: rgba(232,121,43,0.1); color: var(--accent);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 1rem;
  }
  .service-card h3 { font-size: 1.05rem; font-weight: 700; margin-bottom: 0.5rem; color: var(--primary); }
  .service-card p { font-size: 0.88rem; color: var(--text-mid); line-height: 1.6; }
  .services-more { text-align: center; }

  @media (max-width: 768px) { .services-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .services-grid { grid-template-columns: 1fr; } }

  /* WHY CHOOSE US */
  .why-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;
  }
  .why-card {
    display: flex; gap: 1.25rem; padding: 1.75rem;
    background: #fff; border-radius: 10px; border: 1px solid var(--border);
    transition: box-shadow 0.2s;
  }
  .why-card:hover { box-shadow: 0 6px 20px rgba(0,0,0,0.06); }
  .why-card__icon {
    flex-shrink: 0; width: 56px; height: 56px; border-radius: 14px;
    background: rgba(232,121,43,0.1); color: var(--accent);
    display: flex; align-items: center; justify-content: center;
  }
  .why-card__text h3 { font-size: 1.05rem; font-weight: 700; margin-bottom: 0.4rem; color: var(--primary); }
  .why-card__text p { font-size: 0.88rem; color: var(--text-mid); line-height: 1.65; }

  @media (max-width: 768px) { .why-grid { grid-template-columns: 1fr; } }

  /* TESTIMONIALS */
  .testimonials-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem;
  }
  .testimonial-card {
    background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
    border-radius: 10px; padding: 1.75rem;
  }
  .testimonial-card--featured {
    grid-column: 1 / -1;
    background: rgba(232,121,43,0.1); border-color: rgba(232,121,43,0.2);
  }
  .testimonial-card__stars { color: var(--accent); margin-bottom: 0.75rem; display: flex; gap: 2px; }
  .testimonial-card blockquote {
    font-size: 0.95rem; color: rgba(255,255,255,0.85); line-height: 1.7;
    margin-bottom: 0.75rem; font-style: italic;
  }
  .testimonial-card--featured blockquote { font-size: 1.1rem; }
  .testimonial-card cite {
    font-size: 0.85rem; color: rgba(255,255,255,0.5);
    font-style: normal; font-weight: 600;
  }

  @media (max-width: 640px) { .testimonials-grid { grid-template-columns: 1fr; } }

  /* CTA */
  .cta-content h2 { font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 800; color: #fff; margin-bottom: 0.75rem; }
  .cta-content p { font-size: 1.05rem; color: rgba(255,255,255,0.9); margin-bottom: 2rem; }
  .cta-actions { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
  .cta-actions .btn--primary { background: #fff; color: var(--accent); border-color: #fff; }
  .cta-actions .btn--primary:hover { background: #f0f0f0; transform: translateY(-1px); }
  .cta-actions .btn--outline { color: #fff; border-color: rgba(255,255,255,0.5); }

  /* FOOTER */
  .footer { background: #111b27; color: rgba(255,255,255,0.7); padding: 4rem 0 0; }
  .footer__inner { display: grid; grid-template-columns: 1.5fr 1fr 1fr 1fr; gap: 2.5rem; }
  .footer__col h4 { color: #fff; font-size: 0.95rem; font-weight: 700; margin-bottom: 1rem; }
  .footer__col p { font-size: 0.88rem; line-height: 1.65; }
  .footer__col ul { list-style: none; }
  .footer__col li { margin-bottom: 0.4rem; }
  .footer__col a { color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.88rem; transition: color 0.15s; }
  .footer__col a:hover { color: var(--accent); }
  .footer__bottom {
    margin-top: 3rem; padding: 1.25rem 0;
    border-top: 1px solid rgba(255,255,255,0.08); text-align: center;
  }
  .footer__bottom p { font-size: 0.8rem; color: rgba(255,255,255,0.35); }

  @media (max-width: 768px) {
    .footer__inner { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 480px) {
    .footer__inner { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>
</body>
