---
import Analytics from '../../components/Analytics.astro';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Now and Then Antiques — Treasures from Every Era | Alexandria, MN</title>
  <meta name="description" content="Alexandria's favorite antique shop on Broadway Street. Discover vintage furniture, retro collectibles, Victorian pieces, and unique gifts." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <Analytics />
</head>
<body>

  <!-- NAV -->
  <header class="nav">
    <div class="nav__inner">
      <a href="/now-and-then-antiques" class="nav__brand">
        <span class="nav__name">Now &amp; Then Antiques</span>
      </a>
      <nav class="nav__links">
        <a href="/now-and-then-antiques" class="nav__link nav__link--active">Home</a>
        <a href="/now-and-then-antiques/about" class="nav__link">About</a>
        <a href="/now-and-then-antiques/contact" class="nav__link">Contact</a>
      </nav>
      <a href="tel:3207636467" class="nav__cta">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 013.12 4.18 2 2 0 015.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        (320) 763-6467
      </a>
      <button class="nav__hamburger" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </header>

  <!-- HERO -->
  <section class="hero">
    <div class="hero__bg">
      <img src="https://picsum.photos/seed/antiques-shop/1400/700" alt="Now and Then Antiques shop" class="hero__bg-img" />
      <div class="hero__overlay"></div>
    </div>
    <div class="hero__content">
      <span class="hero__badge">Historic Broadway Street</span>
      <h1 class="hero__title">Treasures from Every Era</h1>
      <p class="hero__desc">Alexandria's favorite antique shop. Discover unique finds, vintage collectibles, and timeless pieces.</p>
      <div class="hero__actions">
        <a href="/now-and-then-antiques/contact" class="btn btn--primary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          Visit Us on Broadway
        </a>
        <a href="/now-and-then-antiques/about" class="btn btn--outline">Learn More</a>
      </div>
      <div class="hero__stats">
        <div class="hero__stat">
          <span class="hero__stat-num">Unique</span>
          <span class="hero__stat-label">Finds</span>
        </div>
        <div class="hero__stat-divider"></div>
        <div class="hero__stat">
          <span class="hero__stat-num">Broadway</span>
          <span class="hero__stat-label">Location</span>
        </div>
        <div class="hero__stat-divider"></div>
        <div class="hero__stat">
          <span class="hero__stat-num">All Eras</span>
          <span class="hero__stat-label">Covered</span>
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT YOU'LL FIND -->
  <section class="section" id="finds">
    <div class="container">
      <span class="eyebrow">What We Offer</span>
      <h2 class="section__title">What You'll Find</h2>
      <div class="services-grid">
        <div class="service-card">
          <div class="service-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 16V8a2 2 0 012-2h12a2 2 0 012 2v8"/><path d="M2 16h20v2a2 2 0 01-2 2H4a2 2 0 01-2-2v-2z"/><path d="M6 6V4"/><path d="M18 6V4"/><path d="M8 12h8"/></svg>
          </div>
          <h3>Vintage Furniture</h3>
          <p>Beautiful chairs, tables, dressers, and cabinets from decades past. Each piece tells a story.</p>
        </div>
        <div class="service-card">
          <div class="service-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/><line x1="12" y1="2" x2="12" y2="5"/></svg>
          </div>
          <h3>Retro Collectibles</h3>
          <p>Vinyl records, vintage cameras, classic toys, and nostalgic memorabilia from every decade.</p>
        </div>
        <div class="service-card">
          <div class="service-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><rect x="6" y="6" width="12" height="12" rx="1"/><line x1="3" y1="3" x2="6" y2="6"/><line x1="21" y1="3" x2="18" y2="6"/><line x1="3" y1="21" x2="6" y2="18"/><line x1="21" y1="21" x2="18" y2="18"/></svg>
          </div>
          <h3>Victorian Pieces</h3>
          <p>Ornate mirrors, elegant frames, and refined decorative items from the Victorian era.</p>
        </div>
        <div class="service-card">
          <div class="service-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </div>
          <h3>Antique Jewelry</h3>
          <p>Rings, brooches, necklaces, and watches. Timeless gems and precious metals with character.</p>
        </div>
        <div class="service-card">
          <div class="service-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </div>
          <h3>Rustic Decor</h3>
          <p>Farmhouse signs, lanterns, weathered wood, and charming accents for your home.</p>
        </div>
        <div class="service-card">
          <div class="service-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 010-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 000-5C13 2 12 7 12 7z"/></svg>
          </div>
          <h3>Unique Gifts</h3>
          <p>One-of-a-kind treasures that make the perfect gift for any occasion or collector.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIAL -->
  <section class="section section--testimonial">
    <div class="container">
      <div class="testimonial-highlight">
        <svg class="testimonial-highlight__quote" width="48" height="48" viewBox="0 0 24 24" fill="currentColor"><path d="M4.583 17.321C3.553 16.227 3 15 3 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311C9.591 11.69 11 13.166 11 15c0 1.933-1.567 3.5-3.5 3.5-1.271 0-2.429-.653-2.917-1.179zm10 0C13.553 16.227 13 15 13 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311C19.591 11.69 21 13.166 21 15c0 1.933-1.567 3.5-3.5 3.5-1.271 0-2.429-.653-2.917-1.179z"/></svg>
        <blockquote class="testimonial-highlight__text">My very favorite antique store in MN</blockquote>
        <cite class="testimonial-highlight__cite">&mdash; MapQuest Review</cite>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--cta">
    <div class="container cta-content">
      <h2>Visit Us on Broadway</h2>
      <p>Come browse our ever-changing collection of antiques and unique finds in Alexandria.</p>
      <div class="cta-actions">
        <a href="tel:3207636467" class="btn btn--primary btn--lg">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 013.12 4.18 2 2 0 015.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          Call (320) 763-6467
        </a>
        <a href="https://maps.google.com/?q=601+Broadway+St+Alexandria+MN+56308" target="_blank" rel="noopener" class="btn btn--outline btn--lg">Get Directions</a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container footer__inner">
      <div class="footer__col">
        <h4>Now &amp; Then Antiques</h4>
        <p>A treasure trove of unique finds on historic Broadway Street in Alexandria, MN. From vintage furniture to retro collectibles, there's something for every treasure hunter.</p>
      </div>
      <div class="footer__col">
        <h4>Quick Links</h4>
        <ul>
          <li><a href="/now-and-then-antiques">Home</a></li>
          <li><a href="/now-and-then-antiques/about">About Us</a></li>
          <li><a href="/now-and-then-antiques/contact">Contact</a></li>
        </ul>
      </div>
      <div class="footer__col">
        <h4>Contact</h4>
        <p>601 Broadway St<br/>Alexandria, MN 56308</p>
        <p><a href="tel:3207636467">(320) 763-6467</a></p>
      </div>
    </div>
    <div class="footer__bottom">
      <p>&copy; 2026 Now and Then Antiques. All rights reserved.</p>
    </div>
  </footer>

  <script>
    // Sticky nav shadow
    const nav = document.querySelector('.nav');
    window.addEventListener('scroll', () => {
      nav?.classList.toggle('nav--scrolled', window.scrollY > 20);
    });
    // Mobile menu
    document.querySelector('.nav__hamburger')?.addEventListener('click', () => {
      document.querySelector('.nav__links')?.classList.toggle('nav__links--open');
    });
  </script>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --primary: #4e342e;
    --accent: #bf360c;
    --text: #1a1a1a;
    --text-mid: #555;
    --text-light: #888;
    --bg: #fff;
    --bg-warm: #faf5f0;
    --border: #e5e7eb;
  }

  body {
    font-family: 'Inter', -apple-system, sans-serif;
    color: var(--text);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  .container { max-width: 1140px; margin: 0 auto; padding: 0 1.5rem; }

  /* NAV */
  .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: var(--primary);
    transition: box-shadow 0.2s;
  }
  .nav--scrolled { box-shadow: 0 2px 20px rgba(0,0,0,0.15); }
  .nav__inner {
    max-width: 1140px; margin: 0 auto; padding: 0 1.5rem;
    display: flex; align-items: center; justify-content: space-between;
    height: 64px;
  }
  .nav__brand { display: flex; align-items: center; gap: 0.6rem; text-decoration: none; }
  .nav__name { color: #fff; font-weight: 700; font-size: 1.1rem; }
  .nav__links { display: flex; gap: 0.25rem; }
  .nav__link {
    color: rgba(255,255,255,0.75); text-decoration: none; font-size: 0.88rem;
    font-weight: 500; padding: 0.4rem 0.75rem; border-radius: 6px;
    transition: color 0.15s, background 0.15s;
  }
  .nav__link:hover, .nav__link--active { color: #fff; background: rgba(255,255,255,0.1); }
  .nav__cta {
    display: flex; align-items: center; gap: 0.4rem;
    background: var(--accent); color: #fff; text-decoration: none;
    font-size: 0.85rem; font-weight: 600; padding: 0.5rem 1rem;
    border-radius: 6px; transition: opacity 0.15s;
  }
  .nav__cta:hover { opacity: 0.9; }
  .nav__hamburger {
    display: none; background: none; border: none; cursor: pointer;
    flex-direction: column; gap: 5px; padding: 4px;
  }
  .nav__hamburger span {
    display: block; width: 22px; height: 2px; background: #fff;
    border-radius: 1px; transition: 0.2s;
  }

  @media (max-width: 768px) {
    .nav__links {
      display: none; position: absolute; top: 64px; left: 0; right: 0;
      background: var(--primary); flex-direction: column; padding: 1rem;
      box-shadow: 0 8px 20px rgba(0,0,0,0.2);
    }
    .nav__links--open { display: flex; }
    .nav__link { padding: 0.75rem 1rem; }
    .nav__cta { display: none; }
    .nav__hamburger { display: flex; }
  }

  /* HERO */
  .hero {
    position: relative; min-height: 85vh; display: flex; align-items: center;
    padding: 8rem 1.5rem 5rem;
  }
  .hero__bg { position: absolute; inset: 0; }
  .hero__bg-img { width: 100%; height: 100%; object-fit: cover; }
  .hero__overlay {
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(78,52,46,0.88) 0%, rgba(78,52,46,0.7) 100%);
  }
  .hero__content {
    position: relative; max-width: 720px; margin: 0 auto 0 0;
    padding-left: calc((100vw - 1140px) / 2);
  }
  @media (max-width: 1172px) { .hero__content { padding-left: 1.5rem; } }
  .hero__badge {
    display: inline-block; background: var(--accent); color: #fff;
    font-size: 0.78rem; font-weight: 700; letter-spacing: 0.08em;
    text-transform: uppercase; padding: 0.35rem 0.9rem; border-radius: 4px;
    margin-bottom: 1.25rem;
  }
  .hero__title {
    font-size: clamp(2.25rem, 5vw, 3.5rem); font-weight: 900;
    line-height: 1.1; color: #fff; margin-bottom: 1.25rem;
  }
  .hero__desc {
    font-size: 1.1rem; line-height: 1.7; color: rgba(255,255,255,0.85);
    margin-bottom: 2rem; max-width: 560px;
  }
  .hero__actions { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 2.5rem; }
  .hero__stats {
    display: flex; align-items: center; gap: 2rem;
    padding-top: 2rem; border-top: 1px solid rgba(255,255,255,0.15);
  }
  .hero__stat { text-align: center; }
  .hero__stat-num { display: block; font-size: 1.5rem; font-weight: 800; color: var(--accent); }
  .hero__stat-label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.06em; color: rgba(255,255,255,0.6); }
  .hero__stat-divider { width: 1px; height: 40px; background: rgba(255,255,255,0.15); }

  @media (max-width: 480px) {
    .hero { min-height: 70vh; padding: 6rem 1.25rem 3rem; }
    .hero__actions { flex-direction: column; }
    .hero__stats { gap: 1.25rem; }
    .hero__stat-divider { display: none; }
  }

  /* BUTTONS */
  .btn {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-size: 0.92rem; font-weight: 600; text-decoration: none;
    padding: 0.7rem 1.5rem; border-radius: 6px; transition: all 0.15s;
    border: 2px solid transparent; cursor: pointer;
  }
  .btn--primary { background: var(--accent); color: #fff; border-color: var(--accent); }
  .btn--primary:hover { opacity: 0.9; transform: translateY(-1px); }
  .btn--outline { background: transparent; color: #fff; border-color: rgba(255,255,255,0.4); }
  .btn--outline:hover { border-color: #fff; background: rgba(255,255,255,0.1); }
  .btn--secondary { background: var(--primary); color: #fff; }
  .btn--secondary:hover { opacity: 0.9; }
  .btn--lg { padding: 0.85rem 2rem; font-size: 1rem; }

  /* SECTIONS */
  .section { padding: 5rem 0; }
  .section--cta {
    background: linear-gradient(135deg, #bf360c 0%, #8d2608 100%);
    text-align: center; padding: 4rem 0;
  }
  .eyebrow {
    display: block; font-size: 0.78rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--accent); margin-bottom: 0.5rem;
  }
  .section__title {
    font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 800;
    margin-bottom: 2.5rem; line-height: 1.2;
  }

  /* SERVICES / FINDS GRID */
  .services-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem; margin-bottom: 2rem;
  }
  .service-card {
    background: #fff; border: 1px solid var(--border); border-radius: 8px;
    padding: 1.75rem; transition: box-shadow 0.2s, transform 0.2s;
    border-top: 4px solid var(--accent);
  }
  .service-card:hover { box-shadow: 0 8px 24px rgba(0,0,0,0.08); transform: translateY(-2px); }
  .service-card__icon {
    width: 48px; height: 48px; border-radius: 10px;
    background: rgba(191,54,12,0.1); color: var(--accent);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 1rem;
  }
  .service-card h3 { font-size: 1.05rem; font-weight: 700; margin-bottom: 0.4rem; }
  .service-card p { font-size: 0.88rem; color: var(--text-mid); line-height: 1.6; }

  @media (max-width: 768px) { .services-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .services-grid { grid-template-columns: 1fr; } }

  /* TESTIMONIAL HIGHLIGHT */
  .section--testimonial {
    background: var(--bg-warm);
    padding: 4.5rem 0;
  }
  .testimonial-highlight {
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
  }
  .testimonial-highlight__quote {
    color: var(--accent);
    margin-bottom: 1.25rem;
    opacity: 0.6;
  }
  .testimonial-highlight__text {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    line-height: 1.4;
    color: var(--primary);
    font-style: italic;
    margin-bottom: 1.25rem;
  }
  .testimonial-highlight__cite {
    font-size: 1rem;
    font-style: normal;
    font-weight: 600;
    color: var(--text-mid);
  }

  /* CTA */
  .cta-content h2 { font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 800; color: #fff; margin-bottom: 0.75rem; }
  .cta-content p { font-size: 1.05rem; color: rgba(255,255,255,0.85); margin-bottom: 2rem; }
  .cta-actions { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
  .cta-actions .btn--primary { background: #fff; color: var(--accent); border-color: #fff; }
  .cta-actions .btn--outline { color: #fff; border-color: rgba(255,255,255,0.5); }

  /* FOOTER */
  .footer { background: #2a1a15; color: rgba(255,255,255,0.7); padding: 4rem 0 0; }
  .footer__inner { display: grid; grid-template-columns: 1.5fr 1fr 1fr; gap: 2.5rem; }
  .footer__col h4 { color: #fff; font-size: 0.95rem; font-weight: 700; margin-bottom: 1rem; }
  .footer__col p { font-size: 0.88rem; line-height: 1.65; }
  .footer__col ul { list-style: none; }
  .footer__col li { margin-bottom: 0.4rem; }
  .footer__col a { color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.88rem; transition: color 0.15s; }
  .footer__col a:hover { color: var(--accent); }
  .footer__bottom {
    margin-top: 3rem; padding: 1.25rem 0;
    border-top: 1px solid rgba(255,255,255,0.08); text-align: center;
  }
  .footer__bottom p { font-size: 0.8rem; color: rgba(255,255,255,0.35); }

  @media (max-width: 768px) {
    .footer__inner { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 480px) {
    .footer__inner { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>
</body>
</html>
