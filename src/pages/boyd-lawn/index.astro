---
import Analytics from '../../components/Analytics.astro';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Boyd Lawn — Professional Lawn & Tree Care in West Central Minnesota</title>
  <meta name="description" content="Professional fertilizer, weed control, and tree & shrub care serving Morris, Alexandria, Starbuck, Glenwood, and Benson. BBB Listed. Call (320) 287-3297." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <Analytics />
</head>
<body>

  <!-- NAV -->
  <header class="nav">
    <div class="nav__inner">
      <a href="/boyd-lawn" class="nav__brand">
        <img src="/images/boyd/logo.png" alt="Boyd Lawn" class="nav__logo" />
        <span class="nav__name">Boyd Lawn</span>
      </a>
      <nav class="nav__links">
        <a href="/boyd-lawn" class="nav__link nav__link--active">Home</a>
        <a href="/boyd-lawn/services" class="nav__link">Services</a>
        <a href="/boyd-lawn/contact" class="nav__link">Contact</a>
      </nav>
      <a href="tel:3202873297" class="nav__cta">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 013.12 4.18 2 2 0 015.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        (320) 287-3297
      </a>
      <button class="nav__hamburger" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </header>

  <!-- HERO -->
  <section class="hero">
    <div class="hero__bg">
      <img src="https://picsum.photos/seed/boyd-lawn/1400/700" alt="Professional lawn care in West Central Minnesota" class="hero__bg-img" />
      <div class="hero__overlay"></div>
    </div>
    <div class="hero__content">
      <span class="hero__badge">BBB Listed | Locally Owned</span>
      <h1 class="hero__title">Professional Lawn & Tree Care for West Central Minnesota</h1>
      <p class="hero__desc">Professional fertilizer, weed control, and tree & shrub care for healthier, greener lawns across Pope, Douglas, and Stevens counties.</p>
      <div class="hero__actions">
        <a href="tel:3202873297" class="btn btn--primary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 013.12 4.18 2 2 0 015.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          Call for Service
        </a>
        <a href="/boyd-lawn/services" class="btn btn--outline">View Our Services</a>
      </div>
      <div class="hero__stats">
        <div class="hero__stat">
          <span class="hero__stat-num">BBB</span>
          <span class="hero__stat-label">Listed</span>
        </div>
        <div class="hero__stat-divider"></div>
        <div class="hero__stat">
          <span class="hero__stat-num">5</span>
          <span class="hero__stat-label">Counties Served</span>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURED SERVICES -->
  <section class="section" id="services">
    <div class="container">
      <span class="eyebrow">What We Do</span>
      <h2 class="section__title">Our Services</h2>
      <div class="services-grid">
        <div class="service-card">
          <div class="service-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3>Fertilizer Application</h3>
          <p>Custom fertilizer programs for healthy, green lawns with scheduled applications throughout the growing season.</p>
        </div>
        <div class="service-card">
          <div class="service-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
          </div>
          <h3>Weed Control</h3>
          <p>Pre-emergent and post-emergent treatments to eliminate broadleaf and grassy weeds from your lawn.</p>
        </div>
        <div class="service-card">
          <div class="service-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          </div>
          <h3>Disease Control</h3>
          <p>Lawn disease diagnosis and treatment with fungicide applications and prevention programs.</p>
        </div>
        <div class="service-card">
          <div class="service-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
          </div>
          <h3>Insect Management</h3>
          <p>Grub control, surface insect treatments, and preventive applications to protect your lawn.</p>
        </div>
        <div class="service-card">
          <div class="service-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M17 8l4 4-4 4"/><path d="M3 12h18"/><path d="M12 2v4M12 18v4"/></svg>
          </div>
          <h3>Tree & Shrub Health</h3>
          <p>Deep root feeding, disease prevention, and insect control for trees and shrubs on your property.</p>
        </div>
      </div>
      <div class="services-more">
        <a href="/boyd-lawn/services" class="btn btn--secondary">View All Services &rarr;</a>
      </div>
    </div>
  </section>

  <!-- SERVICE AREA -->
  <section class="section section--area">
    <div class="container">
      <span class="eyebrow">Where We Work</span>
      <h2 class="section__title">Serving West Central Minnesota</h2>
      <div class="area-grid">
        <div class="area-card">
          <div class="area-card__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <h3>Morris</h3>
          <p>Stevens County</p>
        </div>
        <div class="area-card">
          <div class="area-card__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <h3>Alexandria</h3>
          <p>Douglas County</p>
        </div>
        <div class="area-card">
          <div class="area-card__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <h3>Starbuck</h3>
          <p>Pope County</p>
        </div>
        <div class="area-card">
          <div class="area-card__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <h3>Glenwood</h3>
          <p>Pope County</p>
        </div>
        <div class="area-card">
          <div class="area-card__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <h3>Benson</h3>
          <p>Swift County</p>
        </div>
      </div>
      <p class="area-note">Proudly serving Pope, Douglas, and Stevens counties throughout West Central Minnesota.</p>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="section section--dark" id="testimonials">
    <div class="container">
      <span class="eyebrow eyebrow--light">Customer Reviews</span>
      <h2 class="section__title section__title--light">What Our Customers Say</h2>
      <div class="testimonials-grid">
        <div class="testimonial-card testimonial-card--featured">
          <div class="testimonial-card__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <blockquote>"Boyd Lawn transformed our yard. After years of fighting dandelions and crabgrass, their weed control program finally gave us the thick, green lawn we always wanted. Highly recommend their services to anyone in the area."</blockquote>
          <cite>&mdash; Sarah M., Glenwood</cite>
        </div>
        <div class="testimonial-card">
          <div class="testimonial-card__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <blockquote>"Very professional and reliable. They show up on schedule, and our lawn has never looked better. The fertilizer program they set up made a huge difference by midsummer."</blockquote>
          <cite>&mdash; Tom R., Alexandria</cite>
        </div>
        <div class="testimonial-card">
          <div class="testimonial-card__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <blockquote>"We had a grub problem that was destroying patches of our yard. Boyd Lawn diagnosed it quickly and treated the whole lawn. No more dead spots. Great local company."</blockquote>
          <cite>&mdash; Julie K., Morris</cite>
        </div>
        <div class="testimonial-card">
          <div class="testimonial-card__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <blockquote>"Their tree and shrub care saved our apple trees from disease. Knowledgeable team, fair pricing, and they actually care about the results. We use them every year now."</blockquote>
          <cite>&mdash; Dave L., Starbuck</cite>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--cta">
    <div class="container cta-content">
      <h2>Ready for a Healthier Lawn?</h2>
      <p>Call us today for a free estimate. We serve Morris, Alexandria, Starbuck, Glenwood, and Benson.</p>
      <div class="cta-actions">
        <a href="tel:3202873297" class="btn btn--primary btn--lg">Call (320) 287-3297</a>
        <a href="/boyd-lawn/contact" class="btn btn--outline btn--lg">Contact Us</a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container footer__inner">
      <div class="footer__col">
        <h4>Boyd Lawn</h4>
        <p>Professional fertilizer, weed control, and tree & shrub care for West Central Minnesota. Locally owned and operated.</p>
        <div class="footer__social">
          <a href="https://facebook.com/boydlawncompany" target="_blank" rel="noopener" aria-label="Facebook">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
          </a>
        </div>
      </div>
      <div class="footer__col">
        <h4>Quick Links</h4>
        <ul>
          <li><a href="/boyd-lawn">Home</a></li>
          <li><a href="/boyd-lawn/services">Services</a></li>
          <li><a href="/boyd-lawn/contact">Contact</a></li>
        </ul>
      </div>
      <div class="footer__col">
        <h4>Contact</h4>
        <p>12590 County Road 3<br/>Kensington, MN 56343</p>
        <p><a href="tel:3202873297">(320) 287-3297</a></p>
      </div>
      <div class="footer__col">
        <h4>Service Area</h4>
        <ul>
          <li>Pope County</li>
          <li>Douglas County</li>
          <li>Stevens County</li>
        </ul>
        <p class="footer__area-towns">Morris, Alexandria, Starbuck, Glenwood, Benson</p>
      </div>
    </div>
    <div class="footer__bottom">
      <p>&copy; 2026 Boyd Lawn. All rights reserved.</p>
    </div>
  </footer>

  <script>
    // Sticky nav shadow
    const nav = document.querySelector('.nav');
    window.addEventListener('scroll', () => {
      nav?.classList.toggle('nav--scrolled', window.scrollY > 20);
    });
    // Mobile menu
    document.querySelector('.nav__hamburger')?.addEventListener('click', () => {
      document.querySelector('.nav__links')?.classList.toggle('nav__links--open');
    });
  </script>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --primary: #2e7d32;
    --accent: #ff8f00;
    --text: #1a1a1a;
    --text-mid: #555;
    --text-light: #888;
    --bg: #fff;
    --bg-warm: #fafafa;
    --border: #e5e7eb;
  }

  body {
    font-family: 'Inter', -apple-system, sans-serif;
    color: var(--text);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  .container { max-width: 1140px; margin: 0 auto; padding: 0 1.5rem; }

  /* NAV */
  .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: var(--primary);
    transition: box-shadow 0.2s;
  }
  .nav--scrolled { box-shadow: 0 2px 20px rgba(0,0,0,0.15); }
  .nav__inner {
    max-width: 1140px; margin: 0 auto; padding: 0 1.5rem;
    display: flex; align-items: center; justify-content: space-between;
    height: 64px;
  }
  .nav__brand { display: flex; align-items: center; gap: 0.6rem; text-decoration: none; }
  .nav__logo { height: 36px; width: auto; }
  .nav__name { color: #fff; font-weight: 700; font-size: 1.1rem; }
  .nav__links { display: flex; gap: 0.25rem; }
  .nav__link {
    color: rgba(255,255,255,0.75); text-decoration: none; font-size: 0.88rem;
    font-weight: 500; padding: 0.4rem 0.75rem; border-radius: 6px;
    transition: color 0.15s, background 0.15s;
  }
  .nav__link:hover, .nav__link--active { color: #fff; background: rgba(255,255,255,0.1); }
  .nav__cta {
    display: flex; align-items: center; gap: 0.4rem;
    background: var(--accent); color: #fff; text-decoration: none;
    font-size: 0.85rem; font-weight: 600; padding: 0.5rem 1rem;
    border-radius: 6px; transition: opacity 0.15s;
  }
  .nav__cta:hover { opacity: 0.9; }
  .nav__hamburger {
    display: none; background: none; border: none; cursor: pointer;
    flex-direction: column; gap: 5px; padding: 4px;
  }
  .nav__hamburger span {
    display: block; width: 22px; height: 2px; background: #fff;
    border-radius: 1px; transition: 0.2s;
  }

  @media (max-width: 768px) {
    .nav__links {
      display: none; position: absolute; top: 64px; left: 0; right: 0;
      background: var(--primary); flex-direction: column; padding: 1rem;
      box-shadow: 0 8px 20px rgba(0,0,0,0.2);
    }
    .nav__links--open { display: flex; }
    .nav__link { padding: 0.75rem 1rem; }
    .nav__cta { display: none; }
    .nav__hamburger { display: flex; }
  }

  /* HERO */
  .hero {
    position: relative; min-height: 85vh; display: flex; align-items: center;
    padding: 8rem 1.5rem 5rem;
  }
  .hero__bg { position: absolute; inset: 0; }
  .hero__bg-img { width: 100%; height: 100%; object-fit: cover; }
  .hero__overlay {
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(46,125,50,0.88) 0%, rgba(46,125,50,0.7) 100%);
  }
  .hero__content {
    position: relative; max-width: 720px; margin: 0 auto 0 0;
    padding-left: calc((100vw - 1140px) / 2);
  }
  @media (max-width: 1172px) { .hero__content { padding-left: 1.5rem; } }
  .hero__badge {
    display: inline-block; background: var(--accent); color: #fff;
    font-size: 0.78rem; font-weight: 700; letter-spacing: 0.08em;
    text-transform: uppercase; padding: 0.35rem 0.9rem; border-radius: 4px;
    margin-bottom: 1.25rem;
  }
  .hero__title {
    font-size: clamp(2.25rem, 5vw, 3.5rem); font-weight: 900;
    line-height: 1.1; color: #fff; margin-bottom: 1.25rem;
  }
  .hero__desc {
    font-size: 1.1rem; line-height: 1.7; color: rgba(255,255,255,0.85);
    margin-bottom: 2rem; max-width: 560px;
  }
  .hero__actions { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 2.5rem; }
  .hero__stats {
    display: flex; align-items: center; gap: 2rem;
    padding-top: 2rem; border-top: 1px solid rgba(255,255,255,0.15);
  }
  .hero__stat { text-align: center; }
  .hero__stat-num { display: block; font-size: 1.5rem; font-weight: 800; color: var(--accent); }
  .hero__stat-label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.06em; color: rgba(255,255,255,0.6); }
  .hero__stat-divider { width: 1px; height: 40px; background: rgba(255,255,255,0.15); }

  @media (max-width: 480px) {
    .hero { min-height: 70vh; padding: 6rem 1.25rem 3rem; }
    .hero__actions { flex-direction: column; }
    .hero__stats { gap: 1.25rem; }
    .hero__stat-divider { display: none; }
  }

  /* BUTTONS */
  .btn {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-size: 0.92rem; font-weight: 600; text-decoration: none;
    padding: 0.7rem 1.5rem; border-radius: 6px; transition: all 0.15s;
    border: 2px solid transparent; cursor: pointer;
  }
  .btn--primary { background: var(--accent); color: #fff; border-color: var(--accent); }
  .btn--primary:hover { opacity: 0.9; transform: translateY(-1px); }
  .btn--outline { background: transparent; color: #fff; border-color: rgba(255,255,255,0.4); }
  .btn--outline:hover { border-color: #fff; background: rgba(255,255,255,0.1); }
  .btn--secondary { background: var(--primary); color: #fff; }
  .btn--secondary:hover { opacity: 0.9; }
  .btn--lg { padding: 0.85rem 2rem; font-size: 1rem; }

  /* SECTIONS */
  .section { padding: 5rem 0; }
  .section--dark { background: var(--primary); }
  .section--cta {
    background: linear-gradient(135deg, var(--accent) 0%, #e65100 100%);
    text-align: center; padding: 4rem 0;
  }
  .eyebrow {
    display: block; font-size: 0.78rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--accent); margin-bottom: 0.5rem;
  }
  .eyebrow--light { color: var(--accent); }
  .section__title {
    font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 800;
    margin-bottom: 2.5rem; line-height: 1.2;
  }
  .section__title--light { color: #fff; }

  /* SERVICES GRID */
  .services-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem; margin-bottom: 2rem;
  }
  .service-card {
    background: #fff; border: 1px solid var(--border); border-radius: 8px;
    padding: 1.75rem; transition: box-shadow 0.2s, transform 0.2s;
    border-top: 4px solid var(--accent);
  }
  .service-card:hover { box-shadow: 0 8px 24px rgba(0,0,0,0.08); transform: translateY(-2px); }
  .service-card__icon {
    width: 48px; height: 48px; border-radius: 10px;
    background: rgba(255,143,0,0.1); color: var(--accent);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 1rem;
  }
  .service-card h3 { font-size: 1.05rem; font-weight: 700; margin-bottom: 0.4rem; }
  .service-card p { font-size: 0.88rem; color: var(--text-mid); line-height: 1.6; }
  .services-more { text-align: center; }

  @media (max-width: 1024px) { .services-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 768px) { .services-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .services-grid { grid-template-columns: 1fr; } }

  /* SERVICE AREA */
  .section--area { background: var(--bg-warm); }
  .area-grid {
    display: grid; grid-template-columns: repeat(5, 1fr); gap: 1.25rem;
    margin-bottom: 2rem;
  }
  .area-card {
    background: #fff; border: 1px solid var(--border); border-radius: 8px;
    padding: 1.5rem; text-align: center;
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .area-card:hover { box-shadow: 0 8px 24px rgba(0,0,0,0.08); transform: translateY(-2px); }
  .area-card__icon {
    width: 44px; height: 44px; border-radius: 50%;
    background: rgba(46,125,50,0.1); color: var(--primary);
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 0.75rem;
  }
  .area-card h3 { font-size: 1rem; font-weight: 700; margin-bottom: 0.2rem; }
  .area-card p { font-size: 0.82rem; color: var(--text-mid); }
  .area-note {
    text-align: center; font-size: 0.95rem; color: var(--text-mid);
    max-width: 600px; margin: 0 auto;
  }

  @media (max-width: 1024px) { .area-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 768px) { .area-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .area-grid { grid-template-columns: 1fr; } }

  /* TESTIMONIALS */
  .testimonials-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem;
  }
  .testimonial-card {
    background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
    border-radius: 8px; padding: 1.75rem;
  }
  .testimonial-card--featured {
    grid-column: 1 / -1;
