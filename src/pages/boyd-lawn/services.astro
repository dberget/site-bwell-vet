---
import Analytics from '../../components/Analytics.astro';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Services — Boyd Lawn | Lawn & Tree Care in West Central MN</title>
  <meta name="description" content="Professional fertilizer, weed control, disease control, insect management, and tree & shrub care. Serving Morris, Alexandria, Starbuck, Glenwood, and Benson." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <Analytics />
</head>
<body>

  <!-- NAV -->
  <header class="nav">
    <div class="nav__inner">
      <a href="/boyd-lawn" class="nav__brand">
        <img src="/images/boyd/logo.png" alt="Boyd Lawn" class="nav__logo" />
        <span class="nav__name">Boyd Lawn</span>
      </a>
      <nav class="nav__links">
        <a href="/boyd-lawn" class="nav__link">Home</a>
        <a href="/boyd-lawn/services" class="nav__link nav__link--active">Services</a>
        <a href="/boyd-lawn/contact" class="nav__link">Contact</a>
      </nav>
      <a href="tel:3202873297" class="nav__cta">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 013.12 4.18 2 2 0 015.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        (320) 287-3297
      </a>
      <button class="nav__hamburger" aria-label="Menu"><span></span><span></span><span></span></button>
    </div>
  </header>

  <!-- PAGE HEADER -->
  <section class="page-header">
    <div class="container">
      <div class="page-header__breadcrumb">
        <a href="/boyd-lawn">Home</a> <span>/</span> <span>Services</span>
      </div>
      <h1>Our Services</h1>
      <p>Complete lawn and tree care programs for West Central Minnesota properties.</p>
    </div>
  </section>

  <!-- ALL SERVICES -->
  <section class="section">
    <div class="container">

      <div class="service-detail" id="fertilizer">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>Fertilizer Application</h2>
          <p>Custom fertilizer programs designed to promote healthy, green lawns throughout the growing season. We develop a tailored schedule based on your lawn's specific needs, soil conditions, and grass type to deliver the right nutrients at the right time.</p>
          <ul>
            <li>Custom fertilizer programs for your lawn</li>
            <li>Scheduled applications throughout the growing season</li>
            <li>Soil analysis and nutrient assessment</li>
            <li>Slow-release formulas for lasting results</li>
          </ul>
        </div>
      </div>

      <div class="service-detail" id="weed-control">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>Weed Control</h2>
          <p>Comprehensive weed management using both pre-emergent and post-emergent treatments. We target broadleaf weeds like dandelions and clover, as well as grassy weeds like crabgrass, to keep your lawn thick and weed-free all season.</p>
          <ul>
            <li>Pre-emergent weed prevention</li>
            <li>Post-emergent targeted treatments</li>
            <li>Broadleaf weed control</li>
            <li>Grassy weed elimination</li>
          </ul>
        </div>
      </div>

      <div class="service-detail" id="disease-control">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>Disease Control</h2>
          <p>Professional lawn disease diagnosis and treatment to stop brown patches, dollar spot, rust, and other common turf diseases. Our fungicide applications and prevention programs keep your lawn healthy and resilient throughout the season.</p>
          <ul>
            <li>Lawn disease diagnosis and identification</li>
            <li>Fungicide applications</li>
            <li>Prevention programs</li>
            <li>Brown patch and dollar spot treatment</li>
          </ul>
        </div>
      </div>

      <div class="service-detail" id="insect-management">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>Insect Management</h2>
          <p>Protect your lawn from destructive insects with our targeted control programs. From grubs that damage roots to surface insects that feed on grass blades, we apply effective treatments to eliminate pests and prevent future infestations.</p>
          <ul>
            <li>Grub control and prevention</li>
            <li>Surface insect treatments</li>
            <li>Preventive applications</li>
            <li>Lawn damage assessment and recovery</li>
          </ul>
        </div>
      </div>

      <div class="service-detail" id="tree-shrub">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M17 8l4 4-4 4"/><path d="M3 12h18"/><path d="M12 2v4M12 18v4"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>Tree & Shrub Health</h2>
          <p>Keep your trees and shrubs healthy and vibrant with our specialized care programs. We provide deep root feeding to deliver essential nutrients, along with disease prevention and insect control tailored to the specific species on your property.</p>
          <ul>
            <li>Deep root feeding</li>
            <li>Disease prevention for trees and shrubs</li>
            <li>Insect control for woody plants</li>
            <li>Health assessments and treatment plans</li>
          </ul>
        </div>
      </div>

      <!-- Decorative image -->
      <div class="services-image">
        <img src="https://picsum.photos/seed/boyd-services/800/600" alt="Professional lawn care services" />
      </div>

      <!-- Service Area Box -->
      <div class="service-area-box">
        <div class="service-area-box__icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
        <div>
          <h3>Serving West Central Minnesota</h3>
          <p>Morris, Alexandria, Starbuck, Glenwood, Benson &mdash; Pope, Douglas, and Stevens counties.</p>
        </div>
      </div>

      <!-- Free Estimates -->
      <div class="estimates-callout">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 013.12 4.18 2 2 0 015.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        <div>
          <strong>Free Estimates</strong>
          <p>Call <a href="tel:3202873297">(320) 287-3297</a> for a free lawn care consultation and estimate. We'll assess your property and recommend the right program for your needs.</p>
        </div>
      </div>

    </div>
  </section>

  <!-- CTA -->
  <section class="section section--cta">
    <div class="container cta-content">
      <h2>Ready to Get Started?</h2>
      <p>Call us today for a free estimate on any of our lawn and tree care services.</p>
      <div class="cta-actions">
        <a href="tel:3202873297" class="btn btn--primary btn--lg">Call (320) 287-3297</a>
        <a href="/boyd-lawn/contact" class="btn btn--outline btn--lg">Contact Us</a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container footer__inner">
      <div class="footer__col">
        <h4>Boyd Lawn</h4>
        <p>Professional fertilizer, weed control, and tree & shrub care for West Central Minnesota.</p>
        <div class="footer__social">
          <a href="https://facebook.com/boydlawncompany" target="_blank" rel="noopener" aria-label="Facebook">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
          </a>
        </div>
      </div>
      <div class="footer__col">
        <h4>Quick Links</h4>
        <ul><li><a href="/boyd-lawn">Home</a></li><li><a href="/boyd-lawn/services">Services</a></li><li><a href="/boyd-lawn/contact">Contact</a></li></ul>
      </div>
      <div class="footer__col">
        <h4>Contact</h4>
        <p>12590 County Road 3<br/>Kensington, MN 56343</p>
        <p><a href="tel:3202873297">(320) 287-3297</a></p>
      </div>
      <div class="footer__col">
        <h4>Service Area</h4>
        <ul>
          <li>Pope County</li>
          <li>Douglas County</li>
          <li>Stevens County</li>
        </ul>
        <p class="footer__area-towns">Morris, Alexandria, Starbuck, Glenwood, Benson</p>
      </div>
    </div>
    <div class="footer__bottom"><p>&copy; 2026 Boyd Lawn. All rights reserved.</p></div>
  </footer>

  <script>
    const nav = document.querySelector('.nav');
    window.addEventListener('scroll', () => nav?.classList.toggle('nav--scrolled', window.scrollY > 20));
    document.querySelector('.nav__hamburger')?.addEventListener('click', () => document.querySelector('.nav__links')?.classList.toggle('nav__links--open'));
  </script>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root { --primary: #2e7d32; --accent: #ff8f00; --text: #1a1a1a; --text-mid: #555; --bg: #fff; --border: #e5e7eb; }
  body { font-family: 'Inter', -apple-system, sans-serif; color: var(--text); line-height: 1.6; -webkit-font-smoothing: antialiased; }
  .container { max-width: 1140px; margin: 0 auto; padding: 0 1.5rem; }

  /* NAV */
  .nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: var(--primary); transition: box-shadow 0.2s; }
  .nav--scrolled { box-shadow: 0 2px 20px rgba(0,0,0,0.15); }
  .nav__inner { max-width: 1140px; margin: 0 auto; padding: 0 1.5rem; display: flex; align-items: center; justify-content: space-between; height: 64px; }
  .nav__brand { display: flex; align-items: center; gap: 0.6rem; text-decoration: none; }
  .nav__logo { height: 36px; width: auto; }
  .nav__name { color: #fff; font-weight: 700; font-size: 1.1rem; }
  .nav__links { display: flex; gap: 0.25rem; }
  .nav__link { color: rgba(255,255,255,0.75); text-decoration: none; font-size: 0.88rem; font-weight: 500; padding: 0.4rem 0.75rem; border-radius: 6px; transition: color 0.15s, background 0.15s; }
  .nav__link:hover, .nav__link--active { color: #fff; background: rgba(255,255,255,0.1); }
  .nav__cta { display: flex; align-items: center; gap: 0.4rem; background: var(--accent); color: #fff; text-decoration: none; font-size: 0.85rem; font-weight: 600; padding: 0.5rem 1rem; border-radius: 6px; transition: opacity 0.15s; }
  .nav__cta:hover { opacity: 0.9; }
  .nav__hamburger { display: none; background: none; border: none; cursor: pointer; flex-direction: column; gap: 5px; padding: 4px; }
  .nav__hamburger span { display: block; width: 22px; height: 2px; background: #fff; border-radius: 1px; }
  @media (max-width: 768px) {
    .nav__links { display: none; position: absolute; top: 64px; left: 0; right: 0; background: var(--primary); flex-direction: column; padding: 1rem; box-shadow: 0 8px 20px rgba(0,0,0,0.2); }
    .nav__links--open { display: flex; }
    .nav__link { padding: 0.75rem 1rem; }
    .nav__cta { display: none; }
    .nav__hamburger { display: flex; }
  }

  /* PAGE HEADER */
  .page-header { background: var(--primary); padding: 7rem 0 2.5rem; }
  .page-header__breadcrumb { font-size: 0.82rem; color: rgba(255,255,255,0.45); margin-bottom: 0.75rem; }
  .page-header__breadcrumb a { color: rgba(255,255,255,0.6); text-decoration: none; }
  .page-header__breadcrumb a:hover { color: var(--accent); }
  .page-header__breadcrumb span { margin: 0 0.35rem; }
  .page-header h1 { color: #fff; font-size: clamp(1.75rem, 4vw, 2.75rem); font-weight: 800; margin-bottom: 0.5rem; }
  .page-header p { color: rgba(255,255,255,0.7); font-size: 1.05rem; }

  .section { padding: 4.5rem 0; }

  /* SERVICE DETAIL BLOCKS */
  .service-detail {
    display: flex; gap: 1.5rem; padding: 2.25rem 0;
    border-bottom: 1px solid var(--border);
  }
  .service-detail:first-of-type { padding-top: 0; }
  .service-detail__icon {
    flex-shrink: 0; width: 56px; height: 56px; border-radius: 12px;
    background: rgba(255,143,0,0.08); color: var(--accent);
    display: flex; align-items: center; justify-content: center;
  }
  .service-detail__body h2 { font-size: 1.25rem; font-weight: 700; margin-bottom: 0.5rem; }
  .service-detail__body p { font-size: 0.95rem; color: var(--text-mid); line-height: 1.7; margin-bottom: 0.75rem; }
  .service-detail__body ul { list-style: none; display: flex; flex-wrap: wrap; gap: 0.4rem 1.5rem; }
  .service-detail__body li {
    font-size: 0.85rem; color: var(--text-mid); padding-left: 1.1rem;
    position: relative;
  }
  .service-detail__body li::before {
    content: ''; position: absolute; left: 0; top: 0.45rem;
    width: 6px; height: 6px; border-radius: 50%; background: var(--accent);
  }
  @media (max-width: 640px) {
    .service-detail { flex-direction: column; gap: 1rem; }
  }

  /* SERVICES IMAGE */
  .services-image {
    margin: 2.5rem 0; border-radius: 10px; overflow: hidden;
    border: 1px solid var(--border);
  }
  .services-image img { width: 100%; height: auto; display: block; }

  /* SERVICE AREA BOX */
  .service-area-box {
    display: flex; align-items: flex-start; gap: 1.25rem;
    background: rgba(46,125,50,0.06); border: 1px solid rgba(46,125,50,0.15);
    border-radius: 10px; padding: 1.75rem; margin-top: 2rem;
  }
  .service-area-box__icon {
    flex-shrink: 0; width: 52px; height: 52px; border-radius: 12px;
    background: rgba(46,125,50,0.1); color: var(--primary);
    display: flex; align-items: center; justify-content: center;
  }
  .service-area-box h3 { font-size: 1.1rem; font-weight: 700; margin-bottom: 0.35rem; }
  .service-area-box p { font-size: 0.92rem; color: var(--text-mid); line-height: 1.6; }

  /* FREE ESTIMATES CALLOUT */
  .estimates-callout {
    display: flex; align-items: flex-start; gap: 1rem;
    background: rgba(255,143,0,0.06); border: 1px solid rgba(255,143,0,0.15);
    border-radius: 10px; padding: 1.5rem; margin-top: 1.5rem;
    color: var(--accent);
  }
  .estimates-callout svg { flex-shrink: 0; margin-top: 0.1rem; }
  .estimates-callout strong { display: block; font-size: 1rem; color: var(--text); margin-bottom: 0.25rem; }
  .estimates-callout p { font-size: 0.9rem; color: var(--text-mid); line-height: 1.6; }
  .estimates-callout a { color: var(--accent); font-weight: 600; text-decoration: none; }
  .estimates-callout a:hover { text-decoration: underline; }

  /* BUTTONS */
  .btn { display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.92rem; font-weight: 600; text-decoration: none; padding: 0.7rem 1.5rem; border-radius: 6px; transition: all 0.15s; border: 2px solid transparent; cursor: pointer; }
  .btn--primary { background: var(--accent); color: #fff; border-color: var(--accent); }
  .btn--primary:hover { opacity: 0.9; }
  .btn--outline { background: transparent; color: #fff; border-color: rgba(255,255,255,0.4); }
  .btn--outline:hover { border-color: #fff; }
  .btn--lg { padding: 0.85rem 2rem; font-size: 1rem; }

  .section--cta { background: linear-gradient(135deg, var(--accent) 0%, #e65100 100%); text-align: center; padding: 4rem 0; }
  .cta-content h2 { font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 800; color: #fff; margin-bottom: 0.75rem; }
  .cta-content p { font-size: 1.05rem; color: rgba(255,255,255,0.85); margin-bottom: 2rem; }
  .cta-actions { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
  .cta-actions .btn--primary { background: #fff; color: var(--accent); border-color: #fff; }

  /* FOOTER */
  .footer { background: #1a1f23; color: rgba(255,255,255,0.7); padding: 4rem 0 0; }
  .footer__inner { display: grid; grid-template-columns: 1.5fr 1fr 1fr 1fr; gap: 2.5rem; }
  .footer__col h4 { color: #fff; font-size: 0.95rem; font-weight: 700; margin-bottom: 1rem; }
  .footer__col p { font-size: 0.88rem; line-height: 1.65; }
  .footer__col ul { list-style: none; }
  .footer__col li { margin-bottom: 0.4rem; font-size: 0.88rem; }
  .footer__col a { color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.88rem; }
  .footer__col a:hover { color: var(--accent); }
  .footer__social { display: flex; gap: 0.75rem; margin-top: 1rem; }
  .footer__social a { color: rgba(255,255,255,0.5); }
  .footer__social a:hover { color: var(--accent); }
  .footer__area-towns { margin-top: 0.75rem; font-size: 0.82rem; color: rgba(255,255,255,0.45); }
  .footer__bottom { margin-top: 3rem; padding: 1.25rem 0; border-top: 1px solid rgba(255,255,255,0.08); text-align: center; }
  .footer__bottom p { font-size: 0.8rem; color: rgba(255,255,255,0.35); }
  @media (max-width: 768px) { .footer__inner { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 480px) { .footer__inner { grid-template-columns: 1fr; } }
</style>
</body>
</html>
