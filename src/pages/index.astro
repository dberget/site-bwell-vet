  .nav__mobile-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    color: #0f172a;
    padding: 0.25rem;
  }

  .nav__mobile-menu {
    display: none;
    flex-direction: column;
    padding: 1rem 1.5rem 1.5rem;
    border-top: 1px solid #e2e8f0;
    background: #fff;
  }
  .nav__mobile-menu a {
    padding: 0.75rem 0;
    font-size: 1rem;
    font-weight: 500;
    color: #475569;
    border-bottom: 1px solid #f1f5f9;
