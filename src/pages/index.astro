    border: 2px solid transparent;
    cursor: pointer;
    transition: all 0.2s ease;
    text-decoration: none;
    white-space: nowrap;
  }

  .btn--primary {
    background: #c2590a;
    color: #fff;
    border-color: #c2590a;
  }
  .btn--primary:hover {
    background: #a34908;
    border-color: #a34908;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(194, 89, 10, 0.3);
  }

  .btn--outline {
    background: transparent;
    color: #0f172a;
    border-color: #cbd5e1;
  }
  .btn--outline:hover {
    border-color: #94a3b8;
    background: #faf9f7;
  }

  .btn--lg { padding: 0.85rem 1.75rem; font-size: 1rem; }
  .btn--full { width: 100%; justify-content: center; }

  /* ===========================
     SECTION HEADERS
     =========================== */
  .section-label {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #1a6847;
