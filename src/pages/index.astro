    border-bottom: 1px solid #e2e8f0;
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4rem;
  }

  .nav__logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-weight: 700;
    font-size: 1.1rem;
    color: #0f172a;
  }
  .nav__logo svg { flex-shrink: 0; }

  .nav__links {
    display: flex;
    gap: 2rem;
  }
  .nav__links a {
    font-size: 0.9rem;
    font-weight: 500;
    color: #475569;
    transition: color 0.15s;
  }
  .nav__links a:hover { color: #0f172a; }

  .nav__cta {
