    padding: 0.75rem;
    border-radius: 8px;
    border-bottom: none !important;
  }

  .nav.nav--open .nav__mobile-menu { display: flex; }

  @media (max-width: 768px) {
    .nav__links, .nav__cta:not(.nav__cta--mobile) { display: none; }
    .nav__mobile-toggle { display: block; }
  }

