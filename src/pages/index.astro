  <script>
    const nav = document.querySelector('.nav');
    window.addEventListener('scroll', () => {
      nav?.classList.toggle('nav--scrolled', window.scrollY > 20);
    });
    document.querySelector('.nav__hamburger')?.addEventListener('click', () => {
      document.querySelector('.nav__links')?.classList.toggle('nav__links--open');
    });
    // Scroll reveal
    const reveals = document.querySelectorAll('.service-card, .gallery-item, .testimonial-card');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((e, i) => {
        if (e.isIntersecting) {
          e.target.style.transitionDelay = `${(Array.from(e.target.parentElement?.children || []).indexOf(e.target)) * 80}ms`;
          e.target.classList.add('revealed');
          observer.unobserve(e.target);
        }
      });
    }, { threshold: 0.15 });
    reveals.forEach(el => observer.observe(el));
  </script>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  :root {
    --primary: #1a6b5c;
    --primary-light: #e8f3f0;
    --primary-dark: #0f4a3f;
    --accent: #d4883a;
    --accent-light: #fdf4eb;
    --cream: #faf8f4;
    --text: #2d3436;
    --text-mid: #636e72;
    --text-light: #b2bec3;
    --bg: #fff;
    --border: #e8e6e1;
    --shadow-sm: 0 1px 3px rgba(0,0,0,0.06);
    --shadow-md: 0 4px 16px rgba(0,0,0,0.08);
    --shadow-lg: 0 12px 40px rgba(0,0,0,0.1);
    --radius: 10px;
    --font-heading: 'DM Serif Display', Georgia, serif;
    --font-body: 'Nunito Sans', -apple-system, sans-serif;
  }

  body {
    font-family: var(--font-body);
    color: var(--text);
    line-height: 1.65;
    -webkit-font-smoothing: antialiased;
    background: var(--bg);
  }

  .container { max-width: 1140px; margin: 0 auto; padding: 0 1.5rem; }

  /* REVEAL ANIMATIONS */
  .service-card, .gallery-item, .testimonial-card {
    opacity: 0; transform: translateY(24px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  .service-card.revealed, .gallery-item.revealed, .testimonial-card.revealed {
    opacity: 1; transform: translateY(0);
  }

  /* ——— NAV ——— */
  .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: var(--primary);
    transition: background 0.3s, box-shadow 0.3s, backdrop-filter 0.3s;
  }
  .nav--scrolled {
    background: rgba(26,107,92,0.95);
    backdrop-filter: blur(12px);
    box-shadow: 0 2px 24px rgba(0,0,0,0.12);
  }
  .nav__inner {
    max-width: 1140px; margin: 0 auto; padding: 0 1.5rem;
    display: flex; align-items: center; justify-content: space-between;
    height: 68px;
  }
  .nav__brand {
    display: flex; align-items: center; gap: 0.5rem;
    text-decoration: none;
  }
  .nav__paw { color: var(--accent); }
  .nav__name {
    color: #fff; font-family: var(--font-heading);
    font-size: 1.25rem; letter-spacing: -0.01em;
  }
  .nav__links { display: flex; gap: 0.15rem; }
  .nav__link {
    color: rgba(255,255,255,0.72); text-decoration: none;
    font-size: 0.85rem; font-weight: 600; letter-spacing: 0.01em;
    padding: 0.4rem 0.85rem; border-radius: 6px;
    transition: color 0.2s, background 0.2s;
  }
  .nav__link:hover, .nav__link--active {
    color: #fff; background: rgba(255,255,255,0.12);
  }
  .nav__cta {
    display: flex; align-items: center; gap: 0.4rem;
    background: var(--accent); color: #fff; text-decoration: none;
    font-size: 0.82rem; font-weight: 700; padding: 0.5rem 1.1rem;
    border-radius: 8px; transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 2px 8px rgba(212,136,58,0.3);
  }
  .nav__cta:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 14px rgba(212,136,58,0.4);
  }
  .nav__hamburger {
    display: none; background: none; border: none; cursor: pointer;
    flex-direction: column; gap: 5px; padding: 4px;
  }
  .nav__hamburger span {
    display: block; width: 22px; height: 2px; background: #fff;
    border-radius: 2px; transition: 0.25s;
  }

  @media (max-width: 768px) {
    .nav__links {
      display: none; position: absolute; top: 68px; left: 0; right: 0;
      background: var(--primary); flex-direction: column; padding: 0.75rem 1rem 1rem;
      box-shadow: 0 12px 32px rgba(0,0,0,0.2);
    }
    .nav__links--open { display: flex; }
    .nav__link { padding: 0.8rem 1rem; font-size: 0.95rem; }
    .nav__cta { display: none; }
    .nav__hamburger { display: flex; }
  }

  /* ——— HERO ——— */
  .hero {
    position: relative; min-height: 90vh; display: flex; align-items: center;
    padding: 8rem 1.5rem 5rem;
  }
  .hero__bg { position: absolute; inset: 0; }
  .hero__bg-img { width: 100%; height: 100%; object-fit: cover; object-position: center top; }
  .hero__overlay {
    position: absolute; inset: 0;
    background:
      linear-gradient(175deg, rgba(15,74,63,0.82) 0%, rgba(15,74,63,0.55) 50%, rgba(15,74,63,0.75) 100%);
  }
  .hero__content {
    position: relative; max-width: 680px; margin: 0 auto 0 0;
    padding-left: calc((100vw - 1140px) / 2);
  }
  @media (max-width: 1172px) { .hero__content { padding-left: 1.5rem; } }

  .hero__badge {
    display: inline-block;
    background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.2);
    color: rgba(255,255,255,0.9);
    font-size: 0.72rem; font-weight: 700; letter-spacing: 0.1em;
    text-transform: uppercase; padding: 0.4rem 1rem; border-radius: 50px;
    margin-bottom: 1.5rem;
    backdrop-filter: blur(4px);
  }
  .hero__title {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 5.5vw, 4rem); font-weight: 400;
    line-height: 1.1; color: #fff; margin-bottom: 1.25rem;
    letter-spacing: -0.01em;
  }
  .hero__desc {
    font-size: 1.08rem; line-height: 1.75; color: rgba(255,255,255,0.82);
    margin-bottom: 2rem; max-width: 520px;
  }
  .hero__actions {
    display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 2.5rem;
  }
  .hero__trust {
    display: flex; gap: 1.5rem; flex-wrap: wrap;
    padding-top: 1.75rem;
    border-top: 1px solid rgba(255,255,255,0.12);
  }
  .hero__trust-item {
    display: flex; align-items: center; gap: 0.4rem;
    font-size: 0.82rem; font-weight: 600; color: rgba(255,255,255,0.75);
  }
  .hero__trust-item svg { color: var(--accent); }

  @media (max-width: 768px) {
    .hero { min-height: auto; padding: 6.5rem 1.25rem 3rem; }
    .hero__bg-img { object-position: 75% 20%; }
    .hero__overlay {
      background:
        linear-gradient(180deg, rgba(15,74,63,0.88) 0%, rgba(15,74,63,0.72) 40%, rgba(15,74,63,0.92) 100%);
    }
    .hero__content { padding-left: 0.75rem; }
    .hero__title { font-size: 2.2rem; margin-bottom: 0.75rem; }
    .hero__desc { font-size: 1rem; margin-bottom: 1.5rem; }
    .hero__actions { margin-bottom: 1.75rem; }
  }
  @media (max-width: 480px) {
    .hero { min-height: auto; padding: 6rem 1rem 2.5rem; }
    .hero__bg-img { object-position: 80% 15%; }
    .hero__overlay {
      background:
        linear-gradient(180deg, rgba(15,74,63,0.9) 0%, rgba(15,74,63,0.78) 40%, rgba(15,74,63,0.94) 100%);
    }
    .hero__content { padding-left: 0.5rem; padding-right: 0.5rem; }
    .hero__badge { font-size: 0.65rem; padding: 0.35rem 0.8rem; margin-bottom: 1rem; }
    .hero__title { font-size: 2rem; margin-bottom: 0.75rem; }
    .hero__desc { font-size: 0.95rem; margin-bottom: 1.5rem; }
    .hero__actions { flex-direction: column; margin-bottom: 1.5rem; }
    .hero__trust { gap: 0.6rem; padding-top: 1.25rem; }
  }

  /* ——— BUTTONS ——— */
  .btn {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-family: var(--font-body);
    font-size: 0.9rem; font-weight: 700; text-decoration: none;
    padding: 0.72rem 1.5rem; border-radius: 8px;
    transition: all 0.2s ease;
    border: 2px solid transparent; cursor: pointer;
  }
  .btn--accent {
    background: var(--accent); color: #fff; border-color: var(--accent);
    box-shadow: 0 2px 10px rgba(212,136,58,0.25);
  }
  .btn--accent:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(212,136,58,0.35);
  }
  .btn--outline {
    background: transparent; color: #fff;
    border-color: rgba(255,255,255,0.35);
  }
  .btn--outline:hover {
    border-color: #fff; background: rgba(255,255,255,0.08);
  }
  .btn--secondary {
    background: var(--primary); color: #fff;
    box-shadow: 0 2px 8px rgba(26,107,92,0.2);
  }
  .btn--secondary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(26,107,92,0.3);
  }
  .btn--lg { padding: 0.9rem 2.2rem; font-size: 0.95rem; }

  /* ——— SECTIONS ——— */
  .section { padding: 5.5rem 0; }
  .section--cream { background: var(--cream); }

  .section-header { margin-bottom: 2.5rem; }
  .section-header--center { text-align: center; }

  .eyebrow {
    display: block; font-size: 0.72rem; font-weight: 800;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--accent); margin-bottom: 0.5rem;
  }
  .section__title {
    font-family: var(--font-heading);
    font-size: clamp(1.6rem, 3.2vw, 2.4rem); font-weight: 400;
    line-height: 1.2; color: var(--text);
    letter-spacing: -0.01em;
  }

  /* ——— SERVICES GRID ——— */
  .services-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem; margin-bottom: 2.5rem;
  }
  .service-card {
    background: #fff; border: 1px solid var(--border);
    border-radius: var(--radius); padding: 1.75rem 1.5rem;
    transition: box-shadow 0.3s, transform 0.3s;
    position: relative;
    border-left: 4px solid transparent;
  }
  .service-card:hover {
    box-shadow: var(--shadow-lg); transform: translateY(-4px);
    border-left-color: var(--accent);
  }
  .service-card__icon {
    width: 48px; height: 48px; border-radius: 12px;
    background: var(--primary-light); color: var(--primary);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 1rem;
  }
  .service-card h3 {
    font-family: var(--font-heading);
    font-size: 1.1rem; font-weight: 400; margin-bottom: 0.5rem;
    color: var(--text);
  }
  .service-card p {
    font-size: 0.88rem; color: var(--text-mid); line-height: 1.65;
  }
  .services-more { text-align: center; }

  @media (max-width: 768px) { .services-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .services-grid { grid-template-columns: 1fr; } }

  /* ——— GALLERY ——— */
  .gallery-grid {
    display: grid; grid-template-columns: 1.4fr 1fr 1fr;
    gap: 1.25rem;
  }
  .gallery-item {
    overflow: hidden; border-radius: 12px;
    aspect-ratio: 4/3;
    box-shadow: var(--shadow-md);
  }
  .gallery-item--wide { aspect-ratio: 3/2; }
  .gallery-item img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.45s ease;
  }
  .gallery-item:hover img { transform: scale(1.06); }

  @media (max-width: 768px) {
    .gallery-grid { grid-template-columns: 1fr 1fr; }
    .gallery-item--wide { grid-column: 1 / -1; }
  }
  @media (max-width: 480px) { .gallery-grid { grid-template-columns: 1fr; } }

  /* ——— TESTIMONIALS ——— */
  .testimonials-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;
  }
  .testimonial-card {
    background: var(--cream);
    border: 1px solid var(--border);
    border-radius: var(--radius); padding: 2rem 1.75rem 1.5rem;
    position: relative;
  }
  .testimonial-card--featured {
    grid-column: 1 / -1;
    background: var(--primary-light);
    border-color: rgba(26,107,92,0.15);
  }
  .testimonial-card__quote {
    font-family: var(--font-heading);
    font-size: 3.5rem; line-height: 1; color: var(--accent);
    opacity: 0.4; position: absolute; top: 0.75rem; left: 1.5rem;
  }
  .testimonial-card blockquote {
    font-size: 1rem; color: var(--text); line-height: 1.7;
    margin-bottom: 1rem; font-style: italic;
    position: relative;
  }
  .testimonial-card--featured blockquote { font-size: 1.12rem; }
  .testimonial-card__stars {
    color: var(--accent); font-size: 0.85rem; letter-spacing: 2px;
    margin-bottom: 0.25rem;
  }
  .testimonial-card__source {
    font-size: 0.75rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.08em; color: var(--text-light);
  }

  @media (max-width: 640px) { .testimonials-grid { grid-template-columns: 1fr; } }

  /* ——— CTA ——— */
  .section--cta {
    background: var(--primary);
    text-align: center; padding: 5rem 0;
    position: relative; overflow: hidden;
  }
  .section--cta::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(ellipse at 30% 50%, rgba(255,255,255,0.06) 0%, transparent 70%);
    pointer-events: none;
  }
  .cta-content { position: relative; }
  .cta-content h2 {
    font-family: var(--font-heading);
    font-size: clamp(1.6rem, 3.2vw, 2.4rem); font-weight: 400;
    color: #fff; margin-bottom: 0.75rem;
  }
  .cta-content p {
    font-size: 1.05rem; color: rgba(255,255,255,0.78); margin-bottom: 2rem;
  }
  .cta-actions { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
  .cta-actions .btn--accent {
    background: var(--accent); color: #fff; border-color: var(--accent);
  }
  .cta-actions .btn--outline {
    color: #fff; border-color: rgba(255,255,255,0.3);
  }

  /* ——— FOOTER ——— */
  .footer {
    background: #0e2e25; color: rgba(255,255,255,0.65);
    padding: 0;
  }
  .footer__accent {
    height: 4px;
    background: linear-gradient(90deg, var(--accent) 0%, var(--primary) 100%);
  }
  .footer__inner {
    display: grid; grid-template-columns: 1.6fr 1fr 1fr 1fr;
    gap: 2.5rem; padding: 3.5rem 1.5rem 0;
    max-width: 1140px; margin: 0 auto;
  }
  .footer__col h4 {
    font-family: var(--font-heading);
    color: #fff; font-size: 1.05rem; font-weight: 400;
    margin-bottom: 1rem;
  }
  .footer__col p { font-size: 0.88rem; line-height: 1.7; margin-bottom: 0.6rem; }
  .footer__col ul { list-style: none; }
  .footer__col li { margin-bottom: 0.5rem; }
  .footer__col a {
    color: rgba(255,255,255,0.65); text-decoration: none;
    font-size: 0.88rem; transition: color 0.2s;
  }
  .footer__col a:hover { color: var(--accent); }
  .footer__note {
    margin-top: 0.5rem; padding-top: 0.5rem;
    border-top: 1px solid rgba(255,255,255,0.08);
    font-size: 0.82rem; color: rgba(255,255,255,0.45);
  }
  .footer__social { display: flex; gap: 0.75rem; margin-top: 1.25rem; }
  .footer__social a {
    width: 36px; height: 36px; border-radius: 8px;
    background: rgba(255,255,255,0.06);
    display: flex; align-items: center; justify-content: center;
    color: rgba(255,255,255,0.5); transition: all 0.2s;
  }
  .footer__social a:hover {
    background: var(--accent); color: #fff;
  }
  .footer__bottom {
    max-width: 1140px; margin: 2.5rem auto 0; padding: 1.25rem 1.5rem;
    border-top: 1px solid rgba(255,255,255,0.06); text-align: center;
  }
  .footer__bottom p { font-size: 0.78rem; color: rgba(255,255,255,0.3); }

  @media (max-width: 768px) {
    .footer__inner { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 480px) {
    .footer__inner { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>
</body>
</html>
