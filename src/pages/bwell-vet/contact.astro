---
import Analytics from '../../components/Analytics.astro';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Contact — B Well Veterinary Service | Alexandria, MN</title>
  <meta name="description" content="Contact B Well Veterinary Service at 3901 Highway 29 S, Alexandria, MN. Call (320) 762-1575. Walk-ins welcome." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Nunito+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <Analytics />
</head>
<body>

  <!-- NAV -->
  <header class="nav">
    <div class="nav__inner">
      <a href="/bwell-vet" class="nav__brand">
        <svg class="nav__paw" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><ellipse cx="7.5" cy="7" rx="2.5" ry="3"/><ellipse cx="16.5" cy="7" rx="2.5" ry="3"/><ellipse cx="4" cy="13" rx="2" ry="2.5"/><ellipse cx="20" cy="13" rx="2" ry="2.5"/><path d="M12 22c-3 0-5.5-2.5-6.5-5.5-.6-1.8.2-3.5 1.5-4.5 1.5-1.2 3.2-2 5-2s3.5.8 5 2c1.3 1 2.1 2.7 1.5 4.5C17.5 19.5 15 22 12 22z"/></svg>
        <span class="nav__name">B Well Vet</span>
      </a>
      <nav class="nav__links">
        <a href="/bwell-vet" class="nav__link">Home</a>
        <a href="/bwell-vet/services" class="nav__link">Services</a>
        <a href="/bwell-vet/about" class="nav__link">About</a>
        <a href="/bwell-vet/contact" class="nav__link nav__link--active">Contact</a>
      </nav>
      <a href="tel:3207621575" class="nav__cta">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 013.12 4.18 2 2 0 015.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        (320) 762-1575
      </a>
      <button class="nav__hamburger" aria-label="Menu"><span></span><span></span><span></span></button>
    </div>
  </header>

  <!-- PAGE HEADER -->
  <section class="page-header">
    <div class="page-header__bg"></div>
    <div class="container page-header__content">
      <div class="page-header__breadcrumb"><a href="/bwell-vet">Home</a> <span>/</span> <span>Contact</span></div>
      <h1>Contact Us</h1>
      <p>We'd love to hear from you. Reach out today.</p>
    </div>
  </section>

  <!-- CONTACT SECTION -->
  <section class="section">
    <div class="container">
      <div class="contact-grid">

        <!-- LEFT: Info -->
        <div class="contact-info">
          <div class="contact-info__phone">
            <span class="contact-info__phone-label">Call Us</span>
            <a href="tel:3207621575">(320) 762-1575</a>
          </div>

          <div class="contact-info__block">
            <div class="contact-info__icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <strong>Address</strong>
              <p>3901 Highway 29 S<br/>Alexandria, MN 56308</p>
              <a href="https://maps.google.com/?q=3901+Highway+29+S+Alexandria+MN+56308" target="_blank" rel="noopener" class="contact-info__link">Get Directions &rarr;</a>
            </div>
          </div>

          <div class="contact-info__block">
            <div class="contact-info__icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><rect x="2" y="3" width="20" height="14" rx="2"/><polyline points="22 3 12 13 2 3"/></svg>
            </div>
            <div>
              <strong>Email</strong>
              <p><a href="mailto:bwellveterinaryservice@gmail.com">bwellveterinaryservice@gmail.com</a></p>
            </div>
          </div>

          <div class="contact-info__block">
            <div class="contact-info__icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
            </div>
            <div>
              <strong>Facebook</strong>
              <p><a href="https://facebook.com/p/B-Well-Veterinary-Service-100057131122291" target="_blank" rel="noopener">Follow us on Facebook</a></p>
            </div>
          </div>

          <div class="contact-info__note">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
            <p>Walk-ins are welcome! For the shortest wait, call ahead to schedule an appointment.</p>
          </div>
        </div>

        <!-- RIGHT: Form -->
        <div class="contact-form-wrap">
          <h2>Send Us a Message</h2>
          <p class="contact-form-desc">Have questions about your pet's health? We're here to help.</p>
          <form class="contact-form" action="/api/contact" method="POST">
            <input type="hidden" name="site" value="bwell-vet" />
            <input type="text" name="_hp" style="display:none" tabindex="-1" autocomplete="off" />
            <div class="form-group">
              <label for="name">Name</label>
              <input type="text" id="name" name="name" required placeholder="Your name" />
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" required placeholder="you@example.com" />
              </div>
              <div class="form-group">
                <label for="phone">Phone</label>
                <input type="tel" id="phone" name="phone" placeholder="(320) 555-0000" />
              </div>
            </div>
            <div class="form-group">
              <label for="pet-name">Pet's Name</label>
              <input type="text" id="pet-name" name="pet_name" placeholder="Your pet's name" />
            </div>
            <div class="form-group">
              <label for="message">Message</label>
              <textarea id="message" name="message" rows="5" required placeholder="Tell us how we can help with your pet's care..."></textarea>
            </div>
            <button type="submit" class="btn btn--accent btn--lg btn--full">Send Message</button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer__accent"></div>
    <div class="container footer__inner">
      <div class="footer__col">
        <h4>B Well Veterinary Service</h4>
        <p>Compassionate, affordable veterinary care in Alexandria, MN.</p>
        <div class="footer__social">
          <a href="https://facebook.com/p/B-Well-Veterinary-Service-100057131122291" target="_blank" rel="noopener" aria-label="Facebook">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
          </a>
        </div>
      </div>
      <div class="footer__col">
        <h4>Quick Links</h4>
        <ul>
          <li><a href="/bwell-vet">Home</a></li>
          <li><a href="/bwell-vet/services">Services</a></li>
          <li><a href="/bwell-vet/about">About Us</a></li>
          <li><a href="/bwell-vet/contact">Contact</a></li>
        </ul>
      </div>
      <div class="footer__col">
        <h4>Contact</h4>
        <p><a href="mailto:bwellveterinaryservice@gmail.com">bwellveterinaryservice@gmail.com</a></p>
        <p>3901 Highway 29 S<br/>Alexandria, MN 56308</p>
        <p><a href="tel:3207621575">(320) 762-1575</a></p>
      </div>
      <div class="footer__col">
        <h4>Hours</h4>
        <p>Monday &ndash; Friday<br/>8:00 AM &ndash; 5:00 PM</p>
        <p class="footer__note">Walk-ins welcome.<br/>Call ahead for best availability.</p>
      </div>
    </div>
    <div class="footer__bottom">
      <p>&copy; 2026 B Well Veterinary Service. All rights reserved.</p>
    </div>
  </footer>

  <script>
    const nav = document.querySelector('.nav');
    window.addEventListener('scroll', () => nav?.classList.toggle('nav--scrolled', window.scrollY > 20));
    document.querySelector('.nav__hamburger')?.addEventListener('click', () => document.querySelector('.nav__links')?.classList.toggle('nav__links--open'));
  </script>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  :root {
    --primary: #1a6b5c; --primary-light: #e8f3f0; --primary-dark: #0f4a3f;
    --accent: #d4883a; --accent-light: #fdf4eb;
    --cream: #faf8f4; --text: #2d3436; --text-mid: #636e72; --text-light: #b2bec3;
    --border: #e8e6e1;
    --radius: 10px;
    --font-heading: 'DM Serif Display', Georgia, serif;
    --font-body: 'Nunito Sans', -apple-system, sans-serif;
  }
  body { font-family: var(--font-body); color: var(--text); line-height: 1.65; -webkit-font-smoothing: antialiased; }
  .container { max-width: 1140px; margin: 0 auto; padding: 0 1.5rem; }

  /* NAV */
  .nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: var(--primary); transition: background 0.3s, box-shadow 0.3s; }
  .nav--scrolled { background: rgba(26,107,92,0.95); backdrop-filter: blur(12px); box-shadow: 0 2px 24px rgba(0,0,0,0.12); }
  .nav__inner { max-width: 1140px; margin: 0 auto; padding: 0 1.5rem; display: flex; align-items: center; justify-content: space-between; height: 68px; }
  .nav__brand { display: flex; align-items: center; gap: 0.5rem; text-decoration: none; }
  .nav__paw { color: var(--accent); }
  .nav__name { color: #fff; font-family: var(--font-heading); font-size: 1.25rem; }
  .nav__links { display: flex; gap: 0.15rem; }
  .nav__link { color: rgba(255,255,255,0.72); text-decoration: none; font-size: 0.85rem; font-weight: 600; padding: 0.4rem 0.85rem; border-radius: 6px; transition: color 0.2s, background 0.2s; }
  .nav__link:hover, .nav__link--active { color: #fff; background: rgba(255,255,255,0.12); }
  .nav__cta { display: flex; align-items: center; gap: 0.4rem; background: var(--accent); color: #fff; text-decoration: none; font-size: 0.82rem; font-weight: 700; padding: 0.5rem 1.1rem; border-radius: 8px; transition: transform 0.2s, box-shadow 0.2s; box-shadow: 0 2px 8px rgba(212,136,58,0.3); }
  .nav__cta:hover { transform: translateY(-1px); box-shadow: 0 4px 14px rgba(212,136,58,0.4); }
  .nav__hamburger { display: none; background: none; border: none; cursor: pointer; flex-direction: column; gap: 5px; padding: 4px; }
  .nav__hamburger span { display: block; width: 22px; height: 2px; background: #fff; border-radius: 2px; }
  @media (max-width: 768px) {
    .nav__links { display: none; position: absolute; top: 68px; left: 0; right: 0; background: var(--primary); flex-direction: column; padding: 0.75rem 1rem 1rem; box-shadow: 0 12px 32px rgba(0,0,0,0.2); }
    .nav__links--open { display: flex; }
    .nav__link { padding: 0.8rem 1rem; font-size: 0.95rem; }
    .nav__cta { display: none; }
    .nav__hamburger { display: flex; }
  }

  /* PAGE HEADER */
  .page-header { position: relative; padding: 8rem 0 3rem; background: var(--primary); overflow: hidden; }
  .page-header__bg { position: absolute; inset: 0; background: radial-gradient(ellipse at 70% 40%, rgba(255,255,255,0.06) 0%, transparent 60%); }
  .page-header__content { position: relative; }
  .page-header__breadcrumb { font-size: 0.82rem; color: rgba(255,255,255,0.4); margin-bottom: 0.75rem; }
  .page-header__breadcrumb a { color: rgba(255,255,255,0.55); text-decoration: none; transition: color 0.2s; }
  .page-header__breadcrumb a:hover { color: var(--accent); }
  .page-header__breadcrumb span { margin: 0 0.35rem; }
  .page-header h1 { font-family: var(--font-heading); color: #fff; font-size: clamp(2rem, 4.5vw, 3rem); font-weight: 400; margin-bottom: 0.5rem; }
  .page-header p { color: rgba(255,255,255,0.65); font-size: 1.05rem; }

  .section { padding: 5.5rem 0; }

  /* CONTACT GRID */
  .contact-grid { display: grid; grid-template-columns: 1fr 1.3fr; gap: 4rem; }
  @media (max-width: 768px) { .contact-grid { grid-template-columns: 1fr; gap: 3rem; } }

  .contact-info__phone { margin-bottom: 2rem; }
  .contact-info__phone-label {
    display: block; font-size: 0.72rem; font-weight: 800;
    text-transform: uppercase; letter-spacing: 0.12em;
    color: var(--accent); margin-bottom: 0.25rem;
  }
  .contact-info__phone a {
    font-family: var(--font-heading); font-size: 2.25rem;
    color: var(--text); text-decoration: none; letter-spacing: -0.02em;
    transition: color 0.2s;
  }
  .contact-info__phone a:hover { color: var(--primary); }

  .contact-info__block {
    display: flex; gap: 1rem; padding: 1.25rem 0;
    border-bottom: 1px solid var(--border);
  }
  .contact-info__block:last-of-type { border-bottom: none; }
  .contact-info__icon {
    flex-shrink: 0; width: 44px; height: 44px; border-radius: 12px;
    background: var(--primary-light); color: var(--primary);
    display: flex; align-items: center; justify-content: center;
  }
  .contact-info__block strong { display: block; font-size: 0.92rem; margin-bottom: 0.25rem; }
  .contact-info__block p { font-size: 0.9rem; color: var(--text-mid); line-height: 1.6; }
  .contact-info__block a { color: var(--text-mid); text-decoration: none; transition: color 0.2s; }
  .contact-info__block a:hover { color: var(--primary); }
  .contact-info__link {
    display: inline-block; margin-top: 0.4rem;
    color: var(--primary) !important; font-size: 0.85rem; font-weight: 700;
  }

  .contact-info__note {
    display: flex; gap: 0.75rem; align-items: flex-start;
    margin-top: 1.75rem; padding: 1.25rem;
    background: var(--primary-light); border: 1px solid rgba(26,107,92,0.12);
    border-radius: var(--radius);
  }
  .contact-info__note svg { flex-shrink: 0; color: var(--primary); margin-top: 0.15rem; }
  .contact-info__note p { font-size: 0.9rem; color: var(--text-mid); line-height: 1.6; }

  /* FORM */
  .contact-form-wrap {
    background: var(--cream); border-radius: 16px; padding: 2.5rem;
    border: 1px solid var(--border);
  }
  .contact-form-wrap h2 {
    font-family: var(--font-heading); font-size: 1.45rem; font-weight: 400;
    margin-bottom: 0.5rem;
  }
  .contact-form-desc { font-size: 0.92rem; color: var(--text-mid); margin-bottom: 1.75rem; }

  .form-group { margin-bottom: 1.25rem; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  @media (max-width: 480px) { .form-row { grid-template-columns: 1fr; } }

  .form-group label {
    display: block; font-size: 0.82rem; font-weight: 700;
    margin-bottom: 0.4rem; color: var(--text);
  }
  .form-group input, .form-group textarea {
    width: 100%; padding: 0.75rem 1rem; font-size: 0.92rem;
    border: 1.5px solid var(--border); border-radius: 10px;
    font-family: var(--font-body); transition: border-color 0.2s, box-shadow 0.2s;
    background: #fff;
  }
  .form-group input:focus, .form-group textarea:focus {
    outline: none; border-color: var(--primary);
    box-shadow: 0 0 0 3px rgba(26,107,92,0.1);
  }
  .form-group textarea { resize: vertical; min-height: 120px; }

  .btn { display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem; font-family: var(--font-body); font-size: 0.9rem; font-weight: 700; text-decoration: none; padding: 0.72rem 1.5rem; border-radius: 8px; border: 2px solid transparent; cursor: pointer; transition: all 0.2s; }
  .btn--accent { background: var(--accent); color: #fff; border-color: var(--accent); box-shadow: 0 2px 10px rgba(212,136,58,0.25); }
  .btn--accent:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(212,136,58,0.35); }
  .btn--lg { padding: 0.9rem 2.2rem; font-size: 0.95rem; }
  .btn--full { width: 100%; }

  /* FOOTER */
  .footer { background: #0e2e25; color: rgba(255,255,255,0.65); padding: 0; }
  .footer__accent { height: 4px; background: linear-gradient(90deg, var(--accent) 0%, var(--primary) 100%); }
  .footer__inner { display: grid; grid-template-columns: 1.6fr 1fr 1fr 1fr; gap: 2.5rem; padding: 3.5rem 1.5rem 0; max-width: 1140px; margin: 0 auto; }
  .footer__col h4 { font-family: var(--font-heading); color: #fff; font-size: 1.05rem; font-weight: 400; margin-bottom: 1rem; }
  .footer__col p { font-size: 0.88rem; line-height: 1.7; margin-bottom: 0.6rem; }
  .footer__col ul { list-style: none; }
  .footer__col li { margin-bottom: 0.5rem; }
  .footer__col a { color: rgba(255,255,255,0.65); text-decoration: none; font-size: 0.88rem; transition: color 0.2s; }
  .footer__col a:hover { color: var(--accent); }
  .footer__note { margin-top: 0.5rem; padding-top: 0.5rem; border-top: 1px solid rgba(255,255,255,0.08); font-size: 0.82rem; color: rgba(255,255,255,0.45); }
  .footer__social { display: flex; gap: 0.75rem; margin-top: 1.25rem; }
  .footer__social a { width: 36px; height: 36px; border-radius: 8px; background: rgba(255,255,255,0.06); display: flex; align-items: center; justify-content: center; color: rgba(255,255,255,0.5); transition: all 0.2s; }
  .footer__social a:hover { background: var(--accent); color: #fff; }
  .footer__bottom { max-width: 1140px; margin: 2.5rem auto 0; padding: 1.25rem 1.5rem; border-top: 1px solid rgba(255,255,255,0.06); text-align: center; }
  .footer__bottom p { font-size: 0.78rem; color: rgba(255,255,255,0.3); }
  @media (max-width: 768px) { .footer__inner { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 480px) { .footer__inner { grid-template-columns: 1fr; gap: 2rem; } }
</style>
</body>
</html>
