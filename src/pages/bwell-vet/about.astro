---
import Analytics from '../../components/Analytics.astro';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>About Us — B Well Veterinary Service | Alexandria, MN</title>
  <meta name="description" content="Learn about B Well Veterinary Service, formerly Douglas County Animal Hospital. Compassionate, affordable veterinary care in Alexandria, MN." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Nunito+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <Analytics />
</head>
<body>

  <!-- NAV -->
  <header class="nav">
    <div class="nav__inner">
      <a href="/bwell-vet" class="nav__brand">
        <svg class="nav__paw" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><ellipse cx="7.5" cy="7" rx="2.5" ry="3"/><ellipse cx="16.5" cy="7" rx="2.5" ry="3"/><ellipse cx="4" cy="13" rx="2" ry="2.5"/><ellipse cx="20" cy="13" rx="2" ry="2.5"/><path d="M12 22c-3 0-5.5-2.5-6.5-5.5-.6-1.8.2-3.5 1.5-4.5 1.5-1.2 3.2-2 5-2s3.5.8 5 2c1.3 1 2.1 2.7 1.5 4.5C17.5 19.5 15 22 12 22z"/></svg>
        <span class="nav__name">B Well Vet</span>
      </a>
      <nav class="nav__links">
        <a href="/bwell-vet" class="nav__link">Home</a>
        <a href="/bwell-vet/services" class="nav__link">Services</a>
        <a href="/bwell-vet/about" class="nav__link nav__link--active">About</a>
        <a href="/bwell-vet/contact" class="nav__link">Contact</a>
      </nav>
      <a href="tel:3207621575" class="nav__cta">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 013.12 4.18 2 2 0 015.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        (320) 762-1575
      </a>
      <button class="nav__hamburger" aria-label="Menu"><span></span><span></span><span></span></button>
    </div>
  </header>

  <!-- PAGE HEADER -->
  <section class="page-header">
    <div class="page-header__bg"></div>
    <div class="container page-header__content">
      <div class="page-header__breadcrumb"><a href="/bwell-vet">Home</a> <span>/</span> <span>About</span></div>
      <h1>About Us</h1>
      <p>The story behind compassionate, affordable veterinary care.</p>
    </div>
  </section>

  <!-- ABOUT SPLIT -->
  <section class="section">
    <div class="container">
      <div class="about-split">
        <div class="about-split__text">
          <span class="eyebrow">Our Story</span>
          <h2>Caring for Alexandria's Pets Since Day One</h2>
          <p>Formerly known as Douglas County Animal Hospital, B Well Veterinary Service continues a proud tradition of caring for pets in the Alexandria, MN area. Under new ownership and a new name, our mission remains the same: to provide compassionate, affordable veterinary care for every pet that walks through our doors.</p>
          <p>Our dedicated team prioritizes the health and well-being of your pets above all else. We believe every animal deserves quality medical care, regardless of the situation. From routine wellness exams to emergency treatment, we're here for your furry family members.</p>
          <p>We are committed to building lasting relationships with pet owners in our community. When you bring your pet to B Well Vet, you become part of our family. We take the time to listen, educate, and partner with you to ensure the best possible care for your companion.</p>
        </div>
        <div class="about-split__image">
          <img src="https://scontent-msp1-1.xx.fbcdn.net/v/t39.30808-6/481259355_1141826871065006_2609812597859198886_n.jpg?stp=cp6_dst-jpg_tt6&_nc_cat=102&ccb=1-7&_nc_sid=7b2446&_nc_ohc=bn8lTpes5NcQ7kNvwE8S6Gx&_nc_oc=AdnBwk6yMDwucKZLCJp1e4nm7-U7ZtaQtHw8RKRLfR64TCS13fpllyWINWtxZvurSZk&_nc_zt=23&_nc_ht=scontent-msp1-1.xx&_nc_gid=gpLlJnanmOxaz-aGelM9yw&oh=00_Afu4RD1cDmiMUfylnXWMB6UbNqvFBkZqvj7TspKejHWoxQ&oe=69A68DC7" alt="B Well Veterinary Service team" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- VALUES -->
  <section class="section section--cream">
    <div class="container">
      <div class="section-header section-header--center">
        <span class="eyebrow">Why Us</span>
        <h2 class="section__title">Why Choose B Well Vet</h2>
      </div>
      <div class="values-grid">
        <div class="value-card">
          <div class="value-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M19.5 12.572l-7.5 7.428-7.5-7.428A5 5 0 1112 6.006a5 5 0 017.5 6.572"/></svg>
          </div>
          <h3>Compassionate Care</h3>
          <p>We treat every pet with kindness and gentleness, ensuring a comfortable experience for both pets and owners.</p>
        </div>
        <div class="value-card">
          <div class="value-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
          </div>
          <h3>Affordable Pricing</h3>
          <p>Quality veterinary care at fair, transparent prices. We believe every pet deserves access to great care.</p>
        </div>
        <div class="value-card">
          <div class="value-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
          </div>
          <h3>Experienced Team</h3>
          <p>Skilled and dedicated veterinary professionals committed to providing the highest standard of care.</p>
        </div>
        <div class="value-card">
          <div class="value-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          </div>
          <h3>Modern Facilities</h3>
          <p>Up-to-date equipment and techniques to deliver accurate diagnostics and effective treatments.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--cta">
    <div class="container cta-content">
      <h2>Ready to Experience the Difference?</h2>
      <p>Bring your pet in for a visit. Walk-ins welcome or call ahead to schedule.</p>
      <div class="cta-actions">
        <a href="tel:3207621575" class="btn btn--accent btn--lg">Call (320) 762-1575</a>
        <a href="/bwell-vet/contact" class="btn btn--outline btn--lg">Contact Us</a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer__accent"></div>
    <div class="container footer__inner">
      <div class="footer__col">
        <h4>B Well Veterinary Service</h4>
        <p>Compassionate, affordable veterinary care in Alexandria, MN.</p>
        <div class="footer__social">
          <a href="https://facebook.com/p/B-Well-Veterinary-Service-100057131122291" target="_blank" rel="noopener" aria-label="Facebook">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
          </a>
        </div>
      </div>
      <div class="footer__col">
        <h4>Quick Links</h4>
        <ul>
          <li><a href="/bwell-vet">Home</a></li>
          <li><a href="/bwell-vet/services">Services</a></li>
          <li><a href="/bwell-vet/about">About Us</a></li>
          <li><a href="/bwell-vet/contact">Contact</a></li>
        </ul>
      </div>
      <div class="footer__col">
        <h4>Contact</h4>
        <p><a href="mailto:bwellveterinaryservice@gmail.com">bwellveterinaryservice@gmail.com</a></p>
        <p>3901 Highway 29 S<br/>Alexandria, MN 56308</p>
        <p><a href="tel:3207621575">(320) 762-1575</a></p>
      </div>
      <div class="footer__col">
        <h4>Hours</h4>
        <p>Monday &ndash; Friday<br/>8:00 AM &ndash; 5:00 PM</p>
        <p class="footer__note">Walk-ins welcome.<br/>Call ahead for best availability.</p>
      </div>
    </div>
    <div class="footer__bottom">
      <p>&copy; 2026 B Well Veterinary Service. All rights reserved.</p>
    </div>
  </footer>

  <script>
    const nav = document.querySelector('.nav');
    window.addEventListener('scroll', () => nav?.classList.toggle('nav--scrolled', window.scrollY > 20));
    document.querySelector('.nav__hamburger')?.addEventListener('click', () => document.querySelector('.nav__links')?.classList.toggle('nav__links--open'));
  </script>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  :root {
    --primary: #1a6b5c; --primary-light: #e8f3f0; --primary-dark: #0f4a3f;
    --accent: #d4883a; --accent-light: #fdf4eb;
    --cream: #faf8f4; --text: #2d3436; --text-mid: #636e72; --text-light: #b2bec3;
    --border: #e8e6e1;
    --shadow-sm: 0 1px 3px rgba(0,0,0,0.06); --shadow-md: 0 4px 16px rgba(0,0,0,0.08);
    --radius: 10px;
    --font-heading: 'DM Serif Display', Georgia, serif;
    --font-body: 'Nunito Sans', -apple-system, sans-serif;
  }
  body { font-family: var(--font-body); color: var(--text); line-height: 1.65; -webkit-font-smoothing: antialiased; }
  .container { max-width: 1140px; margin: 0 auto; padding: 0 1.5rem; }

  /* NAV */
  .nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: var(--primary); transition: background 0.3s, box-shadow 0.3s; }
  .nav--scrolled { background: rgba(26,107,92,0.95); backdrop-filter: blur(12px); box-shadow: 0 2px 24px rgba(0,0,0,0.12); }
  .nav__inner { max-width: 1140px; margin: 0 auto; padding: 0 1.5rem; display: flex; align-items: center; justify-content: space-between; height: 68px; }
  .nav__brand { display: flex; align-items: center; gap: 0.5rem; text-decoration: none; }
  .nav__paw { color: var(--accent); }
  .nav__name { color: #fff; font-family: var(--font-heading); font-size: 1.25rem; }
  .nav__links { display: flex; gap: 0.15rem; }
  .nav__link { color: rgba(255,255,255,0.72); text-decoration: none; font-size: 0.85rem; font-weight: 600; padding: 0.4rem 0.85rem; border-radius: 6px; transition: color 0.2s, background 0.2s; }
  .nav__link:hover, .nav__link--active { color: #fff; background: rgba(255,255,255,0.12); }
  .nav__cta { display: flex; align-items: center; gap: 0.4rem; background: var(--accent); color: #fff; text-decoration: none; font-size: 0.82rem; font-weight: 700; padding: 0.5rem 1.1rem; border-radius: 8px; transition: transform 0.2s, box-shadow 0.2s; box-shadow: 0 2px 8px rgba(212,136,58,0.3); }
  .nav__cta:hover { transform: translateY(-1px); box-shadow: 0 4px 14px rgba(212,136,58,0.4); }
  .nav__hamburger { display: none; background: none; border: none; cursor: pointer; flex-direction: column; gap: 5px; padding: 4px; }
  .nav__hamburger span { display: block; width: 22px; height: 2px; background: #fff; border-radius: 2px; }
  @media (max-width: 768px) {
    .nav__links { display: none; position: absolute; top: 68px; left: 0; right: 0; background: var(--primary); flex-direction: column; padding: 0.75rem 1rem 1rem; box-shadow: 0 12px 32px rgba(0,0,0,0.2); }
    .nav__links--open { display: flex; }
    .nav__link { padding: 0.8rem 1rem; font-size: 0.95rem; }
    .nav__cta { display: none; }
    .nav__hamburger { display: flex; }
  }

  /* PAGE HEADER */
  .page-header {
    position: relative; padding: 8rem 0 3rem;
    background: var(--primary); overflow: hidden;
  }
  .page-header__bg {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at 70% 40%, rgba(255,255,255,0.06) 0%, transparent 60%);
  }
  .page-header__content { position: relative; }
  .page-header__breadcrumb { font-size: 0.82rem; color: rgba(255,255,255,0.4); margin-bottom: 0.75rem; }
  .page-header__breadcrumb a { color: rgba(255,255,255,0.55); text-decoration: none; transition: color 0.2s; }
  .page-header__breadcrumb a:hover { color: var(--accent); }
  .page-header__breadcrumb span { margin: 0 0.35rem; }
  .page-header h1 { font-family: var(--font-heading); color: #fff; font-size: clamp(2rem, 4.5vw, 3rem); font-weight: 400; margin-bottom: 0.5rem; }
  .page-header p { color: rgba(255,255,255,0.65); font-size: 1.05rem; }

  .section { padding: 5.5rem 0; }
  .section--cream { background: var(--cream); }
  .section-header { margin-bottom: 2.5rem; }
  .section-header--center { text-align: center; }
  .eyebrow { display: block; font-size: 0.72rem; font-weight: 800; letter-spacing: 0.14em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.5rem; }
  .section__title { font-family: var(--font-heading); font-size: clamp(1.6rem, 3.2vw, 2.4rem); font-weight: 400; line-height: 1.2; color: var(--text); }

  /* ABOUT SPLIT */
  .about-split { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  .about-split__text h2 { font-family: var(--font-heading); font-size: 1.85rem; font-weight: 400; margin-bottom: 1.5rem; line-height: 1.2; }
  .about-split__text .eyebrow { margin-bottom: 0.75rem; }
  .about-split__text p { font-size: 0.98rem; color: var(--text-mid); line-height: 1.8; margin-bottom: 1.1rem; }
  .about-split__image img { width: 100%; border-radius: 12px; box-shadow: 0 12px 40px rgba(0,0,0,0.12); }
  @media (max-width: 768px) { .about-split { grid-template-columns: 1fr; gap: 2.5rem; } }

  /* VALUES */
  .values-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }
  .value-card {
    text-align: center; padding: 2rem 1.25rem;
    background: #fff; border-radius: var(--radius);
    border: 1px solid var(--border);
    transition: box-shadow 0.3s, transform 0.3s;
  }
  .value-card:hover { box-shadow: 0 8px 28px rgba(0,0,0,0.08); transform: translateY(-3px); }
  .value-card__icon {
    width: 56px; height: 56px; border-radius: 14px;
    background: var(--primary-light); color: var(--primary);
    display: flex; align-items: center; justify-content: center; margin: 0 auto 1.25rem;
  }
  .value-card h3 { font-family: var(--font-heading); font-size: 1.05rem; font-weight: 400; margin-bottom: 0.5rem; }
  .value-card p { font-size: 0.88rem; color: var(--text-mid); line-height: 1.65; }
  @media (max-width: 768px) { .values-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .values-grid { grid-template-columns: 1fr; } }

  /* BUTTONS */
  .btn { display: inline-flex; align-items: center; gap: 0.5rem; font-family: var(--font-body); font-size: 0.9rem; font-weight: 700; text-decoration: none; padding: 0.72rem 1.5rem; border-radius: 8px; transition: all 0.2s ease; border: 2px solid transparent; cursor: pointer; }
  .btn--accent { background: var(--accent); color: #fff; border-color: var(--accent); box-shadow: 0 2px 10px rgba(212,136,58,0.25); }
  .btn--accent:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(212,136,58,0.35); }
  .btn--outline { background: transparent; color: #fff; border-color: rgba(255,255,255,0.35); }
  .btn--outline:hover { border-color: #fff; background: rgba(255,255,255,0.08); }
  .btn--lg { padding: 0.9rem 2.2rem; font-size: 0.95rem; }

  /* CTA */
  .section--cta { background: var(--primary); text-align: center; padding: 5rem 0; position: relative; overflow: hidden; }
  .section--cta::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at 30% 50%, rgba(255,255,255,0.06) 0%, transparent 70%); pointer-events: none; }
  .cta-content { position: relative; }
  .cta-content h2 { font-family: var(--font-heading); font-size: clamp(1.6rem, 3.2vw, 2.4rem); font-weight: 400; color: #fff; margin-bottom: 0.75rem; }
  .cta-content p { font-size: 1.05rem; color: rgba(255,255,255,0.78); margin-bottom: 2rem; }
  .cta-actions { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }

  /* FOOTER */
  .footer { background: #0e2e25; color: rgba(255,255,255,0.65); padding: 0; }
  .footer__accent { height: 4px; background: linear-gradient(90deg, var(--accent) 0%, var(--primary) 100%); }
  .footer__inner { display: grid; grid-template-columns: 1.6fr 1fr 1fr 1fr; gap: 2.5rem; padding: 3.5rem 1.5rem 0; max-width: 1140px; margin: 0 auto; }
  .footer__col h4 { font-family: var(--font-heading); color: #fff; font-size: 1.05rem; font-weight: 400; margin-bottom: 1rem; }
  .footer__col p { font-size: 0.88rem; line-height: 1.7; margin-bottom: 0.6rem; }
  .footer__col ul { list-style: none; }
  .footer__col li { margin-bottom: 0.5rem; }
  .footer__col a { color: rgba(255,255,255,0.65); text-decoration: none; font-size: 0.88rem; transition: color 0.2s; }
  .footer__col a:hover { color: var(--accent); }
  .footer__note { margin-top: 0.5rem; padding-top: 0.5rem; border-top: 1px solid rgba(255,255,255,0.08); font-size: 0.82rem; color: rgba(255,255,255,0.45); }
  .footer__social { display: flex; gap: 0.75rem; margin-top: 1.25rem; }
  .footer__social a { width: 36px; height: 36px; border-radius: 8px; background: rgba(255,255,255,0.06); display: flex; align-items: center; justify-content: center; color: rgba(255,255,255,0.5); transition: all 0.2s; }
  .footer__social a:hover { background: var(--accent); color: #fff; }
  .footer__bottom { max-width: 1140px; margin: 2.5rem auto 0; padding: 1.25rem 1.5rem; border-top: 1px solid rgba(255,255,255,0.06); text-align: center; }
  .footer__bottom p { font-size: 0.78rem; color: rgba(255,255,255,0.3); }
  @media (max-width: 768px) { .footer__inner { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 480px) { .footer__inner { grid-template-columns: 1fr; gap: 2rem; } }
</style>
</body>
</html>
