---
import Analytics from '../../components/Analytics.astro';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Services — Fine Line Irrigation LLC | Scandia, MN</title>
  <meta name="description" content="Sprinkler system design, installation, repair, spring startups, and fall blowouts. Fine Line Irrigation serves the Twin Cities North Metro from Scandia, MN." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <Analytics />
</head>
<body>

  <!-- NAV -->
  <header class="fl-nav">
    <div class="fl-nav__inner">
      <a href="/fine-line-irrigation" class="fl-nav__brand">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round"><path d="M12 2.69l5.66 5.66a8 8 0 11-11.31 0z"/></svg>
        <span class="fl-nav__name">Fine Line Irrigation</span>
      </a>
      <nav class="fl-nav__links">
        <a href="/fine-line-irrigation" class="fl-nav__link">Home</a>
        <a href="/fine-line-irrigation/services" class="fl-nav__link fl-nav__link--active">Services</a>
        <a href="/fine-line-irrigation/contact" class="fl-nav__link">Contact</a>
      </nav>
      <a href="/fine-line-irrigation/contact" class="fl-nav__cta">Free Estimate</a>
      <button class="fl-nav__hamburger" aria-label="Menu"><span></span><span></span><span></span></button>
    </div>
  </header>

  <!-- PAGE HEADER -->
  <section class="fl-page-header">
    <div class="fl-container">
      <div class="fl-breadcrumb">
        <a href="/fine-line-irrigation">Home</a> <span>/</span> <span>Services</span>
      </div>
      <h1>Our Services</h1>
      <p>From design to installation to year-round maintenance — we handle every aspect of your irrigation system.</p>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="fl-section">
    <div class="fl-container">
      <div class="fl-section__header fl-section__header--center">
        <span class="fl-eyebrow">How We Work</span>
        <h2 class="fl-section__title">Our Process</h2>
        <p class="fl-section__subtitle">A straightforward approach from first call to finished system.</p>
      </div>
      <div class="fl-process">
        <div class="fl-process__step">
          <div class="fl-process__num">1</div>
          <div class="fl-process__connector"></div>
          <h3>Consultation</h3>
          <p>We walk your property, discuss your goals, assess soil type, sun exposure, shade, slopes, and existing landscaping.</p>
        </div>
        <div class="fl-process__step">
          <div class="fl-process__num">2</div>
          <div class="fl-process__connector"></div>
          <h3>Design</h3>
          <p>We create a custom layout with matched precipitation rates, proper head spacing, and zone planning tailored to your property.</p>
        </div>
        <div class="fl-process__step">
          <div class="fl-process__num">3</div>
          <div class="fl-process__connector"></div>
          <h3>Install</h3>
          <p>Professional installation with minimal disruption to your lawn. Quality components, clean trenching, and thorough testing.</p>
        </div>
        <div class="fl-process__step">
          <div class="fl-process__num">4</div>
          <h3>Maintain</h3>
          <p>Spring startups, mid-season adjustments, and fall winterization to keep your system running efficiently for years.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- DETAILED SERVICES -->
  <section class="fl-section fl-section--green">
    <div class="fl-container">
      <div class="fl-section__header">
        <span class="fl-eyebrow">Full Service</span>
        <h2 class="fl-section__title">What We Offer</h2>
      </div>

      <!-- Service 1 -->
      <div class="fl-detail-card">
        <div class="fl-detail-card__content">
          <div class="fl-detail-card__badge">Core Service</div>
          <h3>Sprinkler System Design &amp; Installation</h3>
          <p>Every installation starts with a thorough site assessment. We evaluate your soil conditions, drainage patterns, sun and shade exposure, slopes, plant types, and water pressure to design a system that delivers even, efficient coverage.</p>
          <p>Our designs use matched precipitation rates across all zones — meaning every area gets exactly the water it needs, not more, not less. The result is a healthier lawn and lower water bills.</p>
          <ul class="fl-detail-card__features">
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2.5" stroke-linecap="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              Custom design for every property
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2.5" stroke-linecap="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              Matched precipitation rates
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2.5" stroke-linecap="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              Quality components &amp; materials
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2.5" stroke-linecap="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              Clean installation with lawn restoration
            </li>
          </ul>
        </div>
        <div class="fl-detail-card__image">
          <img src="/images/fine-line-irrigation/lawn.jpg" alt="Sprinkler system installation" />
        </div>
      </div>

      <!-- Service 2 -->
      <div class="fl-detail-card fl-detail-card--reverse">
        <div class="fl-detail-card__content">
          <h3>Diagnosis &amp; Repair</h3>
          <p>Something not working right? We troubleshoot and repair all types of irrigation issues — broken or stuck heads, valve failures, wiring problems, leaks, controller malfunctions, and low pressure issues.</p>
          <p>Our diagnostic process is thorough and systematic. We identify the root cause, not just the symptom, so the fix lasts.</p>
          <ul class="fl-detail-card__features">
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2.5" stroke-linecap="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              Head replacement &amp; adjustment
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2.5" stroke-linecap="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              Valve &amp; wiring diagnosis
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2.5" stroke-linecap="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              Leak detection &amp; pipe repair
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2.5" stroke-linecap="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              Controller reprogramming
            </li>
          </ul>
        </div>
        <div class="fl-detail-card__image">
          <img src="/images/fine-line-irrigation/lawn.jpg" alt="Sprinkler system repair" />
        </div>
      </div>

      <!-- Service 3 -->
      <div class="fl-detail-card">
        <div class="fl-detail-card__content">
          <h3>Additions to Existing Systems</h3>
          <p>Added a patio? New garden beds? Extended the lawn? We integrate new zones and heads into your existing system seamlessly, ensuring the new areas get proper coverage without affecting existing performance.</p>
          <ul class="fl-detail-card__features">
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2.5" stroke-linecap="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              New zone additions
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2.5" stroke-linecap="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              Drip irrigation for garden beds
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2.5" stroke-linecap="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              Seamless integration with existing system
            </li>
          </ul>
        </div>
        <div class="fl-detail-card__image">
          <img src="/images/fine-line-irrigation/lawn.jpg" alt="Landscape with irrigation system addition" />
        </div>
      </div>
    </div>
  </section>

  <!-- SEASONAL SERVICES -->
  <section class="fl-section">
    <div class="fl-container">
      <div class="fl-section__header fl-section__header--center">
        <span class="fl-eyebrow">Year-Round Care</span>
        <h2 class="fl-section__title">Seasonal Maintenance</h2>
        <p class="fl-section__subtitle">Minnesota weather demands proper seasonal care. We've got both ends of the season covered.</p>
      </div>
      <div class="fl-seasonal-detail">
        <div class="fl-seasonal-detail__card">
          <div class="fl-seasonal-detail__header fl-seasonal-detail__header--spring">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
            <h3>Spring Startup</h3>
          </div>
          <div class="fl-seasonal-detail__body">
            <p>Get your system running safely and efficiently after the long Minnesota winter.</p>
            <ul>
              <li>Gradual pressurization to prevent damage</li>
              <li>Zone-by-zone inspection and testing</li>
              <li>Head adjustment and cleaning</li>
              <li>Controller programming and schedule setup</li>
              <li>Leak and damage inspection</li>
              <li>Backflow preventer testing</li>
            </ul>
          </div>
        </div>
        <div class="fl-seasonal-detail__card">
          <div class="fl-seasonal-detail__header fl-seasonal-detail__header--fall">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round"><path d="M12 2.69l5.66 5.66a8 8 0 11-11.31 0z"/></svg>
            <h3>Fall Blowout / Winterization</h3>
          </div>
          <div class="fl-seasonal-detail__body">
            <p>Protect your investment from freeze damage with a professional compressed-air blowout.</p>
            <ul>
              <li>Compressed air blowout of all zones</li>
              <li>Complete water evacuation from lines</li>
              <li>Main line shut-off and drain</li>
              <li>Backflow preventer winterization</li>
              <li>Controller shut-down</li>
              <li>Prevents costly freeze/thaw pipe damage</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WATER CONSERVATION -->
  <section class="fl-conservation">
    <div class="fl-container">
      <div class="fl-conservation__inner">
        <div class="fl-conservation__icon">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round"><path d="M12 2.69l5.66 5.66a8 8 0 11-11.31 0z"/></svg>
        </div>
        <h2>Water Conservation Is Built In</h2>
        <p>Every system we design is engineered for efficiency. We don't just install sprinklers — we design irrigation solutions that use less water while delivering better results. Matched precipitation rates, proper head selection, smart zone planning, and consideration of soil absorption rates all contribute to a system that conserves water by design.</p>
        <a href="/fine-line-irrigation/contact" class="fl-btn fl-btn--primary">Discuss Your Project</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="fl-cta">
    <div class="fl-container fl-cta__inner">
      <h2>Ready to Get Started?</h2>
      <p>Contact us for a free on-site estimate. We'll walk your property, discuss your needs, and provide an honest, detailed quote.</p>
      <a href="/fine-line-irrigation/contact" class="fl-btn fl-btn--white fl-btn--lg">Get Your Free Estimate</a>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="fl-footer">
    <div class="fl-container fl-footer__inner">
      <div class="fl-footer__col fl-footer__col--brand">
        <div class="fl-footer__brand">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round"><path d="M12 2.69l5.66 5.66a8 8 0 11-11.31 0z"/></svg>
          <h4>Fine Line Irrigation LLC</h4>
        </div>
        <p>Professional irrigation services in Scandia, MN. Custom sprinkler system design, installation, repair, and seasonal maintenance for the Twin Cities North Metro.</p>
      </div>
      <div class="fl-footer__col">
        <h4>Quick Links</h4>
        <ul>
          <li><a href="/fine-line-irrigation">Home</a></li>
          <li><a href="/fine-line-irrigation/services">Services</a></li>
          <li><a href="/fine-line-irrigation/contact">Contact</a></li>
        </ul>
      </div>
      <div class="fl-footer__col">
        <h4>Services</h4>
        <ul>
          <li><a href="/fine-line-irrigation/services">System Design &amp; Install</a></li>
          <li><a href="/fine-line-irrigation/services">Repair &amp; Diagnosis</a></li>
          <li><a href="/fine-line-irrigation/services">Spring Startups</a></li>
          <li><a href="/fine-line-irrigation/services">Fall Blowouts</a></li>
        </ul>
      </div>
      <div class="fl-footer__col">
        <h4>Contact</h4>
        <p>Scandia, MN</p>
        <p style="margin-top:0.25rem;">Serving the Twin Cities North Metro</p>
        <a href="/fine-line-irrigation/contact" class="fl-footer__cta-link">Call for a Free Estimate &rarr;</a>
      </div>
    </div>
    <div class="fl-footer__bottom">
      <p>&copy; 2026 Fine Line Irrigation LLC. All rights reserved.</p>
    </div>
  </footer>

  <script>
    const nav = document.querySelector('.fl-nav');
    window.addEventListener('scroll', () => nav?.classList.toggle('fl-nav--scrolled', window.scrollY > 20));
    document.querySelector('.fl-nav__hamburger')?.addEventListener('click', () => {
      document.querySelector('.fl-nav__links')?.classList.toggle('fl-nav__links--open');
    });
  </script>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --primary: #2d5f3f;
    --primary-dark: #1e4a2e;
    --accent: #3a8fd4;
    --accent-light: #e8f4fd;
    --text: #1f2937;
    --text-mid: #6b7280;
    --text-light: #9ca3af;
    --bg: #ffffff;
    --bg-warm: #f9fafb;
    --bg-green: #f0f7f2;
    --border: #e5e7eb;
  }

  body {
    font-family: 'Inter', -apple-system, sans-serif;
    color: var(--text);
    background: var(--bg);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  .fl-container { max-width: 1120px; margin: 0 auto; padding: 0 1.5rem; }

  /* NAV */
  .fl-nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: rgba(255,255,255,0.92); backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(0,0,0,0.06);
    transition: box-shadow 0.2s;
  }
  .fl-nav--scrolled { box-shadow: 0 1px 12px rgba(0,0,0,0.08); }
  .fl-nav__inner {
    max-width: 1120px; margin: 0 auto; padding: 0 1.5rem;
    display: flex; align-items: center; justify-content: space-between;
    height: 64px;
  }
  .fl-nav__brand { display: flex; align-items: center; gap: 0.5rem; text-decoration: none; }
  .fl-nav__name { color: var(--primary); font-weight: 800; font-size: 1rem; }
  .fl-nav__links { display: flex; gap: 0.25rem; }
  .fl-nav__link {
    color: var(--text-mid); text-decoration: none; font-size: 0.88rem;
    font-weight: 500; padding: 0.4rem 0.75rem; border-radius: 6px;
    transition: color 0.15s, background 0.15s;
  }
  .fl-nav__link:hover, .fl-nav__link--active { color: var(--primary); background: var(--bg-green); }
  .fl-nav__cta {
    background: var(--primary); color: #fff; text-decoration: none;
    font-size: 0.85rem; font-weight: 600; padding: 0.5rem 1.15rem;
    border-radius: 6px; transition: background 0.15s;
  }
  .fl-nav__cta:hover { background: var(--primary-dark); }
  .fl-nav__hamburger {
    display: none; background: none; border: none; cursor: pointer;
    flex-direction: column; gap: 5px; padding: 4px;
  }
  .fl-nav__hamburger span {
    display: block; width: 22px; height: 2px; background: var(--primary);
    border-radius: 1px; transition: 0.2s;
  }

  @media (max-width: 768px) {
    .fl-nav__links {
      display: none; position: absolute; top: 64px; left: 0; right: 0;
      background: #fff; flex-direction: column; padding: 1rem;
      box-shadow: 0 8px 20px rgba(0,0,0,0.1);
      border-bottom: 1px solid var(--border);
    }
    .fl-nav__links--open { display: flex; }
    .fl-nav__link { padding: 0.75rem 1rem; }
    .fl-nav__cta { display: none; }
    .fl-nav__hamburger { display: flex; }
  }

  /* PAGE HEADER */
  .fl-page-header {
    padding: 7rem 0 3rem;
    background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  }
  .fl-breadcrumb { font-size: 0.82rem; color: rgba(255,255,255,0.45); margin-bottom: 0.75rem; }
  .fl-breadcrumb a { color: rgba(255,255,255,0.6); text-decoration: none; }
  .fl-breadcrumb a:hover { color: #fff; }
  .fl-breadcrumb span { margin: 0 0.35rem; }
  .fl-page-header h1 {
    color: #fff; font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800; margin-bottom: 0.5rem;
  }
  .fl-page-header p { color: rgba(255,255,255,0.75); font-size: 1.05rem; max-width: 560px; }

  /* SECTIONS */
  .fl-section { padding: 5rem 0; }
  .fl-section--green { background: var(--bg-green); }
  .fl-section__header { margin-bottom: 2.5rem; }
  .fl-section__header--center { text-align: center; }
  .fl-eyebrow {
    display: block; font-size: 0.75rem; font-weight: 700;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--accent); margin-bottom: 0.5rem;
  }
  .fl-section__title {
    font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 800; line-height: 1.15;
  }
  .fl-section__subtitle {
    font-size: 1rem; color: var(--text-mid); margin-top: 0.75rem; max-width: 560px;
  }
  .fl-section__header--center .fl-section__subtitle { margin-left: auto; margin-right: auto; }

  /* PROCESS */
  .fl-process {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 0;
    position: relative;
  }
  .fl-process__step {
    text-align: center; padding: 2rem 1.5rem; position: relative;
  }
  .fl-process__num {
    width: 44px; height: 44px; border-radius: 50%;
    background: var(--primary); color: #fff;
    font-size: 1rem; font-weight: 800;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 1.25rem; position: relative; z-index: 1;
  }
  .fl-process__connector {
    position: absolute; top: calc(2rem + 22px); left: calc(50% + 22px);
    width: calc(100% - 44px); height: 2px;
    background: var(--border);
  }
  .fl-process__step:last-child .fl-process__connector { display: none; }
  .fl-process__step h3 { font-size: 1rem; font-weight: 700; margin-bottom: 0.5rem; }
  .fl-process__step p { font-size: 0.88rem; color: var(--text-mid); line-height: 1.6; }

  @media (max-width: 768px) {
    .fl-process { grid-template-columns: 1fr 1fr; gap: 1rem; }
    .fl-process__connector { display: none; }
  }
  @media (max-width: 480px) {
    .fl-process { grid-template-columns: 1fr; }
  }

  /* DETAIL CARDS */
  .fl-detail-card {
    display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem;
    align-items: center; margin-bottom: 3rem; padding-bottom: 3rem;
    border-bottom: 1px solid var(--border);
  }
  .fl-detail-card:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
  .fl-detail-card--reverse .fl-detail-card__image { order: -1; }
  .fl-detail-card__badge {
    display: inline-block; font-size: 0.72rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--primary); background: rgba(45,95,63,0.08);
    padding: 0.3rem 0.65rem; border-radius: 4px; margin-bottom: 0.75rem;
  }
  .fl-detail-card h3 { font-size: 1.35rem; font-weight: 800; margin-bottom: 0.75rem; }
  .fl-detail-card p { font-size: 0.92rem; color: var(--text-mid); line-height: 1.7; margin-bottom: 0.5rem; }
  .fl-detail-card__features {
    list-style: none; margin-top: 1.25rem;
    display: flex; flex-direction: column; gap: 0.5rem;
  }
  .fl-detail-card__features li {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 0.88rem; font-weight: 500;
  }
  .fl-detail-card__image { border-radius: 12px; overflow: hidden; }
  .fl-detail-card__image img { width: 100%; height: auto; display: block; }

  @media (max-width: 768px) {
    .fl-detail-card { grid-template-columns: 1fr; gap: 1.5rem; }
    .fl-detail-card--reverse .fl-detail-card__image { order: 0; }
  }

  /* SEASONAL DETAIL */
  .fl-seasonal-detail {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;
  }
  .fl-seasonal-detail__card {
    border-radius: 12px; overflow: hidden; background: #fff;
    border: 1px solid var(--border);
  }
  .fl-seasonal-detail__header {
    display: flex; align-items: center; gap: 0.75rem;
    padding: 1.5rem 2rem; color: #fff;
  }
  .fl-seasonal-detail__header--spring { background: var(--primary); }
  .fl-seasonal-detail__header--fall { background: var(--accent); }
  .fl-seasonal-detail__header h3 { font-size: 1.15rem; font-weight: 700; }
  .fl-seasonal-detail__body { padding: 2rem; }
  .fl-seasonal-detail__body p {
