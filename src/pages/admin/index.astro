        historyPanel.innerHTML = '';
        const timeline = document.createElement('div');
        timeline.className = 'history-timeline';
        commits.forEach((c) => {
          const entry = document.createElement('div');
          entry.className = 'history-entry';
          const d = new Date(c.date);
          entry.innerHTML = `
            <div class="history-date">${timeAgo(d)}</div>
            <div class="history-message">${escapeHtml(c.message)}</div>
            <div class="history-author">${escapeHtml(c.author)}</div>
          `;
          timeline.appendChild(entry);
        });
        historyPanel.appendChild(timeline);
      } catch {
        historyPanel.innerHTML = '<div class="history-empty">Failed to load history.</div>';
        historyLoaded = false;
