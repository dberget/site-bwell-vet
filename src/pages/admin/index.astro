    // Create an empty assistant bubble for streaming and return a function to append text
    function createStreamingBubble() {
      const group = document.createElement('div');
      group.className = 'msg-group msg-group-assistant';

      const row = document.createElement('div');
      row.className = 'msg-row';

      const avatar = document.createElement('div');
      avatar.className = 'msg-avatar';
      avatar.innerHTML = AI_AVATAR_SVG;

      const bubble = document.createElement('div');
      bubble.className = 'msg msg-assistant';

      row.appendChild(avatar);
      row.appendChild(bubble);
      group.appendChild(row);

      const time = document.createElement('div');
      time.className = 'msg-time';
      time.textContent = formatTime(new Date());
      group.appendChild(time);

      messagesEl.appendChild(group);

      let rawText = '';
      let deployed = false;

      function computeDisplay() {
        let text = rawText;
        let inCodeBlock = false;

        // Remove complete code blocks (opening + content + closing ```)
        text = text.replace(/```(?:astro-page|site-data)\n[\s\S]*?```\n?/g, () => {
          deployed = true;
          return '';
        });

        // Handle incomplete (still-streaming) code block
        text = text.replace(/```(?:astro-page|site-data)[\s\S]*$/, () => {
          deployed = true;
          inCodeBlock = true;
          return '';
        });

        // Trim trailing whitespace before status line
        if (inCodeBlock) {
          text = text.trimEnd() + '\n✦ Updating your site...';
        }

        return text;
      }

      return {
        append(text) {
          rawText += text;
          bubble.innerHTML = escapeHtml(computeDisplay()).replace(/\n/g, '<br>');
          messagesEl.scrollTop = messagesEl.scrollHeight;
        },
        getText() { return rawText; },
        wasDeployed() { return deployed; },
        finalize() {
          if (deployed) {
            const suffix = previewMode
              ? '\nDone \u2014 your changes are saved. Preview will be ready shortly.'
              : '\nDone \u2014 your site has been updated. Changes will be live in about a minute.';
            bubble.innerHTML = escapeHtml(computeDisplay() + suffix).replace(/\n/g, '<br>');
            messagesEl.scrollTop = messagesEl.scrollHeight;
          }
        },
      };
    }

