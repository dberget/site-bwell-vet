    async function handlePublish() {
      const publishBtn = document.getElementById('publishBtn');
      const discardBtn = document.getElementById('discardBtn');
      publishBtn.disabled = true;
      discardBtn.disabled = true;
      publishBtn.textContent = 'Publishing...';

      try {
        const res = await fetch('/api/publish', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ siteSlug }),
        });
        const data = await res.json();

        if (data.error) {
          showToast('Publish failed: ' + data.error);
          publishBtn.disabled = false;
          discardBtn.disabled = false;
          publishBtn.textContent = 'Publish';
          return;
        }

        // Start polling for the production deploy
        if (data.commitSha) {
          startDeployPolling(data.commitSha, true);
        } else {
          // Fallback: just exit preview mode
          resetPreviewState();
          updatePublishBar();
          refreshPreview();
        }
      } catch {
        showToast('Publish failed. Please try again.');
      }

      publishBtn.disabled = false;
      discardBtn.disabled = false;
      publishBtn.textContent = 'Publish';
    }

    async function handleDiscard() {
      if (!confirm('Discard all unpublished changes? This cannot be undone.')) return;

      const publishBtn = document.getElementById('publishBtn');
      const discardBtn = document.getElementById('discardBtn');
      publishBtn.disabled = true;
      discardBtn.disabled = true;
      discardBtn.textContent = 'Discarding...';

      try {
        const res = await fetch('/api/publish', {
          method: 'DELETE',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ siteSlug }),
        });
        const data = await res.json();

        if (data.error) {
          showToast('Discard failed: ' + data.error);
        } else {
          resetPreviewState();
          updatePublishBar();
          refreshPreview();
        }
      } catch {
        showToast('Discard failed. Please try again.');
      }

      publishBtn.disabled = false;
      discardBtn.disabled = false;
      discardBtn.textContent = 'Discard';
    }

    // ===== On-load: check for existing preview branch =====
    (async function checkPreviewBranch() {
      if (!siteSlug) return;
      try {
        const res = await fetch(`/api/deploy-status?ref=preview-${siteSlug}`);
        const data = await res.json();
        if (data.error) return;
        // Branch exists (either has deployments or branchExists flag)
        if (data.branchExists || (data.status !== 'not_found')) {
          previewMode = true;
          previewBranch = `preview-${siteSlug}`;
          if (data.deploymentUrl) {
            previewDeployUrl = data.deploymentUrl;
            refreshPreview();
          }
          updatePublishBar();
        }
      } catch {
        // No preview branch — that's fine
      }
    })();

    // ===== Expose functions to inline handlers =====
    // Wrap handleSend to support pending image uploads with vision
    function fileToBase64(file) {
      return new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.onload = () => resolve(reader.result.split(',')[1]);
        reader.onerror = reject;
        reader.readAsDataURL(file);
      });
    }

    async function handleSendWithImages() {
      if (pendingFiles.length === 0) {
        return handleSend();
      }

      const files = [...pendingFiles];
      pendingFiles.length = 0;
      renderDropPreview();

      const text = inputEl.value.trim();
      inputEl.value = '';
      inputEl.style.height = 'auto';

      const names = files.map(f => f.name).join(', ');
      addMessage('user', text || `[Attached ${names}]`);
      loading = true;
      sendBtn.disabled = true;
      showTyping();

      // Upload files to GitHub and read base64 in parallel
      const results = await Promise.all(files.map(async (file) => {
        try {
          const [uploadData, base64] = await Promise.all([uploadFile(file), fileToBase64(file)]);
          if (uploadData.error) return { error: `Upload failed for ${file.name}: ${uploadData.error}` };
          return { name: file.name, path: uploadData.path, base64, mediaType: file.type };
        } catch {
          return { error: `Upload failed for ${file.name}` };
        }
      }));

      const errors = results.filter(r => r.error);
      const uploaded = results.filter(r => !r.error);

      if (errors.length > 0) {
        hideTyping();
        for (const e of errors) addMessage('assistant', e.error);
      }

      if (uploaded.length === 0) {
        loading = false;
        sendBtn.disabled = false;
        return;
      }

      // Build multimodal content blocks: images + text
      const contentBlocks = [];
      for (const img of uploaded) {
        contentBlocks.push({
          type: 'image',
          source: { type: 'base64', media_type: img.mediaType, data: img.base64 },
        });
      }
      const paths = uploaded.map(u => u.path).join(', ');
      const instruction = text
        ? `${text}\n\nI uploaded these images to: ${paths}. Use those paths when referencing them in the page.`
        : `I uploaded ${uploaded.length > 1 ? 'these images' : 'this image'} to: ${paths}. Here ${uploaded.length > 1 ? 'they are' : 'it is'} so you can see what ${uploaded.length > 1 ? 'they look' : 'it looks'} like. Use ${uploaded.length > 1 ? 'these paths' : 'this path'} when referencing ${uploaded.length > 1 ? 'them' : 'it'} in the page.`;
      contentBlocks.push({ type: 'text', text: instruction });

      // Push multimodal message into conversation
      messages.push({ role: 'user', content: contentBlocks });

      try {
        await streamChatResponse();
      } catch {
        hideTyping();
        addMessage('assistant', 'Sorry, something went wrong. Please try again.');
      }

      loading = false;
      sendBtn.disabled = false;
      inputEl.focus();
    }
    window.handleSend = handleSendWithImages;
  </script>
</body>
</html>
