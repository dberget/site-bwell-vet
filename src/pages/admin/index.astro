    // ===== Deploy status polling =====
    let deployPollTimer = null;
    let deployTimeoutTimer = null;

    function setDeployState(state, message) {
      const bar = document.getElementById('deployBar');
      const text = document.getElementById('deployText');
      // Remove old state classes
      bar.classList.remove('deploy-pending', 'deploy-building', 'deploy-success', 'deploy-error');
      bar.classList.add('visible', `deploy-${state}`);
      text.textContent = message;
    }

    function clearDeployTimers() {
      if (deployPollTimer) { clearInterval(deployPollTimer); deployPollTimer = null; }
      if (deployTimeoutTimer) { clearTimeout(deployTimeoutTimer); deployTimeoutTimer = null; }
    }

    function startDeployPolling(sha, isPublish = false) {
      clearDeployTimers();
      if (isPublish) {
        setDeployState('pending', 'Publishing — waiting for deploy...');
      } else if (previewMode) {
        setDeployState('pending', 'Changes saved — building preview...');
      } else {
        setDeployState('pending', 'Changes committed — waiting for deploy...');
      }

      deployPollTimer = setInterval(async () => {
        try {
          const res = await fetch(`/api/deploy-status?sha=${sha}`);
          const data = await res.json();

          if (data.error) return; // silently retry on transient errors

          if (data.status === 'building') {
            setDeployState('building', isPublish ? 'Publishing...' : previewMode ? 'Building preview...' : 'Building your site...');
          } else if (data.status === 'success') {
            clearDeployTimers();
            if (isPublish) {
              setDeployState('success', 'Live!');
              resetPreviewState();
              updatePublishBar();
            } else if (previewMode) {
              setDeployState('success', 'Preview ready!');
              if (data.deploymentUrl) previewDeployUrl = data.deploymentUrl;
            } else {
              setDeployState('success', 'Live!');
            }
            refreshPreview();
            setTimeout(() => {
              document.getElementById('deployBar').classList.remove('visible');
            }, 4000);
          } else if (data.status === 'error') {
            clearDeployTimers();
            setDeployState('error', data.message || 'Deploy failed');
            setTimeout(() => {
              document.getElementById('deployBar').classList.remove('visible');
            }, 8000);
          }
          // 'pending' — keep polling
        } catch {
          // Network error — keep polling
        }
      }, 5000);

      // Max timeout: 120s — refresh iframe regardless and hide bar
      deployTimeoutTimer = setTimeout(() => {
        clearDeployTimers();
        const bar = document.getElementById('deployBar');
        if (bar.classList.contains('visible') && !bar.classList.contains('deploy-success')) {
          setDeployState('success', previewMode ? 'Preview ready' : 'Site updated');
          refreshPreview();
          setTimeout(() => {
            bar.classList.remove('visible');
          }, 3000);
        }
      }, 120000);
    }

    // Fallback for when no commitSha is available (legacy path)
    function startDeployFallback() {
      clearDeployTimers();
      setDeployState('pending', 'Changes saved — site updating...');
      setTimeout(() => refreshPreview(), 45000);
      setTimeout(() => {
        document.getElementById('deployBar').classList.remove('visible');
        refreshPreview();
      }, 90000);
    }

    // ===== Shared SSE streaming =====
    async function streamChatResponse() {
      const chatBody = { messages, siteSlug, pageName: currentPage };
      if (previewMode && previewBranch) chatBody.branch = previewBranch;
      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(chatBody),
      });

      // Non-SSE error responses (auth failures, etc.)
      if (res.headers.get('Content-Type')?.includes('application/json')) {
        const data = await res.json();
        hideTyping();
        addMessage('assistant', `Error: ${data.error}`);
        return;
      }

      hideTyping();
      const bubble = createStreamingBubble();
      const reader = res.body.getReader();
      const decoder = new TextDecoder();
      let buffer = '';

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;

        buffer += decoder.decode(value, { stream: true });
        const lines = buffer.split('\n\n');
        buffer = lines.pop() || '';

        for (const line of lines) {
          if (!line.startsWith('data: ')) continue;
          let data;
          try { data = JSON.parse(line.slice(6)); } catch { continue; }

          if (data.text) bubble.append(data.text);
          if (data.error) bubble.append(`\nError: ${data.error}`);

          if (data.done) {
            messages.push({ role: 'assistant', content: bubble.getText() });
            bubble.finalize();

            if (data.previewed && data.branch) {
              previewMode = true;
              previewBranch = data.branch;
              updatePublishBar();
            }

            if (data.dataUpdated || data.previewed) {
              if (data.commitSha) startDeployPolling(data.commitSha);
              else startDeployFallback();
            }
          }
        }
      }
    }

    // ===== Send handler =====
    async function handleSend() {
      const text = inputEl.value.trim();
      if (!text || loading) return;

      inputEl.value = '';
      inputEl.style.height = 'auto';
      addMessage('user', text);
      messages.push({ role: 'user', content: text });

