    // ===== Leads =====
    async function loadLeads() {
      leadsLoaded = true;
      leadsPanel.innerHTML = '<div class="history-empty">Loading leads...</div>';

      try {
        const res = await fetch(`/api/leads?slug=${encodeURIComponent(siteSlug)}`);
