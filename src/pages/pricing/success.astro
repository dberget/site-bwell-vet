---
export const prerender = false;

import Stripe from 'stripe';

const sessionId = Astro.url.searchParams.get('session_id');
let businessName = '';
let email = '';
let plan = 'monthly';

if (sessionId) {
  const stripeKey = import.meta.env.STRIPE_SECRET_KEY;
  if (stripeKey) {
    try {
      const stripe = new Stripe(stripeKey);
      const session = await stripe.checkout.sessions.retrieve(sessionId);
      businessName = session.metadata?.business_name || '';
      email = session.customer_email || '';
      plan = session.metadata?.plan || 'monthly';
    } catch { /* fallback to generic */ }
  }
}

const planLabel = plan === 'annual' ? '$500/year' : '$50/month';
const heading = businessName ? `Welcome aboard, ${businessName}` : 'Welcome aboard';
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Welcome — Lake Country Web Services</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: #fff; color: #0f172a;
      -webkit-font-smoothing: antialiased;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }
    a { text-decoration: none; color: inherit; }

    /* Nav */
    .nav {
      position: sticky; top: 0; z-index: 100;
      background: rgba(255,255,255,0.95); backdrop-filter: blur(12px);
      border-bottom: 1px solid #e2e8f0;
      padding: 0 2rem; height: 64px;
      display: flex; align-items: center; justify-content: space-between;
      max-width: 1200px; margin: 0 auto; width: 100%;
    }
    .nav__logo {
      display: flex; align-items: center; gap: 0.6rem;
      font-weight: 700; font-size: 1.05rem; color: #0f172a;
    }
    .nav__links { display: flex; gap: 2rem; list-style: none; }
    .nav__links a { font-size: 0.9rem; font-weight: 500; color: #475569; transition: color 0.2s; }
    .nav__links a:hover { color: #1a6847; }

    /* Hero */
    .success-hero {
      text-align: center; padding: 4rem 2rem 3rem;
      background: #faf9f7; border-bottom: 1px solid #e2e8f0;
      flex-shrink: 0;
    }
    .success-icon {
      width: 64px; height: 64px;
      background: #1a6847;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 1.5rem;
    }
    .success-hero h1 {
      font-size: clamp(1.75rem, 4vw, 2.25rem); font-weight: 800;
      letter-spacing: -0.03em; margin-bottom: 0.75rem;
    }
    .success-hero p {
      color: #475569; font-size: 1.05rem; max-width: 500px;
      margin: 0 auto; line-height: 1.7;
    }
    .plan-badge {
      display: inline-block;
      background: rgba(26,104,71,0.08);
      border: 1px solid rgba(26,104,71,0.2);
      color: #1a6847;
      padding: 0.35rem 1rem;
      border-radius: 100px;
      font-size: 0.85rem;
      font-weight: 600;
      margin-top: 1rem;
    }
    .email-note {
      font-size: 0.88rem; color: #94a3b8; margin-top: 0.75rem;
    }
    .email-note strong { color: #334155; }

    /* Steps */
    .steps-section {
      padding: 3rem 2rem 4rem;
      max-width: 640px; margin: 0 auto; width: 100%;
      flex: 1;
    }
    .steps-section h2 {
      font-size: 1.25rem; font-weight: 700; text-align: center;
      margin-bottom: 2rem; letter-spacing: -0.02em;
    }
    .steps {
      display: flex; flex-direction: column; gap: 0;
    }
    .step {
      display: flex; gap: 1.25rem; align-items: flex-start;
      padding: 1.25rem 0;
    }
    .step:not(:last-child) { border-bottom: 1px solid #f1f5f9; }
    .step-num {
      width: 32px; height: 32px;
      background: linear-gradient(135deg, #0f2419, #1a3a2a);
      color: white;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 0.8rem;
      font-weight: 700;
      flex-shrink: 0;
    }
    .step-content h3 {
      font-size: 0.95rem; font-weight: 600; margin-bottom: 0.2rem;
    }
    .step-content p {
      color: #64748b; font-size: 0.88rem; line-height: 1.6;
    }

    /* Contact */
    .contact-note {
      text-align: center;
      margin-top: 2rem;
      padding-top: 2rem;
      border-top: 1px solid #f1f5f9;
    }
    .contact-note p {
      font-size: 0.9rem; color: #64748b; margin-bottom: 1rem;
    }
    .contact-note a {
      display: inline-block;
      background: #1a6847;
      color: #fff;
      padding: 0.7rem 1.75rem;
      border-radius: 8px;
      font-size: 0.9rem;
      font-weight: 600;
      transition: background 0.2s;
    }
    .contact-note a:hover { background: #15553a; }

    /* Footer */
    .footer {
      padding: 1.5rem 2rem; border-top: 1px solid #e2e8f0;
      text-align: center; font-size: 0.85rem; color: #94a3b8;
      flex-shrink: 0;
    }

    @media (max-width: 640px) {
      .nav__links { gap: 1rem; }
      .success-hero { padding: 3rem 1.5rem 2.5rem; }
      .steps-section { padding: 2rem 1.5rem 3rem; }
    }
  </style>
</head>
<body>

  <nav class="nav">
    <a href="/" class="nav__logo">
      <svg width="28" height="28" viewBox="0 0 32 32" fill="none" aria-hidden="true">
        <rect width="32" height="32" rx="8" fill="#1a6847"/>
        <path d="M10 22l3-5-2 0 3-5-2 0 2.5-4.5h-1L14 7l1-1.5L16 7l.5.5h-1L18 12l-2 0 3 5-2 0 3 5" fill="#fff" opacity="0.9"/>
        <path d="M7 23.5c1.5-1 3-1 4.5 0s3 1 4.5 0 3-1 4.5 0 3 1 4.5 0" stroke="#fff" stroke-width="1.3" stroke-linecap="round" fill="none" opacity="0.7"/>
        <path d="M7 26c1.5-1 3-1 4.5 0s3 1 4.5 0 3-1 4.5 0 3 1 4.5 0" stroke="#fff" stroke-width="1.3" stroke-linecap="round" fill="none" opacity="0.5"/>
      </svg>
      <span>Lake Country Web Services</span>
    </a>
    <ul class="nav__links">
      <li><a href="/">Home</a></li>
      <li><a href="/pricing">Pricing</a></li>
      <li><a href="mailto:davidberget@gmail.com">Contact</a></li>
    </ul>
  </nav>

  <header class="success-hero">
    <div class="success-icon">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none">
        <path d="M5 13l4 4L19 7" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
    <h1>{heading}</h1>
    <p>Your payment was successful. We're excited to build your new website.</p>
    <div class="plan-badge">{planLabel} plan active</div>
    {email && <p class="email-note">Confirmation sent to <strong>{email}</strong></p>}
  </header>

  <section class="steps-section">
    <h2>Here's what happens next</h2>
    <div class="steps">
      <div class="step">
        <span class="step-num">1</span>
        <div class="step-content">
          <h3>We'll reach out within 24 hours</h3>
          <p>We'll gather your business details, photos, branding, and any preferences to get started on your site.</p>
        </div>
      </div>
      <div class="step">
        <span class="step-num">2</span>
        <div class="step-content">
          <h3>Your custom site gets built</h3>
          <p>We'll design and build your site from scratch, tailored to your business. You'll get a preview to review before anything goes live.</p>
        </div>
      </div>
      <div class="step">
        <span class="step-num">3</span>
        <div class="step-content">
          <h3>Go live and take control</h3>
          <p>Once you approve, we launch your site and hand you the keys to the AI editor so you can make updates anytime.</p>
        </div>
      </div>
    </div>

    <div class="contact-note">
      <p>Questions in the meantime? Reach out anytime.</p>
      <a href="mailto:davidberget@gmail.com">Email Us</a>
    </div>
  </section>

  <footer class="footer">
    &copy; {year} Lake Country Web Services &middot; Central Minnesota
  </footer>

</body>
</html>
