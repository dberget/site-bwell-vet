---
import Analytics from '../../components/Analytics.astro';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Quality Printing — Professional Printing Services in Alexandria, MN</title>
  <meta name="description" content="Professional printing services for businesses in Alexandria, MN and beyond. Business cards, brochures, banners, booklets, and custom projects with free local delivery." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <Analytics />
</head>
<body>

  <!-- NAV -->
  <header class="nav">
    <div class="nav__inner">
      <a href="/quality-printing" class="nav__brand">
        <span class="nav__name">Quality Printing</span>
      </a>
      <nav class="nav__links">
        <a href="/quality-printing" class="nav__link nav__link--active">Home</a>
        <a href="/quality-printing/services" class="nav__link">Services</a>
        <a href="/quality-printing/contact" class="nav__link">Contact</a>
      </nav>
      <a href="tel:3207620606" class="nav__cta">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 013.12 4.18 2 2 0 015.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        (320) 762-0606
      </a>
      <button class="nav__hamburger" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </header>

  <!-- HERO -->
  <section class="hero">
    <div class="hero__bg">
      <img src="https://picsum.photos/seed/quality-print/1400/700" alt="Quality Printing shop" class="hero__bg-img" />
      <div class="hero__overlay"></div>
    </div>
    <div class="hero__content">
      <span class="hero__badge">Alexandria's Print Shop</span>
      <h1 class="hero__title">Fast, Friendly, and<br/>Fully Functional</h1>
      <p class="hero__desc">Professional printing services for businesses in Alexandria and beyond. From business cards to banners, we deliver quality you can count on.</p>
      <div class="hero__actions">
        <a href="tel:3207620606" class="btn btn--primary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 013.12 4.18 2 2 0 015.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          Call Us
        </a>
        <a href="/quality-printing/services" class="btn btn--outline">View Our Services</a>
      </div>
      <div class="hero__stats">
        <div class="hero__stat">
          <span class="hero__stat-num">Local</span>
          <span class="hero__stat-label">Delivery</span>
        </div>
        <div class="hero__stat-divider"></div>
        <div class="hero__stat">
          <span class="hero__stat-num">Same Day</span>
          <span class="hero__stat-label">Available</span>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES PREVIEW -->
  <section class="section" id="services">
    <div class="container">
      <span class="eyebrow">What We Do</span>
      <h2 class="section__title">Our Services</h2>
      <div class="services-grid">
        <div class="service-card">
          <div class="service-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
          </div>
          <h3>Business Cards &amp; Stationery</h3>
          <p>Custom business cards, letterhead, and envelopes that make a lasting impression.</p>
        </div>
        <div class="service-card">
          <div class="service-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          </div>
          <h3>Brochures &amp; Flyers</h3>
          <p>Full-color brochures and flyers in a variety of folds, sizes, and finishes.</p>
        </div>
        <div class="service-card">
          <div class="service-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          </div>
          <h3>Banners &amp; Signage</h3>
          <p>Vinyl banners, yard signs, trade show displays, and window graphics.</p>
        </div>
        <div class="service-card">
          <div class="service-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/></svg>
          </div>
          <h3>Booklets &amp; Manuals</h3>
          <p>Saddle-stitched and perfect bound booklets, catalogs, and employee handbooks.</p>
        </div>
        <div class="service-card">
          <div class="service-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="5" x2="5" y2="19"/><circle cx="6.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/></svg>
          </div>
          <h3>Promotional Materials</h3>
          <p>Postcards, door hangers, stickers, labels, and event programs.</p>
        </div>
        <div class="service-card">
          <div class="service-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </div>
          <h3>Custom Projects</h3>
          <p>Large format printing, specialty paper, die cutting, and unique requests.</p>
        </div>
      </div>
      <div class="services-more">
        <a href="/quality-printing/services" class="btn btn--secondary">View All Services</a>
      </div>
    </div>
  </section>

  <!-- INFO CALLOUT -->
  <section class="section section--highlight">
    <div class="container">
      <div class="callout">
        <div class="callout__icon">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" rx="2"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        </div>
        <div class="callout__body">
          <h3>Free Local Delivery</h3>
          <p>We offer free local delivery to businesses in the Alexandria area. One less thing to worry about for your next print project.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--cta">
    <div class="container cta-content">
      <h2>Ready to Start Your Print Project?</h2>
      <p>Give us a call or send us a message. We'll help bring your ideas to life.</p>
      <div class="cta-actions">
        <a href="tel:3207620606" class="btn btn--primary btn--lg">Call (320) 762-0606</a>
        <a href="/quality-printing/contact" class="btn btn--outline btn--lg">Contact Us</a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container footer__inner">
      <div class="footer__col">
        <h4>Quality Printing</h4>
        <p>Professional printing services for businesses in Alexandria, MN and the surrounding area. Fast turnaround, friendly service, and free local delivery.</p>
      </div>
      <div class="footer__col">
        <h4>Quick Links</h4>
        <ul>
          <li><a href="/quality-printing">Home</a></li>
          <li><a href="/quality-printing/services">Services</a></li>
          <li><a href="/quality-printing/contact">Contact</a></li>
        </ul>
      </div>
      <div class="footer__col">
        <h4>Contact</h4>
        <p>2020 Fillmore St<br/>Alexandria, MN 56308</p>
        <p><a href="tel:3207620606">(320) 762-0606</a></p>
        <p><a href="mailto:info@qualityprintingmn.com">info@qualityprintingmn.com</a></p>
      </div>
      <div class="footer__col">
        <h4>Hours</h4>
        <table class="footer__hours">
          <tr><td>Mon&ndash;Fri</td><td>8:00 AM &ndash; 5:00 PM</td></tr>
          <tr><td>Sat&ndash;Sun</td><td>Closed</td></tr>
        </table>
      </div>
    </div>
    <div class="footer__bottom">
      <p>&copy; 2026 Quality Printing. All rights reserved.</p>
    </div>
  </footer>

  <script>
    // Sticky nav shadow
    const nav = document.querySelector('.nav');
    window.addEventListener('scroll', () => {
      nav?.classList.toggle('nav--scrolled', window.scrollY > 20);
    });
    // Mobile menu
    document.querySelector('.nav__hamburger')?.addEventListener('click', () => {
      document.querySelector('.nav__links')?.classList.toggle('nav__links--open');
    });
  </script>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --primary: #37474f;
    --accent: #00897b;
    --text: #1a1a1a;
    --text-mid: #555;
    --text-light: #888;
    --bg: #fff;
    --bg-warm: #fafafa;
    --border: #e5e7eb;
  }

  body {
    font-family: 'Inter', -apple-system, sans-serif;
    color: var(--text);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  .container { max-width: 1140px; margin: 0 auto; padding: 0 1.5rem; }

  /* NAV */
  .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: var(--primary);
    transition: box-shadow 0.2s;
  }
  .nav--scrolled { box-shadow: 0 2px 20px rgba(0,0,0,0.15); }
  .nav__inner {
    max-width: 1140px; margin: 0 auto; padding: 0 1.5rem;
    display: flex; align-items: center; justify-content: space-between;
    height: 64px;
  }
  .nav__brand { display: flex; align-items: center; gap: 0.6rem; text-decoration: none; }
  .nav__name { color: #fff; font-weight: 700; font-size: 1.1rem; }
  .nav__links { display: flex; gap: 0.25rem; }
  .nav__link {
    color: rgba(255,255,255,0.75); text-decoration: none; font-size: 0.88rem;
    font-weight: 500; padding: 0.4rem 0.75rem; border-radius: 6px;
    transition: color 0.15s, background 0.15s;
  }
  .nav__link:hover, .nav__link--active { color: #fff; background: rgba(255,255,255,0.1); }
  .nav__cta {
    display: flex; align-items: center; gap: 0.4rem;
    background: var(--accent); color: #fff; text-decoration: none;
    font-size: 0.85rem; font-weight: 600; padding: 0.5rem 1rem;
    border-radius: 6px; transition: opacity 0.15s;
  }
  .nav__cta:hover { opacity: 0.9; }
  .nav__hamburger {
    display: none; background: none; border: none; cursor: pointer;
    flex-direction: column; gap: 5px; padding: 4px;
  }
  .nav__hamburger span {
    display: block; width: 22px; height: 2px; background: #fff;
    border-radius: 1px; transition: 0.2s;
  }

  @media (max-width: 768px) {
    .nav__links {
      display: none; position: absolute; top: 64px; left: 0; right: 0;
      background: var(--primary); flex-direction: column; padding: 1rem;
      box-shadow: 0 8px 20px rgba(0,0,0,0.2);
    }
    .nav__links--open { display: flex; }
    .nav__link { padding: 0.75rem 1rem; }
    .nav__cta { display: none; }
    .nav__hamburger { display: flex; }
  }

  /* HERO */
  .hero {
    position: relative; min-height: 85vh; display: flex; align-items: center;
    padding: 8rem 1.5rem 5rem;
  }
  .hero__bg { position: absolute; inset: 0; }
  .hero__bg-img { width: 100%; height: 100%; object-fit: cover; }
  .hero__overlay {
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(55,71,79,0.88) 0%, rgba(55,71,79,0.7) 100%);
  }
  .hero__content {
    position: relative; max-width: 720px; margin: 0 auto 0 0;
    padding-left: calc((100vw - 1140px) / 2);
  }
  @media (max-width: 1172px) { .hero__content { padding-left: 1.5rem; } }
  .hero__badge {
    display: inline-block; background: var(--accent); color: #fff;
    font-size: 0.78rem; font-weight: 700; letter-spacing: 0.08em;
    text-transform: uppercase; padding: 0.35rem 0.9rem; border-radius: 4px;
    margin-bottom: 1.25rem;
  }
  .hero__title {
    font-size: clamp(2.25rem, 5vw, 3.5rem); font-weight: 900;
    line-height: 1.1; color: #fff; margin-bottom: 1.25rem;
  }
  .hero__desc {
    font-size: 1.1rem; line-height: 1.7; color: rgba(255,255,255,0.85);
    margin-bottom: 2rem; max-width: 560px;
  }
  .hero__actions { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 2.5rem; }
  .hero__stats {
    display: flex; align-items: center; gap: 2rem;
    padding-top: 2rem; border-top: 1px solid rgba(255,255,255,0.15);
  }
  .hero__stat { text-align: center; }
  .hero__stat-num { display: block; font-size: 1.5rem; font-weight: 800; color: var(--accent); }
  .hero__stat-label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.06em; color: rgba(255,255,255,0.6); }
  .hero__stat-divider { width: 1px; height: 40px; background: rgba(255,255,255,0.15); }

  @media (max-width: 480px) {
    .hero { min-height: 70vh; padding: 6rem 1.25rem 3rem; }
    .hero__actions { flex-direction: column; }
    .hero__stats { gap: 1.25rem; }
    .hero__stat-divider { display: none; }
  }

  /* BUTTONS */
  .btn {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-size: 0.92rem; font-weight: 600; text-decoration: none;
    padding: 0.7rem 1.5rem; border-radius: 6px; transition: all 0.15s;
    border: 2px solid transparent; cursor: pointer;
  }
  .btn--primary { background: var(--accent); color: #fff; border-color: var(--accent); }
  .btn--primary:hover { opacity: 0.9; transform: translateY(-1px); }
  .btn--outline { background: transparent; color: #fff; border-color: rgba(255,255,255,0.4); }
  .btn--outline:hover { border-color: #fff; background: rgba(255,255,255,0.1); }
  .btn--secondary { background: var(--primary); color: #fff; }
  .btn--secondary:hover { opacity: 0.9; }
  .btn--lg { padding: 0.85rem 2rem; font-size: 1rem; }

  /* SECTIONS */
  .section { padding: 5rem 0; }
  .section--highlight { background: var(--bg-warm); padding: 3.5rem 0; }
  .section--cta {
    background: linear-gradient(135deg, #00897b 0%, #00695c 100%);
    text-align: center; padding: 4rem 0;
  }
  .eyebrow {
    display: block; font-size: 0.78rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--accent); margin-bottom: 0.5rem;
  }
  .section__title {
    font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 800;
    margin-bottom: 2.5rem; line-height: 1.2;
  }

  /* SERVICES GRID */
  .services-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem; margin-bottom: 2rem;
  }
  .service-card {
    background: #fff; border: 1px solid var(--border); border-radius: 8px;
    padding: 1.75rem; transition: box-shadow 0.2s, transform 0.2s;
    border-top: 4px solid var(--accent);
  }
  .service-card:hover { box-shadow: 0 8px 24px rgba(0,0,0,0.08); transform: translateY(-2px); }
  .service-card__icon {
    width: 48px; height: 48px; border-radius: 10px;
    background: rgba(0,137,123,0.1); color: var(--accent);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 1rem;
  }
  .service-card h3 { font-size: 1.05rem; font-weight: 700; margin-bottom: 0.4rem; }
  .service-card p { font-size: 0.88rem; color: var(--text-mid); line-height: 1.6; }
  .services-more { text-align: center; }

  @media (max-width: 768px) { .services-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .services-grid { grid-template-columns: 1fr; } }

  /* CALLOUT */
  .callout {
    display: flex; align-items: center; gap: 1.5rem;
    background: #fff; border: 1px solid var(--border); border-radius: 10px;
    padding: 2rem 2.5rem; border-left: 4px solid var(--accent);
  }
  .callout__icon {
    flex-shrink: 0; width: 64px; height: 64px; border-radius: 14px;
    background: rgba(0,137,123,0.1); color: var(--accent);
    display: flex; align-items: center; justify-content: center;
  }
  .callout__body h3 { font-size: 1.15rem; font-weight: 700; margin-bottom: 0.35rem; }
  .callout__body p { font-size: 0.95rem; color: var(--text-mid); line-height: 1.6; }

  @media (max-width: 480px) {
    .callout { flex-direction: column; text-align: center; padding: 1.5rem; }
  }

  /* CTA */
  .cta-content h2 { font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 800; color: #fff; margin-bottom: 0.75rem; }
  .cta-content p { font-size: 1.05rem; color: rgba(255,255,255,0.85); margin-bottom: 2rem; }
  .cta-actions { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
  .cta-actions .btn--primary { background: #fff; color: var(--accent); border-color: #fff; }
  .cta-actions .btn--outline { color: #fff; border-color: rgba(255,255,255,0.5); }

  /* FOOTER */
  .footer { background: #1a2025; color: rgba(255,255,255,0.7); padding: 4rem 0 0; }
  .footer__inner { display: grid; grid-template-columns: 1.5fr 1fr 1fr 1fr; gap: 2.5rem; }
  .footer__col h4 { color: #fff; font-size: 0.95rem; font-weight: 700; margin-bottom: 1rem; }
  .footer__col p { font-size: 0.88rem; line-height: 1.65; }
  .footer__col ul { list-style: none; }
  .footer__col li { margin-bottom: 0.4rem; }
  .footer__col a { color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.88rem; transition: color 0.15s; }
  .footer__col a:hover { color: var(--accent); }
  .footer__hours { font-size: 0.85rem; border-collapse: collapse; }
  .footer__hours td { padding: 0.2rem 0; }
  .footer__hours td:first-child { padding-right: 1.25rem; font-weight: 500; color: rgba(255,255,255,0.5); }
  .footer__bottom {
    margin-top: 3rem; padding: 1.25rem 0;
    border-top: 1px solid rgba(255,255,255,0.08); text-align: center;
  }
  .footer__bottom p { font-size: 0.8rem; color: rgba(255,255,255,0.35); }

  @media (max-width: 768px) {
    .footer__inner { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 480px) {
    .footer__inner { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>
</body>
</html>
