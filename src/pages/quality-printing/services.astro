---
import Analytics from '../../components/Analytics.astro';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Services — Quality Printing | Alexandria, MN</title>
  <meta name="description" content="Full printing services in Alexandria, MN. Business cards, brochures, banners, booklets, promotional materials, and custom projects with free local delivery." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <Analytics />
</head>
<body>

  <!-- NAV -->
  <header class="nav">
    <div class="nav__inner">
      <a href="/quality-printing" class="nav__brand">
        <span class="nav__name">Quality Printing</span>
      </a>
      <nav class="nav__links">
        <a href="/quality-printing" class="nav__link">Home</a>
        <a href="/quality-printing/services" class="nav__link nav__link--active">Services</a>
        <a href="/quality-printing/contact" class="nav__link">Contact</a>
      </nav>
      <a href="tel:3207620606" class="nav__cta">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 013.12 4.18 2 2 0 015.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        (320) 762-0606
      </a>
      <button class="nav__hamburger" aria-label="Menu"><span></span><span></span><span></span></button>
    </div>
  </header>

  <!-- PAGE HEADER -->
  <section class="page-header">
    <div class="container">
      <div class="page-header__breadcrumb">
        <a href="/quality-printing">Home</a> <span>/</span> <span>Services</span>
      </div>
      <h1>Our Services</h1>
      <p>From business cards to banners &mdash; we print it all.</p>
    </div>
  </section>

  <!-- SERVICE DETAILS -->
  <section class="section">
    <div class="container">

      <div class="service-detail" id="business-cards">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>Business Cards &amp; Stationery</h2>
          <p>Make a lasting first impression with professionally designed and printed business cards, letterhead, and envelopes. We offer a range of paper stocks and finishes to match your brand identity.</p>
          <ul>
            <li>Custom card designs</li>
            <li>Multiple paper stocks and finishes</li>
            <li>Quick turnaround available</li>
            <li>Matching envelopes and letterhead</li>
          </ul>
        </div>
      </div>

      <div class="service-detail" id="brochures">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>Brochures &amp; Flyers</h2>
          <p>Eye-catching brochures and flyers that get your message across. Perfect for trade shows, mailers, and in-store displays. We handle everything from layout to final print.</p>
          <ul>
            <li>Tri-fold and bi-fold options</li>
            <li>Full color printing</li>
            <li>Various sizes available</li>
            <li>Bulk pricing for large runs</li>
          </ul>
        </div>
      </div>

      <div class="service-detail" id="banners">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>Banners &amp; Signage</h2>
          <p>Big impact printing for events, storefronts, and promotions. Durable materials built to last indoors and out. We can handle any size and quantity.</p>
          <ul>
            <li>Vinyl banners</li>
            <li>Yard signs</li>
            <li>Trade show displays</li>
            <li>Window graphics</li>
          </ul>
        </div>
      </div>

      <div class="service-detail" id="booklets">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>Booklets &amp; Manuals</h2>
          <p>Professional multi-page documents for training, marketing, or reference. We offer multiple binding options and paper weights to suit your project.</p>
          <ul>
            <li>Saddle-stitched binding</li>
            <li>Perfect bound options</li>
            <li>Employee handbooks</li>
            <li>Product catalogs</li>
          </ul>
        </div>
      </div>

      <div class="service-detail" id="promotional">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="5" x2="5" y2="19"/><circle cx="6.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>Promotional Materials</h2>
          <p>Get the word out with printed promotional items. Whether it's a direct mail campaign or event giveaway, we have you covered with fast, affordable printing.</p>
          <ul>
            <li>Postcards</li>
            <li>Door hangers</li>
            <li>Stickers and labels</li>
            <li>Event programs</li>
          </ul>
        </div>
      </div>

      <div class="service-detail" id="custom">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>Custom Projects</h2>
          <p>Have something unique in mind? We love a challenge. From specialty paper and large format printing to die cutting and unusual requests, we'll work with you to make it happen.</p>
          <ul>
            <li>Large format printing</li>
            <li>Specialty paper options</li>
            <li>Die cutting</li>
            <li>Unique and custom requests</li>
          </ul>
        </div>
      </div>

      <!-- NOTE BOX -->
      <div class="note-box">
        <div class="note-box__icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" rx="2"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        </div>
        <p>Free local delivery to businesses in the Alexandria area.</p>
      </div>

    </div>
  </section>

  <!-- CTA -->
  <section class="section section--cta">
    <div class="container cta-content">
      <h2>Ready to Start Your Print Project?</h2>
      <p>Give us a call or send us a message. We'll help bring your ideas to life.</p>
      <div class="cta-actions">
        <a href="tel:3207620606" class="btn btn--primary btn--lg">Call (320) 762-0606</a>
        <a href="/quality-printing/contact" class="btn btn--outline btn--lg">Contact Us</a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container footer__inner">
      <div class="footer__col">
        <h4>Quality Printing</h4>
        <p>Professional printing services for businesses in Alexandria, MN and the surrounding area.</p>
      </div>
      <div class="footer__col">
        <h4>Quick Links</h4>
        <ul>
          <li><a href="/quality-printing">Home</a></li>
          <li><a href="/quality-printing/services">Services</a></li>
          <li><a href="/quality-printing/contact">Contact</a></li>
        </ul>
      </div>
      <div class="footer__col">
        <h4>Contact</h4>
        <p>2020 Fillmore St<br/>Alexandria, MN 56308</p>
        <p><a href="tel:3207620606">(320) 762-0606</a></p>
        <p><a href="mailto:info@qualityprintingmn.com">info@qualityprintingmn.com</a></p>
      </div>
      <div class="footer__col">
        <h4>Hours</h4>
        <table class="footer__hours">
          <tr><td>Mon&ndash;Fri</td><td>8:00 AM &ndash; 5:00 PM</td></tr>
          <tr><td>Sat&ndash;Sun</td><td>Closed</td></tr>
        </table>
      </div>
    </div>
    <div class="footer__bottom">
      <p>&copy; 2026 Quality Printing. All rights reserved.</p>
    </div>
  </footer>

  <script>
    const nav = document.querySelector('.nav');
    window.addEventListener('scroll', () => nav?.classList.toggle('nav--scrolled', window.scrollY > 20));
    document.querySelector('.nav__hamburger')?.addEventListener('click', () => document.querySelector('.nav__links')?.classList.toggle('nav__links--open'));
  </script>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root { --primary: #37474f; --accent: #00897b; --text: #1a1a1a; --text-mid: #555; --bg: #fff; --border: #e5e7eb; }
  body { font-family: 'Inter', -apple-system, sans-serif; color: var(--text); line-height: 1.6; -webkit-font-smoothing: antialiased; }
  .container { max-width: 1140px; margin: 0 auto; padding: 0 1.5rem; }

  /* NAV */
  .nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: var(--primary); transition: box-shadow 0.2s; }
  .nav--scrolled { box-shadow: 0 2px 20px rgba(0,0,0,0.15); }
  .nav__inner { max-width: 1140px; margin: 0 auto; padding: 0 1.5rem; display: flex; align-items: center; justify-content: space-between; height: 64px; }
  .nav__brand { display: flex; align-items: center; gap: 0.6rem; text-decoration: none; }
  .nav__name { color: #fff; font-weight: 700; font-size: 1.1rem; }
  .nav__links { display: flex; gap: 0.25rem; }
  .nav__link { color: rgba(255,255,255,0.75); text-decoration: none; font-size: 0.88rem; font-weight: 500; padding: 0.4rem 0.75rem; border-radius: 6px; transition: color 0.15s, background 0.15s; }
  .nav__link:hover, .nav__link--active { color: #fff; background: rgba(255,255,255,0.1); }
  .nav__cta { display: flex; align-items: center; gap: 0.4rem; background: var(--accent); color: #fff; text-decoration: none; font-size: 0.85rem; font-weight: 600; padding: 0.5rem 1rem; border-radius: 6px; transition: opacity 0.15s; }
  .nav__cta:hover { opacity: 0.9; }
  .nav__hamburger { display: none; background: none; border: none; cursor: pointer; flex-direction: column; gap: 5px; padding: 4px; }
  .nav__hamburger span { display: block; width: 22px; height: 2px; background: #fff; border-radius: 1px; }
  @media (max-width: 768px) {
    .nav__links { display: none; position: absolute; top: 64px; left: 0; right: 0; background: var(--primary); flex-direction: column; padding: 1rem; box-shadow: 0 8px 20px rgba(0,0,0,0.2); }
    .nav__links--open { display: flex; }
    .nav__link { padding: 0.75rem 1rem; }
    .nav__cta { display: none; }
    .nav__hamburger { display: flex; }
  }

  /* PAGE HEADER */
  .page-header { background: var(--primary); padding: 7rem 0 2.5rem; }
  .page-header__breadcrumb { font-size: 0.82rem; color: rgba(255,255,255,0.45); margin-bottom: 0.75rem; }
  .page-header__breadcrumb a { color: rgba(255,255,255,0.6); text-decoration: none; }
  .page-header__breadcrumb a:hover { color: var(--accent); }
  .page-header__breadcrumb span { margin: 0 0.35rem; }
  .page-header h1 { color: #fff; font-size: clamp(1.75rem, 4vw, 2.75rem); font-weight: 800; margin-bottom: 0.5rem; }
  .page-header p { color: rgba(255,255,255,0.7); font-size: 1.05rem; }

  .section { padding: 4.5rem 0; }

  /* SERVICE DETAIL BLOCKS */
  .service-detail {
    display: flex; gap: 1.5rem; padding: 2.25rem 0;
    border-bottom: 1px solid var(--border);
  }
  .service-detail:first-of-type { padding-top: 0; }
  .service-detail__icon {
    flex-shrink: 0; width: 56px; height: 56px; border-radius: 12px;
    background: rgba(0,137,123,0.1); color: var(--accent);
    display: flex; align-items: center; justify-content: center;
  }
  .service-detail__body h2 { font-size: 1.25rem; font-weight: 700; margin-bottom: 0.5rem; }
  .service-detail__body p { font-size: 0.95rem; color: var(--text-mid); line-height: 1.7; margin-bottom: 0.75rem; }
  .service-detail__body ul { list-style: none; display: flex; flex-wrap: wrap; gap: 0.4rem 1.5rem; }
  .service-detail__body li {
    font-size: 0.85rem; color: var(--text-mid); padding-left: 1.1rem;
    position: relative;
  }
  .service-detail__body li::before {
    content: ''; position: absolute; left: 0; top: 0.45rem;
    width: 6px; height: 6px; border-radius: 50%; background: var(--accent);
  }
  @media (max-width: 640px) {
    .service-detail { flex-direction: column; gap: 1rem; }
  }

  /* NOTE BOX */
  .note-box {
    display: flex; align-items: center; gap: 1rem;
    margin-top: 2.5rem; padding: 1.25rem 1.75rem;
    background: rgba(0,137,123,0.06); border: 1px solid rgba(0,137,123,0.15);
    border-radius: 10px;
  }
  .note-box__icon {
    flex-shrink: 0; width: 44px; height: 44px; border-radius: 10px;
    background: rgba(0,137,123,0.1); color: var(--accent);
    display: flex; align-items: center; justify-content: center;
  }
  .note-box p { font-size: 0.95rem; font-weight: 600; color: var(--primary); }
  @media (max-width: 480px) {
    .note-box { flex-direction: column; text-align: center; padding: 1.25rem; }
  }

  /* BUTTONS */
  .btn { display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.92rem; font-weight: 600; text-decoration: none; padding: 0.7rem 1.5rem; border-radius: 6px; transition: all 0.15s; border: 2px solid transparent; cursor: pointer; }
  .btn--primary { background: var(--accent); color: #fff; border-color: var(--accent); }
  .btn--primary:hover { opacity: 0.9; transform: translateY(-1px); }
  .btn--outline { background: transparent; color: #fff; border-color: rgba(255,255,255,0.4); }
  .btn--outline:hover { border-color: #fff; background: rgba(255,255,255,0.1); }
  .btn--lg { padding: 0.85rem 2rem; font-size: 1rem; }

  /* CTA SECTION */
  .section--cta { background: linear-gradient(135deg, #00897b 0%, #00695c 100%); text-align: center; padding: 4rem 0; }
  .cta-content h2 { font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 800; color: #fff; margin-bottom: 0.75rem; }
  .cta-content p { font-size: 1.05rem; color: rgba(255,255,255,0.85); margin-bottom: 2rem; }
  .cta-actions { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
  .cta-actions .btn--primary { background: #fff; color: var(--accent); border-color: #fff; }
  .cta-actions .btn--outline { color: #fff; border-color: rgba(255,255,255,0.5); }

  /* FOOTER */
  .footer { background: #1a2025; color: rgba(255,255,255,0.7); padding: 4rem 0 0; }
  .footer__inner { display: grid; grid-template-columns: 1.5fr 1fr 1fr 1fr; gap: 2.5rem; }
  .footer__col h4 { color: #fff; font-size: 0.95rem; font-weight: 700; margin-bottom: 1rem; }
  .footer__col p { font-size: 0.88rem; line-height: 1.65; }
  .footer__col ul { list-style: none; }
  .footer__col li { margin-bottom: 0.4rem; }
  .footer__col a { color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.88rem; transition: color 0.15s; }
  .footer__col a:hover { color: var(--accent); }
  .footer__hours { font-size: 0.85rem; border-collapse: collapse; }
  .footer__hours td { padding: 0.2rem 0; }
  .footer__hours td:first-child { padding-right: 1.25rem; font-weight: 500; color: rgba(255,255,255,0.5); }
  .footer__bottom { margin-top: 3rem; padding: 1.25rem 0; border-top: 1px solid rgba(255,255,255,0.08); text-align: center; }
  .footer__bottom p { font-size: 0.8rem; color: rgba(255,255,255,0.35); }
  @media (max-width: 768px) { .footer__inner { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 480px) { .footer__inner { grid-template-columns: 1fr; gap: 2rem; } }
</style>
</body>
</html>
