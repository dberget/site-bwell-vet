---
import Analytics from '../../components/Analytics.astro';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Services — Rosengren Lawn Care | Alexandria, MN</title>
  <meta name="description" content="Full lawn care and landscaping services in Alexandria, MN. Mowing, fall clean up, shrub trimming, paver installation, snow removal, and landscaping design." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <Analytics />
</head>
<body>

  <!-- NAV -->
  <header class="nav">
    <div class="nav__inner">
      <a href="/rosengren-lawn" class="nav__brand">
        <img src="/images/rosengren/logo.png" alt="Rosengren Lawn Care" class="nav__logo" />
        <span class="nav__name">Rosengren Lawn Care</span>
      </a>
      <nav class="nav__links">
        <a href="/rosengren-lawn" class="nav__link">Home</a>
        <a href="/rosengren-lawn/services" class="nav__link nav__link--active">Services</a>
        <a href="/rosengren-lawn/contact" class="nav__link">Contact</a>
      </nav>
      <a href="tel:3208153217" class="nav__cta">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 013.12 4.18 2 2 0 015.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        (320) 815-3217
      </a>
      <button class="nav__hamburger" aria-label="Menu"><span></span><span></span><span></span></button>
    </div>
  </header>

  <!-- PAGE HEADER -->
  <section class="page-header">
    <div class="container">
      <div class="page-header__breadcrumb">
        <a href="/rosengren-lawn">Home</a> <span>/</span> <span>Services</span>
      </div>
      <h1>Our Services</h1>
      <p>Comprehensive lawn care, landscaping, and seasonal services for Alexandria and the surrounding area.</p>
    </div>
  </section>

  <!-- ALL SERVICES -->
  <section class="section">
    <div class="container">

      <div class="service-detail" id="lawn-care">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v8l4-2"/><path d="M8.5 2.5C5.1 3.9 3 7 3 11c0 5 4 9 9 9s9-4 9-9c0-4-2.1-7.1-5.5-8.5"/><path d="M12 10c-2.2 0-4 1.8-4 4"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>Lawn Care</h2>
          <p>Keep your lawn looking its best with our professional mowing and maintenance programs. We tailor our approach to your lawn's specific needs, ensuring healthy growth and a clean, manicured appearance throughout the growing season.</p>
          <ul>
            <li>Weekly and biweekly mowing programs</li>
            <li>Precision edging along walks and drives</li>
            <li>String trimming around obstacles and beds</li>
            <li>Seasonal maintenance programs</li>
          </ul>
        </div>
      </div>

      <div class="service-detail" id="fall-cleanup">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 019.8 6.9C15.5 4.9 17 3 17 3s2 5-2.2 7.5"/><path d="M11.2 13.8V20"/><path d="M7 16.5c2.1-1 4.2-1 6.3 0"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>Fall Clean Up</h2>
          <p>Prepare your property for winter with our thorough fall cleanup services. We remove leaves, clean out garden beds, and get your landscape ready to weather the cold Minnesota months so it comes back strong in spring.</p>
          <ul>
            <li>Complete leaf removal and disposal</li>
            <li>Garden bed cleanup and trimming</li>
            <li>Gutter clearing of leaves and debris</li>
            <li>Winterizing preparation for beds and plants</li>
          </ul>
        </div>
      </div>

      <div class="service-detail" id="shrub-trimming">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="3"/><path d="M8.12 8.12L12 12"/><circle cx="18" cy="18" r="3"/><path d="M15.88 15.88L12 12"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>Shrub Trimming</h2>
          <p>Well-maintained shrubs and hedges make a huge difference in your property's curb appeal. Our team shapes, prunes, and trims your shrubs to promote healthy growth while keeping them looking neat and defined.</p>
          <ul>
            <li>Decorative shaping and sculpting</li>
            <li>Seasonal pruning for healthy growth</li>
            <li>Hedge maintenance and leveling</li>
            <li>Plant health assessment and care</li>
          </ul>
        </div>
      </div>

      <div class="service-detail" id="pavers">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>Paver Installation</h2>
          <p>Transform your outdoor space with custom hardscaping. From patios to walkways to retaining walls, we handle every step of the process -- from design and grading to installation and finishing -- to create durable, beautiful outdoor features.</p>
          <ul>
            <li>Custom patio design and installation</li>
            <li>Walkways and garden paths</li>
            <li>Retaining walls and borders</li>
            <li>Drainage solutions and grading</li>
          </ul>
        </div>
      </div>

      <div class="service-detail" id="snow-removal">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 17.58A5 5 0 0018 8h-1.26A8 8 0 104 16.25"/><path d="M8 16h.01"/><path d="M8 20h.01"/><path d="M12 18h.01"/><path d="M12 22h.01"/><path d="M16 16h.01"/><path d="M16 20h.01"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>Snow Removal</h2>
          <p>Don't let Minnesota winters slow you down. We provide reliable snow removal for both residential and commercial properties, keeping driveways, parking lots, and walkways clear and safe throughout the season.</p>
          <ul>
            <li>Residential driveway plowing</li>
            <li>Commercial lot and parking area plowing</li>
            <li>Sidewalk and walkway shoveling</li>
            <li>Salt and sand application for ice control</li>
          </ul>
        </div>
      </div>

      <div class="service-detail" id="landscaping">
        <div class="service-detail__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22V8"/><path d="M5 12H2a10 10 0 0020 0h-3"/><path d="M8 5.2C9 4 10.5 3 12 3s3 1 4 2.2"/><circle cx="12" cy="5" r="2"/></svg>
        </div>
        <div class="service-detail__body">
          <h2>Landscaping</h2>
          <p>Whether you're starting from scratch or refreshing an existing landscape, we offer complete design and installation services. We work with you to create outdoor spaces that match your vision, lifestyle, and budget.</p>
          <ul>
            <li>Design consultation and planning</li>
            <li>Tree, shrub, and perennial planting</li>
            <li>Mulching and bed edging</li>
            <li>New bed creation and grading</li>
            <li>Landscape renovation and refresh</li>
          </ul>
        </div>
      </div>

    </div>
  </section>

  <!-- CTA -->
  <section class="section section--cta">
    <div class="container cta-content">
      <h2>Ready to Get Started?</h2>
      <p>Call us today for a free estimate. No job is too big or too small.</p>
      <div class="cta-actions">
        <a href="tel:3208153217" class="btn btn--primary btn--lg">Call (320) 815-3217</a>
        <a href="/rosengren-lawn/contact" class="btn btn--outline btn--lg">Contact Us</a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container footer__inner">
      <div class="footer__col">
        <h4>Rosengren Lawn Care</h4>
        <p>Professional lawn care and landscaping in Alexandria, MN. 25+ years of experience.</p>
        <div class="footer__social">
          <a href="https://facebook.com/ryguythelawnguy" target="_blank" rel="noopener" aria-label="Facebook">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
          </a>
        </div>
      </div>
      <div class="footer__col">
        <h4>Quick Links</h4>
        <ul>
          <li><a href="/rosengren-lawn">Home</a></li>
          <li><a href="/rosengren-lawn/services">Services</a></li>
          <li><a href="/rosengren-lawn/contact">Contact</a></li>
        </ul>
      </div>
      <div class="footer__col">
        <h4>Contact</h4>
        <p>Alexandria, MN 56308</p>
        <p><a href="tel:3208153217">(320) 815-3217</a></p>
        <p><a href="https://facebook.com/ryguythelawnguy" target="_blank" rel="noopener">Facebook</a></p>
      </div>
      <div class="footer__col">
        <h4>Seasonal Note</h4>
        <p>We offer snow removal services during the winter months. Contact us for residential and commercial plowing availability.</p>
      </div>
    </div>
    <div class="footer__bottom">
      <p>&copy; 2026 Rosengren Lawn Care. All rights reserved.</p>
    </div>
  </footer>

  <script>
    const nav = document.querySelector('.nav');
    window.addEventListener('scroll', () => nav?.classList.toggle('nav--scrolled', window.scrollY > 20));
    document.querySelector('.nav__hamburger')?.addEventListener('click', () => document.querySelector('.nav__links')?.classList.toggle('nav__links--open'));
  </script>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root { --primary: #33691e; --accent: #e65100; --text: #1a1a1a; --text-mid: #555; --bg: #fff; --border: #e5e7eb; }
  body { font-family: 'Inter', -apple-system, sans-serif; color: var(--text); line-height: 1.6; -webkit-font-smoothing: antialiased; }
  .container { max-width: 1140px; margin: 0 auto; padding: 0 1.5rem; }

  .nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: var(--primary); transition: box-shadow 0.2s; }
  .nav--scrolled { box-shadow: 0 2px 20px rgba(0,0,0,0.15); }
  .nav__inner { max-width: 1140px; margin: 0 auto; padding: 0 1.5rem; display: flex; align-items: center; justify-content: space-between; height: 64px; }
  .nav__brand { display: flex; align-items: center; gap: 0.6rem; text-decoration: none; }
  .nav__logo { height: 36px; width: auto; }
  .nav__name { color: #fff; font-weight: 700; font-size: 1.1rem; }
  .nav__links { display: flex; gap: 0.25rem; }
  .nav__link { color: rgba(255,255,255,0.75); text-decoration: none; font-size: 0.88rem; font-weight: 500; padding: 0.4rem 0.75rem; border-radius: 6px; transition: color 0.15s, background 0.15s; }
  .nav__link:hover, .nav__link--active { color: #fff; background: rgba(255,255,255,0.1); }
  .nav__cta { display: flex; align-items: center; gap: 0.4rem; background: var(--accent); color: #fff; text-decoration: none; font-size: 0.85rem; font-weight: 600; padding: 0.5rem 1rem; border-radius: 6px; transition: opacity 0.15s; }
  .nav__cta:hover { opacity: 0.9; }
  .nav__hamburger { display: none; background: none; border: none; cursor: pointer; flex-direction: column; gap: 5px; padding: 4px; }
  .nav__hamburger span { display: block; width: 22px; height: 2px; background: #fff; border-radius: 1px; }
  @media (max-width: 768px) {
    .nav__links { display: none; position: absolute; top: 64px; left: 0; right: 0; background: var(--primary); flex-direction: column; padding: 1rem; box-shadow: 0 8px 20px rgba(0,0,0,0.2); }
    .nav__links--open { display: flex; }
    .nav__link { padding: 0.75rem 1rem; }
    .nav__cta { display: none; }
    .nav__hamburger { display: flex; }
  }

  /* PAGE HEADER */
  .page-header { background: var(--primary); padding: 7rem 0 2.5rem; }
  .page-header__breadcrumb { font-size: 0.82rem; color: rgba(255,255,255,0.45); margin-bottom: 0.75rem; }
  .page-header__breadcrumb a { color: rgba(255,255,255,0.6); text-decoration: none; }
  .page-header__breadcrumb a:hover { color: var(--accent); }
  .page-header__breadcrumb span { margin: 0 0.35rem; }
  .page-header h1 { color: #fff; font-size: clamp(1.75rem, 4vw, 2.75rem); font-weight: 800; margin-bottom: 0.5rem; }
  .page-header p { color: rgba(255,255,255,0.7); font-size: 1.05rem; }

  .section { padding: 4.5rem 0; }

  /* SERVICE DETAIL BLOCKS */
  .service-detail {
    display: flex; gap: 1.5rem; padding: 2.25rem 0;
    border-bottom: 1px solid var(--border);
  }
  .service-detail:first-of-type { padding-top: 0; }
  .service-detail__icon {
    flex-shrink: 0; width: 56px; height: 56px; border-radius: 12px;
    background: rgba(230,81,0,0.08); color: var(--accent);
    display: flex; align-items: center; justify-content: center;
  }
  .service-detail__body h2 { font-size: 1.25rem; font-weight: 700; margin-bottom: 0.5rem; }
  .service-detail__body p { font-size: 0.95rem; color: var(--text-mid); line-height: 1.7; margin-bottom: 0.75rem; }
  .service-detail__body ul { list-style: none; display: flex; flex-wrap: wrap; gap: 0.4rem 1.5rem; }
  .service-detail__body li {
    font-size: 0.85rem; color: var(--text-mid); padding-left: 1.1rem;
    position: relative;
  }
  .service-detail__body li::before {
    content: ''; position: absolute; left: 0; top: 0.45rem;
    width: 6px; height: 6px; border-radius: 50%; background: var(--accent);
  }
  @media (max-width: 640px) {
    .service-detail { flex-direction: column; gap: 1rem; }
  }

  .btn { display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.92rem; font-weight: 600; text-decoration: none; padding: 0.7rem 1.5rem; border-radius: 6px; transition: all 0.15s; border: 2px solid transparent; cursor: pointer; }
  .btn--primary { background: var(--accent); color: #fff; border-color: var(--accent); }
  .btn--primary:hover { opacity: 0.9; }
  .btn--outline { background: transparent; color: #fff; border-color: rgba(255,255,255,0.4); }
  .btn--outline:hover { border-color: #fff; background: rgba(255,255,255,0.1); }
  .btn--lg { padding: 0.85rem 2rem; font-size: 1rem; }

  .section--cta { background: linear-gradient(135deg, var(--accent) 0%, #bf360c 100%); text-align: center; padding: 4rem 0; }
  .cta-content h2 { font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 800; color: #fff; margin-bottom: 0.75rem; }
  .cta-content p { font-size: 1.05rem; color: rgba(255,255,255,0.85); margin-bottom: 2rem; }
  .cta-actions { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
  .cta-actions .btn--primary { background: #fff; color: var(--accent); border-color: #fff; }
  .cta-actions .btn--outline { color: #fff; border-color: rgba(255,255,255,0.5); }

  .footer { background: #1a2110; color: rgba(255,255,255,0.7); padding: 4rem 0 0; }
  .footer__inner { display: grid; grid-template-columns: 1.5fr 1fr 1fr 1fr; gap: 2.5rem; }
  .footer__col h4 { color: #fff; font-size: 0.95rem; font-weight: 700; margin-bottom: 1rem; }
  .footer__col p { font-size: 0.88rem; line-height: 1.65; }
  .footer__col ul { list-style: none; }
  .footer__col li { margin-bottom: 0.4rem; }
  .footer__col a { color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.88rem; transition: color 0.15s; }
  .footer__col a:hover { color: var(--accent); }
  .footer__social { display: flex; gap: 0.75rem; margin-top: 1rem; }
  .footer__social a { color: rgba(255,255,255,0.5); transition: color 0.15s; }
  .footer__social a:hover { color: var(--accent); }
  .footer__bottom { margin-top: 3rem; padding: 1.25rem 0; border-top: 1px solid rgba(255,255,255,0.08); text-align: center; }
  .footer__bottom p { font-size: 0.8rem; color: rgba(255,255,255,0.35); }
  @media (max-width: 768px) { .footer__inner { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 480px) { .footer__inner { grid-template-columns: 1fr; gap: 2rem; } }
</style>
</body>
</html>