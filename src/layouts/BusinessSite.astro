---
import type { SiteContent } from '../schema/content';

interface Props {
  site: SiteContent;
}

const { site } = Astro.props;
const { business, contact, hours, services, team, testimonials, announcements, seo } = site;
const featuredServices = services.filter((s) => s.featured);
const activeAnnouncements = announcements.filter((a) => a.active);
const fullAddress = `${contact.address.street}, ${contact.address.city}, ${contact.address.state} ${contact.address.zip}`;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

function formatHours(open: string, close: string): string {
  const fmt = (t: string) => {
    const [h, m] = t.split(':').map(Number);
    const suffix = h >= 12 ? 'PM' : 'AM';
    const hour12 = h % 12 || 12;
    return m === 0 ? `${hour12} ${suffix}` : `${hour12}:${m.toString().padStart(2, '0')} ${suffix}`;
  };
  return `${fmt(open)} – ${fmt(close)}`;
}

function capitalize(s: string): string {
  return s.charAt(0).toUpperCase() + s.slice(1);
}

const socialIcons: Record<string, string> = {
  facebook: `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>`,
  nextdoor: `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm4.5 14.5h-3v-4.25a1.5 1.5 0 0 0-3 0v4.25h-3V10h3v1.2a3.5 3.5 0 0 1 6 2.45V16.5z"/></svg>`,
  yelp: `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12.622 11.076l-3.23-5.283c-.3-.49-.1-.89.44-1.08l4.1-1.43c.54-.19.94.07.98.63l.31 5.93c.03.56-.39.87-.87.64l-1.73-.41zm-1.25 2.2l-5.51 1.76c-.55.18-.68.62-.33 1.03l2.62 3.07c.35.41.82.39 1.1-.05l2.89-4.78c.28-.46.05-.9-.46-1.04l-.31-.01zm3.63.56l2.3 4.98c.23.5.67.56 1.05.18l2.84-2.84c.38-.38.32-.82-.14-1.06l-5.05-2.58c-.46-.24-.92.03-1 .54v.78zm-1.88-1.67l5.32-2.36c.53-.24.58-.68.15-1.04l-3.23-2.7c-.43-.36-.89-.26-1.09.23l-2.1 5.06c-.2.49.12.9.65.89l.3-.08z"/></svg>`,
  instagram: `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>`,
  twitter: `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
  linkedin: `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  youtube: `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814z"/><path fill="#fff" d="M9.545 15.568V8.432L15.818 12z"/></svg>`,
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="icon" href={`${base}favicon.ico`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    {seo.keywords && <meta name="keywords" content={seo.keywords.join(', ')} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Source+Sans+3:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style set:html={`:root { --primary: ${business.primaryColor ?? '#2c5f7c'}; --accent: ${business.accentColor ?? '#d4853e'}; }`}></style>
  </head>

  <body>
    <!-- Announcements Banner -->
    {activeAnnouncements.length > 0 && (
      <div class="announcements">
        {activeAnnouncements.map((a) => (
          <div class={`announcement announcement--${a.type}`}>
            <span class="announcement__badge">{a.type === 'promo' ? 'Special' : a.type === 'warning' ? 'Alert' : 'Notice'}</span>
            <span><strong>{a.title}</strong> &mdash; {a.body}</span>
          </div>
        ))}
      </div>
    )}

    <!-- Navigation -->
    <nav class="nav">
      <div class="container nav__inner">
        <a href="#" class="nav__brand">{business.name}</a>
        <div class="nav__links">
          <a href="#services">Services</a>
          <a href="#testimonials">Reviews</a>
          {team.length > 0 && <a href="#team">Our Team</a>}
          <a href="#contact">Contact</a>
        </div>
        <a href={`tel:${contact.phone.replace(/\D/g, '')}`} class="nav__phone">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          {contact.phone}
        </a>
      </div>
    </nav>

    <main>
      <!-- Hero -->
      <section class="hero">
        <div class="hero__accent-bar"></div>
        <div class="container hero__content">
          <p class="hero__tagline">{business.tagline}</p>
          <h1 class="hero__title">{business.name}</h1>
          <p class="hero__description">{business.description}</p>
          <div class="hero__actions">
            <a href={`tel:${contact.phone.replace(/\D/g, '')}`} class="btn btn--primary">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
              Call Us Today
            </a>
            <a href={`mailto:${contact.email}`} class="btn btn--secondary">
              Send an Email
            </a>
          </div>
        </div>
      </section>

      <!-- Services -->
      <section class="section" id="services">
        <div class="container">
          <div class="section__header">
            <h2 class="section__title">Our Services</h2>
            <div class="section__rule"></div>
          </div>
          <div class="services-grid">
            {featuredServices.map((service) => (
              <div class="service-card">
                {service.icon && <span class="service-card__icon">{service.icon}</span>}
                <h3 class="service-card__name">{service.name}</h3>
                <p class="service-card__desc">{service.description}</p>
              </div>
            ))}
          </div>
          {services.length > featuredServices.length && (
            <div class="also-offer">
              <p class="also-offer__label">We also offer:</p>
              <p class="also-offer__list">
                {services.filter((s) => !s.featured).map((s, i, arr) => (
                  <span>{s.icon && <span>{s.icon} </span>}{s.name}{i < arr.length - 1 ? <span class="also-offer__sep"> · </span> : ''}</span>
                ))}
              </p>
            </div>
          )}
        </div>
      </section>

      <!-- Testimonials -->
      <section class="section section--warm" id="testimonials">
        <div class="container">
          <div class="section__header">
            <h2 class="section__title">What Our Customers Say</h2>
            <div class="section__rule"></div>
          </div>
          <div class="testimonials-grid">
            {testimonials.map((t) => (
              <blockquote class="testimonial">
                <div class="testimonial__quote-mark">&ldquo;</div>
                {t.rating && (
                  <div class="testimonial__stars" aria-label={`${t.rating} out of 5 stars`}>
                    {Array.from({length: 5}).map((_, idx) => (
                      <svg width="15" height="15" viewBox="0 0 24 24" fill={idx < t.rating! ? 'var(--accent)' : '#ddd'}>
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                      </svg>
                    ))}
                  </div>
                )}
                <p class="testimonial__text">{t.text}</p>
                <footer class="testimonial__footer">
                  <cite class="testimonial__author">&mdash; {t.author}</cite>
                  {t.source && <span class="testimonial__source">{t.source}</span>}
                </footer>
              </blockquote>
            ))}
          </div>
        </div>
      </section>

      <!-- Team -->
      {team.length > 0 && (
        <section class="section" id="team">
          <div class="container">
            <div class="section__header">
              <h2 class="section__title">Meet Our Team</h2>
              <div class="section__rule"></div>
            </div>
            <div class="team-grid">
              {team.map((member) => (
                <div class="team-card">
                  <div class="team-card__avatar">
                    <span>{member.name.split(' ').map((n) => n[0]).join('')}</span>
                  </div>
                  <h3 class="team-card__name">{member.name}</h3>
                  <p class="team-card__role">{member.role}</p>
                  {member.bio && <p class="team-card__bio">{member.bio}</p>}
                </div>
              ))}
            </div>
          </div>
        </section>
      )}

      <!-- Hours & Contact -->
      <section class="section section--warm" id="contact">
        <div class="container">
          <div class="section__header">
            <h2 class="section__title">Hours &amp; Contact</h2>
            <div class="section__rule"></div>
          </div>
          <div class="contact-grid">
            <div class="contact-card">
              <h3 class="contact-card__title">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                Business Hours
              </h3>
              <table class="hours-table">
                <tbody>
                  {hours.regular.map((day) => (
                    <tr class={day.closed ? 'closed' : ''}>
                      <td>{capitalize(day.day)}</td>
                      <td>{day.closed ? 'Closed' : formatHours(day.open, day.close)}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
              {hours.note && <p class="hours-note">{hours.note}</p>}
            </div>
            <div class="contact-card">
              <h3 class="contact-card__title">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                Get in Touch
              </h3>
              <div class="contact-items">
                <a href={`tel:${contact.phone.replace(/\D/g, '')}`} class="contact-item">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
                  <div>
                    <span class="contact-item__label">Phone</span>
                    <span class="contact-item__value">{contact.phone}</span>
                  </div>
                </a>
                <a href={`mailto:${contact.email}`} class="contact-item">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                  <div>
                    <span class="contact-item__label">Email</span>
                    <span class="contact-item__value">{contact.email}</span>
                  </div>
                </a>
                <div class="contact-item">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                  <div>
                    <span class="contact-item__label">Address</span>
                    <span class="contact-item__value">{fullAddress}</span>
                  </div>
                </div>
              </div>
              {contact.socials && (
                <div class="social-links">
                  {Object.entries(contact.socials).map(([key, url]) => url && (
                    <a href={url} target="_blank" rel="noopener noreferrer" class="social-link" aria-label={capitalize(key)}>
                      <Fragment set:html={socialIcons[key] ?? ''} />
                      <span>{capitalize(key)}</span>
                    </a>
                  ))}
                </div>
              )}
            </div>
          </div>
        </div>
      </section>
    </main>

    <!-- Footer -->
    <footer class="footer">
      <div class="container footer__inner">
        <p class="footer__name">{business.name}</p>
        <p class="footer__address">{fullAddress} &middot; {contact.phone}</p>
        <p class="footer__copy">&copy; {new Date().getFullYear()} {business.name}. All rights reserved.</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  /* ========================================
     RESET & FOUNDATIONS
     ======================================== */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html {
    font-family: 'Source Sans 3', 'Segoe UI', system-ui, sans-serif;
    font-size: 16px;
    line-height: 1.65;
    color: #333;
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
  }

  body { background: #fff; overflow-x: hidden; }

  a { color: var(--primary); text-decoration: none; }
  a:hover { text-decoration: underline; }

  img { max-width: 100%; height: auto; display: block; }

  .container { max-width: 1060px; margin: 0 auto; padding: 0 1.5rem; }

  :root {
    --primary-soft: color-mix(in srgb, var(--primary) 10%, #fff);
    --primary-mid: color-mix(in srgb, var(--primary) 85%, #000);
    --accent-soft: color-mix(in srgb, var(--accent) 12%, #fff);
    --text: #333;
    --text-muted: #666;
    --text-light: #999;
    --bg: #ffffff;
    --bg-warm: #f9f8f6;
    --border: #e5e2dd;
    --border-light: #eeecea;
  }

  /* ========================================
     ANNOUNCEMENTS
     ======================================== */
  .announcements { background: var(--primary-mid); }

  .announcement {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    padding: 0.5rem 1.5rem;
    font-size: 0.875rem;
    color: #fff;
    text-align: center;
    flex-wrap: wrap;
  }

  .announcement__badge {
    display: inline-block;
    padding: 0.1rem 0.55rem;
    border-radius: 3px;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background: rgba(255,255,255,0.2);
  }

  .announcement--promo { background: var(--accent); color: #fff; }
  .announcement--promo .announcement__badge { background: rgba(0,0,0,0.15); }
  .announcement--warning { background: #c0392b; }

  /* ========================================
     NAVIGATION
     ======================================== */
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: #fff;
    border-bottom: 1px solid var(--border);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    height: 64px;
  }

  .nav__brand {
    font-family: 'Lora', Georgia, serif;
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--text);
    text-decoration: none;
    white-space: nowrap;
  }

  .nav__brand:hover { color: var(--text); text-decoration: none; }

  .nav__links {
    display: flex;
    gap: 0.25rem;
  }

  .nav__links a {
    padding: 0.4rem 0.75rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-muted);
    border-radius: 4px;
    text-decoration: none;
    transition: color 0.15s, background 0.15s;
  }

  .nav__links a:hover {
    color: var(--primary);
    background: var(--primary-soft);
    text-decoration: none;
  }

  .nav__phone {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--primary);
    white-space: nowrap;
    text-decoration: none;
  }

  .nav__phone:hover { text-decoration: none; opacity: 0.85; }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    position: relative;
    padding: 4.5rem 0 4rem;
    background: var(--bg-warm);
    border-bottom: 1px solid var(--border-light);
  }

  .hero__accent-bar {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: var(--primary);
  }

  .hero__content {
    max-width: 640px;
  }

  .hero__tagline {
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .hero__title {
    font-family: 'Lora', Georgia, serif;
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 700;
    line-height: 1.15;
    color: var(--text);
    margin-bottom: 1rem;
  }

  .hero__description {
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--text-muted);
    margin-bottom: 2rem;
    max-width: 540px;
  }

  .hero__actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }

  /* ========================================
     BUTTONS
     ======================================== */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.7rem 1.5rem;
    border-radius: 5px;
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
    cursor: pointer;
    transition: opacity 0.15s, box-shadow 0.15s;
    border: none;
  }

  .btn:hover { text-decoration: none; }

  .btn--primary {
    background: var(--primary);
    color: #fff;
  }

  .btn--primary:hover {
    opacity: 0.9;
    color: #fff;
  }

  .btn--secondary {
    background: #fff;
    color: var(--primary);
    border: 1px solid var(--border);
