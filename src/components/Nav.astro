---
import type { SiteContent, PageDef } from '../schema/content';

interface Props {
  site: SiteContent;
  pages?: Record<string, PageDef>;
  currentPage: string;
  theme?: string;
  slug: string;
}

const { site, pages, currentPage, theme = 'default', slug } = Astro.props;
const { business, contact } = site;
const phoneDigits = contact.phone.replace(/\D/g, '');
const logo = business.logo;
const pageEntries = pages ? Object.entries(pages) : [];
---

<nav class={`site-nav site-nav--${theme}`} id="siteNav">
  <div class="site-nav__inner">
    <a href={`/${slug}`} class="site-nav__brand">
      {logo ? (
        <img src={logo} alt={business.name} class="site-nav__logo" />
      ) : (
        <span class="site-nav__name">{business.name}</span>
      )}
    </a>

    <button class="site-nav__toggle" aria-label="Open menu" id="navMenuToggle">
      <span></span>
      <span></span>
      <span></span>
    </button>

    {pageEntries.length > 0 && (
      <div class="site-nav__links" id="navMenuLinks">
        {pageEntries.map(([key, page]) => {
          const href = key === 'home' ? `/${slug}` : `/${slug}/${key}`;
          const isActive = key === currentPage;
          return (
            <a href={href} class:list={['site-nav__link', { 'site-nav__link--active': isActive }]}>
              {page.title}
            </a>
          );
        })}
      </div>
    )}

    <a href={`tel:${phoneDigits}`} class="site-nav__cta">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
      {site.ui?.nav?.ctaLabel || 'Call Now'}
    </a>
  </div>
</nav>

<script>
  (() => {
    const toggle = document.getElementById('navMenuToggle');
    const links = document.getElementById('navMenuLinks');
    if (toggle && links) {
      toggle.addEventListener('click', () => {
        links.classList.toggle('site-nav__links--open');
        toggle.classList.toggle('site-nav__toggle--active');
      });
      links.querySelectorAll('a').forEach((a) => {
        a.addEventListener('click', () => {
          links.classList.remove('site-nav__links--open');
          toggle.classList.remove('site-nav__toggle--active');
        });
      });
    }

    const nav = document.getElementById('siteNav');
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          nav?.classList.toggle('site-nav--scrolled', window.scrollY > 40);
          ticking = false;
        });
        ticking = true;
      }
    });
  })();
</script>

<style is:global>
  /* ===== SHARED NAV ===== */
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--primary, var(--maroon, #6b1d2a));
    transition: box-shadow 0.25s;
  }

  .site-nav--scrolled {
    box-shadow: 0 2px 16px rgba(0,0,0,0.2);
  }

  .site-nav__inner {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    height: 68px;
  }

  .site-nav__brand {
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .site-nav__logo {
    height: 44px;
    width: auto;
    object-fit: contain;
  }

  .site-nav__name {
    font-size: 1.15rem;
    font-weight: 700;
    color: #fff;
    white-space: nowrap;
  }

  .site-nav__links {
    display: flex;
    align-items: center;
    gap: 0.15rem;
  }

  .site-nav__link {
    padding: 0.4rem 0.85rem;
    font-size: 0.88rem;
    font-weight: 500;
    color: rgba(255,255,255,0.8);
    border-radius: 4px;
    transition: color 0.15s, background 0.15s;
    white-space: nowrap;
  }

  .site-nav__link:hover {
    color: #fff;
    background: rgba(255,255,255,0.1);
  }

  .site-nav__link--active {
    color: #fff;
    background: rgba(255,255,255,0.12);
  }

  .site-nav__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 1.15rem;
    background: var(--yellow, #ffd700);
    color: var(--primary, var(--navy, #1a2744));
    font-weight: 700;
    font-size: 0.85rem;
    border-radius: 4px;
    white-space: nowrap;
    transition: background 0.15s, opacity 0.15s;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .site-nav__cta:hover {
    opacity: 0.9;
  }

  /* Toggle (mobile) */
  .site-nav__toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }

  .site-nav__toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: #fff;
    border-radius: 1px;
    transition: transform 0.25s, opacity 0.25s;
  }

  .site-nav__toggle--active span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .site-nav__toggle--active span:nth-child(2) { opacity: 0; }
  .site-nav__toggle--active span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* ===== THEME: SUSPENDED ===== */
  .site-nav--suspended {
    background: #fff;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }

  .site-nav--suspended .site-nav__name {
    color: var(--text, #2c2c2c);
  }

  .site-nav--suspended .site-nav__link {
    color: var(--text-mid, #555);
  }

  .site-nav--suspended .site-nav__link:hover {
    color: var(--primary, var(--maroon, #6b1d2a));
    background: rgba(0,0,0,0.04);
  }

  .site-nav--suspended .site-nav__link--active {
    color: var(--primary, var(--maroon, #6b1d2a));
    background: rgba(0,0,0,0.05);
  }

  .site-nav--suspended .site-nav__cta {
    background: var(--primary, var(--maroon, #6b1d2a));
    color: #fff;
    border-radius: 100px;
  }

  .site-nav--suspended .site-nav__toggle span {
    background: var(--text, #2c2c2c);
  }

  .site-nav--suspended.site-nav--scrolled {
    box-shadow: 0 2px 12px rgba(0,0,0,0.08);
  }

  /* ===== THEME: EDITORIAL ===== */
  .site-nav--editorial {
    background: #111;
  }

  .site-nav--editorial .site-nav__link {
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.8rem;
    font-weight: 700;
  }

  .site-nav--editorial .site-nav__link:hover {
    color: var(--yellow, #ffd700);
    background: transparent;
  }

  .site-nav--editorial .site-nav__link--active {
    color: var(--yellow, #ffd700);
    background: transparent;
  }

  .site-nav--editorial .site-nav__cta {
    border-radius: 2px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.8rem;
  }

  /* ===== THEME: BOLD ===== */
  .site-nav--bold {
    background: var(--primary, var(--maroon, #6b1d2a));
  }

  .site-nav--bold .site-nav__link {
    text-transform: uppercase;
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.05em;
  }

  .site-nav--bold .site-nav__cta {
    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* ===== MOBILE ===== */
  @media (max-width: 768px) {
    .site-nav__toggle { display: flex; }

    .site-nav__links {
      display: none;
      position: absolute;
      top: 68px;
      left: 0;
      right: 0;
      background: inherit;
      flex-direction: column;
      padding: 0.5rem 1.5rem 1rem;
      border-top: 1px solid rgba(255,255,255,0.08);
      box-shadow: 0 8px 20px rgba(0,0,0,0.2);
    }

    .site-nav--suspended .site-nav__links {
      background: #fff;
      border-top-color: rgba(0,0,0,0.06);
      box-shadow: 0 8px 20px rgba(0,0,0,0.08);
    }

    .site-nav__links--open { display: flex; }

    .site-nav__link {
      padding: 0.75rem 0.5rem;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      width: 100%;
    }

    .site-nav--suspended .site-nav__link {
      border-bottom-color: rgba(0,0,0,0.05);
    }

    .site-nav__cta { display: none; }
  }
</style>
