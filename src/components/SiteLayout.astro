---
/**
 * Shared layout for all business site pages.
 * Used by both the catch-all [slug]/[...page].astro route and
 * any legacy individual page files that still exist.
 */
import type { SiteContent, PageDef } from '../schema/content';
import Analytics from './Analytics.astro';
import Nav from './Nav.astro';
import Footer from './Footer.astro';
import SectionRenderer from './SectionRenderer.astro';

interface Props {
  site: SiteContent;
  theme?: string;
  pages: Record<string, PageDef>;
  currentPage: string;
  pageSections: { type: string; props?: Record<string, any> }[];
  pageTitle: string;
  slug: string;
}

const { site, theme = 'default', pages, currentPage, pageSections, pageTitle, slug } = Astro.props;
const { seo, ui, business } = site;

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const primary = business.primaryColor || '#6b1d2a';
const accent = business.accentColor || '#ffd700';

const titleSuffix = business.name;
const fullTitle = currentPage === 'home'
  ? (seo?.title || titleSuffix)
  : `${pageTitle} | ${titleSuffix}`;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />
  <title>{fullTitle}</title>
  <meta name="description" content={seo?.description || ''} />
  {seo?.keywords && <meta name="keywords" content={seo.keywords.join(', ')} />}
  {business.favicon
    ? <link rel="icon" href={business.favicon} />
    : <>
        <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
        <link rel="icon" href={`${base}favicon.ico`} />
      </>
  }
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bitter:wght@400;500;600;700;800;900&family=DM+Sans:wght@300;400;500;600;700;800&family=Barlow:wght@400;500;600;700;800&family=Barlow+Condensed:wght@600;700&display=swap" rel="stylesheet" />
</head>

<body>
  <Nav
    site={site}
    pages={pages}
    currentPage={currentPage}
    theme={theme}
    slug={slug}
  />

  <main>
    <SectionRenderer
      sections={pageSections}
      site={site}
      base={base}
      ui={ui}
      theme={theme}
    />
  </main>

  <Footer
    site={site}
    pages={pages}
    theme={theme}
    slug={slug}
  />

  <Analytics />
</body>
</html>

<style is:global define:vars={{ primary, accent }}>
  /* ===== RESET & BASE ===== */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --primary: var(--primary);
    --maroon: var(--primary);
    --maroon-deep: color-mix(in srgb, var(--primary), black 20%);
    --navy: color-mix(in srgb, var(--primary), black 40%);
    --navy-light: color-mix(in srgb, var(--primary), black 30%);
    --yellow: var(--accent);
    --yellow-dim: color-mix(in srgb, var(--accent), black 15%);
    --text: #2c2c2c;
    --text-mid: #555;
    --text-light: #888;
    --bg: #ffffff;
    --bg-warm: #faf8f5;
    --border: #e4e0db;
  }

  html {
    font-family: 'DM Sans', 'Segoe UI', system-ui, sans-serif;
    font-size: 16px;
    line-height: 1.65;
    color: var(--text);
    scroll-behavior: smooth;
    scroll-padding-top: 72px;
    -webkit-font-smoothing: antialiased;
  }

  body {
    background: var(--bg);
    overflow-x: hidden;
  }

  a { color: inherit; text-decoration: none; }
  img { max-width: 100%; height: auto; display: block; }
  ul { list-style: none; }

  .container {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ===== BUTTONS ===== */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.8rem 1.75rem;
    border-radius: 4px;
    font-weight: 700;
    font-size: 0.9rem;
    cursor: pointer;
    border: none;
    transition: background 0.15s, transform 0.1s, box-shadow 0.15s;
    text-decoration: none;
    font-family: inherit;
  }

  .btn:active { transform: scale(0.98); }

  .btn--yellow {
    background: var(--yellow);
    color: var(--navy);
  }

  .btn--yellow:hover {
    background: var(--yellow-dim);
  }

  .btn--outline {
    background: transparent;
    color: #fff;
    border: 2px solid rgba(255,255,255,0.4);
  }

  .btn--outline:hover { border-color: #fff; }

  .btn--full { width: 100%; margin-top: 1.5rem; }

  /* ===== SECTIONS ===== */
  .section { padding: 5rem 0; }
  .section--warm { background: var(--bg-warm); }
  .section--dark { background: var(--maroon-deep); }
  .section--navy { background: var(--navy); }

  .section__header { margin-bottom: 2.75rem; }

  .section__eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--primary);
    margin-bottom: 0.5rem;
  }

  .section__eyebrow--light { color: var(--yellow); }

  .section__title {
    font-family: 'Bitter', Georgia, serif;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    color: var(--text);
    line-height: 1.25;
  }

  .section__title--light { color: #fff; }

  .section__subtitle {
    font-size: 1rem;
    color: var(--text-mid);
    line-height: 1.7;
    margin-top: 0.6rem;
    max-width: 600px;
  }

  .section__subtitle--light { color: rgba(255,255,255,0.65); }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    .section { padding: 3.5rem 0; }
    .container { padding: 0 1.25rem; }
  }
</style>
