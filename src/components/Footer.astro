---
import type { SiteContent, PageDef } from '../schema/content';

interface Props {
  site: SiteContent;
  pages?: Record<string, PageDef>;
  theme?: string;
  slug: string;
}

const { site, pages, theme = 'default', slug } = Astro.props;
const { business, contact, hours } = site;
const phoneDigits = contact.phone.replace(/\D/g, '');
const pageEntries = pages ? Object.entries(pages) : [];
const socials = contact.socials || {};
const socialEntries = Object.entries(socials).filter(([, url]) => url);

const dayLabels: Record<string, string> = {
  monday: 'Mon', tuesday: 'Tue', wednesday: 'Wed', thursday: 'Thu',
  friday: 'Fri', saturday: 'Sat', sunday: 'Sun',
};

// Group consecutive same-hours days
function formatHours(regular: typeof hours.regular) {
  const groups: { days: string[]; text: string }[] = [];
  for (const h of regular) {
    const text = h.closed ? 'Closed' : `${h.open} – ${h.close}`;
    const label = dayLabels[h.day] || h.day;
    const last = groups[groups.length - 1];
    if (last && last.text === text) {
      last.days.push(label);
    } else {
      groups.push({ days: [label], text });
    }
  }
  return groups.map(g => ({
    range: g.days.length > 1 ? `${g.days[0]}–${g.days[g.days.length - 1]}` : g.days[0],
    text: g.text,
  }));
}

const hoursFormatted = formatHours(hours.regular);

const socialIcons: Record<string, string> = {
