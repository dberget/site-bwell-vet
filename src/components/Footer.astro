  instagram: '<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>',
  twitter: '<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/></svg>',
  linkedin: '<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>',
  youtube: '<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>',
  nextdoor: '<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="10"/><text x="12" y="16" text-anchor="middle" fill="#fff" font-size="12" font-weight="bold">N</text></svg>',
  yelp: '<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.16 12.594l-4.995 1.433c-.96.276-1.74-.8-1.176-1.63l2.996-4.428c.408-.603 1.37-.45 1.573.25l1.602 5.542c.152.525-.348 1.005-.872.833h-.128zm-8.568 5.226l4.463-2.192c.87-.428 1.776.506 1.37 1.414l-2.154 4.814c-.293.655-1.264.655-1.588.03l-2.718-3.197c-.325-.382-.054-.964.465-1.022l.162.153zm-1.94-2.97l-4.463 2.192c-.87.428-1.775-.506-1.37-1.415l2.154-4.813c.293-.655 1.264-.655 1.588-.03l2.718 3.197c.325.381.054.963-.465 1.022l-.162-.153zm.86-10.78l.63 5.239c.115.96-1.1 1.475-1.835.777L5.3 7.086c-.531-.504-.222-1.4.505-1.465l4.542-.55c.525-.064.948.42.865.935l.3.064zm2.36 6.12V4.95c0-.99 1.364-1.283 1.88-.405l2.718 4.625c.354.604-.075 1.383-.788 1.275l-3.247-.485c-.356-.053-.563-.38-.563-.715z"/></svg>',
};
---

<footer class={`site-footer site-footer--${theme}`}>
  <div class="container">
    <div class="site-footer__grid">
      <!-- Business Info -->
      <div class="site-footer__col">
        {business.logo ? (
          <img src={business.logo} alt={business.name} class="site-footer__logo" />
        ) : (
          <p class="site-footer__brand">{business.name}</p>
        )}
        <p class="site-footer__desc">{business.description?.slice(0, 160)}{business.description && business.description.length > 160 ? '...' : ''}</p>
        {socialEntries.length > 0 && (
          <div class="site-footer__socials">
            {socialEntries.map(([platform, url]) => (
              <a href={url} target="_blank" rel="noopener noreferrer" class="site-footer__social" aria-label={platform} set:html={socialIcons[platform] || platform} />
            ))}
          </div>
        )}
      </div>

      <!-- Quick Links -->
      {pageEntries.length > 0 && (
        <div class="site-footer__col">
          <p class="site-footer__heading">Quick Links</p>
          <ul class="site-footer__links">
            {pageEntries.map(([key, page]) => {
              const href = key === 'home' ? `/${slug}` : `/${slug}/${key}`;
              return <li><a href={href}>{page.title}</a></li>;
            })}
          </ul>
        </div>
      )}

      <!-- Contact Info -->
      <div class="site-footer__col">
        <p class="site-footer__heading">Contact</p>
        <ul class="site-footer__contact">
          <li>
            <a href={`tel:${phoneDigits}`}>{contact.phone}</a>
          </li>
          <li>
            <a href={`mailto:${contact.email}`}>{contact.email}</a>
          </li>
          <li>
            {contact.address.street}<br />
            {contact.address.city}, {contact.address.state} {contact.address.zip}
          </li>
        </ul>
      </div>

      <!-- Hours -->
      <div class="site-footer__col">
        <p class="site-footer__heading">Hours</p>
        <ul class="site-footer__hours">
          {hoursFormatted.map((h) => (
            <li>
              <span class="site-footer__hours-day">{h.range}</span>
              <span>{h.text}</span>
            </li>
          ))}
        </ul>
        {hours.note && <p class="site-footer__hours-note">{hours.note}</p>}
      </div>
    </div>

    <div class="site-footer__bottom">
      <p>&copy; {new Date().getFullYear()} {business.name}. All rights reserved.</p>
    </div>
  </div>
</footer>

<style is:global>
  /* ===== SHARED FOOTER ===== */
  .site-footer {
    background: #1a1a1a;
    color: rgba(255,255,255,0.6);
    padding: 3.5rem 0 0;
    font-size: 0.88rem;
  }

  .site-footer__grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 2.5rem;
  }

  .site-footer__logo {
    height: 40px;
    width: auto;
    margin-bottom: 1rem;
    opacity: 0.85;
  }

  .site-footer__brand {
    font-size: 1.1rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 0.75rem;
  }

  .site-footer__desc {
    line-height: 1.65;
    color: rgba(255,255,255,0.45);
    margin-bottom: 1rem;
  }

  .site-footer__socials {
    display: flex;
    gap: 0.75rem;
  }

  .site-footer__social {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.6);
    transition: background 0.2s, color 0.2s;
  }

  .site-footer__social:hover {
    background: var(--primary, var(--maroon, #6b1d2a));
    color: #fff;
  }

  .site-footer__heading {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.85);
    margin-bottom: 1rem;
  }

  .site-footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .site-footer__links li {
    margin-bottom: 0.5rem;
  }

  .site-footer__links a {
    color: rgba(255,255,255,0.55);
    transition: color 0.15s;
  }

  .site-footer__links a:hover {
    color: #fff;
  }

  .site-footer__contact {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .site-footer__contact li {
    margin-bottom: 0.6rem;
    line-height: 1.5;
    color: rgba(255,255,255,0.55);
  }

  .site-footer__contact a {
    color: rgba(255,255,255,0.55);
    transition: color 0.15s;
  }

  .site-footer__contact a:hover {
    color: #fff;
  }

  .site-footer__hours {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .site-footer__hours li {
    display: flex;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.3rem;
    color: rgba(255,255,255,0.55);
  }

  .site-footer__hours-day {
    font-weight: 600;
    color: rgba(255,255,255,0.7);
    white-space: nowrap;
  }

  .site-footer__hours-note {
    margin-top: 0.75rem;
    font-size: 0.82rem;
    font-style: italic;
    color: rgba(255,255,255,0.4);
  }

  .site-footer__bottom {
    margin-top: 2.5rem;
    padding: 1.25rem 0;
    border-top: 1px solid rgba(255,255,255,0.08);
    text-align: center;
    font-size: 0.8rem;
    color: rgba(255,255,255,0.3);
  }

  /* ===== THEME: SUSPENDED ===== */
  .site-footer--suspended {
    background: #fafafa;
    color: var(--text-mid, #555);
  }

  .site-footer--suspended .site-footer__brand {
    color: var(--text, #2c2c2c);
  }

  .site-footer--suspended .site-footer__desc {
    color: var(--text-mid, #555);
  }

  .site-footer--suspended .site-footer__heading {
    color: var(--text, #2c2c2c);
  }

  .site-footer--suspended .site-footer__links a,
  .site-footer--suspended .site-footer__contact li,
  .site-footer--suspended .site-footer__contact a,
  .site-footer--suspended .site-footer__hours li {
    color: var(--text-mid, #555);
  }

  .site-footer--suspended .site-footer__links a:hover,
  .site-footer--suspended .site-footer__contact a:hover {
    color: var(--primary, var(--maroon, #6b1d2a));
  }

  .site-footer--suspended .site-footer__hours-day {
    color: var(--text, #2c2c2c);
  }

  .site-footer--suspended .site-footer__social {
    background: rgba(0,0,0,0.06);
    color: var(--text-mid, #555);
  }

  .site-footer--suspended .site-footer__social:hover {
    background: var(--primary, var(--maroon, #6b1d2a));
    color: #fff;
  }

  .site-footer--suspended .site-footer__bottom {
    border-top-color: rgba(0,0,0,0.08);
    color: var(--text-light, #888);
  }

  .site-footer--suspended .site-footer__hours-note {
    color: var(--text-light, #888);
  }

  .site-footer--suspended .site-footer__logo {
    opacity: 1;
  }

  /* ===== THEME: EDITORIAL ===== */
  .site-footer--editorial {
    background: #111;
  }

  .site-footer--editorial .site-footer__heading {
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  /* ===== THEME: BOLD ===== */
  .site-footer--bold {
    background: color-mix(in srgb, var(--primary, #6b1d2a), black 70%);
  }

  .site-footer--bold .site-footer__heading {
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 800;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 900px) {
    .site-footer__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 600px) {
    .site-footer__grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .site-footer { padding: 2.5rem 0 0; }
  }
</style>
