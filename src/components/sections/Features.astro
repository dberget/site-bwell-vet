---
import type { SiteContent, UIStrings } from '../../schema/content';

interface Props {
  site: SiteContent;
  base: string;
  ui?: UIStrings;
  features: { icon: string; title: string; description: string }[];
}

const { features = [] } = Astro.props;
---

<section class="features-section">
  <div class="container">
    <div class="features-grid">
      {features.map((feature) => (
        <div class="feature-card">
          <span class="feature-card__icon">{feature.icon}</span>
          <h3 class="feature-card__title">{feature.title}</h3>
          <p class="feature-card__desc">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .features-section {
    padding: 4rem 0;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .feature-card {
    text-align: center;
    padding: 2rem 1.5rem;
    border-radius: 8px;
    background: var(--bg-warm, #faf8f5);
    border: 1px solid var(--border, #e4e0db);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .feature-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
  }

  .feature-card__icon {
    display: block;
    font-size: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1;
  }

  .feature-card__title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text, #2c2c2c);
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }

  .feature-card__desc {
    font-size: 0.92rem;
    line-height: 1.65;
    color: var(--text-mid, #555);
  }

  /* Theme: Suspended */
  .theme-suspended .feature-card {
    border-radius: 12px;
    border: none;
    background: #fff;
    box-shadow: 0 1px 8px rgba(0,0,0,0.06);
  }

  /* Theme: Editorial */
  .theme-editorial .feature-card {
    background: #1a1a1a;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 2px;
    color: #fff;
  }

  .theme-editorial .feature-card__title {
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .theme-editorial .feature-card__desc {
    color: rgba(255,255,255,0.65);
  }

  .theme-editorial .feature-card:hover {
    border-color: rgba(255,255,255,0.2);
  }

  /* Theme: Bold */
  .theme-bold .feature-card {
    border-radius: 4px;
    border: none;
    box-shadow: 0 4px 16px rgba(0,0,0,0.1);
  }

  .theme-bold .feature-card__title {
    text-transform: uppercase;
    font-weight: 800;
    letter-spacing: 0.02em;
  }

  .theme-bold .feature-card:hover {
    box-shadow: 0 8px 28px rgba(0,0,0,0.15);
    transform: translateY(-4px);
  }

  @media (max-width: 900px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .features-grid {
      grid-template-columns: 1fr;
    }
    .features-section { padding: 3rem 0; }
  }
</style>
