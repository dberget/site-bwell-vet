---
import type { SiteContent, UIStrings } from '../../schema/content';

interface Props {
  site: SiteContent;
  base: string;
  ui?: UIStrings;
}

const { site, base, ui } = Astro.props;
const { business, contact } = site;
const phoneDigits = contact.phone.replace(/\D/g, '');
const heroImage = business.heroImage;
---

<section class={`hero ${heroImage ? 'hero--has-image' : ''}`}>
  <div class="hero__bg">
    {heroImage && <img src={heroImage} alt="" class="hero__bg-image" />}
    <div class="hero__overlay"></div>
  </div>
  <div class="container hero__content">
    {business?.tagline && <p class="hero__tagline">{business.tagline}</p>}
    <h1 class="hero__title">{business.name}</h1>
    {business?.description && <p class="hero__description">{business.description}</p>}
    <div class="hero__actions">
      <a href={`tel:${phoneDigits}`} class="btn btn--yellow">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        {ui?.hero?.ctaPrimary || 'Call Us Today'}
      </a>
      <a href={`mailto:${contact.email}`} class="btn btn--outline">
        {ui?.hero?.ctaSecondary || 'Contact Us'}
      </a>
    </div>
    {ui?.hero?.badge && (
      <div class="hero__badges">
        <div class="hero__badge">
          <span class="hero__badge-value">{ui.hero.badge}</span>
        </div>
      </div>
    )}
  </div>
</section>

<style is:global>
  /* --- Hero --- */
  .hero {
    position: relative;
    padding: 7rem 0 4.5rem;
    background: var(--primary, var(--maroon));
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 80% 20%, rgba(255,255,255,0.04) 0%, transparent 50%),
      radial-gradient(ellipse at 20% 80%, rgba(0,0,0,0.15) 0%, transparent 60%);
  }

  .hero--has-image .hero__bg {
    background: none;
  }

  .hero__bg-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero--has-image .hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
  }

  .hero:not(.hero--has-image) .hero__overlay {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0,0,0,0.03) 2px,
      rgba(0,0,0,0.03) 4px
    );
  }

  .hero--has-image {
    padding: 9rem 0 5.5rem;
  }

  .hero__content { position: relative; max-width: 640px; }

  .hero__tagline {
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--yellow);
    margin-bottom: 1rem;
  }

  .hero--has-image .hero__tagline {
    text-shadow: 0 1px 3px rgba(0,0,0,0.4);
  }

  .hero__title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    line-height: 1.15;
    color: #fff;
    margin-bottom: 1.25rem;
  }

  .hero--has-image .hero__title {
    font-size: clamp(2.25rem, 5.5vw, 3.5rem);
    text-shadow: 0 2px 8px rgba(0,0,0,0.4);
  }

  .hero__description {
    font-size: 1.05rem;
    line-height: 1.75;
    color: rgba(255,255,255,0.75);
    margin-bottom: 2rem;
    max-width: 540px;
  }

  .hero--has-image .hero__description {
    color: rgba(255,255,255,0.9);
    text-shadow: 0 1px 3px rgba(0,0,0,0.3);
  }

  .hero__actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  .hero__badges {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255,255,255,0.1);
  }

  .hero__badge { text-align: center; }

  .hero__badge-label {
    display: block;
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgba(255,255,255,0.5);
    margin-bottom: 0.15rem;
  }

  .hero__badge-value {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--yellow);
  }

  .hero__badge-divider {
    width: 1px;
    height: 36px;
    background: rgba(255,255,255,0.12);
  }

  @media (max-width: 768px) {
    .hero { padding: 6rem 0 3rem; }
    .hero--has-image { padding: 7rem 0 4rem; }
    .hero__badges { gap: 1rem; }
    .hero__badge-value { font-size: 1rem; }
  }

  @media (max-width: 480px) {
    .hero { padding: 5.5rem 0 2rem; }
    .hero--has-image { padding: 6rem 0 3rem; }
    .hero__actions { flex-direction: column; }
    .hero__actions .btn { justify-content: center; width: 100%; }
    .hero__badges { flex-wrap: wrap; gap: 0.75rem; }
    .hero__badge-divider { display: none; }
  }
</style>

<style is:global>
  /* =============================================
     THEME: SUSPENDED — Clean & Airy
     ============================================= */

  .theme-suspended .hero {
    background: #fff;
    padding: 8rem 0 6rem;
    display: grid;
    grid-template-columns: 55% 45%;
    align-items: center;
    min-height: 520px;
  }

  .theme-suspended .hero--has-image {
    padding: 8rem 0 6rem;
  }

  .theme-suspended .hero__bg {
    position: relative;
    grid-column: 2;
    grid-row: 1;
    inset: auto;
    width: 100%;
    height: 100%;
    min-height: 400px;
    background: none;
    border-radius: 12px;
    overflow: hidden;
  }

  .theme-suspended .hero:not(.hero--has-image) .hero__bg {
    background:
      linear-gradient(135deg, rgba(var(--primary-rgb, 128,0,0), 0.04) 0%, rgba(var(--primary-rgb, 128,0,0), 0.01) 100%);
  }

  .theme-suspended .hero:not(.hero--has-image) .hero__overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 30% 40%, rgba(var(--primary-rgb, 128,0,0), 0.06) 0%, transparent 50%),
      radial-gradient(circle at 70% 60%, rgba(var(--primary-rgb, 128,0,0), 0.04) 0%, transparent 50%);
  }

  .theme-suspended .hero--has-image .hero__bg-image {
    position: absolute;
    inset: 0;
    border-radius: 12px;
    object-fit: cover;
  }

  .theme-suspended .hero--has-image .hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.15);
    border-radius: 12px;
  }

  .theme-suspended .hero__content {
    grid-column: 1;
    grid-row: 1;
    max-width: 540px;
    padding-right: 3rem;
  }

  .theme-suspended .hero__tagline {
    color: var(--primary, var(--maroon));
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .theme-suspended .hero--has-image .hero__tagline {
    text-shadow: none;
  }

  .theme-suspended .hero__title {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--text, #1a1a1a);
    margin-bottom: 1.25rem;
  }

  .theme-suspended .hero--has-image .hero__title {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    text-shadow: none;
  }

  .theme-suspended .hero__description {
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--text-mid, #555);
    margin-bottom: 2rem;
    max-width: 480px;
  }

  .theme-suspended .hero--has-image .hero__description {
    color: var(--text-mid, #555);
    text-shadow: none;
  }

  .theme-suspended .hero__actions .btn {
    border-radius: 100px;
    padding: 0.75rem 2rem;
    font-weight: 600;
  }

  .theme-suspended .hero__actions .btn--outline {
    border-radius: 100px;
    color: var(--text, #1a1a1a);
    border-color: rgba(0, 0, 0, 0.2);
    background: transparent;
  }

  .theme-suspended .hero__actions .btn--outline:hover {
    border-color: var(--primary, var(--maroon));
    color: var(--primary, var(--maroon));
  }

  .theme-suspended .hero__badges {
    border-top-color: rgba(0, 0, 0, 0.08);
  }

  .theme-suspended .hero__badge-label {
    color: var(--text-mid, #555);
  }

  .theme-suspended .hero__badge-value {
    color: var(--primary, var(--maroon));
  }

  .theme-suspended .hero__badge-divider {
    background: rgba(0, 0, 0, 0.08);
  }

  @media (max-width: 1024px) {
    .theme-suspended .hero {
      grid-template-columns: 1fr 1fr;
    }

    .theme-suspended .hero__content {
      padding-right: 2rem;
    }
  }

  @media (max-width: 768px) {
    .theme-suspended .hero {
      grid-template-columns: 1fr;
      padding: 6rem 0 3rem;
      gap: 2rem;
    }

    .theme-suspended .hero--has-image {
      padding: 6rem 0 3rem;
    }

    .theme-suspended .hero__content {
      grid-column: 1;
      grid-row: 1;
      padding-right: 0;
      max-width: 100%;
    }

    .theme-suspended .hero__bg {
      grid-column: 1;
      grid-row: 2;
      min-height: 280px;
    }
  }

  @media (max-width: 480px) {
    .theme-suspended .hero {
      padding: 5rem 0 2rem;
    }

    .theme-suspended .hero--has-image {
      padding: 5rem 0 2rem;
    }

    .theme-suspended .hero__bg {
      min-height: 220px;
    }

    .theme-suspended .hero__actions {
      flex-direction: column;
    }

    .theme-suspended .hero__actions .btn {
      justify-content: center;
      width: 100%;
    }
  }


  /* =============================================
     THEME: EDITORIAL — Bold & Editorial
     ============================================= */

  .theme-editorial .hero {
    min-height: 100vh;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    background: var(--primary, var(--maroon));
  }

  .theme-editorial .hero--has-image {
    padding: 0;
  }

  .theme-editorial .hero__bg {
    position: absolute;
    inset: 0;
  }

  .theme-editorial .hero:not(.hero--has-image) .hero__bg {
    background:
      linear-gradient(135deg, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.7) 100%);
  }

  .theme-editorial .hero:not(.hero--has-image) .hero__overlay {
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(
        45deg,
        transparent,
        transparent 40px,
        rgba(255,255,255,0.015) 40px,
        rgba(255,255,255,0.015) 80px
      ),
      repeating-linear-gradient(
        -45deg,
        transparent,
        transparent 40px,
        rgba(255,255,255,0.01) 40px,
        rgba(255,255,255,0.01) 80px
      );
  }

  .theme-editorial .hero--has-image .hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
  }

  .theme-editorial .hero__content {
    position: relative;
    max-width: 1000px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 6rem 2rem;
  }

  .theme-editorial .hero__tagline {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--yellow);
    margin-bottom: 1.5rem;
    order: -1;
  }

  .theme-editorial .hero--has-image .hero__tagline {
    text-shadow: 0 1px 4px rgba(0,0,0,0.5);
  }

  .theme-editorial .hero__title {
    font-size: clamp(3rem, 7vw, 5rem);
    font-weight: 900;
    text-transform: uppercase;
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: #fff;
    margin-bottom: 1.5rem;
  }

  .theme-editorial .hero--has-image .hero__title {
    font-size: clamp(3rem, 7vw, 5rem);
    text-shadow: 0 3px 12px rgba(0,0,0,0.5);
  }

  .theme-editorial .hero__description {
    font-size: 1.15rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.8);
    margin-bottom: 2.5rem;
    max-width: 650px;
    text-align: center;
  }

  .theme-editorial .hero--has-image .hero__description {
    color: rgba(255,255,255,0.9);
    text-shadow: 0 1px 4px rgba(0,0,0,0.4);
  }

  .theme-editorial .hero__actions {
    justify-content: center;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  .theme-editorial .hero__actions .btn {
    border-radius: 2px;
    padding: 0.9rem 2.5rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.9rem;
  }

  .theme-editorial .hero__actions .btn--outline {
    border-radius: 2px;
    border-width: 2px;
  }

  .theme-editorial .hero__badges {
    justify-content: center;
    border-top-color: rgba(255,255,255,0.15);
  }

  /* Scroll indicator */
  .theme-editorial .hero::after {
    content: '';
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    width: 24px;
    height: 24px;
    border-right: 2px solid rgba(255,255,255,0.6);
    border-bottom: 2px solid rgba(255,255,255,0.6);
    transform: translateX(-50%) rotate(45deg);
    animation: editorial-bounce 2s ease infinite;
  }

  @keyframes editorial-bounce {
    0%, 20%, 50%, 80%, 100% {
      transform: translateX(-50%) rotate(45deg) translateY(0);
    }
    40% {
      transform: translateX(-50%) rotate(45deg) translateY(8px);
    }
    60% {
      transform: translateX(-50%) rotate(45deg) translateY(4px);
    }
  }

  @media (max-width: 1024px) {
    .theme-editorial .hero__title {
      font-size: clamp(2.5rem, 6vw, 4rem);
    }

    .theme-editorial .hero--has-image .hero__title {
      font-size: clamp(2.5rem, 6vw, 4rem);
    }
  }

  @media (max-width: 768px) {
    .theme-editorial .hero {
      min-height: 80vh;
    }

    .theme-editorial .hero__content {
      padding: 5rem 1.5rem;
    }

    .theme-editorial .hero__title {
      font-size: clamp(2.25rem, 6vw, 3.5rem);
    }

    .theme-editorial .hero--has-image .hero__title {
      font-size: clamp(2.25rem, 6vw, 3.5rem);
    }

    .theme-editorial .hero__description {
      font-size: 1.05rem;
    }

    .theme-editorial .hero::after {
      bottom: 1.5rem;
    }
  }

  @media (max-width: 480px) {
    .theme-editorial .hero {
      min-height: 70vh;
    }

    .theme-editorial .hero__content {
      padding: 4rem 1rem;
    }

    .theme-editorial .hero__title {
      font-size: clamp(2rem, 8vw, 3rem);
    }

    .theme-editorial .hero--has-image .hero__title {
      font-size: clamp(2rem, 8vw, 3rem);
    }

    .theme-editorial .hero__actions {
      flex-direction: column;
    }

    .theme-editorial .hero__actions .btn {
      justify-content: center;
      width: 100%;
    }

    .theme-editorial .hero::after {
      display: none;
    }
  }


  /* =============================================
     THEME: BOLD — Energetic & Punchy
     ============================================= */

  .theme-bold .hero {
    position: relative;
    padding: 8rem 0 7rem;
    background: var(--primary, var(--maroon));
    clip-path: polygon(0 0, 100% 0, 100% calc(100% - 4rem), 0 100%);
    overflow: hidden;
  }

  .theme-bold .hero--has-image {
    padding: 9rem 0 8rem;
  }

  .theme-bold .hero__bg {
    position: absolute;
    inset: 0;
    background: none;
  }

  .theme-bold .hero:not(.hero--has-image) .hero__bg {
    background:
      linear-gradient(135deg, var(--primary, var(--maroon)) 0%, color-mix(in srgb, var(--primary, var(--maroon)), black 30%) 100%);
  }

  .theme-bold .hero:not(.hero--has-image) .hero__overlay {
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(
        -60deg,
        transparent,
        transparent 20px,
        rgba(255,255,255,0.03) 20px,
        rgba(255,255,255,0.03) 22px
      ),
      repeating-linear-gradient(
        60deg,
        transparent,
        transparent 20px,
        rgba(255,255,255,0.02) 20px,
        rgba(255,255,255,0.02) 22px
      ),
      linear-gradient(
        180deg,
        rgba(255,255,255,0.04) 0%,
        transparent 40%,
        transparent 60%,
        rgba(0,0,0,0.1) 100%
      );
  }

  .theme-bold .hero--has-image .hero__overlay {
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, var(--primary, var(--maroon)) 70%, transparent);
  }

  .theme-bold .hero__content {
    position: relative;
    max-width: 700px;
  }

  .theme-bold .hero__tagline {
    font-size: 0.85rem;
    font-weight: 800;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--yellow);
    margin-bottom: 1rem;
  }

  .theme-bold .hero--has-image .hero__tagline {
    text-shadow: 0 2px 6px rgba(0,0,0,0.4);
  }

  .theme-bold .hero__title {
    font-size: clamp(2.25rem, 5.5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.1;
    color: #fff;
    margin-bottom: 1.25rem;
    text-transform: uppercase;
    letter-spacing: -0.01em;
  }

  .theme-bold .hero--has-image .hero__title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    text-shadow: 0 3px 10px rgba(0,0,0,0.4);
  }

  .theme-bold .hero__description {
    font-size: 1.1rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.85);
    margin-bottom: 2.25rem;
    max-width: 580px;
  }

  .theme-bold .hero--has-image .hero__description {
    color: rgba(255,255,255,0.95);
    text-shadow: 0 1px 4px rgba(0,0,0,0.3);
  }

  .theme-bold .hero__actions {
    gap: 0.85rem;
    margin-bottom: 2.5rem;
  }

  .theme-bold .hero__actions .btn {
    border-radius: 4px;
    padding: 0.85rem 2.25rem;
    font-weight: 700;
    box-shadow: 0 4px 14px rgba(0,0,0,0.25);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    font-size: 0.92rem;
  }

  .theme-bold .hero__actions .btn:hover {
    box-shadow: 0 6px 20px rgba(0,0,0,0.35);
    transform: translateY(-1px);
  }

  .theme-bold .hero__actions .btn--outline {
    border-radius: 4px;
    border-width: 2px;
    box-shadow: 0 4px 14px rgba(0,0,0,0.15);
  }

  .theme-bold .hero__badges {
    border-top-color: rgba(255,255,255,0.15);
  }

  .theme-bold .hero__badge {
    background: rgba(255,255,255,0.1);
    border-radius: 100px;
    padding: 0.5rem 1.25rem;
  }

  .theme-bold .hero__badge-label {
    color: rgba(255,255,255,0.6);
  }

  .theme-bold .hero__badge-value {
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--yellow);
  }

  .theme-bold .hero__badge-divider {
    background: rgba(255,255,255,0.2);
  }

  @media (max-width: 1024px) {
    .theme-bold .hero {
      clip-path: polygon(0 0, 100% 0, 100% calc(100% - 3rem), 0 100%);
    }
  }

  @media (max-width: 768px) {
    .theme-bold .hero {
      padding: 7rem 0 5.5rem;
      clip-path: polygon(0 0, 100% 0, 100% calc(100% - 2.5rem), 0 100%);
    }

    .theme-bold .hero--has-image {
      padding: 7.5rem 0 6rem;
    }

    .theme-bold .hero__title {
      font-size: clamp(2rem, 5vw, 3rem);
    }

    .theme-bold .hero--has-image .hero__title {
      font-size: clamp(2.25rem, 5.5vw, 3.25rem);
    }
  }

  @media (max-width: 480px) {
    .theme-bold .hero {
      padding: 5.5rem 0 4.5rem;
      clip-path: polygon(0 0, 100% 0, 100% calc(100% - 2rem), 0 100%);
    }

    .theme-bold .hero--has-image {
      padding: 6rem 0 5rem;
    }

    .theme-bold .hero__title {
      font-size: clamp(1.85rem, 7vw, 2.5rem);
    }

    .theme-bold .hero--has-image .hero__title {
      font-size: clamp(2rem, 7vw, 2.75rem);
    }

    .theme-bold .hero__actions {
      flex-direction: column;
    }

    .theme-bold .hero__actions .btn {
      justify-content: center;
      width: 100%;
    }

    .theme-bold .hero__badge {
      padding: 0.4rem 1rem;
    }
  }
</style>
